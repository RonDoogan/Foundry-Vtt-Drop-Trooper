function getDropTrooperReactionSocketTargetUser(actor) {
  if (!actor) return null;
  const owners = (game.users?.filter(user => user.active && actor?.testUserPermission?.(user, "OWNER")) || []);
  return owners.find(user => !user.isGM) || owners.find(user => user.isGM) || game.users?.activeGM || null;
}

function getDropTrooperReactionTokenObject(tokenLike) {
  if (!tokenLike) return null;
  return tokenLike.object || canvas?.tokens?.get(tokenLike.id) || tokenLike;
}

function getDropTrooperReactionTokenCenter(tokenLike) {
  const token = getDropTrooperReactionTokenObject(tokenLike);
  if (token?.center) return token.center;
  const doc = tokenLike?.document || tokenLike;
  const size = Number(canvas?.grid?.size ?? 100);
  return {
    x: Number(doc?.x ?? 0) + (Number(doc?.width ?? 1) * size / 2),
    y: Number(doc?.y ?? 0) + (Number(doc?.height ?? 1) * size / 2)
  };
}

function getDropTrooperReactionVisibility(sourceTokenLike, targetTokenLike) {
  try {
    const sourceObj = getDropTrooperReactionTokenObject(sourceTokenLike);
    const targetPoint = getDropTrooperReactionTokenCenter(targetTokenLike);
    if (canvas?.visibility?.testVisibility) {
      return Boolean(canvas.visibility.testVisibility(targetPoint, { object: sourceObj }));
    }
  } catch (error) {
    console.warn("Drop Trooper | Reaction visibility check failed", error);
  }
  return true;
}

function getDropTrooperPreferredReactionWeapon(actor, sourceTokenLike, targetTokenLike) {
  if (!actor) return null;
  const preferredId = String(actor.getFlag("drop-trooper", "overwatchWeaponId") || "").trim();
  const weapons = Array.from(actor.items || []).filter(item => item?.type === "weapon" && !item?.system?.aoeEnabled);
  const ordered = sortDropTrooperItemsByDisplayOrder(weapons);
  const candidates = preferredId
    ? [ordered.find(item => item.id === preferredId), ...ordered.filter(item => item.id !== preferredId)]
    : ordered;

  for (const weapon of candidates) {
    if (!weapon) continue;
    const ammo = Number(weapon.system?.ammo ?? 0);
    const usesAmmo = Boolean(weapon.system?.usesAmmo);
    if (usesAmmo && ammo <= 0) continue;
    const sourcePoint = getDropTrooperReactionTokenCenter(sourceTokenLike);
    const targetPoint = getDropTrooperReactionTokenCenter(targetTokenLike);
    const distance = Math.max(0, Number(canvas?.grid?.measureDistance?.(sourcePoint, targetPoint) ?? 0));
    const longRange = Math.max(0, Number(weapon.system?.longRange || weapon.system?.range || 0));
    if (longRange <= 0) continue;
    if (distance > longRange + 0.1) continue;
    return { weapon, distance, longRange };
  }
  return null;
}

async function executeDropTrooperReturnFire(payload = {}) {
  const actor = game.actors?.get(String(payload?.actorId || "").trim());
  const targetToken = canvas?.tokens?.get(String(payload?.targetTokenId || "").trim());
  const sourceToken = canvas?.tokens?.get(String(payload?.sourceTokenId || "").trim());
  if (!actor || !targetToken) throw new Error("Return fire actor or target not found.");

  const weaponData = getDropTrooperPreferredReactionWeapon(actor, sourceToken?.document || sourceToken, targetToken?.document || targetToken);
  if (!weaponData?.weapon) throw new Error(`${actor.name} has no valid return fire weapon.`);

  const previousTargets = Array.from(game.user?.targets || []).map(t => t.id);
  try {
    for (const token of canvas?.tokens?.placeables || []) {
      if (game.user?.targets?.has(token)) token.setTarget(false, { user: game.user, releaseOthers: false });
    }
    targetToken.setTarget(true, { user: game.user, releaseOthers: true, groupSelection: false });
    const sheet = actor.sheet;
    if (!sheet || typeof sheet._onWeaponSingleAttack !== "function") throw new Error(`${actor.name} cannot return fire from this client.`);
    const attackResolved = await sheet._onWeaponSingleAttack(weaponData.weapon, {
      attackCardMode: "returnFire",
      attackCardSubtitle: "Return Fire",
      attackCardTag: "Reaction Shot",
      targetToken
    });
    if (!attackResolved) {
      return {
        ok: false,
        reason: "Return Fire attack did not resolve.",
        weaponName: weaponData.weapon?.name || "Weapon"
      };
    }
    return {
      ok: true,
      weaponName: weaponData.weapon?.name || "Weapon",
      targetName: targetToken?.name || targetToken?.actor?.name || "Target"
    };
  } finally {
    for (const token of canvas?.tokens?.placeables || []) {
      if (game.user?.targets?.has(token)) token.setTarget(false, { user: game.user, releaseOthers: false });
    }
    for (const tokenId of previousTargets) {
      const token = canvas?.tokens?.get(tokenId);
      if (token) token.setTarget(true, { user: game.user, releaseOthers: false, groupSelection: false });
    }
  }
}

async function promptDropTrooperReactionDecision(payload = {}) {
  const actor = game.actors?.get(String(payload?.targetActorId || "").trim());
  if (!actor) throw new Error("Reaction actor not found.");
  const state = getDropTrooperReactionState(actor);
  if (!state.hasReaction || !state.reactionAvailable) {
    return { choice: "none", consumed: false, reason: "No reaction available." };
  }

  const sourceToken = canvas?.tokens?.get(String(payload?.sourceTokenId || "").trim());
  const targetToken = canvas?.tokens?.get(String(payload?.targetTokenId || "").trim());
  const seesAttacker = Boolean(sourceToken && targetToken && getDropTrooperReactionVisibility(targetToken.document || targetToken, sourceToken.document || sourceToken));
  const returnFireWeapon = seesAttacker ? getDropTrooperPreferredReactionWeapon(actor, targetToken?.document || targetToken, sourceToken?.document || sourceToken) : null;
  const canReturnFire = Boolean(seesAttacker && returnFireWeapon?.weapon);
  const attackName = String(payload?.weaponName || payload?.attackLabel || "Attack");
  const attackerName = String(payload?.sourceActorName || sourceToken?.name || "Attacker");
  const promptId = foundry.utils.randomID();
  const timeoutSeconds = 6;
  const combatId = game.combat?.id || null;
  const startTurn = Number(game.combat?.turn ?? -1);
  const startRound = Number(game.combat?.round ?? -1);

  return await new Promise(resolve => {
    let settled = false;
    let remaining = timeoutSeconds;
    let intervalId = null;
    let turnHookId = null;
    let dialog = null;

    const cleanup = () => {
      if (intervalId) {
        clearInterval(intervalId);
        intervalId = null;
      }
      if (turnHookId) {
        Hooks.off("updateCombat", turnHookId);
        turnHookId = null;
      }
    };

    const finish = async result => {
      if (settled) return;
      settled = true;
      cleanup();
      try {
        if (dialog?.rendered) await dialog.close();
      } catch (err) {
        console.warn("Drop Trooper | Failed closing reaction dialog", err);
      }
      resolve(result);
    };

    const setCountdownLabel = () => {
      const root = document.querySelector(`[data-dt-reaction-id="${promptId}"]`);
      if (!root) return;
      const countdownEl = root.querySelector("[data-dt-reaction-countdown]");
      if (countdownEl) {
        countdownEl.textContent = `Reaction expires in ${Math.max(0, remaining)}s`;
      }
      const returnFireBtn = root.closest('.application')?.querySelector('button[data-action="returnFire"]');
      if (returnFireBtn) {
        returnFireBtn.textContent = `Return Fire (${Math.max(0, remaining)}s)`;
      }
    };

    turnHookId = Hooks.on("updateCombat", (combat, changed) => {
      if (settled) return;
      if (!combatId || String(combat?.id || "") !== String(combatId)) return;
      const turnChanged = Object.prototype.hasOwnProperty.call(changed || {}, "turn") || Object.prototype.hasOwnProperty.call(changed || {}, "round") || Object.prototype.hasOwnProperty.call(changed || {}, "combatantId") || !combat?.started;
      if (!turnChanged) return;
      const nowTurn = Number(combat?.turn ?? -1);
      const nowRound = Number(combat?.round ?? -1);
      if (nowTurn !== startTurn || nowRound !== startRound || !combat?.started) {
        void finish({ choice: "none", consumed: false, canReturnFire: false, reason: "Reaction window closed." });
      }
    });

    intervalId = setInterval(() => {
      if (settled) return;
      remaining -= 1;
      setCountdownLabel();
      if (remaining <= 0) {
        void finish({ choice: "none", consumed: false, canReturnFire: false, reason: "Reaction prompt timed out." });
      }
    }, 1000);

    dialog = new foundry.applications.api.DialogV2({
      window: { title: `${actor.name}: Reaction` },
      content: `
        <div data-dt-reaction-id="${promptId}">
          <p><strong>${escapeDropTrooperHtml(attackerName)}</strong> attacked <strong>${escapeDropTrooperHtml(actor.name)}</strong> with <strong>${escapeDropTrooperHtml(attackName)}</strong>.</p>
          <p>Spend this round's reaction?</p>
          <p>${canReturnFire ? `Return Fire will use <strong>${escapeDropTrooperHtml(returnFireWeapon.weapon.name)}</strong>.` : `<em>Return Fire unavailable${seesAttacker ? " (no valid Overwatch weapon in range)" : " (attacker not visible)"}.</em>`}</p>
          <p class="dt-chat-small" data-dt-reaction-countdown>Reaction expires in ${timeoutSeconds}s</p>
        </div>
      `,
      buttons: [
        { action: "brace", label: "Brace", callback: async () => {
          const defensePool = Number(actor.system?.skills?.defense) || 0;
          if (defensePool > 0) {
            await actor.setFlag("drop-trooper", "pendingDefenseBrace", { multiplier: 2, source: "Brace Reaction" });
          }
          await actor.update({ "system.combat.reactionAvailable": false, "system.combat.overwatch": false });
          await finish({ choice: "brace", consumed: true, canReturnFire: false });
          return false;
        } },
        ...(canReturnFire ? [{ action: "returnFire", label: `Return Fire (${timeoutSeconds}s)`, default: true, callback: async () => {
          await actor.update({ "system.combat.reactionAvailable": false, "system.combat.overwatch": false });
          await finish({
            choice: "returnFire",
            consumed: true,
            canReturnFire: true,
            weaponId: returnFireWeapon?.weapon?.id || null
          });
          return false;
        } }] : [])
      ],
      close: () => {
        if (!settled) {
          void finish({ choice: "none", consumed: false, canReturnFire: false });
        }
        return "none";
      }
    });

    dialog.render(true);
    setTimeout(setCountdownLabel, 50);
  });
}

async function requestDropTrooperReactionDecision(payload = {}) {
  const actor = game.actors?.get(String(payload?.targetActorId || "").trim());
  if (!actor) return { choice: "none", consumed: false, reason: "Reaction actor not found." };
  const targetUser = getDropTrooperReactionSocketTargetUser(actor);
  if (!targetUser) return { choice: "none", consumed: false, reason: "No reaction owner online." };
  if (String(targetUser.id) === String(game.user?.id || "")) {
    return promptDropTrooperReactionDecision(payload);
  }

  const requestId = getDropTrooperSocketRequestId();
  return await new Promise((resolve, reject) => {
    const timeout = setTimeout(() => {
      dropTrooperSocketPendingRequests.delete(requestId);
      resolve({ choice: "none", consumed: false, reason: "Reaction prompt timed out." });
    }, 20000);

    dropTrooperSocketPendingRequests.set(requestId, { resolve, reject, timeout });
    game.socket.emit(DROP_TROOPER_SOCKET_NAMESPACE, {
      action: DROP_TROOPER_SOCKET_ACTION_REACTION_PROMPT,
      requestId,
      requesterUserId: game.user?.id || "",
      targetUserId: targetUser.id,
      payload
    });
  });
}

async function requestDropTrooperReturnFire(payload = {}) {
  const actor = game.actors?.get(String(payload?.actorId || "").trim());
  if (!actor) return { ok: false, reason: "Return fire actor not found." };
  const targetUser = getDropTrooperReactionSocketTargetUser(actor);
  if (!targetUser) return { ok: false, reason: "No return fire owner online." };
  if (String(targetUser.id) === String(game.user?.id || "")) {
    return await executeDropTrooperReturnFire(payload);
  }

  const requestId = getDropTrooperSocketRequestId();
  return await new Promise((resolve, reject) => {
    const timeout = setTimeout(() => {
      dropTrooperSocketPendingRequests.delete(requestId);
      resolve({ ok: false, reason: "Return fire request timed out." });
    }, 20000);

    dropTrooperSocketPendingRequests.set(requestId, { resolve, reject, timeout });
    game.socket.emit(DROP_TROOPER_SOCKET_NAMESPACE, {
      action: DROP_TROOPER_SOCKET_ACTION_RETURN_FIRE,
      requestId,
      requesterUserId: game.user?.id || "",
      targetUserId: targetUser.id,
      payload
    });
  });
}

const getDropTrooperAssignedDroneActors = (...args) => globalThis.DropTrooperDroneHelpers.getDropTrooperAssignedDroneActors(...args);

const getDropTrooperAssignedDroneActor = (...args) => globalThis.DropTrooperDroneHelpers.getDropTrooperAssignedDroneActor(...args);

const getDropTrooperSocketRequestId = (...args) => {
  const helper = globalThis.DropTrooperDroneHelpers?.getDropTrooperSocketRequestId;
  if (typeof helper === 'function') return helper(...args);
  return randomID();
};

const getDropTrooperFirstActiveGmUser = (...args) => {
  const helper = globalThis.DropTrooperDroneHelpers?.getDropTrooperFirstActiveGmUser;
  if (typeof helper === 'function') return helper(...args);
  const active = (game.users?.contents || []).find(user => user?.isGM && user?.active);
  if (active) return active;
  return (game.users?.contents || []).find(user => user?.isGM) || null;
};

async function requestOrPerformDropTrooperDroneDeploy(trooperActorId, droneActorId = null) {
  if (game.user?.isGM) {
    return performDropTrooperDroneDeploy(trooperActorId, droneActorId);
  }
  return queueDropTrooperGmDroneApproval(trooperActorId, "droneDeploy", droneActorId);
}

async function requestOrPerformDropTrooperDroneRecall(trooperActorId, droneActorId = null) {
  if (game.user?.isGM) {
    return performDropTrooperDroneRecall(trooperActorId, droneActorId);
  }
  return queueDropTrooperGmDroneApproval(trooperActorId, "droneRecall", droneActorId);
}

function requestDropTrooperGmDroneAction(action, payload = {}) {
  const gmUser = getDropTrooperFirstActiveGmUser();
  if (!gmUser) {
    return Promise.reject(new Error("No GM is online to process that drone action."));
  }

  const requestId = getDropTrooperSocketRequestId();
  return new Promise((resolve, reject) => {
    const timeout = setTimeout(() => {
      dropTrooperSocketPendingRequests.delete(requestId);
      reject(new Error("The GM did not respond to the drone action request."));
    }, 15000);

    dropTrooperSocketPendingRequests.set(requestId, { resolve, reject, timeout });

    game.socket.emit(DROP_TROOPER_SOCKET_NAMESPACE, {
      action,
      requestId,
      requesterUserId: game.user?.id || "",
      payload
    });
  });
}

async function queueDropTrooperGmDroneApproval(trooperActorId, requestType = "droneDeploy", droneActorId = null) {
  const trooperActor = game.actors?.get(String(trooperActorId || "").trim());
  if (!trooperActor || String(trooperActor.type || "") !== "trooper") {
    throw new Error("Assigned trooper not found.");
  }

  const isRecall = String(requestType) === "droneRecall";
  const actionLabel = isRecall ? "drone recall" : "drone deploy";
  const approvalWindowOpened = await beginDropTrooperPendingApprovalWindow(game.user?.id, actionLabel);
  if (!approvalWindowOpened) {
    throw new Error(`Finish the pending GM approval before starting another ${actionLabel}.`);
  }

  try {
    const assignedDrone = getDropTrooperAssignedDroneActor(trooperActor, droneActorId);
    const targetName = String(assignedDrone?.name || trooperActor.system?.drone?.assignedActorName || "Assigned Drone").trim() || "Assigned Drone";
    const resolvedDroneActorId = String(assignedDrone?.id || droneActorId || "").trim();

    await createDropTrooperGmDamageApprovalMessage({
      requestType,
      sourceActorId: trooperActor.id,
      sourceActorName: trooperActor.name || "Trooper",
      trooperActorId: trooperActor.id,
      targetName,
      requestedByUserId: game.user?.id || "",
      requestedByName: game.user?.name || "Player",
      droneActorId: resolvedDroneActorId
    });

    return {
      ok: true,
      queued: true,
      message: `${trooperActor.name}: ${isRecall ? "drone recall" : "drone deployment"} sent to the GM queue.`
    };
  } catch (err) {
    await releaseDropTrooperPendingApprovalWindow(game.user?.id);
    throw err;
  }
}

async function queueDropTrooperGmArmorApproval(trooperActorId, mode = "toggle") {
  const trooperActor = game.actors?.get(String(trooperActorId || "").trim());
  if (!trooperActor || String(trooperActor.type || "") !== "trooper") {
    throw new Error("Trooper not found.");
  }

  const state = getDropTrooperOutOfArmorState(trooperActor);
  const normalizedMode = String(mode || "").trim().toLowerCase();
  const desiredMode = normalizedMode === "toggle"
    ? (state.active ? "return" : "exit")
    : (normalizedMode === "return" ? "return" : "exit");
  const requestType = desiredMode === "return" ? "armorReturn" : "armorExit";
  const actionLabel = desiredMode === "return" ? "return to armor" : "exit armor";
  const approvalWindowOpened = await beginDropTrooperPendingApprovalWindow(game.user?.id, actionLabel);
  if (!approvalWindowOpened) {
    throw new Error(`Finish the pending GM approval before starting another ${actionLabel}.`);
  }

  try {
    await createDropTrooperGmDamageApprovalMessage({
      requestType,
      sourceActorId: trooperActor.id,
      sourceActorName: trooperActor.name || "Trooper",
      trooperActorId: trooperActor.id,
      targetName: trooperActor.name || "Trooper",
      requestedByUserId: game.user?.id || "",
      requestedByName: game.user?.name || "Player",
      armorMode: desiredMode
    });

    return {
      ok: true,
      queued: true,
      message: `${trooperActor.name}: ${desiredMode === "return" ? "return to armor" : "exit armor"} sent to the GM queue.`
    };
  } catch (err) {
    await releaseDropTrooperPendingApprovalWindow(game.user?.id);
    throw err;
  }
}

function resolveDropTrooperSocketRequestResponse(data) {
  const requestId = String(data?.requestId || "").trim();
  if (!requestId) return;

  const pending = dropTrooperSocketPendingRequests.get(requestId);
  if (!pending) return;

  clearTimeout(pending.timeout);
  dropTrooperSocketPendingRequests.delete(requestId);

  if (data?.ok) {
    pending.resolve(data?.result || { ok: true });
    return;
  }

  pending.reject(new Error(data?.error || "Drone action failed."));
}

async function respondToDropTrooperSocketRequest(requesterUserId, requestId, response) {
  game.socket.emit(DROP_TROOPER_SOCKET_NAMESPACE, {
    action: DROP_TROOPER_SOCKET_ACTION_RESPONSE,
    requestId,
    targetUserId: requesterUserId,
    ...response
  });
}

async function performDropTrooperDroneDeploy(trooperActorId, droneActorId = null) {
  const trooperActor = game.actors?.get(String(trooperActorId || "").trim());
  if (!trooperActor || String(trooperActor.type || "") !== "trooper") {
    throw new Error("Assigned trooper not found.");
  }

  if (!canvas?.ready || !canvas.scene) {
    throw new Error("Open the battle map before deploying a drone.");
  }

  const assignedDrone = getDropTrooperAssignedDroneActor(trooperActor, droneActorId);
  if (!assignedDrone || String(assignedDrone.type || "") !== "drone") {
    throw new Error(`${trooperActor.name}: set Assigned Drone Actor ID first.`);
  }

  const sourceToken = getDropTrooperPreferredActorTokenByActor(trooperActor);
  if (!sourceToken?.document) {
    throw new Error(`${trooperActor.name}: place this trooper on the map before deploying a drone.`);
  }

  const conflictingDrone = findDropTrooperActiveDroneConflict(trooperActor.id, assignedDrone.id);
  if (conflictingDrone) {
    throw new Error(`${trooperActor.name}: ${conflictingDrone.name} is already the active drone for this trooper.`);
  }

  const currentlyDeployed = getDropTrooperDroneCurrentDeployed(assignedDrone);
  const currentIntegrity = getDropTrooperDroneCurrentIntegrity(assignedDrone);
  if (currentlyDeployed && currentIntegrity > 0) {
    throw new Error(`${assignedDrone.name} is already deployed.`);
  }

  let tokenDoc;
  try {
    tokenDoc = await assignedDrone.getTokenDocument({ hidden: false });
  } catch (err) {
    console.warn("Drop Trooper | Failed to prepare drone token document", err);
    throw new Error(`Failed to prepare ${assignedDrone.name} for deployment.`);
  }

  const spawn = getDropTrooperNearestOpenDroneSpawnPosition(sourceToken.document, tokenDoc, canvas.scene);
  tokenDoc.updateSource({ x: spawn.x, y: spawn.y, hidden: false });

  const existingTokens = getDropTrooperCanvasTokensForActor(assignedDrone);
  const tokenIds = existingTokens.map(token => token.id).filter(Boolean);
  if (tokenIds.length) {
    await canvas.scene.deleteEmbeddedDocuments("Token", tokenIds);
  }

  const currentUses = Math.max(0, Number(trooperActor?.system?.drone?.uses) || 0);
  const deploymentPaid = Boolean(assignedDrone?.system?.combat?.deploymentPaid);
  const needsReplacement = currentIntegrity <= 0;
  const needsUse = needsReplacement || !deploymentPaid;
  if (needsUse && currentUses <= 0) {
    throw new Error(`${trooperActor.name}: no Drone Uses remaining.`);
  }

  try {
    await canvas.scene.createEmbeddedDocuments("Token", [tokenDoc.toObject()]);
  } catch (err) {
    console.warn("Drop Trooper | Failed to create drone token", err);
    throw new Error(`Failed to place ${assignedDrone.name} on the map.`);
  }

  const droneUpdates = {
    "system.control.controllerActorId": trooperActor.id,
    "system.control.controllerName": String(trooperActor.name || "").trim(),
    "system.combat.deployed": true,
    "system.combat.actionsRemaining": getDropTrooperDroneCurrentActionsPerTurn(assignedDrone),
    "system.combat.deploymentPaid": true
  };

  if (needsReplacement) {
    const integrityMax = Math.max(1, Number(assignedDrone?.system?.armor?.integrity?.max) || 1);
    droneUpdates["system.armor.integrity.value"] = integrityMax;
  }

  const trooperUpdates = {};
  if (needsUse) {
    trooperUpdates["system.drone.uses"] = Math.max(0, currentUses - 1);
  }
  if (String(trooperActor?.system?.drone?.assignedActorName || "").trim() !== String(assignedDrone.name || "").trim()) {
    trooperUpdates["system.drone.assignedActorName"] = String(assignedDrone.name || "").trim();
  }

  await assignedDrone.update(droneUpdates);
  if (Object.keys(trooperUpdates).length) {
    await trooperActor.update(trooperUpdates);
  }

  return {
    ok: true,
    message: `${trooperActor.name} deploys ${assignedDrone.name}.`
  };
}

async function performDropTrooperDroneRecall(trooperActorId, droneActorId = null) {
  const trooperActor = game.actors?.get(String(trooperActorId || "").trim());
  if (!trooperActor || String(trooperActor.type || "") !== "trooper") {
    throw new Error("Assigned trooper not found.");
  }

  if (!canvas?.ready || !canvas.scene) {
    throw new Error("Open the battle map before recalling a drone.");
  }

  const assignedDrone = getDropTrooperAssignedDroneActor(trooperActor, droneActorId);
  if (!assignedDrone || String(assignedDrone.type || "") !== "drone") {
    throw new Error(`${trooperActor.name}: set Assigned Drone Actor ID first.`);
  }

  if (!getDropTrooperDroneCurrentDeployed(assignedDrone)) {
    throw new Error(`${trooperActor.name}: no active drone to recall.`);
  }

  const currentIntegrity = getDropTrooperDroneCurrentIntegrity(assignedDrone);
  if (currentIntegrity <= 0) {
    throw new Error(`${assignedDrone.name} is destroyed and cannot be recalled.`);
  }

  const tokenIds = getDropTrooperCanvasTokensForActor(assignedDrone).map(token => token.id).filter(Boolean);
  if (tokenIds.length) {
    await canvas.scene.deleteEmbeddedDocuments("Token", tokenIds);
  }

  await assignedDrone.update({
    "system.control.controllerActorId": trooperActor.id,
    "system.control.controllerName": String(trooperActor.name || "").trim(),
    "system.combat.deployed": false,
    "system.combat.actionsRemaining": 0
  });

  return {
    ok: true,
    message: `${trooperActor.name} recalls ${assignedDrone.name}.`
  };
}

function getDropTrooperPreferredActorTokenByActor(actor) {
  if (!canvas?.ready || !actor) return null;
  const actorId = actor.id;
  const controlled = (canvas.tokens?.controlled || []).find(token => {
    if (!token?.actor) return false;
    if (token.actor === actor) return true;
    if (token.actor?.id && token.actor.id === actorId) return true;
    if (token.document?.actorId && token.document.actorId === actorId) return true;
    return false;
  });
  if (controlled) return controlled;
  return getDropTrooperCanvasTokensForActor(actor)[0] || null;
}

function getDropTrooperCanvasTokensForActor(actor) {
  if (!canvas?.ready || !actor) return [];
  const actorId = actor.id;
  return (canvas.tokens?.placeables || []).filter(token => {
    if (!token?.actor) return false;
    if (token.actor === actor) return true;
    if (token.actor?.id && token.actor.id === actorId) return true;
    if (token.document?.actorId && token.document.actorId === actorId) return true;
    return false;
  });
}

function getDropTrooperTokenDocumentFromActor(actor) {
  if (!actor?.isToken) return null;
  if (actor.token?.documentName === "Token") return actor.token;
  if (actor.parent?.documentName === "Token") return actor.parent;
  return null;
}

function getDropTrooperSyncTargetsForActor(actor, tokenDocument = null) {
  const explicitTokenDocument = tokenDocument || getDropTrooperTokenDocumentFromActor(actor);
  if (explicitTokenDocument) {
    const placeable = explicitTokenDocument.object;
    if (placeable) return [placeable];
    return [];
  }

  return getDropTrooperCanvasTokensForActor(actor);
}

function isDropTrooperActorDefeated(actor) {
  if (foundry.utils.hasProperty(actor, "system.health.value")) {
    const healthValue = Number(actor?.system?.health?.value);
    return Number.isFinite(healthValue) && healthValue <= 0;
  }

  const integrityValue = Number(actor?.system?.armor?.integrity?.value);
  return Number.isFinite(integrityValue) && integrityValue <= 0;
}

const playDropTrooperDefeatSound = (...args) => globalThis.DropTrooperWeaponAudio.playDropTrooperDefeatSound(...args);

const playDropTrooperCritSuccessSound = (...args) => globalThis.DropTrooperWeaponAudio.playDropTrooperCritSuccessSound(...args);

const playDropTrooperRandomHitSound = (...args) => globalThis.DropTrooperWeaponAudio.playDropTrooperRandomHitSound(...args);

const playDropTrooperEffectSound = (...args) => globalThis.DropTrooperWeaponAudio.playDropTrooperEffectSound(...args);

const playDropTrooperBlastSound = (...args) => globalThis.DropTrooperWeaponAudio.playDropTrooperBlastSound(...args);

const playDropTrooperConeSound = (...args) => globalThis.DropTrooperWeaponAudio.playDropTrooperConeSound(...args);

function playDropTrooperCritVideoLocal() {
  const videoPath = "video/Old Dudes Blast 2.mp4";
  const existing = document.getElementById("dt-crit-video");
  if (existing) existing.remove();

  const wrapper = document.createElement("div");
  wrapper.id = "dt-crit-video";
  wrapper.style.position = "fixed";
  wrapper.style.top = "50%";
  wrapper.style.left = "50%";
  wrapper.style.transform = "translate(-50%, -50%)";
  wrapper.style.width = "min(70vw, 960px)";
  wrapper.style.maxHeight = "70vh";
  wrapper.style.zIndex = "10000";
  wrapper.style.pointerEvents = "none";
  wrapper.style.display = "flex";
  wrapper.style.alignItems = "center";
  wrapper.style.justifyContent = "center";
  wrapper.style.background = "transparent";

  const video = document.createElement("video");
  video.src = videoPath;
  video.autoplay = true;
  video.playsInline = true;
  video.preload = "auto";
  video.style.maxWidth = "100%";
  video.style.maxHeight = "100%";
  video.style.objectFit = "contain";
  video.style.border = "none";
  video.style.boxShadow = "0 0 24px rgba(0,0,0,0.65)";

  const cleanup = () => wrapper.remove();
  video.addEventListener("ended", cleanup, { once: true });
  video.addEventListener("error", cleanup, { once: true });

  wrapper.appendChild(video);
  document.body.appendChild(wrapper);

  const playPromise = video.play();
  if (playPromise?.catch) playPromise.catch(() => cleanup());

  setTimeout(() => {
    if (wrapper.isConnected) {
      try { video.pause(); } catch (_) {}
      cleanup();
    }
  }, 6000);
}

async function playDropTrooperCritSuccessCelebration() {
  playDropTrooperCritVideoLocal();

  if (game.socket) {
    game.socket.emit(DROP_TROOPER_SOCKET_NAMESPACE, {
      action: DROP_TROOPER_SOCKET_ACTION_PLAY_CRIT_VIDEO,
      userId: game.user?.id || null
    });
  }
}

async function syncDropTrooperDefeatStateForActor(actor, { playSound = false, tokenDocument = null } = {}) {
  if (!game.user?.isGM) return;
  if (!isDropTrooperHealthTrackedActor(actor)) return;

  const shouldBeDefeated = isDropTrooperActorDefeated(actor);
  const canvasTokens = getDropTrooperSyncTargetsForActor(actor, tokenDocument);
  let changedToDefeated = false;

  for (const token of canvasTokens) {
    const tokenActor = token.actor;
    if (!tokenActor?.toggleStatusEffect) continue;

    const hasStatus = token.document?.hasStatusEffect?.(DROP_TROOPER_DEFEATED_STATUS_ID) ?? false;
    if (shouldBeDefeated && !hasStatus) {
      await tokenActor.toggleStatusEffect(DROP_TROOPER_DEFEATED_STATUS_ID, { active: true, overlay: true });
      changedToDefeated = true;
    } else if (!shouldBeDefeated && hasStatus) {
      await tokenActor.toggleStatusEffect(DROP_TROOPER_DEFEATED_STATUS_ID, { active: false, overlay: true });
    }

    const combatant = token.combatant || token.document?.combatant;
    if (combatant && combatant.defeated !== shouldBeDefeated) {
      await combatant.update({ defeated: shouldBeDefeated });
    }
  }

  if (playSound && changedToDefeated) {
    await playDropTrooperDefeatSound();
  }
}

async function syncDropTrooperDefeatStatesOnCanvas() {
  if (!game.user?.isGM) return;

  for (const token of canvas?.tokens?.placeables || []) {
    if (!isDropTrooperHealthTrackedActor(token?.actor)) continue;
    await syncDropTrooperDefeatStateForActor(token.actor, {
      playSound: false,
      tokenDocument: token.document
    });
  }
}

async function applyDropTrooperDamageToTokenDocument(tokenDocument, damage, options = {}) {
  const targetActor = tokenDocument?.actor;
  if (!targetActor) {
    throw new Error("Target token actor not found.");
  }

  const currentIntegrity = Number(targetActor.system?.armor?.integrity?.value) || 0;
  const tracksHealth = foundry.utils.hasProperty(targetActor, "system.health.value");
  const currentHealth = tracksHealth ? (Number(targetActor.system?.health?.value) || 0) : 0;
  const safeDamage = Math.max(0, Number(damage) || 0);
  const damageTarget = normalizeDropTrooperWeaponDamageTarget(options?.damageTarget, "normal");

  let integrityDamage = 0;
  let healthDamage = 0;
  let newIntegrity = currentIntegrity;
  let newHealth = currentHealth;

  if (damageTarget === "health") {
    healthDamage = tracksHealth ? Math.min(currentHealth, safeDamage) : 0;
    newHealth = tracksHealth ? Math.max(0, currentHealth - healthDamage) : 0;
  } else {
    integrityDamage = Math.min(currentIntegrity, safeDamage);
    const remainingAfterIntegrity = Math.max(0, safeDamage - currentIntegrity);
    healthDamage = tracksHealth ? Math.min(currentHealth, remainingAfterIntegrity) : 0;
    newIntegrity = Math.max(0, currentIntegrity - integrityDamage);
    newHealth = tracksHealth ? Math.max(0, currentHealth - healthDamage) : 0;
  }

  const updateData = {
    "system.armor.integrity.value": newIntegrity
  };

  if (tracksHealth) {
    updateData["system.health.value"] = newHealth;
  }

  await targetActor.update(updateData);

  return {
    integrityDamage,
    healthDamage,
    newIntegrity,
    newHealth,
    tracksHealth,
    damageTarget,
    damageTargetLabel: getDropTrooperDamageTargetLabel(damageTarget)
  };
}

function getDropTrooperActiveGmUser() {
  return game.users?.find(user => user?.isGM && user?.active) || null;
}

function getDropTrooperDocumentOwnershipNoneLevel() {
  return Number(CONST?.DOCUMENT_OWNERSHIP_LEVELS?.NONE ?? 0);
}

function getDropTrooperDocumentOwnershipOwnerLevel() {
  return Number(CONST?.DOCUMENT_OWNERSHIP_LEVELS?.OWNER ?? 3);
}

function cloneDropTrooperOwnershipMap(source = null) {
  const cloned = foundry.utils.deepClone(source || {}) || {};
  if (!Object.prototype.hasOwnProperty.call(cloned, "default")) {
    cloned.default = getDropTrooperDocumentOwnershipNoneLevel();
  }
  return cloned;
}

function normalizeDropTrooperOwnershipMap(source = null) {
  const normalized = cloneDropTrooperOwnershipMap(source);
  const keys = Object.keys(normalized).sort();
  const result = {};
  for (const key of keys) {
    result[key] = Number(normalized[key]) || 0;
  }
  return result;
}

function areDropTrooperOwnershipMapsEqual(left = null, right = null) {
  const leftMap = normalizeDropTrooperOwnershipMap(left);
  const rightMap = normalizeDropTrooperOwnershipMap(right);
  return JSON.stringify(leftMap) === JSON.stringify(rightMap);
}

function getDropTrooperPrimaryNonGmOwnerUser(controllerActor) {
  const ownership = normalizeDropTrooperOwnershipMap(controllerActor?.ownership);
  const ownerLevel = getDropTrooperDocumentOwnershipOwnerLevel();
  const candidates = Object.entries(ownership)
    .filter(([userId, level]) => userId !== "default" && Number(level) >= ownerLevel)
    .map(([userId, level]) => ({ user: game.users?.get(userId), level: Number(level) || 0 }))
    .filter(entry => entry.user && !entry.user.isGM);

  if (!candidates.length) return null;

  candidates.sort((a, b) => {
    if (Number(b.user?.active) !== Number(a.user?.active)) {
      return Number(b.user?.active) - Number(a.user?.active);
    }
    if (b.level !== a.level) return b.level - a.level;
    return String(a.user?.name || "").localeCompare(String(b.user?.name || ""));
  });

  return candidates[0].user || null;
}

function getDropTrooperDroneOwnershipSyncPayload(droneActor, controllerActor) {
  const controllerName = String(controllerActor?.name || "").trim();
  const primaryOwnerUser = getDropTrooperPrimaryNonGmOwnerUser(controllerActor);
  const ownerName = String(primaryOwnerUser?.name || "").trim();
  const ownerUserId = String(primaryOwnerUser?.id || "").trim();

  return {
    controllerName,
    ownerName,
    ownerUserId,
    ownership: cloneDropTrooperOwnershipMap(controllerActor?.ownership),
    hasPlayerOwner: !!ownerUserId
  };
}

async function sendDropTrooperDroneOwnershipGmNotice(droneActor, controllerActor, reason, payload = null) {
  const whisperIds = ChatMessage.getWhisperRecipients("GM").map(user => user.id);
  if (!whisperIds.length) return;

  const droneName = escapeDropTrooperHtml(droneActor?.name || "Drone");
  const controllerName = escapeDropTrooperHtml(controllerActor?.name || payload?.controllerName || "Unknown Trooper");
  const ownerName = escapeDropTrooperHtml(payload?.ownerName || "None");
  const ownerUserId = escapeDropTrooperHtml(payload?.ownerUserId || "None");
  const reasonText = escapeDropTrooperHtml(reason || "Ownership could not be applied automatically.");

  await ChatMessage.create({
    whisper: whisperIds,
    speaker: ChatMessage.getSpeaker({ actor: droneActor || controllerActor || null }),
    content: `
      <div class="dt-chat-card">
        <div class="dt-chat-header">
          <div class="dt-chat-title">${droneName}</div>
          <div class="dt-chat-subtitle">Drone Ownership Check</div>
        </div>
        <div class="dt-chat-body">
          <div class="dt-chat-section">
            <div><strong>Controller:</strong> ${controllerName}</div>
            <div><strong>Suggested Owner:</strong> ${ownerName}</div>
            <div><strong>Owner User ID:</strong> ${ownerUserId}</div>
            <div class="dt-help-text" style="margin-top:6px;">${reasonText}</div>
          </div>
          <div class="dt-chat-section">
            <div><strong>GM Fallback:</strong> Configure Ownership on the drone actor if manual assignment is needed.</div>
          </div>
        </div>
      </div>
    `
  });
}

async function syncDropTrooperDroneOwnershipFromController(droneActor, { notifyGmOnFailure = false } = {}) {
  if (!game.user?.isGM) return false;
  if (!isDropTrooperDroneActor(droneActor)) return false;
  if (!getDropTrooperDroneCurrentDeployed(droneActor)) return false;

  const controllerActorId = getDropTrooperDroneCurrentControllerActorId(droneActor);
  if (!controllerActorId) {
    if (notifyGmOnFailure) {
      await sendDropTrooperDroneOwnershipGmNotice(
        droneActor,
        null,
        "Deploy succeeded, but the drone has no Controller Actor ID.",
        null
      );
    }
    return false;
  }

  const controllerActor = game.actors?.get(controllerActorId);
  if (!controllerActor || String(controllerActor.type || "") !== "trooper") {
    if (notifyGmOnFailure) {
      await sendDropTrooperDroneOwnershipGmNotice(
        droneActor,
        controllerActor,
        "Deploy succeeded, but the Controller Actor ID does not point to a valid trooper actor.",
        null
      );
    }
    return false;
  }

  const payload = getDropTrooperDroneOwnershipSyncPayload(droneActor, controllerActor);
  const updates = {};

  if (String(droneActor?.system?.control?.controllerName || "").trim() !== payload.controllerName) {
    updates["system.control.controllerName"] = payload.controllerName;
  }

  if (String(droneActor?.system?.control?.ownerName || "").trim() !== payload.ownerName) {
    updates["system.control.ownerName"] = payload.ownerName;
  }

  if (String(droneActor?.system?.control?.ownerUserId || "").trim() !== payload.ownerUserId) {
    updates["system.control.ownerUserId"] = payload.ownerUserId;
  }

  if (!areDropTrooperOwnershipMapsEqual(droneActor?.ownership, payload.ownership)) {
    updates.ownership = payload.ownership;
  }

  if (Object.keys(updates).length) {
    await droneActor.update(updates);
  }

  if (!payload.hasPlayerOwner && notifyGmOnFailure) {
    await sendDropTrooperDroneOwnershipGmNotice(
      droneActor,
      controllerActor,
      "No non-GM owner was found on the controller trooper, so player ownership may still need a manual GM pass.",
      payload
    );
  }

  return true;
}

function getDropTrooperGmApprovalMessageByRequestId(requestId) {
  const safeRequestId = String(requestId || "").trim();
  if (!safeRequestId) return null;

  return Array.from(game.messages?.contents || []).find(message => {
    const data = message.getFlag("drop-trooper", "gmDamageApproval") || {};
    return String(data.requestId || "").trim() === safeRequestId;
  }) || null;
}

function getDropTrooperGmApprovalResolutionLockKey(message, approvalData = null) {
  const liveData = approvalData || message?.getFlag?.("drop-trooper", "gmDamageApproval") || {};
  const requestId = String(liveData?.requestId || "").trim();
  const messageId = String(message?.id || "").trim();
  return requestId || messageId || null;
}

function isDropTrooperGmApprovalResolutionLocked(message, approvalData = null) {
  const lockKey = getDropTrooperGmApprovalResolutionLockKey(message, approvalData);
  return !!lockKey && dropTrooperGmApprovalResolutionLocks.has(lockKey);
}

function lockDropTrooperGmApprovalResolution(message, approvalData = null) {
  const lockKey = getDropTrooperGmApprovalResolutionLockKey(message, approvalData);
  if (!lockKey) return false;
  if (dropTrooperGmApprovalResolutionLocks.has(lockKey)) return false;
  dropTrooperGmApprovalResolutionLocks.add(lockKey);
  return true;
}

function unlockDropTrooperGmApprovalResolution(message, approvalData = null) {
  const lockKey = getDropTrooperGmApprovalResolutionLockKey(message, approvalData);
  if (!lockKey) return;
  dropTrooperGmApprovalResolutionLocks.delete(lockKey);
}

async function updateDropTrooperGmApprovalMessageState(message, approvalData) {
  await message.update({
    content: renderDropTrooperGmDamageApprovalCard(approvalData),
    flags: {
      "drop-trooper": {
        gmDamageApproval: approvalData
      }
    }
  });
}

async function settleDropTrooperGmApprovalRequestForUser(userId, delta = -1) {
  if (!userId) return;
  await adjustDropTrooperPendingApprovalCount(userId, delta);
}

function getDropTrooperGmApprovalMessages() {
  const messages = Array.from(game.messages?.contents || []).filter(message => !!message.getFlag("drop-trooper", "gmDamageApproval"));
  return messages.sort((a, b) => {
    const aData = a.getFlag("drop-trooper", "gmDamageApproval") || {};
    const bData = b.getFlag("drop-trooper", "gmDamageApproval") || {};
    return Number(aData.createdAt || 0) - Number(bData.createdAt || 0);
  });
}

function getDropTrooperPendingGmApprovalMessages() {
  return getDropTrooperGmApprovalMessages().filter(message => {
    const data = message.getFlag("drop-trooper", "gmDamageApproval") || {};
    return String(data.status || "pending") === "pending";
  });
}

function getDropTrooperGmApprovalPanelId() {
  return "drop-trooper-gm-approval-panel";
}

function buildDropTrooperGmApprovalPanelItem(message) {
  const data = foundry.utils.deepClone(message.getFlag("drop-trooper", "gmDamageApproval") || {});
  const requestType = String(data.requestType || "damage");
  const attackerName = escapeDropTrooperHtml(data.sourceActorName || data.requestedByName || "Attacker");
  const attackName = escapeDropTrooperHtml(data.weaponName || data.attackLabel || data.abilityName || "Attack");
  const targetName = escapeDropTrooperHtml(data.targetName || "Target");

  if (requestType === "droneDeploy" || requestType === "droneRecall") {
    const isRecall = requestType === "droneRecall";
    const trooperName = escapeDropTrooperHtml(data.sourceActorName || data.requestedByName || "Trooper");
    const droneName = escapeDropTrooperHtml(data.targetName || "Assigned Drone");
    const requestedBy = escapeDropTrooperHtml(data.requestedByName || "Player");
    const queueLabel = isRecall ? "GM Drone Recall Approval" : "GM Drone Deploy Approval";
    const actionLabel = isRecall ? "Recall" : "Deploy";

    const status = String(data.status || "pending");
    let statusHtml = `<div style="margin-top:8px;padding:6px 8px;border-radius:6px;background:#4b3f17;color:#ffe8a3;font-size:11px;font-weight:700;">Pending Approval</div>`;
    if (status === "applied") {
      const resultMessage = escapeDropTrooperHtml(data.resultMessage || (isRecall ? "Drone recalled." : "Drone deployed."));
      statusHtml = `<div style="margin-top:8px;padding:6px 8px;border-radius:6px;background:#1f4d32;color:#d8ffe7;font-size:11px;font-weight:700;">Approved${resultMessage ? ` • ${resultMessage}` : ""}</div>`;
    } else if (status === "rejected") {
      statusHtml = `<div style="margin-top:8px;padding:6px 8px;border-radius:6px;background:#5a2222;color:#ffd7d7;font-size:11px;font-weight:700;">Rejected</div>`;
    } else if (status === "failed") {
      const failureReason = escapeDropTrooperHtml(data.failureReason || "Drone action failed.");
      statusHtml = `<div style="margin-top:8px;padding:6px 8px;border-radius:6px;background:#5a2222;color:#ffd7d7;font-size:11px;font-weight:700;">Failed${failureReason ? ` • ${failureReason}` : ""}</div>`;
    }

    const buttonsHtml = status === "pending"
      ? `<div style="display:flex;gap:6px;margin-top:8px;">
          <button type="button" data-dt-panel-action="apply" data-message-id="${message.id}" style="flex:1;height:28px;border:1px solid #2d8e57;border-radius:6px;background:#173c24;color:#e9fff2;font-weight:800;cursor:pointer;">Apply</button>
          <button type="button" data-dt-panel-action="reject" data-message-id="${message.id}" style="flex:1;height:28px;border:1px solid #8e4141;border-radius:6px;background:#4a1d1d;color:#ffecec;font-weight:700;cursor:pointer;">Reject</button>
        </div>`
      : "";

    return `
      <div data-dt-panel-item="${message.id}" style="border:1px solid #2c3947;border-radius:8px;background:#16212c;padding:8px;">
        <div style="display:flex;justify-content:space-between;gap:8px;align-items:flex-start;">
          <div style="min-width:0;">
            <div style="font-size:12px;font-weight:800;color:#ffffff;line-height:1.15;word-break:break-word;">${droneName}</div>
            <div style="margin-top:2px;font-size:10px;letter-spacing:0.05em;text-transform:uppercase;color:#8eb9dd;">${queueLabel}</div>
          </div>
          <div style="font-size:14px;font-weight:900;color:#79c8ff;line-height:1;white-space:nowrap;">${actionLabel}</div>
        </div>
        <div style="margin-top:6px;font-size:11px;color:#c7d6e4;line-height:1.25;">
          <div><strong>Trooper:</strong> ${trooperName}</div>
          <div style="margin-top:2px;"><strong>Requested By:</strong> ${requestedBy}</div>
        </div>
        ${statusHtml}
        ${buttonsHtml}
      </div>
    `;
  }

  if (requestType === "armorExit" || requestType === "armorReturn") {
    const isReturn = requestType === "armorReturn";
    const requestedBy = escapeDropTrooperHtml(data.requestedByName || "Player");
    const trooperName = escapeDropTrooperHtml(data.sourceActorName || data.targetName || "Trooper");
    const queueLabel = isReturn ? "GM Return to Armor Approval" : "GM Exit Armor Approval";
    const actionLabel = isReturn ? "Return" : "Exit";
    const status = String(data.status || "pending");

    let statusHtml = `<div style="margin-top:8px;padding:6px 8px;border-radius:6px;background:#4b3f17;color:#ffe8a3;font-size:11px;font-weight:700;">Pending Approval</div>`;
    if (status === "applied") {
      const resultMessage = escapeDropTrooperHtml(data.resultMessage || (isReturn ? "Returned to armor." : "Exited armor."));
      statusHtml = `<div style="margin-top:8px;padding:6px 8px;border-radius:6px;background:#1f4d32;color:#d8ffe7;font-size:11px;font-weight:700;">Approved${resultMessage ? ` • ${resultMessage}` : ""}</div>`;
    } else if (status === "rejected") {
      statusHtml = `<div style="margin-top:8px;padding:6px 8px;border-radius:6px;background:#5a2222;color:#ffd7d7;font-size:11px;font-weight:700;">Rejected</div>`;
    } else if (status === "failed") {
      const failureReason = escapeDropTrooperHtml(data.failureReason || "Armor change failed.");
      statusHtml = `<div style="margin-top:8px;padding:6px 8px;border-radius:6px;background:#5a2222;color:#ffd7d7;font-size:11px;font-weight:700;">Failed${failureReason ? ` • ${failureReason}` : ""}</div>`;
    }

    const buttonsHtml = status === "pending"
      ? `<div style="display:flex;gap:6px;margin-top:8px;">
          <button type="button" data-dt-panel-action="apply" data-message-id="${message.id}" style="flex:1;height:28px;border:1px solid #2d8e57;border-radius:6px;background:#173c24;color:#e9fff2;font-weight:800;cursor:pointer;">Apply</button>
          <button type="button" data-dt-panel-action="reject" data-message-id="${message.id}" style="flex:1;height:28px;border:1px solid #8e4141;border-radius:6px;background:#4a1d1d;color:#ffecec;font-weight:700;cursor:pointer;">Reject</button>
        </div>`
      : "";

    return `
      <div data-dt-panel-item="${message.id}" style="border:1px solid #2c3947;border-radius:8px;background:#16212c;padding:8px;">
        <div style="display:flex;justify-content:space-between;gap:8px;align-items:flex-start;">
          <div style="min-width:0;">
            <div style="font-size:12px;font-weight:800;color:#ffffff;line-height:1.15;word-break:break-word;">${trooperName}</div>
            <div style="margin-top:2px;font-size:10px;letter-spacing:0.05em;text-transform:uppercase;color:#8eb9dd;">${queueLabel}</div>
          </div>
          <div style="font-size:14px;font-weight:900;color:#79c8ff;line-height:1;white-space:nowrap;">${actionLabel}</div>
        </div>
        <div style="margin-top:6px;font-size:11px;color:#c7d6e4;line-height:1.25;">
          <div><strong>Trooper:</strong> ${trooperName}</div>
          <div style="margin-top:2px;"><strong>Requested By:</strong> ${requestedBy}</div>
        </div>
        ${statusHtml}
        ${buttonsHtml}
      </div>
    `;
  }

  if (requestType === "sheetChange") {
    const requestedBy = escapeDropTrooperHtml(data.requestedByName || "Player");
    const trooperName = escapeDropTrooperHtml(data.sourceActorName || data.targetName || "Trooper");
    const fieldLabel = escapeDropTrooperHtml(data.fieldLabel || "Sheet Field");
    const currentValueDisplay = escapeDropTrooperHtml(data.currentValueDisplay || "—");
    const requestedValueDisplay = escapeDropTrooperHtml(data.requestedValueDisplay || "—");
    const status = String(data.status || "pending");

    let statusHtml = `<div style="margin-top:8px;padding:6px 8px;border-radius:6px;background:#4b3f17;color:#ffe8a3;font-size:11px;font-weight:700;">Pending Approval</div>`;
    if (status === "applied") {
      const resultMessage = escapeDropTrooperHtml(data.resultMessage || "Sheet change applied.");
      statusHtml = `<div style="margin-top:8px;padding:6px 8px;border-radius:6px;background:#1f4d32;color:#d8ffe7;font-size:11px;font-weight:700;">Approved${resultMessage ? ` • ${resultMessage}` : ""}</div>`;
    } else if (status === "rejected") {
      statusHtml = `<div style="margin-top:8px;padding:6px 8px;border-radius:6px;background:#5a2222;color:#ffd7d7;font-size:11px;font-weight:700;">Rejected</div>`;
    } else if (status === "failed") {
      const failureReason = escapeDropTrooperHtml(data.failureReason || "Sheet change failed.");
      statusHtml = `<div style="margin-top:8px;padding:6px 8px;border-radius:6px;background:#5a2222;color:#ffd7d7;font-size:11px;font-weight:700;">Failed${failureReason ? ` • ${failureReason}` : ""}</div>`;
    }

    const buttonsHtml = status === "pending"
      ? `<div style="display:flex;gap:6px;margin-top:8px;">
          <button type="button" data-dt-panel-action="apply" data-message-id="${message.id}" style="flex:1;height:28px;border:1px solid #2d8e57;border-radius:6px;background:#173c24;color:#e9fff2;font-weight:800;cursor:pointer;">Apply</button>
          <button type="button" data-dt-panel-action="reject" data-message-id="${message.id}" style="flex:1;height:28px;border:1px solid #8e4141;border-radius:6px;background:#4a1d1d;color:#ffecec;font-weight:700;cursor:pointer;">Reject</button>
        </div>`
      : "";

    return `
      <div data-dt-panel-item="${message.id}" style="border:1px solid #2c3947;border-radius:8px;background:#16212c;padding:8px;">
        <div style="display:flex;justify-content:space-between;gap:8px;align-items:flex-start;">
          <div style="min-width:0;">
            <div style="font-size:12px;font-weight:800;color:#ffffff;line-height:1.15;word-break:break-word;">${trooperName}</div>
            <div style="margin-top:2px;font-size:10px;letter-spacing:0.05em;text-transform:uppercase;color:#8eb9dd;">GM Sheet Change Approval</div>
          </div>
          <div style="font-size:12px;font-weight:900;color:#79c8ff;line-height:1.1;text-align:right;">${fieldLabel}</div>
        </div>
        <div style="margin-top:6px;font-size:11px;color:#c7d6e4;line-height:1.25;">
          <div><strong>Requested By:</strong> ${requestedBy}</div>
          <div style="margin-top:2px;"><strong>Current:</strong> ${currentValueDisplay}</div>
          <div style="margin-top:2px;"><strong>Requested:</strong> ${requestedValueDisplay}</div>
        </div>
        ${statusHtml}
        ${buttonsHtml}
      </div>
    `;
  }

  if (requestType === "commandDice") {
    const spendDice = Math.max(0, Number(data.spendDice) || 0);
    const existingBonusDice = Math.max(0, Number(data.existingBonusDice) || 0);
    const totalGrantedDice = Math.max(0, Number(data.totalGrantedDice) || spendDice);

    return `
      <div data-dt-panel-item="${message.id}" style="border:1px solid #2c3947;border-radius:8px;background:#16212c;padding:8px;">
        <div style="display:flex;justify-content:space-between;gap:8px;align-items:flex-start;">
          <div style="min-width:0;">
            <div style="font-size:12px;font-weight:800;color:#ffffff;line-height:1.15;word-break:break-word;">${targetName}</div>
            <div style="margin-top:2px;font-size:10px;letter-spacing:0.05em;text-transform:uppercase;color:#8eb9dd;">${attackName}</div>
          </div>
          <div style="font-size:16px;font-weight:900;color:#79c8ff;line-height:1;white-space:nowrap;">+${spendDice}d6</div>
        </div>
        <div style="margin-top:6px;font-size:11px;color:#c7d6e4;line-height:1.25;">
          <div><strong>From:</strong> ${attackerName}</div>
          ${existingBonusDice > 0 ? `<div style="margin-top:2px;"><strong>Existing:</strong> +${existingBonusDice}d6</div>` : ""}
          <div style="margin-top:2px;"><strong>Next Roll:</strong> +${totalGrantedDice}d6</div>
        </div>
        <div style="display:flex;gap:6px;margin-top:8px;">
          <button type="button" data-dt-panel-action="apply" data-message-id="${message.id}" style="flex:1;height:28px;border:1px solid #2d8e57;border-radius:6px;background:#173c24;color:#e9fff2;font-weight:800;cursor:pointer;">Apply</button>
          <button type="button" data-dt-panel-action="reject" data-message-id="${message.id}" style="flex:1;height:28px;border:1px solid #8e4141;border-radius:6px;background:#4a1d1d;color:#ffecec;font-weight:700;cursor:pointer;">Reject</button>
        </div>
      </div>
    `;
  }

  const safeDamage = Math.max(0, Number(data.damage) || 0);
  const integrityDamage = Math.max(0, Number(data.integrityDamage) || 0);
  const healthDamage = Math.max(0, Number(data.healthDamage) || 0);
  const newIntegrity = Math.max(0, Number(data.newIntegrity) || 0);
  const newHealth = Math.max(0, Number(data.newHealth) || 0);
  const tracksHealth = data.tracksHealth !== false;
  const damageTargetLabel = escapeDropTrooperHtml(data.damageTargetLabel || getDropTrooperDamageTargetLabel(data.damageTarget));

  return `
    <div data-dt-panel-item="${message.id}" style="border:1px solid #2c3947;border-radius:8px;background:#16212c;padding:8px;">
      <div style="display:flex;justify-content:space-between;gap:8px;align-items:flex-start;">
        <div style="min-width:0;">
          <div style="font-size:12px;font-weight:800;color:#ffffff;line-height:1.15;word-break:break-word;">${targetName}</div>
          <div style="margin-top:2px;font-size:10px;letter-spacing:0.05em;text-transform:uppercase;color:#8eb9dd;">${attackName}</div>
        </div>
        <div style="font-size:18px;font-weight:900;color:#ffcc6f;line-height:1;white-space:nowrap;">${safeDamage}</div>
      </div>
      <div style="margin-top:6px;font-size:11px;color:#c7d6e4;line-height:1.25;">
        <div><strong>From:</strong> ${attackerName}</div>
        <div style="margin-top:2px;"><strong>Damage Type:</strong> ${damageTargetLabel}</div>
        <div style="margin-top:2px;"><strong>Integrity:</strong> -${integrityDamage} → ${newIntegrity}</div>
        ${tracksHealth ? `<div style="margin-top:2px;"><strong>Health:</strong> -${healthDamage} → ${newHealth}</div>` : ""}
      </div>
      <div style="display:flex;gap:6px;margin-top:8px;">
        <button type="button" data-dt-panel-action="apply" data-message-id="${message.id}" style="flex:1;height:28px;border:1px solid #2d8e57;border-radius:6px;background:#173c24;color:#e9fff2;font-weight:800;cursor:pointer;">Apply</button>
        <button type="button" data-dt-panel-action="reject" data-message-id="${message.id}" style="flex:1;height:28px;border:1px solid #8e4141;border-radius:6px;background:#4a1d1d;color:#ffecec;font-weight:700;cursor:pointer;">Reject</button>
      </div>
    </div>
  `;
}

function getDropTrooperGmApprovalPanelStorageKey() {
  return "drop-trooper.gm-damage-panel-position";
}

function getDropTrooperDefaultGmApprovalPanelPosition() {
  return {
    top: 88,
    right: 16
  };
}

function getDropTrooperStoredGmApprovalPanelPosition() {
  const defaults = getDropTrooperDefaultGmApprovalPanelPosition();

  try {
    const raw = window.localStorage?.getItem(getDropTrooperGmApprovalPanelStorageKey());
    if (!raw) return defaults;

    const parsed = JSON.parse(raw);
    const top = Number(parsed?.top);
    const left = Number(parsed?.left);
    const right = Number(parsed?.right);

    if (Number.isFinite(top) && Number.isFinite(left)) {
      return { top, left };
    }

    if (Number.isFinite(top) && Number.isFinite(right)) {
      return { top, right };
    }
  } catch (err) {
    console.warn("Drop Trooper | Could not read GM damage panel position", err);
  }

  return defaults;
}

function saveDropTrooperGmApprovalPanelPosition(position = {}) {
  try {
    window.localStorage?.setItem(getDropTrooperGmApprovalPanelStorageKey(), JSON.stringify(position));
  } catch (err) {
    console.warn("Drop Trooper | Could not save GM damage panel position", err);
  }
}

function applyDropTrooperGmApprovalPanelPosition(panel, position = {}) {
  if (!panel) return;

  const top = Math.max(8, Math.round(Number(position.top) || 88));
  panel.style.top = `${top}px`;

  if (Number.isFinite(Number(position.left))) {
    panel.style.left = `${Math.max(8, Math.round(Number(position.left)))}px`;
    panel.style.right = "auto";
  } else {
    panel.style.left = "auto";
    panel.style.right = `${Math.max(8, Math.round(Number(position.right) || 16))}px`;
  }
}

function clampDropTrooperGmApprovalPanelPosition(panel, left, top) {
  const panelWidth = panel.offsetWidth || 180;
  const panelHeight = panel.offsetHeight || 200;
  const maxLeft = Math.max(8, window.innerWidth - panelWidth - 8);
  const maxTop = Math.max(8, window.innerHeight - Math.min(panelHeight, window.innerHeight - 16) - 8);

  return {
    left: Math.min(Math.max(8, Math.round(left)), maxLeft),
    top: Math.min(Math.max(8, Math.round(top)), maxTop)
  };
}

function enableDropTrooperGmApprovalPanelDragging(panel) {
  if (!panel || panel.dataset.dtDragReady === "1") return;
  panel.dataset.dtDragReady = "1";

  let dragState = null;

  panel.addEventListener("pointerdown", event => {
    const header = event.target.closest("[data-dt-panel-header]");
    if (!header) return;
    if (event.target.closest("button")) return;

    const rect = panel.getBoundingClientRect();
    dragState = {
      pointerId: event.pointerId,
      offsetX: event.clientX - rect.left,
      offsetY: event.clientY - rect.top
    };

    panel.setPointerCapture?.(event.pointerId);
    panel.style.userSelect = "none";
    panel.style.cursor = "grabbing";
    event.preventDefault();
  });

  panel.addEventListener("pointermove", event => {
    if (!dragState || event.pointerId !== dragState.pointerId) return;

    const nextLeft = event.clientX - dragState.offsetX;
    const nextTop = event.clientY - dragState.offsetY;
    const clamped = clampDropTrooperGmApprovalPanelPosition(panel, nextLeft, nextTop);
    applyDropTrooperGmApprovalPanelPosition(panel, clamped);
  });

  const finishDrag = event => {
    if (!dragState || event.pointerId !== dragState.pointerId) return;

    const rect = panel.getBoundingClientRect();
    const clamped = clampDropTrooperGmApprovalPanelPosition(panel, rect.left, rect.top);
    applyDropTrooperGmApprovalPanelPosition(panel, clamped);
    saveDropTrooperGmApprovalPanelPosition(clamped);
    panel.releasePointerCapture?.(event.pointerId);
    panel.style.userSelect = "";
    panel.style.cursor = "";
    dragState = null;
  };

  panel.addEventListener("pointerup", finishDrag);
  panel.addEventListener("pointercancel", finishDrag);
}

function ensureDropTrooperGmApprovalPanel() {
  const panelId = getDropTrooperGmApprovalPanelId();
  let panel = document.getElementById(panelId);

  if (!game.user?.isGM) {
    if (panel) panel.remove();
    return null;
  }

  if (!panel) {
    panel = document.createElement("section");
    panel.id = panelId;
    panel.dataset.collapsed = "0";
    panel.style.position = "fixed";
    panel.style.top = "88px";
    panel.style.right = "16px";
    panel.style.width = "180px";
    panel.style.maxHeight = "70vh";
    panel.style.zIndex = "100";
    panel.style.background = "#101923";
    panel.style.border = "1px solid #2c3947";
    panel.style.borderRadius = "10px";
    panel.style.boxShadow = "0 10px 28px rgba(0,0,0,0.35)";
    panel.style.color = "#dbe6f1";
    panel.style.overflow = "hidden";
    panel.style.fontFamily = "sans-serif";
    panel.style.pointerEvents = "auto";

    panel.addEventListener("click", async event => {
      const toggleButton = event.target.closest("[data-dt-panel-toggle]");
      if (toggleButton) {
        event.preventDefault();
        panel.dataset.collapsed = panel.dataset.collapsed === "1" ? "0" : "1";
        refreshDropTrooperGmApprovalPanel();
        return;
      }

      const actionButton = event.target.closest("[data-dt-panel-action]");
      if (!actionButton) return;

      event.preventDefault();
      event.stopPropagation();

      if (actionButton.dataset.dtBusy === "1") return;
      actionButton.dataset.dtBusy = "1";

      const messageId = actionButton.dataset.messageId;
      const action = actionButton.dataset.dtPanelAction || "apply";
      const message = game.messages?.get(messageId);
      if (!message) {
        refreshDropTrooperGmApprovalPanel();
        return;
      }

      if (isDropTrooperGmApprovalResolutionLocked(message)) {
        refreshDropTrooperGmApprovalPanel();
        return;
      }

      const itemRoot = actionButton.closest("[data-dt-panel-item]");
      if (itemRoot) {
        itemRoot.querySelectorAll("button").forEach(button => {
          button.disabled = true;
        });
      }

      try {
        await resolveDropTrooperGmDamageApproval(message, action);
      } catch (err) {
        console.error("Drop Trooper | GM damage panel action failed", err);
        ui.notifications.error(`GM damage approval failed: ${err.message}`);
      } finally {
        refreshDropTrooperGmApprovalPanel();
      }
    });

    document.body.appendChild(panel);
    applyDropTrooperGmApprovalPanelPosition(panel, getDropTrooperStoredGmApprovalPanelPosition());
    enableDropTrooperGmApprovalPanelDragging(panel);
  }

  return panel;
}

function refreshDropTrooperGmApprovalPanel() {
  const panel = ensureDropTrooperGmApprovalPanel();
  if (!panel) return;

  const collapsed = panel.dataset.collapsed === "1";
  const pendingMessages = getDropTrooperPendingGmApprovalMessages();
  const count = pendingMessages.length;
  const badgeStyle = count > 0
    ? "display:inline-flex;min-width:18px;height:18px;padding:0 6px;border-radius:999px;background:#8a2d2d;color:#fff;align-items:center;justify-content:center;font-size:11px;font-weight:800;"
    : "display:inline-flex;min-width:18px;height:18px;padding:0 6px;border-radius:999px;background:#314252;color:#dbe6f1;align-items:center;justify-content:center;font-size:11px;font-weight:800;";

  const listHtml = collapsed
    ? ""
    : (count
      ? pendingMessages.map(message => buildDropTrooperGmApprovalPanelItem(message)).join("")
      : '<div style="padding:12px;border:1px dashed #304151;border-radius:8px;color:#a8b9c8;font-size:12px;text-align:center;">No pending approvals.</div>');

  panel.innerHTML = `
    <div data-dt-panel-header="1" style="display:flex;align-items:center;justify-content:space-between;gap:6px;padding:10px 10px;background:linear-gradient(90deg,#192633,#223447);border-bottom:${collapsed ? '0' : '1px solid #324255'};cursor:grab;touch-action:none;">
      <div style="display:flex;align-items:center;gap:6px;min-width:0;">
        <div style="font-weight:800;font-size:11px;letter-spacing:0.05em;text-transform:uppercase;color:#79c8ff;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">GM Queue</div>
        <span style="${badgeStyle}">${count}</span>
      </div>
      <button type="button" data-dt-panel-toggle="1" style="width:24px;height:24px;border:1px solid #415566;border-radius:6px;background:#16212c;color:#e8edf2;font-weight:800;cursor:pointer;flex:0 0 auto;">${collapsed ? '+' : '–'}</button>
    </div>
    ${collapsed ? '' : `<div style="padding:8px;display:grid;gap:8px;max-height:calc(70vh - 44px);overflow-y:auto;">${listHtml}</div>`}
  `;
}

function renderDropTrooperGmDamageApprovalCard(payload = {}) {
  const status = String(payload.status || "pending");
  const requestType = String(payload.requestType || "damage");
  const attackerName = escapeDropTrooperHtml(payload.sourceActorName || payload.requestedByName || "Attacker");
  const attackName = escapeDropTrooperHtml(payload.weaponName || payload.attackLabel || payload.abilityName || "Attack");
  const targetName = escapeDropTrooperHtml(payload.targetName || "Target");

  let statusHtml = `<div style="margin-top:8px;padding:6px 8px;border-radius:6px;background:#4b3f17;border:1px solid #8a7430;font-size:12px;"><strong>Status:</strong> Waiting for GM approval</div>`;
  if (status === "applied") {
    statusHtml = `<div style="margin-top:8px;padding:6px 8px;border-radius:6px;background:#173c24;border:1px solid #2c8c55;font-size:12px;"><strong>Status:</strong> Applied by ${escapeDropTrooperHtml(payload.resolvedByName || "GM")}</div>`;
  } else if (status === "rejected") {
    statusHtml = `<div style="margin-top:8px;padding:6px 8px;border-radius:6px;background:#4a1d1d;border:1px solid #9b3d3d;font-size:12px;"><strong>Status:</strong> Rejected by ${escapeDropTrooperHtml(payload.resolvedByName || "GM")}</div>`;
  } else if (status === "failed") {
    statusHtml = `<div style="margin-top:8px;padding:6px 8px;border-radius:6px;background:#4a1d1d;border:1px solid #9b3d3d;font-size:12px;"><strong>Status:</strong> Apply failed${payload.failureReason ? ` — ${escapeDropTrooperHtml(payload.failureReason)}` : ""}</div>`;
  }

  const buttonsHtml = status === "pending"
    ? `
      <div style="display:flex;gap:8px;margin-top:8px;">
        <button type="button" data-dt-gm-damage-action="apply" style="flex:1;padding:6px 8px;font-weight:700;">Apply</button>
        <button type="button" data-dt-gm-damage-action="reject" style="flex:1;padding:6px 8px;">Reject</button>
      </div>
    `
    : "";

  if (requestType === "droneDeploy" || requestType === "droneRecall") {
    const isRecall = requestType === "droneRecall";
    const trooperName = escapeDropTrooperHtml(payload.sourceActorName || payload.requestedByName || "Trooper");
    const droneName = escapeDropTrooperHtml(payload.targetName || "Assigned Drone");
    const requestedBy = escapeDropTrooperHtml(payload.requestedByName || "Player");
    const queueLabel = isRecall ? "GM Drone Recall Approval" : "GM Drone Deploy Approval";
    const actionLabel = isRecall ? "Recall" : "Deploy";

    if (requestType === "repairKit") {
    const requestedBy = escapeDropTrooperHtml(payload.requestedByName || "Player");
    const trooperName = escapeDropTrooperHtml(payload.sourceActorName || payload.requestedByName || "Trooper");
    const queueLabel = "GM Repair Kit Approval";

    return `
      <div class="dt-gm-damage-card" style="background:#101923;border:1px solid #2c3947;border-radius:8px;padding:10px;color:#dbe6f1;">
        <div style="font-weight:800;font-size:13px;letter-spacing:0.04em;text-transform:uppercase;color:#79c8ff;">${queueLabel}</div>
        <div style="margin-top:8px;font-size:12px;"><strong>Trooper:</strong> ${trooperName}</div>
        <div style="margin-top:4px;font-size:12px;"><strong>Target:</strong> ${targetName}</div>
        <div style="margin-top:4px;font-size:12px;"><strong>Requested By:</strong> ${requestedBy}</div>
        <div style="margin-top:4px;font-size:12px;"><strong>Health Repair:</strong> ${Math.max(0, Number(payload.healthRepair) || 0)}</div>
        <div style="margin-top:4px;font-size:12px;"><strong>Integrity Repair:</strong> ${Math.max(0, Number(payload.integrityRepair) || 0)}</div>
        <div style="margin-top:4px;font-size:12px;"><strong>New Health:</strong> ${Math.max(0, Number(payload.newHealth) || 0)}</div>
        <div style="margin-top:4px;font-size:12px;"><strong>New Integrity:</strong> ${Math.max(0, Number(payload.newIntegrity) || 0)}</div>
        ${statusHtml}
        ${buttonsHtml}
      </div>
    `;
  }

  return `
      <div class="dt-gm-damage-card" style="background:#101923;border:1px solid #2c3947;border-radius:8px;padding:10px;color:#dbe6f1;">
        <div style="font-weight:800;font-size:13px;letter-spacing:0.04em;text-transform:uppercase;color:#79c8ff;">${queueLabel}</div>
        <div style="margin-top:8px;font-size:12px;"><strong>Trooper:</strong> ${trooperName}</div>
        <div style="margin-top:4px;font-size:12px;"><strong>Drone:</strong> ${droneName}</div>
        <div style="margin-top:4px;font-size:12px;"><strong>Requested By:</strong> ${requestedBy}</div>
        <div style="margin-top:4px;font-size:12px;"><strong>Action:</strong> ${actionLabel}</div>
        ${statusHtml}
        ${buttonsHtml}
      </div>
    `;
  }

  if (requestType === "armorExit" || requestType === "armorReturn") {
    const isReturn = requestType === "armorReturn";
    const requestedBy = escapeDropTrooperHtml(payload.requestedByName || "Player");
    const trooperName = escapeDropTrooperHtml(payload.sourceActorName || payload.targetName || "Trooper");
    const queueLabel = isReturn ? "GM Return to Armor Approval" : "GM Exit Armor Approval";
    const actionLabel = isReturn ? "Return" : "Exit";

    return `
      <div class="dt-gm-damage-card" style="background:#101923;border:1px solid #2c3947;border-radius:8px;padding:10px;color:#dbe6f1;">
        <div style="font-weight:800;font-size:13px;letter-spacing:0.04em;text-transform:uppercase;color:#79c8ff;">${queueLabel}</div>
        <div style="margin-top:8px;font-size:12px;"><strong>Trooper:</strong> ${trooperName}</div>
        <div style="margin-top:4px;font-size:12px;"><strong>Requested By:</strong> ${requestedBy}</div>
        <div style="margin-top:4px;font-size:12px;"><strong>Action:</strong> ${actionLabel}</div>
        ${statusHtml}
        ${buttonsHtml}
      </div>
    `;
  }

  if (requestType === "sheetChange") {
    const requestedBy = escapeDropTrooperHtml(payload.requestedByName || "Player");
    const trooperName = escapeDropTrooperHtml(payload.sourceActorName || payload.targetName || "Trooper");
    const fieldLabel = escapeDropTrooperHtml(payload.fieldLabel || "Sheet Field");
    const currentValueDisplay = escapeDropTrooperHtml(payload.currentValueDisplay || "—");
    const requestedValueDisplay = escapeDropTrooperHtml(payload.requestedValueDisplay || "—");

    return `
      <div class="dt-gm-damage-card" style="background:#101923;border:1px solid #2c3947;border-radius:8px;padding:10px;color:#dbe6f1;">
        <div style="font-weight:800;font-size:13px;letter-spacing:0.04em;text-transform:uppercase;color:#79c8ff;">GM Sheet Change Approval</div>
        <div style="margin-top:8px;font-size:12px;"><strong>Trooper:</strong> ${trooperName}</div>
        <div style="margin-top:4px;font-size:12px;"><strong>Requested By:</strong> ${requestedBy}</div>
        <div style="margin-top:4px;font-size:12px;"><strong>Field:</strong> ${fieldLabel}</div>
        <div style="margin-top:4px;font-size:12px;"><strong>Current:</strong> ${currentValueDisplay}</div>
        <div style="margin-top:4px;font-size:12px;"><strong>Requested:</strong> ${requestedValueDisplay}</div>
        ${statusHtml}
        ${buttonsHtml}
      </div>
    `;
  }

  if (requestType === "commandDice") {
    const spendDice = Math.max(0, Number(payload.spendDice) || 0);
    const existingBonusDice = Math.max(0, Number(payload.existingBonusDice) || 0);
    const totalGrantedDice = Math.max(0, Number(payload.totalGrantedDice) || spendDice);

    return `
      <div class="dt-gm-damage-card" style="background:#101923;border:1px solid #2c3947;border-radius:8px;padding:10px;color:#dbe6f1;">
        <div style="font-weight:800;font-size:13px;letter-spacing:0.04em;text-transform:uppercase;color:#79c8ff;">GM Command Dice Approval</div>
        <div style="margin-top:8px;font-size:12px;"><strong>Source:</strong> ${attackerName}</div>
        <div style="margin-top:4px;font-size:12px;"><strong>Ability:</strong> ${attackName}</div>
        <div style="margin-top:4px;font-size:12px;"><strong>Target:</strong> ${targetName}</div>
        <div style="margin-top:4px;font-size:12px;"><strong>Dice Granted:</strong> +${spendDice}d6</div>
        ${existingBonusDice > 0 ? `<div style="margin-top:8px;font-size:12px;"><strong>Existing Bonus:</strong> +${existingBonusDice}d6</div>` : ""}
        <div style="margin-top:4px;font-size:12px;"><strong>Next Roll Bonus:</strong> +${totalGrantedDice}d6</div>
        ${statusHtml}
        ${buttonsHtml}
      </div>
    `;
  }

  const safeDamage = Math.max(0, Number(payload.damage) || 0);
  const integrityDamage = Math.max(0, Number(payload.integrityDamage) || 0);
  const healthDamage = Math.max(0, Number(payload.healthDamage) || 0);
  const newIntegrity = Math.max(0, Number(payload.newIntegrity) || 0);
  const newHealth = Math.max(0, Number(payload.newHealth) || 0);
  const tracksHealth = payload.tracksHealth !== false;
  const damageTargetLabel = escapeDropTrooperHtml(payload.damageTargetLabel || getDropTrooperDamageTargetLabel(payload.damageTarget));

  return `
    <div class="dt-gm-damage-card" style="background:#101923;border:1px solid #2c3947;border-radius:8px;padding:10px;color:#dbe6f1;">
      <div style="font-weight:800;font-size:13px;letter-spacing:0.04em;text-transform:uppercase;color:#79c8ff;">GM Damage Approval</div>
      <div style="margin-top:8px;font-size:12px;"><strong>Attacker:</strong> ${attackerName}</div>
      <div style="margin-top:4px;font-size:12px;"><strong>Attack:</strong> ${attackName}</div>
      <div style="margin-top:4px;font-size:12px;"><strong>Target:</strong> ${targetName}</div>
      <div style="margin-top:4px;font-size:12px;"><strong>Damage:</strong> ${safeDamage}</div>
      <div style="margin-top:4px;font-size:12px;"><strong>Damage Type:</strong> ${damageTargetLabel}</div>
      <div style="margin-top:8px;font-size:12px;"><strong>Integrity Damage:</strong> ${integrityDamage} → ${newIntegrity} remaining</div>
      ${tracksHealth ? `<div style="margin-top:4px;font-size:12px;"><strong>Health Damage:</strong> ${healthDamage} → ${newHealth} remaining</div>` : ""}
      ${statusHtml}
      ${buttonsHtml}
    </div>
  `;
}

function getDropTrooperPendingApprovalCount(userId = game.user?.id) {
  if (!userId) return 0;
  const user = game.users?.get(userId);
  const rawCount = Number(user?.getFlag?.("drop-trooper", "pendingApprovalCount")) || 0;
  return Math.max(0, rawCount);
}

function getDropTrooperPendingApprovalLock(userId = game.user?.id) {
  if (!userId) return null;
  const user = game.users?.get(userId);
  const raw = user?.getFlag?.("drop-trooper", "pendingApprovalLock");
  return raw && typeof raw === "object" ? raw : null;
}

async function setDropTrooperPendingApprovalLock(userId, data = {}) {
  if (!userId) return;
  const user = game.users?.get(userId);
  if (!user) return;
  await user.setFlag("drop-trooper", "pendingApprovalLock", {
    startedAt: Date.now(),
    ...(data || {})
  });
}

async function clearDropTrooperPendingApprovalLock(userId) {
  if (!userId) return;
  const user = game.users?.get(userId);
  if (!user) return;
  await user.unsetFlag("drop-trooper", "pendingApprovalLock");
}

async function beginDropTrooperPendingApprovalWindow(userId = game.user?.id, actionLabel = "action") {
  if (!userId || game.user?.isGM) return true;

  const pendingCount = getDropTrooperPendingApprovalCount(userId);
  const pendingLock = getDropTrooperPendingApprovalLock(userId);
  if (pendingCount > 0 || pendingLock) {
    ui.notifications.warn(`Finish the pending GM approval before starting another ${actionLabel}.`);
    return false;
  }

  await setDropTrooperPendingApprovalLock(userId, { actionLabel });
  return true;
}

async function releaseDropTrooperPendingApprovalWindow(userId = game.user?.id) {
  if (!userId) return;
  if (getDropTrooperPendingApprovalCount(userId) > 0) return;
  await clearDropTrooperPendingApprovalLock(userId);
}

async function setDropTrooperPendingApprovalCount(userId, count) {
  if (!userId) return;
  const user = game.users?.get(userId);
  if (!user) return;

  const safeCount = Math.max(0, Number(count) || 0);

  if (safeCount <= 0) {
    await user.unsetFlag("drop-trooper", "pendingApprovalCount");
    await clearDropTrooperPendingApprovalLock(userId);
    return;
  }

  await user.setFlag("drop-trooper", "pendingApprovalCount", safeCount);
}

async function adjustDropTrooperPendingApprovalCount(userId, delta = 0) {
  if (!userId || !delta) return;
  const nextCount = getDropTrooperPendingApprovalCount(userId) + (Number(delta) || 0);
  await setDropTrooperPendingApprovalCount(userId, nextCount);
}

async function createDropTrooperGmDamageApprovalMessage(payload = {}) {
  const approvalData = {
    ...payload,
    requestId: String(payload.requestId || foundry.utils.randomID()).trim(),
    status: payload.status || "pending"
  };

  const existingMessage = getDropTrooperGmApprovalMessageByRequestId(approvalData.requestId);
  if (existingMessage) {
    return existingMessage;
  }

  const gmUser = approvalData.gmUserId ? game.users?.get(approvalData.gmUserId) : getDropTrooperActiveGmUser();
  if (!gmUser) {
    if (approvalData.status === "pending" && approvalData.requestedByUserId) {
      await clearDropTrooperPendingApprovalLock(approvalData.requestedByUserId);
    }
    throw new Error("No active GM found for damage approval.");
  }

  try {
    const message = await ChatMessage.create({
      user: game.user?.id,
      speaker: ChatMessage.getSpeaker({ actor: game.actors?.get(approvalData.sourceActorId) || null }),
      whisper: [gmUser.id],
      blind: true,
      content: renderDropTrooperGmDamageApprovalCard(approvalData),
      flags: {
        "drop-trooper": {
          gmDamageApproval: approvalData
        }
      }
    });

    if (approvalData.status === "pending" && approvalData.requestedByUserId) {
      await adjustDropTrooperPendingApprovalCount(approvalData.requestedByUserId, 1);
      await clearDropTrooperPendingApprovalLock(approvalData.requestedByUserId);
    }

    return message;
  } catch (err) {
    if (approvalData.status === "pending" && approvalData.requestedByUserId) {
      await clearDropTrooperPendingApprovalLock(approvalData.requestedByUserId);
    }
    throw err;
  }
}

async function resolveDropTrooperGmDamageApproval(message, action = "apply") {
  if (!game.user?.isGM) return;

  const approvalData = foundry.utils.deepClone(message.getFlag("drop-trooper", "gmDamageApproval") || {});
  if (!approvalData || approvalData.status !== "pending") return;
  if (!lockDropTrooperGmApprovalResolution(message, approvalData)) return;

  try {
    const pendingRequesterId = approvalData.requestedByUserId || null;

    approvalData.resolvedByUserId = game.user.id;
    approvalData.resolvedByName = game.user.name || "GM";
    approvalData.resolvedAt = Date.now();

    if (action === "reject") {
      approvalData.status = "rejected";
      await updateDropTrooperGmApprovalMessageState(message, approvalData);
    const rejectRequestType = String(approvalData.requestType || "damage");
    const rejectLabel = rejectRequestType === "commandDice"
      ? "Command Dice"
      : rejectRequestType === "droneDeploy"
        ? "drone deploy"
        : rejectRequestType === "droneRecall"
          ? "drone recall"
          : rejectRequestType === "armorExit"
            ? "exit armor"
            : rejectRequestType === "armorReturn"
              ? "return to armor"
              : rejectRequestType === "sheetChange"
                ? "sheet change"
                : rejectRequestType === "repairKit"
                  ? "repair kit"
                  : "damage";
    if (pendingRequesterId) {
      await settleDropTrooperGmApprovalRequestForUser(pendingRequesterId, -1);
    }
    ui.notifications.info(`Rejected ${rejectLabel} for ${approvalData.targetName || "target"}.`);
    return;
  }

  const approvalRequestType = String(approvalData.requestType || "damage");

  if (approvalRequestType === "droneDeploy" || approvalRequestType === "droneRecall") {
    try {
      const result = approvalRequestType === "droneRecall"
        ? await performDropTrooperDroneRecall(approvalData.trooperActorId, approvalData.droneActorId)
        : await performDropTrooperDroneDeploy(approvalData.trooperActorId, approvalData.droneActorId);

      approvalData.status = "applied";
      approvalData.resultMessage = String(result?.message || "").trim();

      await updateDropTrooperGmApprovalMessageState(message, approvalData)

      if (pendingRequesterId) {
        await settleDropTrooperGmApprovalRequestForUser(pendingRequesterId, -1);
      }

      ui.notifications.info(approvalData.resultMessage || `${approvalRequestType === "droneRecall" ? "Drone recall" : "Drone deploy"} approved.`);
      return;
    } catch (err) {
      approvalData.status = "failed";
      approvalData.failureReason = err?.message || "Drone action failed.";

      await updateDropTrooperGmApprovalMessageState(message, approvalData)

      if (pendingRequesterId) {
        await settleDropTrooperGmApprovalRequestForUser(pendingRequesterId, -1);
      }

      ui.notifications.warn(approvalData.failureReason);
      return;
    }
  }

  if (approvalRequestType === "armorExit" || approvalRequestType === "armorReturn") {
    try {
      const result = approvalRequestType === "armorReturn"
        ? await performDropTrooperReturnArmor(approvalData.trooperActorId)
        : await performDropTrooperExitArmor(approvalData.trooperActorId);

      approvalData.status = "applied";
      approvalData.resultMessage = String(result?.message || "").trim();

      await updateDropTrooperGmApprovalMessageState(message, approvalData)

      if (pendingRequesterId) {
        await settleDropTrooperGmApprovalRequestForUser(pendingRequesterId, -1);
      }

      ui.notifications.info(approvalData.resultMessage || `${approvalRequestType === "armorReturn" ? "Return to armor" : "Exit armor"} approved.`);
      return;
    } catch (err) {
      approvalData.status = "failed";
      approvalData.failureReason = err?.message || "Armor change failed.";

      await updateDropTrooperGmApprovalMessageState(message, approvalData)

      if (pendingRequesterId) {
        await settleDropTrooperGmApprovalRequestForUser(pendingRequesterId, -1);
      }

      ui.notifications.warn(approvalData.failureReason);
      return;
    }
  }

  if (approvalRequestType === "sheetChange") {
    try {
      const targetActor = game.actors?.get(String(approvalData.trooperActorId || approvalData.sourceActorId || "").trim());
      if (!targetActor || String(targetActor.type || "") !== "trooper") {
        throw new Error(`Trooper not found for ${approvalData.fieldLabel || "sheet change"}.`);
      }

      const fieldPath = String(approvalData.fieldPath || "").trim();
      const normalizedValue = normalizeDropTrooperRequestedSheetChangeValue(targetActor.type, fieldPath, approvalData.requestedValue);
      await targetActor.update({ [fieldPath]: normalizedValue });

      approvalData.status = "applied";
      approvalData.resultMessage = `${approvalData.fieldLabel || "Sheet field"} updated.`;
      approvalData.requestedValue = normalizedValue;
      approvalData.requestedValueDisplay = formatDropTrooperSheetChangeValue(normalizedValue, getDropTrooperSheetChangeRule(targetActor.type, fieldPath));

      await updateDropTrooperGmApprovalMessageState(message, approvalData)

      if (pendingRequesterId) {
        await settleDropTrooperGmApprovalRequestForUser(pendingRequesterId, -1);
      }

      ui.notifications.info(approvalData.resultMessage);
      return;
    } catch (err) {
      approvalData.status = "failed";
      approvalData.failureReason = err?.message || "Sheet change failed.";

      await updateDropTrooperGmApprovalMessageState(message, approvalData)

      if (pendingRequesterId) {
        await settleDropTrooperGmApprovalRequestForUser(pendingRequesterId, -1);
      }

      ui.notifications.warn(approvalData.failureReason);
      return;
    }
  }

  const { tokenDocument, actor } = getDropTrooperRequestedRollTarget(approvalData.sceneId, approvalData.tokenId, approvalData.actorId);
  const targetActor = tokenDocument?.actor || actor || null;
  const targetName = approvalData.targetName || tokenDocument?.name || targetActor?.name || "Target";

  if (!tokenDocument || !targetActor) {
    approvalData.status = "failed";
    await updateDropTrooperGmApprovalMessageState(message, approvalData)
    const failRequestType = String(approvalData.requestType || "damage");
    const failLabel = failRequestType === "commandDice" ? "Command Dice target" : "damage request target";
    if (pendingRequesterId) {
      await settleDropTrooperGmApprovalRequestForUser(pendingRequesterId, -1);
    }
    ui.notifications.warn(`Drop Trooper: ${failLabel} not found for ${targetName}.`);
    return;
  }

  if (String(approvalData.requestType || "damage") === "repairKit") {
    await targetActor.update({
      "system.health.value": Math.max(0, Number(approvalData.newHealth) || 0),
      "system.armor.integrity.value": Math.max(0, Number(approvalData.newIntegrity) || 0)
    });

    approvalData.status = "applied";

    await updateDropTrooperGmApprovalMessageState(message, approvalData)

    if (pendingRequesterId) {
      await settleDropTrooperGmApprovalRequestForUser(pendingRequesterId, -1);
    }
    ui.notifications.info(`Applied Repair Kit to ${targetName}.`);
    return;
  }

  if (String(approvalData.requestType || "damage") === "commandDice") {
    const spendDice = Math.max(0, Number(approvalData.spendDice) || 0);
    const abilityName = approvalData.abilityName || approvalData.attackLabel || "Command Dice";
    const existingBonus = targetActor.getFlag("drop-trooper", "pendingRollBonus");
    const existingBonusDice = Math.max(0, Number(existingBonus?.dice) || 0);
    const totalGrantedDice = existingBonusDice + spendDice;
    const existingSources = String(existingBonus?.source || "")
      .split("+")
      .map(part => part.trim())
      .filter(Boolean);
    const bonusSource = existingSources.includes(abilityName)
      ? existingSources.join(" + ") || abilityName
      : [...existingSources, abilityName].filter(Boolean).join(" + ") || abilityName;

    await targetActor.setFlag("drop-trooper", "pendingRollBonus", {
      dice: totalGrantedDice,
      source: bonusSource
    });

    approvalData.status = "applied";
    approvalData.existingBonusDice = existingBonusDice;
    approvalData.totalGrantedDice = totalGrantedDice;
    approvalData.bonusSource = bonusSource;

    await updateDropTrooperGmApprovalMessageState(message, approvalData)

    if (pendingRequesterId) {
      await settleDropTrooperGmApprovalRequestForUser(pendingRequesterId, -1);
    }
    ui.notifications.info(`Applied +${spendDice}d6 Command Dice to ${targetName}.`);
    return;
  }

  const result = await applyDropTrooperDamageToTokenDocument(tokenDocument, approvalData.damage, {
    damageTarget: approvalData.damageTarget
  });
  approvalData.status = "applied";
  approvalData.integrityDamage = result.integrityDamage;
  approvalData.healthDamage = result.healthDamage;
  approvalData.newIntegrity = result.newIntegrity;
  approvalData.newHealth = result.newHealth;
  approvalData.damageTarget = result.damageTarget;
  approvalData.damageTargetLabel = result.damageTargetLabel;

  await message.update({
    content: renderDropTrooperGmDamageApprovalCard(approvalData),
    flags: {
      "drop-trooper": {
        gmDamageApproval: approvalData
      }
    }
  });

  if (pendingRequesterId) {
    await settleDropTrooperGmApprovalRequestForUser(pendingRequesterId, -1);
  }

  ui.notifications.info(`Applied ${Math.max(0, Number(approvalData.damage) || 0)} damage to ${targetName}.`);
  } catch (err) {
    console.error("Drop Trooper | GM approval resolution failed", err);
    const failureReason = err?.message || "GM approval failed.";
    approvalData.status = "failed";
    approvalData.failureReason = failureReason;
    try {
      await updateDropTrooperGmApprovalMessageState(message, approvalData);
    } catch (updateErr) {
      console.error("Drop Trooper | GM approval failure state update failed", updateErr);
    }
    if (approvalData.requestedByUserId) {
      await settleDropTrooperGmApprovalRequestForUser(approvalData.requestedByUserId, -1);
    }
    ui.notifications.warn(failureReason);
  } finally {
    unlockDropTrooperGmApprovalResolution(message, approvalData);
  }
}

Hooks.once("init", function () {
  console.log("Drop Trooper | System Initializing");

  const hasDefeatedStatus = (CONFIG.statusEffects || []).some(effect => {
    const effectId = effect?.id || effect?._id;
    return effectId === DROP_TROOPER_DEFEATED_STATUS_ID;
  });

  if (!hasDefeatedStatus) {
    CONFIG.statusEffects.push({
      id: DROP_TROOPER_DEFEATED_STATUS_ID,
      name: DROP_TROOPER_DEFEATED_STATUS_NAME,
      img: DROP_TROOPER_DEFEATED_STATUS_ICON
    });
  }

  Actors.registerSheet("drop-trooper", DropTrooperSheet, {
    types: ["trooper", "npc", "drone"],
    makeDefault: true
  });

  Items.unregisterSheet("core", ItemSheet);

  Items.registerSheet("drop-trooper", DropTrooperWeaponSheet, {
    types: ["weapon", "ability"],
    makeDefault: true
  });
});

Hooks.on("preCreateCombatant", (combatantDocument, source) => {
  const actor = getDropTrooperCombatantActor(combatantDocument, source);
  if (!shouldExcludeDropTrooperActorFromCombatTracker(actor)) return true;

  if (game.user?.isGM) {
    const actorName = actor?.name || combatantDocument?.name || "Actor";
    const reason = String(actor?.type || "") === "drone"
      ? "Drones act on their controller's turn and do not get separate combat tracker entries."
      : "Mob units resolve during the shared Mob phase and do not get separate combat tracker entries.";
    ui.notifications.info(`${actorName} skipped combat tracker entry. ${reason}`);
  }

  return false;
});

