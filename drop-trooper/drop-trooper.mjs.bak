});

Hooks.on("renderChatMessage", (message, html) => {
  const root = html?.[0] || html;
  if (!root?.querySelectorAll) return;

  const gmApprovalData = message.getFlag("drop-trooper", "gmDamageApproval");
  if (gmApprovalData) {
    if (root?.style) {
      root.style.display = "none";
    }
    if (root?.setAttribute) {
      root.setAttribute("aria-hidden", "true");
    }
    if (game.user?.isGM) {
      setTimeout(() => refreshDropTrooperGmApprovalPanel(), 0);
    }
    return;
  }

  const pushData = message.getFlag("drop-trooper", "pushRoll");
  if (pushData) {
    const actor = game.actors?.get(pushData.actorId);
    const canPush = !!actor && canUserResolveDropTrooperRequestedRoll(actor, game.user);
    const status = String(pushData.status || "pending");
    const resolution = String(pushData.resolution || "");

    root.querySelectorAll(".dt-push-roll-btn").forEach(button => {
      if (status !== "pending") {
        button.disabled = true;
        button.textContent = resolution === "push" ? "Pushed" : "Resolved";
        button.style.opacity = "0.7";
        button.style.cursor = "default";
        return;
      }

      if (!canPush) {
        button.disabled = true;
        button.textContent = "Waiting for owner / GM";
        button.style.opacity = "0.55";
        button.style.cursor = "default";
        return;
      }

      button.addEventListener("click", async event => {
        event.preventDefault();
        event.stopPropagation();

        if (button.dataset.dtRolling === "1") return;
        button.dataset.dtRolling = "1";
        button.disabled = true;
        button.textContent = "Pushing...";

        root.querySelectorAll(".dt-no-push-roll-btn").forEach(other => {
          other.disabled = true;
          other.style.opacity = "0.7";
          other.style.cursor = "default";
        });

        try {
          const resolved = await executeDropTrooperPushRoll(message, pushData);
          if (resolved) {
            button.textContent = "Pushed";
            button.style.opacity = "0.7";
            button.style.cursor = "default";
          } else {
            button.disabled = false;
            button.dataset.dtRolling = "0";
            button.textContent = "Push";
            root.querySelectorAll(".dt-no-push-roll-btn").forEach(other => {
              other.disabled = false;
              other.style.opacity = "";
              other.style.cursor = "pointer";
            });
          }
        } catch (err) {
          console.error("Drop Trooper | Push roll failed", err);
          ui.notifications.error(`Push roll failed: ${err.message}`);
          button.disabled = false;
          button.dataset.dtRolling = "0";
          button.textContent = "Push";
          root.querySelectorAll(".dt-no-push-roll-btn").forEach(other => {
            other.disabled = false;
            other.style.opacity = "";
            other.style.cursor = "pointer";
          });
        }
      }, { once: true });
    });

    root.querySelectorAll(".dt-no-push-roll-btn").forEach(button => {
      if (status !== "pending") {
        button.disabled = true;
        button.textContent = resolution === "no-push" ? "No Push" : "Resolved";
        button.style.opacity = "0.7";
        button.style.cursor = "default";
        return;
      }

      if (!canPush) {
        button.disabled = true;
        button.textContent = "Waiting for owner / GM";
        button.style.opacity = "0.55";
        button.style.cursor = "default";
        return;
      }

      button.addEventListener("click", async event => {
        event.preventDefault();
        event.stopPropagation();

        if (button.dataset.dtRolling === "1") return;
        button.dataset.dtRolling = "1";
        button.disabled = true;
        button.textContent = "Resolving...";

        root.querySelectorAll(".dt-push-roll-btn").forEach(other => {
          other.disabled = true;
          other.style.opacity = "0.7";
          other.style.cursor = "default";
        });

        try {
          const resolved = await executeDropTrooperNoPushRoll(message, pushData);
          if (resolved) {
            button.textContent = "No Push";
            button.style.opacity = "0.7";
            button.style.cursor = "default";
          } else {
            button.disabled = false;
            button.dataset.dtRolling = "0";
            button.textContent = "No Push";
            root.querySelectorAll(".dt-push-roll-btn").forEach(other => {
              other.disabled = false;
              other.style.opacity = "";
              other.style.cursor = "pointer";
            });
          }
        } catch (err) {
          console.error("Drop Trooper | No Push resolution failed", err);
          ui.notifications.error(`No Push resolution failed: ${err.message}`);
          button.disabled = false;
          button.dataset.dtRolling = "0";
          button.textContent = "No Push";
          root.querySelectorAll(".dt-push-roll-btn").forEach(other => {
            other.disabled = false;
            other.style.opacity = "";
            other.style.cursor = "pointer";
          });
        }
      }, { once: true });
    });
  }

  const requestData = message.getFlag("drop-trooper", "rollRequest");
  if (!requestData) return;

  root.querySelectorAll(".dt-request-roll-btn").forEach(button => {
    if (button.classList.contains("dt-push-roll-btn") || button.classList.contains("dt-no-push-roll-btn")) {
      return;
    }

    const { actor } = getDropTrooperRequestedRollTarget(requestData.sceneId, requestData.tokenId, requestData.actorId);
    const canRoll = canUserResolveDropTrooperRequestedRoll(actor, game.user);
    const rollLabel = getDropTrooperRequestedRollLabel(requestData.rollType, requestData.rollKey);

    if (!canRoll) {
      button.disabled = true;
      button.textContent = "Waiting for owner / GM";
      button.style.opacity = "0.55";
      button.style.cursor = "default";
      return;
    }

    button.addEventListener("click", async event => {
      event.preventDefault();
      event.stopPropagation();

      if (button.dataset.dtRolling === "1") return;
      button.dataset.dtRolling = "1";
      button.disabled = true;
      button.textContent = "Rolling...";

      try {
        const resolved = await executeDropTrooperRequestedRoll(requestData);
        if (resolved) {
          button.textContent = "Rolled";
          button.style.opacity = "0.7";
          button.style.cursor = "default";
        } else {
          button.disabled = false;
          button.dataset.dtRolling = "0";
          button.textContent = `Roll ${rollLabel}`;
        }
      } catch (err) {
        console.error("Drop Trooper | Requested roll failed", err);
        ui.notifications.error(`Requested roll failed: ${err.message}`);
        button.disabled = false;
        button.dataset.dtRolling = "0";
        button.textContent = `Roll ${rollLabel}`;
      }
    }, { once: true });
  });
});
