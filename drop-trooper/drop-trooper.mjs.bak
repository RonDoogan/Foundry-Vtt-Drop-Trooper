async function adoptPreCombatDropTrooperSmokeForCombat(combat) {
  if (!game.user?.isGM || !canvas?.scene || !combat) return;

  const templates = canvas.templates?.placeables || [];
  const currentRound = Math.max(1, Number(combat.round) || 1);
  const updates = [];

  for (const template of templates) {
    const smokeData = template.document?.getFlag("drop-trooper", "smokeData");
    if (!smokeData) continue;
    if (smokeData.combatId) continue;

    const durationRounds = Math.max(1, Math.floor(Number(smokeData.durationRounds) || 1));
    updates.push({
      _id: template.id,
      "flags.drop-trooper.smokeData.createdRound": currentRound,
      "flags.drop-trooper.smokeData.combatId": combat.id,
      "flags.drop-trooper.smokeData.removeAtRound": currentRound + Math.max(0, durationRounds - 1)
    });
  }

  if (updates.length > 0) {
    await canvas.scene.updateEmbeddedDocuments("MeasuredTemplate", updates);
  }
}

Hooks.on("createCombat", (combat) => {
  if (!game.user?.isGM) return;

  adoptPreCombatDropTrooperSmokeForCombat(combat).catch(err => {
    console.warn("Drop Trooper | Failed to adopt pre-combat smoke into combat", err);
  });

  AbilityService.refreshCombatNanoFromCombat(combat).catch(err => {
    console.warn("Drop Trooper | Failed to initialize combat Nano Repair uses", err);
  });
});

Hooks.on("updateCombat", (combat, changed) => {
  if (!game.user?.isGM) return;
  if (!changed) return;

  if (changed.turn !== undefined || changed.combatantId !== undefined) {
    refreshDropTrooperTurnReactionState(combat).catch(err => {
      console.warn("Drop Trooper | Failed to refresh turn reaction state", err);
    });
  }

  if (changed.round === undefined) return;

  if (Number(changed.round) === 1) {
    adoptPreCombatDropTrooperSmokeForCombat(combat).catch(err => {
      console.warn("Drop Trooper | Failed to adopt pre-combat smoke into combat", err);
    });

    AbilityService.refreshCombatNanoFromCombat(combat).catch(err => {
      console.warn("Drop Trooper | Failed to refresh combat Nano Repair uses", err);
    });
  }

  clearExpiredDropTrooperGroupMarkers(combat).catch(err => {
    console.warn("Drop Trooper | Failed to clear group attack markers", err);
  });

  const activeSheet = Object.values(ui.windows).find(app => app instanceof DropTrooperSheet);
  if (activeSheet && typeof activeSheet._removeExpiredSmokeTemplates === "function") {
    activeSheet._removeExpiredSmokeTemplates(combat).catch(err => {
      console.warn("Drop Trooper | Failed to remove expired smoke templates", err);
    });
  } else if (canvas?.scene) {
    const templates = canvas.templates?.placeables || [];
    const expiredIds = templates
      .filter(template => {
        const smokeData = template.document?.getFlag("drop-trooper", "smokeData");
        if (!smokeData) return false;
        if (smokeData.combatId && smokeData.combatId !== combat.id) return false;
        const removeAtRound = Number(smokeData.removeAtRound);
        return Number.isFinite(removeAtRound) && (Number(combat.round) || 0) >= removeAtRound;
      })
      .map(template => template.id);

    if (expiredIds.length > 0) {
      canvas.scene.deleteEmbeddedDocuments("MeasuredTemplate", expiredIds).catch(err => {
        console.warn("Drop Trooper | Failed to remove expired smoke templates", err);
      });
    }
  }
});

Hooks.on("deleteCombat", (combat) => {
  if (!game.user?.isGM) return;

  AbilityService.refreshFieldNanoFromCombat(combat).catch(err => {
    console.warn("Drop Trooper | Failed to refresh field Nano Repair uses", err);
  });

  if (!canvas?.scene) return;
  clearExpiredDropTrooperGroupMarkers({ id: combat?.id, round: Number.MAX_SAFE_INTEGER }).catch(err => {
    console.warn("Drop Trooper | Failed to clear group attack markers after combat", err);
  });
});

