Hooks.on("createMeasuredTemplate", templateDocument => {
  queueDropTrooperSmokeOcclusionRefresh();
  queueDropTrooperSmokeTemplatePresentationRefresh();
  if (!game.user?.isGM) return;

  if (isDropTrooperSmokeTemplate(templateDocument)) {
    syncDropTrooperSmokeVisualForTemplate(templateDocument).catch(err => {
      console.warn("Drop Trooper | Failed to create smoke visual", err);
    });
    syncDropTrooperSmokeWallsForTemplate(templateDocument).catch(err => {
      console.warn("Drop Trooper | Failed to create smoke walls", err);
    });
  }

  if (isDropTrooperBlastVisualTemplate(templateDocument)) {
    createDropTrooperBlastVisualForTemplate(templateDocument).catch(err => {
      console.warn("Drop Trooper | Failed to create blast visual", err);
    });
  }

  if (isDropTrooperConeVisualTemplate(templateDocument)) {
    createDropTrooperConeVisualForTemplate(templateDocument).catch(err => {
      console.warn("Drop Trooper | Failed to create cone visual", err);
    });
  }
});

Hooks.on("updateMeasuredTemplate", templateDocument => {
  queueDropTrooperSmokeOcclusionRefresh();
  queueDropTrooperSmokeTemplatePresentationRefresh();
  if (!game.user?.isGM) return;

  if (isDropTrooperSmokeTemplate(templateDocument)) {
    syncDropTrooperSmokeVisualForTemplate(templateDocument).catch(err => {
      console.warn("Drop Trooper | Failed to update smoke visual", err);
    });
    syncDropTrooperSmokeWallsForTemplate(templateDocument).catch(err => {
      console.warn("Drop Trooper | Failed to update smoke walls", err);
    });
  }

  if (isDropTrooperBlastVisualTemplate(templateDocument)) {
    createDropTrooperBlastVisualForTemplate(templateDocument).catch(err => {
      console.warn("Drop Trooper | Failed to update blast visual", err);
    });
  }

  if (isDropTrooperConeVisualTemplate(templateDocument)) {
    createDropTrooperConeVisualForTemplate(templateDocument).catch(err => {
      console.warn("Drop Trooper | Failed to update cone visual", err);
    });
  }
});

Hooks.on("deleteMeasuredTemplate", templateDocument => {
  queueDropTrooperSmokeOcclusionRefresh();
  queueDropTrooperSmokeTemplatePresentationRefresh();
  if (!game.user?.isGM) return;

  if (isDropTrooperSmokeTemplate(templateDocument)) {
    deleteDropTrooperSmokeVisualForTemplate(templateDocument).catch(err => {
      console.warn("Drop Trooper | Failed to remove smoke visual", err);
    });
    deleteDropTrooperSmokeWallsForTemplate(templateDocument).catch(err => {
      console.warn("Drop Trooper | Failed to remove smoke walls", err);
    });
  }

  if (isDropTrooperBlastVisualTemplate(templateDocument)) {
    deleteDropTrooperBlastVisualForTemplate(templateDocument).catch(err => {
      console.warn("Drop Trooper | Failed to remove blast visual", err);
    });
  }

  if (isDropTrooperConeVisualTemplate(templateDocument)) {
    deleteDropTrooperConeVisualForTemplate(templateDocument).catch(err => {
      console.warn("Drop Trooper | Failed to remove cone visual", err);
    });
  }
});


// ===== Stream View Follow Helper =====
const DT_STREAM_MODULE_ID = "drop-trooper";
const DT_STREAM_WORLD_SCOPE = "world";
const DT_STREAM_SOCKET_NAME = "drop-trooper-stream-follow";
const DT_STREAM_DEFAULT_USER = "Stream View";

function dtStreamSocketActive() {
  return Boolean(game.modules.get("socketlib")?.active);
}
function dtStreamCurrentPanScale() {
  const stageScale = Number(canvas?.stage?.scale?.x);
  return Number.isFinite(stageScale) && stageScale > 0 ? stageScale : 1;
}
function dtStreamFindTokenById(tokenId) {
  if (!tokenId || !canvas?.tokens) return null;
  return canvas.tokens.placeables.find(token => token?.id === tokenId) || null;
}
function dtStreamFindTokenByName(tokenName) {
  const needle = String(tokenName || "").trim().toLowerCase();
  if (!needle || !canvas?.tokens) return null;
  return canvas.tokens.placeables.find(token => String(token?.name || "").trim().toLowerCase() === needle) || null;
}
function dtStreamFindUserIdByName(userName) {
  const needle = String(userName || "").trim().toLowerCase();
  if (!needle) return null;
  const user = game.users?.find(entry => String(entry?.name || "").trim().toLowerCase() === needle);
  return user?.id || null;
}
function dtStreamGetDocumentCenter(document, change = {}) {
  const gridSize = Number(canvas?.grid?.size) || Number(canvas?.dimensions?.size) || 100;
  const width = Number(document?.width) || Number(document?.object?.document?.width) || 1;
  const height = Number(document?.height) || Number(document?.object?.document?.height) || 1;
  const x = Object.prototype.hasOwnProperty.call(change || {}, "x") ? Number(change.x) : Number(document?.x);
  const y = Object.prototype.hasOwnProperty.call(change || {}, "y") ? Number(change.y) : Number(document?.y);
  if (!Number.isFinite(x) || !Number.isFinite(y)) return null;
  return {
    x: x + ((width * gridSize) / 2),
    y: y + ((height * gridSize) / 2)
  };
}
async function dtStreamPanLocalToTokenId(tokenId, options = {}) {
  const duration = Math.max(0, Number(options.duration) || 400);
  const scale = Number.isFinite(Number(options.scale)) && Number(options.scale) > 0 ? Number(options.scale) : dtStreamCurrentPanScale();
  const pointX = Number(options.x);
  const pointY = Number(options.y);
  if (Number.isFinite(pointX) && Number.isFinite(pointY)) {
    await canvas.animatePan({ x: pointX, y: pointY, scale, duration });
    return true;
  }
  await new Promise(resolve => window.setTimeout(resolve, 75));
  const token = dtStreamFindTokenById(tokenId);
  if (!token) return false;
  await canvas.animatePan({ x: token.center.x, y: token.center.y, scale, duration });
  return true;
}
function dtStreamReadState() {
  return {
    enabled: Boolean(game.settings.get(DT_STREAM_MODULE_ID, "streamFollowEnabled")),
    leaderTokenId: String(game.settings.get(DT_STREAM_MODULE_ID, "streamLeaderTokenId") || ""),
    leaderTokenName: String(game.settings.get(DT_STREAM_MODULE_ID, "streamLeaderTokenName") || ""),
    streamUserName: String(game.settings.get(DT_STREAM_MODULE_ID, "streamUserName") || DT_STREAM_DEFAULT_USER)
  };
}
async function dtStreamPushPanToUser(tokenId, options = {}) {
  const state = dtStreamReadState();
  const userId = dtStreamFindUserIdByName(state.streamUserName);
  if (!userId) return false;
  if (!dtStreamSocketActive()) return false;
  return game.dropTrooperStreamFollow.socket.executeAsUser("panToTokenId", userId, tokenId, options);
}
function dtStreamIsLeaderMove(document, change) {
  const state = dtStreamReadState();
  if (!state.enabled || !state.leaderTokenId) return false;
  if (!document?.id || document.id !== state.leaderTokenId) return false;
  return Object.prototype.hasOwnProperty.call(change || {}, "x") || Object.prototype.hasOwnProperty.call(change || {}, "y");
}
Hooks.once("init", () => {
  game.settings.register(DT_STREAM_MODULE_ID, "streamUserName", {
    name: "Stream View User Name",
    hint: "User name that receives camera pans from Drop Trooper stream macros.",
    scope: DT_STREAM_WORLD_SCOPE,
    config: true,
    type: String,
    default: DT_STREAM_DEFAULT_USER
  });
  game.settings.register(DT_STREAM_MODULE_ID, "streamLeaderTokenId", { name: "Stream Leader Token Id", hint: "Internal token id used by the stream follow helper.", scope: DT_STREAM_WORLD_SCOPE, config: false, type: String, default: "" });
  game.settings.register(DT_STREAM_MODULE_ID, "streamLeaderTokenName", { name: "Stream Leader Token Name", hint: "Leader token name used only for display and backup lookup.", scope: DT_STREAM_WORLD_SCOPE, config: false, type: String, default: "" });
  game.settings.register(DT_STREAM_MODULE_ID, "streamFollowEnabled", { name: "Stream Follow Enabled", hint: "Whether Stream View should auto-follow the saved leader token when it moves.", scope: DT_STREAM_WORLD_SCOPE, config: false, type: Boolean, default: false });
});
Hooks.once("ready", () => {
  let socket = null;
  if (dtStreamSocketActive()) {
    socket = socketlib.registerSystem(DT_STREAM_MODULE_ID);
    socket.register("panToTokenId", dtStreamPanLocalToTokenId);
  } else if (game.user?.isGM) {
    console.warn("Drop Trooper | socketlib is not active. Stream follow macros will not control Stream View until socketlib is enabled.");
  }
  game.dropTrooperStreamFollow = {
    socket,
    readState: dtStreamReadState,
    findLeaderToken() {
      const state = dtStreamReadState();
      return dtStreamFindTokenById(state.leaderTokenId) || dtStreamFindTokenByName(state.leaderTokenName);
    },
    async followLeaderNow(options = {}) {
      if (!game.user?.isGM) throw new Error("Only the GM can move Stream View.");
      const token = this.findLeaderToken();
      if (!token) throw new Error("Saved leader token was not found on the active scene.");
      if (!dtStreamSocketActive() || !this.socket) throw new Error("socketlib must be installed and enabled.");
      const moved = await dtStreamPushPanToUser(token.id, options);
      if (!moved) throw new Error("Stream View user was not found or could not be moved.");
      return token;
    },
    async setFollowLeaderEnabled(enabled) {
      if (!game.user?.isGM) throw new Error("Only the GM can change stream follow state.");
      await game.settings.set(DT_STREAM_MODULE_ID, "streamFollowEnabled", Boolean(enabled));
      return Boolean(enabled);
    },
    async panStreamToToken(token, options = {}) {
      if (!game.user?.isGM) throw new Error("Only the GM can move Stream View.");
      if (!token?.id) throw new Error("Token not found.");
      if (!dtStreamSocketActive() || !this.socket) throw new Error("socketlib must be installed and enabled.");
      const moved = await dtStreamPushPanToUser(token.id, options);
      if (!moved) throw new Error("Stream View user was not found or could not be moved.");
      return true;
    }
  };
});
Hooks.on("updateToken", async (document, change) => {
  if (!game.user?.isGM) return;
  if (!dtStreamIsLeaderMove(document, change)) return;
  if (!game.dropTrooperStreamFollow?.socket) return;
  try {
    const point = dtStreamGetDocumentCenter(document, change);
    await game.dropTrooperStreamFollow.panStreamToToken(document.object || { id: document.id }, {
      duration: 250,
      ...(point || {})
    });
  } catch (error) {
    console.warn("Drop Trooper | Stream leader follow failed", error);
  }
});
// ===== End Stream View Follow Helper =====

