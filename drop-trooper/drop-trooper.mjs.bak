    button: true,
    visible: game.user?.isGM,
    onChange: () => {
      openDropTrooperRollRequestDialog();
    }
  };
});

registerDropTrooperMovementHooks();

Hooks.on("ready", () => {
  game.dropTrooperMovement = createDropTrooperMovementApi();

  game.socket.on(DROP_TROOPER_SOCKET_NAMESPACE, async data => {
    if (!data || typeof data !== "object") return;

    if (data.action === DROP_TROOPER_SOCKET_ACTION_RESPONSE) {
      if (data.targetUserId && data.targetUserId !== game.user?.id) return;
      resolveDropTrooperSocketRequestResponse(data);
      return;
    }

    if (data.action === DROP_TROOPER_SOCKET_ACTION_PLAY_CRIT_VIDEO) {
      if (data.userId && data.userId === game.user?.id) return;
      playDropTrooperCritVideoLocal();
      return;
    }

    if (data.action === DROP_TROOPER_SOCKET_ACTION_REACTION_PROMPT) {
      if (data.targetUserId && data.targetUserId !== game.user?.id) return;
      try {
        const result = await promptDropTrooperReactionDecision(data?.payload || {});
        await respondToDropTrooperSocketRequest(data.requesterUserId, data.requestId, { ok: true, result });
      } catch (err) {
        await respondToDropTrooperSocketRequest(data.requesterUserId, data.requestId, { ok: false, error: err?.message || "Reaction prompt failed." });
      }
      return;
    }

    if (data.action === DROP_TROOPER_SOCKET_ACTION_RETURN_FIRE) {
      if (data.targetUserId && data.targetUserId !== game.user?.id) return;
      try {
        const result = await executeDropTrooperReturnFire(data?.payload || {});
        await respondToDropTrooperSocketRequest(data.requesterUserId, data.requestId, { ok: true, result: result || { ok: true } });
      } catch (err) {
        await respondToDropTrooperSocketRequest(data.requesterUserId, data.requestId, { ok: false, error: err?.message || "Return fire failed." });
      }
      return;
    }

    if (!game.user?.isGM) return;
    const gmUser = getDropTrooperFirstActiveGmUser();
    if (gmUser?.id !== game.user?.id) return;

    try {
      if (data.action === DROP_TROOPER_SOCKET_ACTION_DRONE_DEPLOY) {
        const result = await performDropTrooperDroneDeploy(data?.payload?.trooperActorId, data?.payload?.droneActorId);
        await respondToDropTrooperSocketRequest(data.requesterUserId, data.requestId, { ok: true, result });
        return;
      }

      if (data.action === DROP_TROOPER_SOCKET_ACTION_DRONE_RECALL) {
        const result = await performDropTrooperDroneRecall(data?.payload?.trooperActorId, data?.payload?.droneActorId);
        await respondToDropTrooperSocketRequest(data.requesterUserId, data.requestId, { ok: true, result });
        return;
      }

      if (data.action === DROP_TROOPER_SOCKET_ACTION_TOGGLE_OUT_OF_ARMOR) {
        const requestedMode = String(data?.payload?.mode || "").trim().toLowerCase();
        const result = requestedMode === "return"
          ? await performDropTrooperReturnArmor(data?.payload?.trooperActorId)
          : await performDropTrooperExitArmor(data?.payload?.trooperActorId);
        await respondToDropTrooperSocketRequest(data.requesterUserId, data.requestId, { ok: true, result });
        return;
      }
    } catch (err) {
      await respondToDropTrooperSocketRequest(data.requesterUserId, data.requestId, {
        ok: false,
        error: err?.message || "Drone action failed."
      });
    }
  });

  if (!game.user?.isGM) return;
  ensureDropTrooperReactionDefaults().catch(err => {
    console.warn("Drop Trooper | Failed to initialize reaction defaults", err);
  });
  setTimeout(() => refreshDropTrooperGmApprovalPanel(), 0);
});

