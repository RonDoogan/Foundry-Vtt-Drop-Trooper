function getDropTrooperItemDisplayOrder(item, fallbackIndex = 0) {
  const raw = Number(item?.system?.displayOrder);
  if (Number.isFinite(raw) && raw > 0) return raw;

  const sortValue = Number(item?.sort);
  if (Number.isFinite(sortValue) && sortValue !== 0) return sortValue;

  return (fallbackIndex + 1) * 10;
}

function sortDropTrooperItemsByDisplayOrder(items) {
  return [...(items || [])].sort((a, b) => {
    const aOrder = getDropTrooperItemDisplayOrder(a, 0);
    const bOrder = getDropTrooperItemDisplayOrder(b, 0);

    if (aOrder !== bOrder) return aOrder - bOrder;
    return String(a?.name || "").localeCompare(String(b?.name || ""));
  });
}

function dropTrooperWeaponFxLog(message, payload = undefined) {
  if (!DROP_TROOPER_WEAPON_FX_DEBUG) return;
  if (payload === undefined) {
    console.log(`Drop Trooper FX | ${message}`);
    return;
  }
  console.log(`Drop Trooper FX | ${message}`, payload);
}

function dropTrooperWeaponFxWarn(message, payload = undefined) {
  if (payload === undefined) {
    console.warn(`Drop Trooper FX | ${message}`);
    return;
  }
  console.warn(`Drop Trooper FX | ${message}`, payload);
}

function isDropTrooperMobActor(actor) {
  return String(actor?.type || "") === "npc" && Boolean(actor?.system?.mob);
}

function shouldExcludeDropTrooperActorFromCombatTracker(actor) {
  if (!actor) return false;
  if (String(actor?.type || "") === "drone") return true;
  return isDropTrooperMobActor(actor);
}

function getDropTrooperCombatantActor(combatantDocument, source = {}) {
  const directActor = combatantDocument?.actor;
  if (directActor) return directActor;

  const combat = combatantDocument?.parent;
  const sceneId = combat?.scene?.id || combat?.sceneId || combatantDocument?.sceneId || source?.sceneId;
  const scene = (sceneId ? game.scenes?.get(sceneId) : null) || canvas?.scene || null;
  const tokenId = combatantDocument?.tokenId || source?.tokenId;
  const actorId = combatantDocument?.actorId || source?.actorId;

  const tokenDocument = tokenId
    ? scene?.tokens?.get?.(tokenId) || scene?.tokens?.find?.(token => token?.id === tokenId)
    : null;

  return tokenDocument?.actor || (actorId ? game.actors?.get(actorId) : null) || null;
}

function describeDropTrooperFxLocation(value) {
  if (!value) return null;

  const centerX = Number(value?.center?.x);
  const centerY = Number(value?.center?.y);
  if (Number.isFinite(centerX) && Number.isFinite(centerY)) {
    return {
      kind: "token",
      name: value?.document?.name || value?.name || value?.document?.actor?.name || "Unknown",
      x: Math.round(centerX),
      y: Math.round(centerY)
    };
  }

  const x = Number(value?.x);
  const y = Number(value?.y);
  if (Number.isFinite(x) && Number.isFinite(y)) {
    return {
      kind: "point",
      x: Math.round(x),
      y: Math.round(y)
    };
  }

  return {
    kind: typeof value
  };
}

class DropTrooperSheet extends ActorSheet {
  static get defaultOptions() {
    return foundry.utils.mergeObject(super.defaultOptions, {
      classes: ["drop-trooper", "sheet", "actor"],
      width: 900,
      height: 900,
      resizable: true
    });
  }

  get template() {
    if (this.actor.type === "npc") {
      return "systems/drop-trooper/templates/actor/npc-sheet.hbs";
    }

    if (this.actor.type === "drone") {
      return "systems/drop-trooper/templates/actor/drone-sheet.hbs";
    }

    return "systems/drop-trooper/templates/actor/trooper-sheet.hbs";
  }

  getData() {
    const data = super.getData();
    data.system = this.actor.system;
    data.isDrone = this._isDroneActor(this.actor);
    data.reaction = getDropTrooperReactionState(this.actor);
    data.droneDerived = this._getDroneDerivedStats(this.actor);
    data.skillDisplayRows = this._buildSkillDisplayRows(this.actor);
    data.trooperDrone = this._buildTrooperDroneDisplayData(this.actor);
    const overwatchWeaponId = String(this.actor.getFlag("drop-trooper", "overwatchWeaponId") || "").trim();
    data.weapons = sortDropTrooperItemsByDisplayOrder(
      this.actor.items.filter(item => item.type === "weapon")
    ).map(item => {
      const skillKey = this._isDroneActor(this.actor)
        ? "droneControl"
        : normalizeDropTrooperSkill(item.system?.skill, "shooting");
      const poolData = this._getSkillPoolData(skillKey, this.actor);
      return {
        _id: item.id,
        name: item.name,
        type: item.type,
        system: item.system,
        isOverwatchPreferred: item.id === overwatchWeaponId,
        ammoDisplay: this._formatWeaponAmmoDisplay(item),
        reloadVisible: this._shouldShowReload(item),
        attackLabel: this._getWeaponAttackLabel(item),
        linkedSkillLabel: this._getSkillLabel(skillKey),
        poolFormulaLabel: this._getDisplayPoolFormulaLabel(poolData),
        poolDiceLabel: `${Math.max(0, Number(poolData?.baseDice) || 0)}d6`
      };
    });
    data.abilities = sortDropTrooperItemsByDisplayOrder(
      this.actor.items.filter(item => item.type === "ability")
    ).map(item => {
      const linkedSkillKey = this._isDroneActor(this.actor)
        ? "droneControl"
        : normalizeDropTrooperSkill(item.system?.linkedSkill, "tech");
      const poolData = item.system?.abilityType === "skill"
        ? this._getSkillPoolData(linkedSkillKey, this.actor)
        : null;
      return {
        _id: item.id,
        name: item.name,
        type: item.type,
        system: item.system,
        abilityModeLabel: this._getAbilityModeLabel(item),
        linkedSkillLabel: this._getAbilityLinkedSkillLabel(item),
        poolDisplay: this._getAbilityPoolDisplay(item),
        resetVisible: this._shouldShowAbilityReset(item),
        poolFormulaLabel: poolData ? this._getDisplayPoolFormulaLabel(poolData) : "—",
        poolDiceLabel: poolData ? `${Math.max(0, Number(poolData?.baseDice) || 0)}d6` : "—"
      };
    });
    return data;
  }

  activateListeners(html) {
  super.activateListeners(html);

  this._activeTab = this._activeTab || "main";

  html.find(".roll-shoot").click(this._onRollShoot.bind(this));
  html.find(".roll-defense").click(this._onRollDefense.bind(this));
  html.find(".brace-roll").click(this._onBrace.bind(this));
  html.find(".roll-damage").click(this._onRollDamage.bind(this));
  html.find(".roll-skill").click(this._onRollSkill.bind(this));
  html.find(".roll-attribute").click(this._onRollAttribute.bind(this));
  html.find(".micro-missile-test").click(this._onMicroMissileTest.bind(this));
  html.find(".weapon-attack").click(this._onWeaponAttack.bind(this));
  html.find(".weapon-delete").click(this._onWeaponDelete.bind(this));
  html.find(".weapon-edit").click(this._onWeaponEdit.bind(this));
  html.find(".weapon-reload").click(this._onWeaponReload.bind(this));
  html.find(".weapon-overwatch-toggle").change(this._onWeaponOverwatchToggle.bind(this));
  html.find(".weapon-create").click(this._onWeaponCreate.bind(this));
  html.find(".npc-blueprint-export").click(this._onNpcBlueprintExport.bind(this));
  html.find(".ability-create").click(this._onAbilityCreate.bind(this));
  html.find(".ability-use").click(this._onAbilityUse.bind(this));
  html.find(".ability-edit").click(this._onAbilityEdit.bind(this));
  html.find(".ability-delete").click(this._onAbilityDelete.bind(this));
  html.find(".ability-reset").click(this._onAbilityReset.bind(this));
  html.find(".nano-repair").click(this._onNanoRepair.bind(this));
  html.find(".drone-deploy").click(this._onDeployAssignedDrone.bind(this));
  html.find(".drone-recall").click(this._onRecallAssignedDrone.bind(this));

  html.find(".dt-side-tab").click((event) => {
    event.preventDefault();
    const tab = event.currentTarget?.dataset?.tab;
    if (!tab) return;
    this._setActiveTab(html, tab);
  });

  this._setActiveTab(html, this._activeTab);

  this._activateItemReorder(html);
  applyDropTrooperActorSheetPermissions(html, this);
  applyDropTrooperOutOfArmorSheetState(html, this);
}

  _setActiveTab(html, tab) {
    const nextTab = tab || "main";
    this._activeTab = nextTab;
    html.find(".dt-side-tab").removeClass("is-active");
    html.find(`.dt-side-tab[data-tab="${nextTab}"]`).addClass("is-active");
    html.find(".dt-tab-panel").removeClass("is-active");
    html.find(`.dt-tab-panel[data-tab-panel="${nextTab}"]`).addClass("is-active");
  }

  async _onChangeInput(event) {
    const target = event?.target;
    if (!game.user?.isGM && isDropTrooperQueuedSheetChangeControl(target, this.actor?.type)) {
      event.preventDefault();
      event.stopPropagation();
      return false;
    }
    return super._onChangeInput(event);
  }

  _getSortedActorItemsByType(itemType) {
    return sortDropTrooperItemsByDisplayOrder(
      this.actor.items.filter(item => item.type === itemType)
    );
  }

  _getNextDisplayOrder(itemType) {
    const items = this._getSortedActorItemsByType(itemType);
    if (!items.length) return 10;
    const maxOrder = Math.max(...items.map((item, index) => getDropTrooperItemDisplayOrder(item, index)));
    return Math.max(10, Math.ceil(maxOrder / 10) * 10 + 10);
  }

  async _resequenceDisplayOrder(itemType, orderedIds) {
    const items = this._getSortedActorItemsByType(itemType);
    if (!items.length) return;

    const idSet = new Set(orderedIds || []);
    const orderedItems = [];
    for (const id of orderedIds || []) {
      const item = items.find(entry => entry.id === id);
      if (item) orderedItems.push(item);
    }
    for (const item of items) {
      if (!idSet.has(item.id)) orderedItems.push(item);
    }

    const updates = orderedItems.map((item, index) => ({
      _id: item.id,
      "system.displayOrder": (index + 1) * 10
    }));

    await this.actor.updateEmbeddedDocuments("Item", updates);
  }

  _activateItemReorder(html) {
    if (!game.user?.isGM) return;

    const root = html?.[0];
    if (!root) return;

    const sortableSelector = "[data-dt-order-group][data-item-id]";
    const sortableElements = Array.from(root.querySelectorAll(sortableSelector));
    if (!sortableElements.length) return;

    const clearDropState = () => {
      for (const element of sortableElements) {
        element.style.outline = "";
        element.style.outlineOffset = "";
        delete element.dataset.dtDropPosition;
      }
    };

    for (const element of sortableElements) {
      element.setAttribute("draggable", "true");

      element.addEventListener("dragstart", (event) => {
        const itemId = element.dataset.itemId;
        const group = element.dataset.dtOrderGroup;
        if (!itemId || !group) return;

        event.dataTransfer?.setData("text/plain", JSON.stringify({ itemId, group }));
        if (event.dataTransfer) event.dataTransfer.effectAllowed = "move";
        element.style.opacity = "0.45";
      });

      element.addEventListener("dragend", () => {
        element.style.opacity = "";
        clearDropState();
      });

      element.addEventListener("dragover", (event) => {
        const raw = event.dataTransfer?.getData("text/plain");
        if (!raw) return;

        let dragData = null;
        try {
          dragData = JSON.parse(raw);
        } catch (err) {
          return;
        }

        if (!dragData?.itemId || dragData.group !== element.dataset.dtOrderGroup || dragData.itemId === element.dataset.itemId) {
          return;
        }

        event.preventDefault();
        const rect = element.getBoundingClientRect();
        const after = event.clientY > (rect.top + rect.height / 2);
        clearDropState();
        element.style.outline = after ? "2px solid #79c8ff" : "2px solid #ffcc6f";
        element.style.outlineOffset = "-2px";
        element.dataset.dtDropPosition = after ? "after" : "before";
      });

      element.addEventListener("drop", async (event) => {
        const raw = event.dataTransfer?.getData("text/plain");
        clearDropState();
        if (!raw) return;

        let dragData = null;
        try {
          dragData = JSON.parse(raw);
        } catch (err) {
          return;
        }

        const itemType = element.dataset.dtOrderGroup;
        const targetId = element.dataset.itemId;
        const draggedId = dragData?.itemId;
        if (!draggedId || !targetId || dragData.group !== itemType || draggedId === targetId) {
          return;
        }

        event.preventDefault();

        const items = this._getSortedActorItemsByType(itemType).map(item => item.id);
        const fromIndex = items.indexOf(draggedId);
        const targetIndex = items.indexOf(targetId);
        if (fromIndex === -1 || targetIndex === -1) return;

        const [moved] = items.splice(fromIndex, 1);
        let insertionIndex = items.indexOf(targetId);
        const dropPosition = element.dataset.dtDropPosition === "after" ? "after" : "before";
        if (dropPosition === "after") insertionIndex += 1;
        items.splice(insertionIndex, 0, moved);

        await this._resequenceDisplayOrder(itemType, items);
        this.render(false);
      });
    }
  }

  _isDroneActor(actor = this.actor) {
    return String(actor?.type || "") === "drone";
  }

  _actorTracksHealth(actor = this.actor) {
    return foundry.utils.hasProperty(actor, "system.health.value");
  }

  _getDroneDerivedStats(actor = this.actor) {
    const droneControl = Math.max(0, Number(actor?.system?.skills?.droneControl) || 0);
    return {
      droneControl,
      attackDice: droneControl,
      abilityDice: droneControl,
      defenseDice: Math.max(1, Math.floor(droneControl / 2))
    };
  }

  _getBaseDefenseDice(actor = this.actor) {
    if (this._isDroneActor(actor)) {
      return this._getDroneDerivedStats(actor).defenseDice;
    }

    return Number(actor?.system?.skills?.defense) || 0;
  }

  _getSkillAttributeKey(skillKey) {
    const attributeMap = {
      shooting: "agility",
      maneuvering: "agility",
      melee: "strength",
      heavyWeapons: "strength",
      recon: "perception",
      sensors: "perception",
      electronics: "tech",
      engineering: "tech",
      droneControl: "tech",
      command: "will",
      discipline: "will",
      survival: "will"
    };

    return attributeMap[String(skillKey || "")] || null;
  }

  _getSkillPoolData(skillKey, actor = this.actor) {
    const normalizedSkillKey = String(skillKey || "");
    const skillDice = Math.max(0, Number(actor?.system?.skills?.[normalizedSkillKey]) || 0);

    if (this._isDroneActor(actor)) {
      return {
        skillKey: normalizedSkillKey,
        skillLabel: this._getSkillLabel(normalizedSkillKey),
        skillDice,
        attributeKey: null,
        attributeLabel: null,
        attributeDice: 0,
        baseDice: skillDice,
        usesCombinedPool: false
      };
    }

    const attributeKey = this._getSkillAttributeKey(normalizedSkillKey);
    const attributeDice = attributeKey ? Math.max(0, Number(actor?.system?.attributes?.[attributeKey]) || 0) : 0;

    return {
      skillKey: normalizedSkillKey,
      skillLabel: this._getSkillLabel(normalizedSkillKey),
      skillDice,
      attributeKey,
      attributeLabel: attributeKey ? this._getSkillLabel(attributeKey) : null,
      attributeDice,
      baseDice: Math.max(0, skillDice + attributeDice),
      usesCombinedPool: !!attributeKey
    };
  }

  _getAdjustedSkillRollData(skillKey, actor = this.actor) {
    const poolData = this._getSkillPoolData(skillKey, actor);
    const rollData = this._getAdjustedRollData(poolData.baseDice, actor, {
      pushPenaltyKey: skillKey,
      pushPenaltyLabel: poolData.skillLabel || this._getSkillLabel(skillKey) || "Skill"
    });
    return {
      ...poolData,
      ...rollData
    };
  }

  _getAdjustedSkillAttackRollData(skillKey, actor = this.actor) {
    const poolData = this._getSkillPoolData(skillKey, actor);
    const rollData = this._getAdjustedAttackRollData(poolData.baseDice, actor, {
      pushPenaltyKey: skillKey,
      pushPenaltyLabel: poolData.skillLabel || this._getSkillLabel(skillKey) || "Skill"
    });
    return {
      ...poolData,
      ...rollData
    };
  }

  _getSkillBreakdownHtml(poolData, options = {}) {
    const showBaseDice = options.showBaseDice !== false;
    if (!poolData || !poolData.usesCombinedPool) {
      return showBaseDice
        ? `<div class="dt-chat-line"><span class="dt-chat-small">Base Dice</span><br><span class="dt-chat-strong">${Math.max(0, Number(poolData?.baseDice) || 0)}d6</span></div>`
        : "";
    }

    return `
      <div class="dt-chat-line"><span class="dt-chat-small">Attribute</span><br><span class="dt-chat-strong">${poolData.attributeLabel} ${poolData.attributeDice}</span></div>
      <div class="dt-chat-line"><span class="dt-chat-small">Skill</span><br><span class="dt-chat-strong">${poolData.skillLabel} ${poolData.skillDice}</span></div>
      ${showBaseDice ? `<div class="dt-chat-line"><span class="dt-chat-small">Base Dice</span><br><span class="dt-chat-strong">${poolData.attributeDice} + ${poolData.skillDice} = ${poolData.baseDice}d6</span></div>` : ""}
    `;
  }

  _getSkillBreakdownText(poolData) {
    if (!poolData) return "";
    if (!poolData.usesCombinedPool) {
      return `${poolData.skillLabel || "Skill"} ${poolData.skillDice} = ${poolData.baseDice}d6`;
    }

    return `${poolData.attributeLabel} ${poolData.attributeDice} + ${poolData.skillLabel} ${poolData.skillDice} = ${poolData.baseDice}d6`;
  }

  _getSkillLabel(skillKey) {
    const labelMap = {
      shooting: "Shooting",
      heavyWeapons: "Heavy Weapons",
      melee: "Melee",
      maneuvering: "Maneuvering",
      recon: "Recon",
      sensors: "Sensors",
      electronics: "Electronics",
      engineering: "Engineering",
      droneControl: "Drone Control",
      command: "Command",
      discipline: "Discipline",
      survival: "Survival",
      defense: "Defense",
      strength: "Strength",
      agility: "Agility",
      perception: "Perception",
      tech: "Tech",
      will: "Will"
    };

    return labelMap[skillKey] || "—";
  }

  _getAttributeAbbreviation(attributeKey) {
    const map = {
      strength: "STR",
      agility: "AGI",
      perception: "PER",
      tech: "TEC",
      will: "WIL"
    };
    return map[String(attributeKey || "")] || this._getSkillLabel(attributeKey);
  }

  _getDisplayPoolFormulaLabel(poolData) {
    if (!poolData) return "—";
    if (!poolData.usesCombinedPool) {
      const skillLabel = poolData.skillLabel || "Skill";
      return `${skillLabel} ${Math.max(0, Number(poolData.skillDice) || 0)}`;
    }

    const attributeShort = this._getAttributeAbbreviation(poolData.attributeKey);
    return `${attributeShort}(${Math.max(0, Number(poolData.attributeDice) || 0)}) + ${Math.max(0, Number(poolData.skillDice) || 0)}`;
  }

  _buildSkillDisplayRows(actor = this.actor) {
    if (this._isDroneActor(actor)) return [];
    const order = [
      "shooting",
      "heavyWeapons",
      "melee",
      "maneuvering",
      "recon",
      "sensors",
      "electronics",
      "engineering",
      "droneControl",
      "command",
      "discipline",
      "survival"
    ];

    return order.map(skillKey => {
      const poolData = this._getSkillPoolData(skillKey, actor);
      return {
        key: skillKey,
        label: this._getSkillLabel(skillKey),
        value: Math.max(0, Number(actor?.system?.skills?.[skillKey]) || 0),
        inputName: `system.skills.${skillKey}`,
        formulaLabel: this._getDisplayPoolFormulaLabel(poolData),
        totalDiceLabel: `${Math.max(0, Number(poolData?.baseDice) || 0)}d6`
      };
    });
  }

  _getTrooperAssignedDroneIds(actor = this.actor) {
    if (!actor || String(actor.type || "") !== "trooper") return [];
    const raw = String(actor.system?.drone?.assignedActorId || "");
    return raw
      .split(/[\n,;]/)
      .map(entry => String(entry || "").trim())
      .filter(Boolean);
  }

  _getTrooperAssignedDroneActors(actor = this.actor) {
    const seen = new Set();
    return this._getTrooperAssignedDroneIds(actor)
      .map(actorId => game.actors?.get(actorId) || null)
      .filter(candidate => {
        if (!candidate || String(candidate.type || "") !== "drone") return false;
        if (seen.has(candidate.id)) return false;
        seen.add(candidate.id);
        return true;
      });
  }

  _getTrooperAssignedDroneActor(actor = this.actor, preferredActorId = null) {
    if (!actor || String(actor.type || "") !== "trooper") return null;
    const assignedDrones = this._getTrooperAssignedDroneActors(actor);
    if (!assignedDrones.length) return null;

    const preferredId = String(preferredActorId || "").trim();
    if (preferredId) {
      const preferred = assignedDrones.find(candidate => candidate.id === preferredId);
      if (preferred) return preferred;
    }

    const activeDrone = assignedDrones.find(candidate => getDropTrooperDroneCurrentDeployed(candidate));
    return activeDrone || assignedDrones[0] || null;
  }

  async _promptTrooperDroneSelection(actor = this.actor, { title = "Deploy Drone", confirmLabel = "Deploy" } = {}) {
    const assignedDrones = this._getTrooperAssignedDroneActors(actor);
    if (!assignedDrones.length) return null;
    if (assignedDrones.length === 1) return assignedDrones[0];

    const optionsHtml = assignedDrones.map((drone, index) => {
      const integrity = Math.max(0, Number(drone?.system?.armor?.integrity?.value) || 0);
      const deployed = getDropTrooperDroneCurrentDeployed(drone);
      const status = deployed
        ? `Active • Integrity ${integrity}`
        : integrity <= 0
          ? "Destroyed"
          : `Stowed • Integrity ${integrity}`;
      const selected = index === 0 ? "selected" : "";
      return `<option value="${escapeDropTrooperHtml(drone.id)}" ${selected}>${escapeDropTrooperHtml(drone.name)} — ${escapeDropTrooperHtml(status)}</option>`;
    }).join("");

    const dialogResult = await Dialog.wait({
      title,
      content: `
        <form>
          <div class="form-group">
            <label>Choose Drone</label>
            <select name="droneActorId">${optionsHtml}</select>
          </div>
        </form>
      `,
      buttons: {
        confirm: {
          label: confirmLabel,
          callback: (html) => String(html.find('[name="droneActorId"]').val() || "").trim()
        },
        cancel: {
          label: "Cancel",
          callback: () => null
        }
      },
      default: "confirm",
      close: () => null
    });

    if (!dialogResult) return null;
    return this._getTrooperAssignedDroneActor(actor, dialogResult);
  }

  _buildTrooperDroneDisplayData(actor = this.actor) {
    const assignedDrones = this._getTrooperAssignedDroneActors(actor);
    const assignedDrone = this._getTrooperAssignedDroneActor(actor);
    const activeDrone = assignedDrones.find(candidate => getDropTrooperDroneCurrentDeployed(candidate)) || null;
    const displayDrone = activeDrone || assignedDrone;
    const uses = Math.max(0, Number(actor?.system?.drone?.uses) || 0);
    const assignedActorId = String(actor?.system?.drone?.assignedActorId || "").trim();
    const assignedActorName = String(actor?.system?.drone?.assignedActorName || "").trim() || String(displayDrone?.name || "");
    const droneIntegrity = Math.max(0, Number(displayDrone?.system?.armor?.integrity?.value) || 0);
    const deployed = displayDrone ? getDropTrooperDroneCurrentDeployed(displayDrone) : false;
    let statusLabel = "No drone assigned";
    if (assignedDrones.length === 1 && displayDrone) {
      statusLabel = deployed
        ? `Active • Integrity ${droneIntegrity}`
        : `Stowed • Integrity ${droneIntegrity}`;
    } else if (assignedDrones.length > 1) {
      if (activeDrone) {
        statusLabel = `${activeDrone.name} active • Integrity ${droneIntegrity}`;
      } else {
        statusLabel = `${assignedDrones.length} linked drones`;
      }
    }
    return {
      uses,
      assignedActorId,
      assignedActorName,
      hasAssignedDrone: assignedDrones.length > 0,
      linkedDroneCount: assignedDrones.length,
      droneIntegrity,
      isDeployed: deployed,
      statusLabel
    };
  }

  _getPreferredActorToken(actor = this.actor) {
    const explicitToken = getDropTrooperTokenDocumentFromActor(actor)?.object;
    if (explicitToken) return explicitToken;
    const tokens = getDropTrooperCanvasTokensForActor(actor);
    return tokens.find(token => token?.controlled) || tokens[0] || null;
  }

  _getAbilityModeLabel(ability) {
    return globalThis.DropTrooperAbilityHelpers.getAbilityModeLabel(ability);
  }

  _getAbilityLinkedSkillLabel(ability) {
    return globalThis.DropTrooperAbilityHelpers.getAbilityLinkedSkillLabel(ability, {
      getSkillLabel: this._getSkillLabel.bind(this)
    });
  }

  _getAbilityPoolDisplay(ability) {
    return globalThis.DropTrooperAbilityHelpers.getAbilityPoolDisplay(ability);
  }

  _shouldShowAbilityReset(ability) {
    return globalThis.DropTrooperAbilityHelpers.shouldShowAbilityReset(ability);
  }

  _getPendingRollBonus(actor = this.actor) {
    const raw = actor.getFlag("drop-trooper", "pendingRollBonus");
    const dice = Number(raw?.dice) || 0;
    if (dice <= 0) return null;

    return {
      dice,
      source: raw?.source || "Bonus Dice"
    };
  }

  _getPendingRollPenalty(actor = this.actor) {
    const raw = actor.getFlag("drop-trooper", "pendingRollPenalty");
    const dice = Number(raw?.dice) || 0;
    if (dice <= 0) return null;

    return {
      dice,
      source: raw?.source || "Penalty Dice"
    };
  }

  _getPushRollPenalties(actor = this.actor) {
    const raw = actor?.getFlag?.("drop-trooper", "pushRollPenalties");
    if (!raw || typeof raw !== "object" || Array.isArray(raw)) return {};

    return Object.entries(raw).reduce((acc, [key, value]) => {
      const dice = Math.max(0, Number(value?.dice) || 0);
      if (dice <= 0) return acc;

      acc[key] = {
        dice,
        source: value?.source || "Push Failure",
        label: value?.label || this._getSkillLabel(key) || key
      };
      return acc;
    }, {});
  }

  _getPushRollPenalty(rollKey, actor = this.actor) {
    const key = String(rollKey || "").trim();
    if (!key) return null;

    return this._getPushRollPenalties(actor)[key] || null;
  }

  async _addPushRollPenalty(rollKey, actor = this.actor, options = {}) {
    const key = String(rollKey || "").trim();
    if (!key || !actor) return null;

    const penalties = this._getPushRollPenalties(actor);
    const currentDice = Number(penalties[key]?.dice) || 0;
    const nextPenalty = {
      dice: currentDice + 1,
      source: options.source || "Push Failure",
      label: options.label || penalties[key]?.label || this._getSkillLabel(key) || key
    };

    const nextData = {
      ...penalties,
      [key]: nextPenalty
    };

    await actor.setFlag("drop-trooper", "pushRollPenalties", nextData);
    return nextPenalty;
  }

  async _clearPushRollPenalties(actor = this.actor) {
    if (!actor) return;
    await actor.unsetFlag("drop-trooper", "pushRollPenalties");
  }

  _getPendingRollModifiers(actor = this.actor, options = {}) {
    const pendingBonus = this._getPendingRollBonus(actor);
    const pendingPenalty = this._getPendingRollPenalty(actor);
    const pushPenalty = options.pushPenaltyKey
      ? this._getPushRollPenalty(options.pushPenaltyKey, actor)
      : null;

    return {
      pendingBonus,
      pendingPenalty,
      pushPenalty,
      bonusDice: pendingBonus?.dice || 0,
      penaltyDice: pendingPenalty?.dice || 0,
      pushPenaltyDice: pushPenalty?.dice || 0
    };
  }

  _getAdjustedRollData(baseDice, actor = this.actor, options = {}) {
    const modifierData = this._getPendingRollModifiers(actor, options);
    const base = Number(baseDice) || 0;

    return {
      baseDice: base,
      totalDice: Math.max(0, base + modifierData.bonusDice - modifierData.penaltyDice - modifierData.pushPenaltyDice),
      pendingBonus: modifierData.pendingBonus,
      pendingPenalty: modifierData.pendingPenalty,
      pushPenalty: modifierData.pushPenalty,
      bonusDice: modifierData.bonusDice,
      penaltyDice: modifierData.penaltyDice,
      pushPenaltyDice: modifierData.pushPenaltyDice
    };
  }

  async _consumePendingRollBonus(actor = this.actor) {
    await actor.unsetFlag("drop-trooper", "pendingRollBonus");
  }

  async _consumePendingRollPenalty(actor = this.actor) {
    await actor.unsetFlag("drop-trooper", "pendingRollPenalty");
  }

  async _consumePendingRollModifiers(actor = this.actor, modifierData = null) {
    const data = modifierData || this._getPendingRollModifiers(actor);

    if (data?.bonusDice > 0) {
      await this._consumePendingRollBonus(actor);
    }

    if (data?.penaltyDice > 0) {
      await this._consumePendingRollPenalty(actor);
    }
  }

  async _consumePendingStandardRollEffects(actor = this.actor, rollData = null) {
    const data = rollData || this._getPendingRollModifiers(actor);

    if ((data?.bonusDice || 0) > 0 || (data?.penaltyDice || 0) > 0) {
      await this._consumePendingRollModifiers(actor, data);
    }
  }

  async _setPendingRollBonus(actor, dice, source = "Bonus Dice") {
    await actor.setFlag("drop-trooper", "pendingRollBonus", {
      dice,
      source
    });
  }

  async _setPendingRollPenalty(actor, dice, source = "Penalty Dice") {
    await actor.setFlag("drop-trooper", "pendingRollPenalty", {
      dice,
      source
    });
  }

  _getPendingDefenseBrace(actor = this.actor) {
    const raw = actor.getFlag("drop-trooper", "pendingDefenseBrace");
    const multiplier = Number(raw?.multiplier) || 0;
    if (multiplier <= 1) return null;

    return {
      multiplier,
      source: raw?.source || "Brace"
    };
  }

  _getAdjustedDefenseRollData(actor = this.actor) {
    const baseDefense = this._getBaseDefenseDice(actor);
    const rollData = this._getAdjustedRollData(baseDefense, actor);
    const pendingBrace = this._getPendingDefenseBrace(actor);
    const braceMultiplier = pendingBrace?.multiplier || 1;
    const preBraceDice = rollData.totalDice;

    return {
      ...rollData,
      pendingBrace,
      braceMultiplier,
      preBraceDice,
      totalDice: Math.max(0, preBraceDice * braceMultiplier)
    };
  }

  async _setPendingDefenseBrace(actor, multiplier = 2, source = "Brace") {
    await actor.setFlag("drop-trooper", "pendingDefenseBrace", {
      multiplier,
      source
    });
  }

  async _consumePendingDefenseBrace(actor = this.actor) {
    await actor.unsetFlag("drop-trooper", "pendingDefenseBrace");
  }

  async _consumePendingDefenseEffects(actor = this.actor, defenseData = null) {
    const data = defenseData || this._getAdjustedDefenseRollData(actor);

    if (data?.bonusDice > 0 || data?.penaltyDice > 0) {
      await this._consumePendingRollModifiers(actor, data);
    }

    if ((data?.braceMultiplier || 1) > 1) {
      await this._consumePendingDefenseBrace(actor);
    }
  }

  _getPendingAttackAim(actor = this.actor) {
    const raw = actor.getFlag("drop-trooper", "pendingAttackAim");
    const dice = Number(raw?.dice) || 0;
    if (dice <= 0) return null;

    return {
      dice,
      source: raw?.source || "Aim"
    };
  }

  _getAdjustedAttackRollData(baseDice, actor = this.actor, options = {}) {
    const rollData = this._getAdjustedRollData(baseDice, actor, options);
    const pendingAim = this._getPendingAttackAim(actor);
    const aimDice = pendingAim?.dice || 0;

    return {
      ...rollData,
      pendingAim,
      aimDice,
      totalDice: Math.max(0, rollData.totalDice + aimDice)
    };
  }

  async _setPendingAttackAim(actor, dice = 2, source = "Aim") {
    await actor.setFlag("drop-trooper", "pendingAttackAim", {
      dice,
      source
    });
  }

  async _consumePendingAttackAim(actor = this.actor) {
    await actor.unsetFlag("drop-trooper", "pendingAttackAim");
  }

  async _consumePendingAttackEffects(actor = this.actor, attackData = null) {
    const data = attackData || this._getAdjustedAttackRollData(0, actor);

    if (data?.bonusDice > 0 || data?.penaltyDice > 0) {
      await this._consumePendingRollModifiers(actor, data);
    }

    if ((data?.aimDice || 0) > 0) {
      await this._consumePendingAttackAim(actor);
    }
  }

  _getSceneActorChoices(excludeSelf = true) {
    if (!canvas?.ready) return [];

    const seen = new Set();
    const choices = [];

    for (const token of canvas.tokens.placeables) {
      const actor = token.actor;
      if (!actor) continue;
      if (excludeSelf && actor.id === this.actor.id) continue;
      if (seen.has(actor.id)) continue;

      seen.add(actor.id);
      choices.push({
        actor,
        label: token.name || actor.name
      });
    }

    return choices;
  }

  _getWeaponAmmoState(weapon) {
    return globalThis.DropTrooperWeaponHelpers.getWeaponAmmoState(weapon);
  }

  _validateWeaponAmmoState(weapon, ammoState) {
    return globalThis.DropTrooperWeaponHelpers.validateWeaponAmmoState(weapon, ammoState);
  }

  _formatWeaponAmmoDisplay(weapon) {
    return globalThis.DropTrooperWeaponHelpers.formatWeaponAmmoDisplay(
      weapon,
      this._getWeaponAmmoState.bind(this)
    );
  }

  _shouldShowReload(weapon) {
    return globalThis.DropTrooperWeaponHelpers.shouldShowReload(
      weapon,
      this._getWeaponAmmoState.bind(this)
    );
  }

  _getWeaponAttackLabel(weapon) {
    return globalThis.DropTrooperWeaponHelpers.getWeaponAttackLabel(
      weapon,
      this._isSmokeWeapon.bind(this),
      this._getAoeType.bind(this)
    );
  }

  _getAoeType(data) {
    return globalThis.DropTrooperWeaponHelpers.getAoeType(data);
  }

  _getAoeEffectType(data) {
    return globalThis.DropTrooperWeaponHelpers.getAoeEffectType(data);
  }

  _isSmokeWeapon(weapon) {
    return globalThis.DropTrooperWeaponHelpers.isSmokeWeapon(
      weapon,
      this._getAoeType.bind(this),
      this._getAoeEffectType.bind(this)
    );
  }

  _getWeaponBlastSoundPath(weapon) {
    return globalThis.DropTrooperWeaponHelpers.getWeaponBlastSoundPath(weapon);
  }

  _getWeaponBlastImagePath(weapon) {
    return globalThis.DropTrooperWeaponHelpers.getWeaponBlastImagePath(weapon);
  }

  _getWeaponConeSoundPath(weapon) {
    return globalThis.DropTrooperWeaponHelpers.getWeaponConeSoundPath(weapon);
  }

  _getWeaponConeImagePath(weapon) {
    return globalThis.DropTrooperWeaponHelpers.getWeaponConeImagePath(weapon);
  }

  _getConfiguredWeaponEffectType(weapon) {
    return normalizeDropTrooperWeaponEffectType(weapon?.system?.fireEffect, "auto");
  }

  _getWeaponEffectType(weapon) {
    if (!weapon) return "ballistic";

    const configuredType = this._getConfiguredWeaponEffectType(weapon);
    if (configuredType === "none") return "none";
    if (configuredType !== "auto") return configuredType;

    const rawTags = Array.isArray(weapon.system?.tags) ? weapon.system.tags.join(" ") : "";
    const searchText = [
      weapon.name,
      weapon.system?.weaponType,
      weapon.system?.notes,
      rawTags,
      weapon.system?.skill
    ].map(value => String(value ?? "").trim().toLowerCase()).join(" ");

    if (weapon.system?.aoeEnabled) {
      const aoeType = this._getAoeType(weapon.system);
      const aoeEffect = this._getAoeEffectType(weapon.system);

      if (aoeEffect === "smoke") return "smoke";
      if (/emp|electro[- ]?magnetic|tesla/.test(searchText)) return "emp";
      if (/lightning|electric|shock|arc/.test(searchText)) return "lightning";
      if (/plasma/.test(searchText)) return "plasma";
      if (/acid|corrosive|melt/.test(searchText)) return "acid";
      if (/ice|cold|frost|cryo/.test(searchText)) return "ice";
      if (/poison|toxic|venom|gas/.test(searchText)) return "poison";
      if (/sonic|thunder|shockwave/.test(searchText)) return "sonic";
      if (/force|arcane|grav|gravity/.test(searchText)) return "force";
      if (/radiant|holy|solar/.test(searchText)) return "radiant";
      if (/necrotic|shadow|void|dark/.test(searchText)) return "necrotic";
      if (/heal|healing|medic|repair/.test(searchText)) return "healing";
      if (/nano|nanite/.test(searchText)) return "nano";
      if (aoeType === "cone") return "flamer";
      if (/missile|rocket|micro[- ]?missile|launcher/.test(searchText)) return "missile";
      if (/grenade|frag|bomb/.test(searchText)) return "grenade";
      return "missile";
    }

    if (/emp|electro[- ]?magnetic/.test(searchText)) return "emp";
    if (/lightning|electric|shock|tesla|arc/.test(searchText)) return "lightning";
    if (/plasma/.test(searchText)) return "plasma";
    if (/laser|beam/.test(searchText)) return "laser";
    if (/acid|corrosive|melt/.test(searchText)) return "acid";
    if (/ice|cold|frost|cryo/.test(searchText)) return "ice";
    if (/poison|toxic|venom|gas/.test(searchText)) return "poison";
    if (/smoke|fog/.test(searchText)) return "smoke";
    if (/sonic|thunder|shockwave/.test(searchText)) return "sonic";
    if (/force|arcane|grav|gravity/.test(searchText)) return "force";
    if (/radiant|holy|solar/.test(searchText)) return "radiant";
    if (/necrotic|shadow|void|dark/.test(searchText)) return "necrotic";
    if (/psychic|psionic|mind/.test(searchText)) return "psychic";
    if (/heal|healing|medic|repair/.test(searchText)) return "healing";
    if (/nano|nanite/.test(searchText)) return "nano";
    if (/missile|rocket|micro[- ]?missile|launcher/.test(searchText)) return "missile";
    if (/flamer|flame|incinerator|burn|fire/.test(searchText)) return "flamer";
    if (/grenade|frag|bomb/.test(searchText)) return "grenade";
    return "ballistic";
  }

  _getWeaponFireSoundPath(weapon, effectType = null) {
    const customPath = String(weapon?.system?.fireSoundPath ?? "").trim();
    if (customPath) return customPath;

    const resolvedType = normalizeDropTrooperWeaponEffectType(effectType || this._getWeaponEffectType(weapon), "auto");
    return DROP_TROOPER_WEAPON_FIRE_SOUND_DEFAULTS[resolvedType] || "";
  }

  _queueWeaponFireEffect(weapon, context = {}) {
    dropTrooperWeaponFxLog("queue requested", {
      weapon: weapon?.name || "Unknown Weapon",
      configuredType: this._getConfiguredWeaponEffectType(weapon),
      resolvedType: this._getWeaponEffectType(weapon),
      context: {
        attachToSource: !!context.attachToSource,
        stretchToTarget: context.stretchToTarget !== false,
        source: describeDropTrooperFxLocation(context.sourceToken || context.sourcePoint || null),
        target: describeDropTrooperFxLocation(context.targetToken || context.targetPoint || null)
      }
    });

    this._playWeaponFireEffect(weapon, context).catch(err => {
      dropTrooperWeaponFxWarn("play threw an exception", err);
    });
  }

  async _playWeaponFireEffect(weapon, context = {}) {
    const configuredType = this._getConfiguredWeaponEffectType(weapon);
    const effectType = normalizeDropTrooperWeaponEffectType(context.effectType || this._getWeaponEffectType(weapon), "ballistic");
    const source = context.sourceToken || this._getActorTokenOnCanvas() || context.sourcePoint || null;
    const target = context.targetToken || context.targetPoint || null;

    dropTrooperWeaponFxLog("play start", {
      weapon: weapon?.name || "Unknown Weapon",
      configuredType,
      resolvedType: effectType,
      sequencerModuleActive: !!game.modules?.get("sequencer")?.active,
      sequenceClassPresent: typeof globalThis.Sequence === "function",
      sequencerDatabasePresent: !!globalThis.Sequencer?.Database,
      source: describeDropTrooperFxLocation(source),
      target: describeDropTrooperFxLocation(target)
    });

    if (!isDropTrooperSequencerAvailable()) {
      dropTrooperWeaponFxWarn("stopped: Sequencer is not available");
      return false;
    }

    if (effectType === "none") {
      dropTrooperWeaponFxLog("stopped: weapon effect type is set to none");
      return false;
    }

    if (!source || !target) {
      dropTrooperWeaponFxWarn("stopped: missing source or target", {
        source: describeDropTrooperFxLocation(source),
        target: describeDropTrooperFxLocation(target)
      });
      return false;
    }

    const effectPath = getDropTrooperWeaponEffectDbPath(effectType);
    dropTrooperWeaponFxLog("effect path lookup finished", {
      effectType,
      effectPath: effectPath || "(none)"
    });

    if (!effectPath) {
      dropTrooperWeaponFxWarn("stopped: no JB2A/Sequencer database path was found for this effect type", {
        effectType
      });
      return false;
    }

    const sequence = createDropTrooperSequence();
    if (!sequence?.effect) {
      dropTrooperWeaponFxWarn("stopped: could not create a Sequencer Sequence object");
      return false;
    }

    const fireSoundPath = this._getWeaponFireSoundPath(weapon, effectType);
    dropTrooperWeaponFxLog("building sequence", {
      effectPath,
      fireSoundPath: fireSoundPath || "(none)"
    });

    if (fireSoundPath && sequence.sound) {
      sequence.sound()
        .file(fireSoundPath)
        .volume(0.8);
    }

    const effect = sequence.effect()
      .file(effectPath)
      .atLocation(source);

    if (effect.xray) {
      effect.xray();
      dropTrooperWeaponFxLog("applied xray() to effect");
    }

    if (context.attachToSource) {
      effect.attachTo(source, { bindElevation: false });
    }

    if (context.stretchToTarget !== false) {
      effect.stretchTo(target);
      dropTrooperWeaponFxLog("effect.stretchTo(target) applied without remote/options");
    } else {
      effect.rotateTowards(target);
      dropTrooperWeaponFxLog("effect.rotateTowards(target) applied");
    }

    const size = Number(context.size) || 0;
    if (size > 0 && effect.size) {
      effect.size(size);
    }

    const scale = Number(context.scale) || 0;
    if (scale > 0 && effect.scale) {
      effect.scale(scale);
    }

    sequence.play();
    dropTrooperWeaponFxLog("sequence.play called locally (no remote)");

    return true;
  }

  _projectPointFromDirection(origin, directionDegrees, distanceFeet) {
    if (!origin) return null;

    const pixelsPerFoot = canvas?.dimensions
      ? (canvas.dimensions.size / canvas.dimensions.distance)
      : 1;

    const distancePixels = Math.max(0, Number(distanceFeet) || 0) * pixelsPerFoot;
    const angleRad = this._normalizeDirection(directionDegrees) * (Math.PI / 180);

    return {
      x: Number(origin.x) + (Math.cos(angleRad) * distancePixels),
      y: Number(origin.y) + (Math.sin(angleRad) * distancePixels)
    };
  }

  _getNumericValue(rawValue, defaultValue = 0) {
    if (rawValue === "" || rawValue === null || rawValue === undefined) return defaultValue;
    const parsed = Number(rawValue);
    return Number.isFinite(parsed) ? parsed : defaultValue;
  }

  _normalizeDirection(direction) {
    return ((Number(direction) % 360) + 360) % 360;
  }

  _getPointDirectionDegrees(origin, point) {
    const dx = point.x - origin.x;
    const dy = point.y - origin.y;
    return this._normalizeDirection(Math.atan2(dy, dx) * (180 / Math.PI));
  }

  _getAngleDifference(a, b) {
    let diff = Math.abs(this._normalizeDirection(a) - this._normalizeDirection(b));
    if (diff > 180) diff = 360 - diff;
    return diff;
  }

  _getActorTokenOnCanvas() {
    if (!canvas?.ready) return null;

    const controlled = canvas.tokens.controlled.find(token => token.actor?.id === this.actor.id);
    if (controlled) return controlled;

    return canvas.tokens.placeables.find(token => token.actor?.id === this.actor.id) || null;
  }

_getCanvasTokenById(tokenId) {
  if (!canvas?.ready || !tokenId) return null;
  return canvas.tokens?.placeables?.find(token => token?.id === tokenId) || null;
}

  _formatRangeBand(start, end) {
    if (end <= 0 || end <= start) return "Disabled";
    return `${start}–${end} ft`;
  }

  _buildDiceHtml(dieResults, successOnSix = true) {
    let diceHtml = "";

    for (let d of dieResults) {
      const isSuccess = successOnSix && d === 6;
      const dieClass = isSuccess ? "dt-die-pill success" : "dt-die-pill";
      diceHtml += `<span class="${dieClass}">${d}</span>`;
    }

    return diceHtml;
  }

  _getStandardRollSubtitle(type) {
    const subtitleMap = {
      skill: "Skill Roll",
      defense: "Defense Roll",
      attribute: "Attribute Roll"
    };

    return subtitleMap[type] || "Roll";
  }

  _buildStandardRollChatCardHtml(label, type, options = {}) {
    const actorName = escapeDropTrooperHtml(this.actor?.name || "Drop Trooper");
    const totalDice = Number(options.totalDice) || 0;
    const baseDice = Number(options.baseDice) || 0;
    const bonusDice = Number(options.bonusDice) || 0;
    const penaltyDice = Number(options.penaltyDice) || 0;
    const pushPenaltyDice = Number(options.pushPenaltyDice) || 0;
    const defenseMultiplier = Number(options.defenseMultiplier) || 1;
    const preMultiplierDice = Number(options.preMultiplierDice ?? totalDice) || 0;
    const result = options.result || { dieResults: [], successes: 0 };
    const diceHtml = this._buildDiceHtml(result.dieResults || [], true);
    const escapedLabel = escapeDropTrooperHtml(label || "Roll");
    const pushStatus = String(options.pushStatus || "").trim().toLowerCase();
    const pushButtonHtml = options.pushButtonHtml || "";

    const pushStatusHtml = pushStatus === "used"
      ? `
              <div class="dt-chat-line">
                <span class="dt-chat-small">Push</span><br>
                <span class="dt-chat-strong">Used</span>
              </div>`
      : (pushStatus === "declined"
        ? `
              <div class="dt-chat-line">
                <span class="dt-chat-small">Push</span><br>
                <span class="dt-chat-strong">Declined</span>
              </div>`
        : (pushStatus === "available"
          ? `
              <div class="dt-chat-line">
                <span class="dt-chat-small">Push</span><br>
                <span class="dt-chat-strong">Available</span>
              </div>`
          : ""));

    const pushPenaltyHtml = pushPenaltyDice > 0 ? `
              <div class="dt-chat-line">
                <span class="dt-chat-small">${escapeDropTrooperHtml(options.pushPenaltySource || "Push Penalty")}</span><br>
                <span class="dt-chat-strong">-${pushPenaltyDice}d6</span>
              </div>` : "";

    const pushFailureHtml = options.pushPenaltyApplied ? `
          <div class="dt-chat-section">
            <div class="dt-chat-line">
              <span class="dt-chat-small">Push Failure</span><br>
              <span class="dt-chat-strong">-1 die to ${escapeDropTrooperHtml(options.appliedPushPenalty?.label || options.pushPenaltyLabel || label)} until Refit (${Number(options.appliedPushPenalty?.dice) || 1} total)</span>
            </div>
          </div>` : "";

    const pushInfoHtml = options.pushInfoHtml ? `
          <div class="dt-chat-section">
            ${options.pushInfoHtml}
          </div>` : "";

    return `
      <div class="dt-chat-card">
        <div class="dt-chat-header">
          <div class="dt-chat-title">${actorName}</div>
          <div class="dt-chat-subtitle">${this._getStandardRollSubtitle(type)}</div>
        </div>
        <div class="dt-chat-body">
          <div class="dt-chat-section">
            <div class="dt-chat-grid">
              <div class="dt-chat-line">
                <span class="dt-chat-small">${escapedLabel}</span><br>
                <span class="dt-chat-strong">${totalDice}d6</span>
              </div>
              <div class="dt-chat-line">
                <span class="dt-chat-small">Successes</span><br>
                <span class="dt-chat-strong">${Number(result.successes) || 0}</span>
              </div>
              ${totalDice <= 0 ? `
              <div class="dt-chat-line">
                <span class="dt-chat-small">Result</span><br>
                <span class="dt-chat-strong">Automatic Fail (0 dice)</span>
              </div>` : ""}
              ${options.poolData?.usesCombinedPool ? this._getSkillBreakdownHtml(options.poolData) : ((bonusDice > 0 || penaltyDice > 0 || pushPenaltyDice > 0) ? `
              <div class="dt-chat-line">
                <span class="dt-chat-small">Base Dice</span><br>
                <span class="dt-chat-strong">${baseDice}d6</span>
              </div>` : "")}
              ${bonusDice > 0 ? `
              <div class="dt-chat-line">
                <span class="dt-chat-small">${escapeDropTrooperHtml(options.bonusSource || "Bonus Dice")}</span><br>
                <span class="dt-chat-strong">+${bonusDice}d6</span>
              </div>` : ""}
              ${penaltyDice > 0 ? `
              <div class="dt-chat-line">
                <span class="dt-chat-small">${escapeDropTrooperHtml(options.penaltySource || "Penalty Dice")}</span><br>
                <span class="dt-chat-strong">-${penaltyDice}d6</span>
              </div>` : ""}
              ${pushPenaltyHtml}
              ${defenseMultiplier > 1 ? `
              <div class="dt-chat-line">
                <span class="dt-chat-small">${escapeDropTrooperHtml(options.defenseMultiplierSource || "Brace")}</span><br>
                <span class="dt-chat-strong">${preMultiplierDice}d6 × ${defenseMultiplier}</span>
              </div>` : ""}
              ${pushStatusHtml}
            </div>
            <div class="dt-chat-dice-row">${diceHtml}</div>
          </div>
          ${pushInfoHtml}
          ${pushFailureHtml}
          ${pushButtonHtml}
        </div>
      </div>
    `;
  }

  _formatMultiplier(multiplier) {
    if (Number.isInteger(multiplier)) return String(multiplier);
    return multiplier.toFixed(2).replace(/\.00$/, "");
  }

  async _showDice3D(formula) {
    if (!game?.dice3d) return;
    try {
      const roll = await new Roll(formula).evaluate();
      await game.dice3d.showForRoll(roll, game.user, true, null, false);
    } catch (err) {
      console.warn("Drop Trooper | Dice So Nice preview failed", err);
    }
  }

  async _rollVisibleDicePool(dicePool) {
    if (dicePool <= 0) {
      return {
        dieResults: [],
        successes: 0
      };
    }

    const roll = await new Roll(`${dicePool}d6`).evaluate();

    if (game?.dice3d) {
      try {
        await game.dice3d.showForRoll(roll, game.user, true, null, false);
      } catch (err) {
        console.warn("Drop Trooper | Dice So Nice visible roll failed", err);
      }
    }

    const dieResults = roll.dice[0]?.results?.map(r => r.result) ?? [];
    const successes = dieResults.filter(d => d === 6).length;

    return {
      dieResults,
      successes
    };
  }

  async _rollDicePool(dicePool) {
    if (dicePool <= 0) {
      return {
        dieResults: [],
        successes: 0
      };
    }

    const roll = await new Roll(`${dicePool}d6`).evaluate();
    const dieResults = roll.dice[0]?.results?.map(r => r.result) ?? [];
    const successes = dieResults.filter(d => d === 6).length;

    return {
      dieResults,
      successes
    };
  }

  async _rollDamageDice(diceCount) {
    if (diceCount <= 0) {
      return {
        dieResults: [],
        total: 0
      };
    }

    const roll = await new Roll(`${diceCount}d6`).evaluate();
    const dieResults = roll.dice[0]?.results?.map(r => r.result) ?? [];
    const total = dieResults.reduce((sum, d) => sum + d, 0);

    return {
      dieResults,
      total
    };
  }

  async _rollPool(label, dicePool, type = "skill", options = {}) {
    const baseDice = Number(options.baseDice ?? dicePool) || 0;
    const bonusDice = Number(options.bonusDice ?? 0) || 0;
    const penaltyDice = Number(options.penaltyDice ?? 0) || 0;
    const pushPenaltyDice = Number(options.pushPenaltyDice ?? 0) || 0;
    const defenseMultiplier = Number(options.defenseMultiplier ?? 1) || 1;
    const preMultiplierDice = Number(options.preMultiplierDice ?? Math.max(0, baseDice + bonusDice - penaltyDice - pushPenaltyDice)) || 0;
    const totalDice = Math.max(0, dicePool);
    const firstResult = await this._rollVisibleDicePool(totalDice);

    const canOfferChatPush = totalDice > 0
      && firstResult.successes <= 0
      && (type === "skill" || type === "attribute")
      && !!options.pushPenaltyKey;

    const pushButtonHtml = canOfferChatPush
      ? `
          <div class="dt-chat-section dt-push-roll-section">
            <button type="button" class="dt-request-roll-btn dt-push-roll-btn" style="background:#c62828;color:#ffffff;border:1px solid #8e1d1d;border-radius:6px;padding:4px 10px;font-weight:700;cursor:pointer;">Push</button>
          </div>`
      : "";

    const pushInfoHtml = canOfferChatPush
      ? `<div class="dt-chat-line"><span class="dt-chat-small">Push Available</span><br><span class="dt-chat-strong">Reroll this failed roll. A second failure adds -1 die to ${escapeDropTrooperHtml(options.pushPenaltyLabel || label)} until Refit.</span></div>`
      : "";

    const content = this._buildStandardRollChatCardHtml(label, type, {
      totalDice,
      baseDice,
      bonusDice,
      penaltyDice,
      pushPenaltyDice,
      pushPenaltySource: options.pushPenaltySource,
      defenseMultiplier,
      preMultiplierDice,
      defenseMultiplierSource: options.defenseMultiplierSource,
      result: firstResult,
      poolData: options.poolData,
      bonusSource: options.bonusSource,
      penaltySource: options.penaltySource,
      pushStatus: canOfferChatPush ? "available" : "",
      pushInfoHtml,
      pushButtonHtml
    });

    const chatData = {
      speaker: ChatMessage.getSpeaker({ actor: this.actor }),
      content
    };

    if (canOfferChatPush) {
      chatData.flags = {
        "drop-trooper": {
          pushRoll: {
            status: "pending",
            actorId: this.actor?.id || null,
            rollType: type,
            label,
            totalDice,
            baseDice,
            bonusDice,
            penaltyDice,
            pushPenaltyDice,
            pushPenaltySource: options.pushPenaltySource || "Push Penalty",
            pushPenaltyKey: options.pushPenaltyKey,
            pushPenaltyLabel: options.pushPenaltyLabel || label,
            poolData: options.poolData || null,
            bonusSource: options.bonusSource || "Bonus Dice",
            penaltySource: options.penaltySource || "Penalty Dice"
          }
        }
      };
    }

    await ChatMessage.create(chatData);

    if ((type === "skill" || type === "attribute") && firstResult.successes >= 3) {
      await playDropTrooperCritSuccessCelebration();
    }

    if (options.consumeBonus || options.consumePenalty) {
      await this._consumePendingRollModifiers(this.actor, { bonusDice, penaltyDice });
    }

    if (options.consumeBrace && defenseMultiplier > 1) {
      await this._consumePendingDefenseBrace(this.actor);
    }

    return {
      ...firstResult,
      pushed: false,
      pushDeclined: false,
      pushPenaltyApplied: false,
      appliedPushPenalty: null,
      pushAvailable: canOfferChatPush
    };
  }

  _getAttackOutcome(successes) {
    if (successes <= 0) return "Miss";
    if (successes === 1) return "Hit";
    if (successes === 2) return "Accurate Hit (+1 damage die)";
    if (successes === 3) return "Critical Hit (damage x2)";
    return "Epic Hit (damage x2 + epic effect)";
  }

  _getOutcomeClass(successes) {
    if (successes <= 0) return "miss";
    if (successes === 1 || successes === 2) return "hit";
    if (successes === 3) return "crit";
    return "epic";
  }

  _getAttackDamageModifiers(successes, baseDamage) {
    return DamageService.getAttackDamageModifiers(successes, baseDamage);
  }

  _getTierRank(tier) {
    return DamageService.getTierRank(tier);
  }

  _getTierMultiplier(weaponTier, armorTier) {
    return DamageService.getTierMultiplier(weaponTier, armorTier);
  }

  _getTierInteractionLabel(weaponTier, armorTier) {
    return DamageService.getTierInteractionLabel(weaponTier, armorTier);
  }

  _previewDamageApplication(targetActor, damage, options = {}) {
    const preview = DamageService.previewDamageApplication(targetActor, damage, options);
    return {
      ...preview,
      damageTargetLabel: getDropTrooperDamageTargetLabel(preview.damageTarget)
    };
  }

  async _ensureNoPendingGmApprovals(actionLabel = "action") {
    if (game.user?.isGM) return true;

    const pendingCount = getDropTrooperPendingApprovalCount(game.user?.id);
    const pendingLock = getDropTrooperPendingApprovalLock(game.user?.id);
    if (pendingCount <= 0 && !pendingLock) return true;

    ui.notifications.warn(`Finish the pending GM approval before starting another ${actionLabel}.`);
    return false;
  }

  async _runWithPendingGmApprovalLock(actionLabel = "action", callback = async () => true) {
    if (game.user?.isGM) {
      return callback();
    }

    const userId = game.user?.id;
    const acquired = await beginDropTrooperPendingApprovalWindow(userId, actionLabel);
    if (!acquired) return false;

    try {
      return callback();
    } finally {
      await releaseDropTrooperPendingApprovalWindow(userId);
    }
  }

  _buildGmDamageApprovalPayload(targetActor, damage, options = {}) {
    const preview = this._previewDamageApplication(targetActor, damage, options);
    const targetToken = options?.targetToken || getDropTrooperTokenDocumentFromActor(targetActor) || null;
    const targetTokenId = targetToken?.id || targetToken?._id || null;
    const targetSceneId = targetToken?.parent?.id || targetToken?.scene?.id || canvas?.scene?.id || null;
    const gmUser = getDropTrooperActiveGmUser();

    if (!targetTokenId || !targetSceneId) {
      return {
        preview,
        payload: null,
        error: "Drop Trooper: could not find the target token for GM damage approval."
      };
    }

    if (!gmUser) {
      return {
        preview,
        payload: null,
        error: "Drop Trooper: no active GM found to approve damage."
      };
    }

    return {
      preview,
      payload: {
        requestId: foundry.utils.randomID(),
        gmUserId: gmUser.id,
        requestedByUserId: game.user?.id || null,
        requestedByName: game.user?.name || "Player",
        sourceActorId: options?.sourceActor?.id || this.actor?.id || null,
        sourceActorName: options?.sourceActor?.name || this.actor?.name || game.user?.name || "Attacker",
        sourceTokenId: options?.sourceToken?.id || this.actor?.token?.id || null,
        weaponName: options?.weaponName || "Attack",
        attackLabel: options?.attackLabel || "Attack",
        sceneId: targetSceneId,
        tokenId: targetTokenId,
        actorId: targetActor?.id || null,
        targetName: targetToken?.name || targetActor?.name || "Target",
        damage: Math.max(0, Number(damage) || 0),
        damageTarget: preview.damageTarget,
        damageTargetLabel: preview.damageTargetLabel,
        integrityDamage: preview.integrityDamage,
        healthDamage: preview.healthDamage,
        newIntegrity: preview.newIntegrity,
        newHealth: preview.newHealth,
        tracksHealth: preview.tracksHealth,
        createdAt: Date.now(),
        status: "pending"
      },
      error: null
    };
  }

  async _flushDeferredGmApprovals(payloads = []) {
    if (!Array.isArray(payloads) || !payloads.length) return;

    for (const payload of payloads) {
      if (!payload) continue;
      await createDropTrooperGmDamageApprovalMessage(payload);
    }
  }

  async _queueDamageForGmApproval(targetActor, damage, options = {}) {
    const queuedApproval = this._buildGmDamageApprovalPayload(targetActor, damage, options);
    const preview = queuedApproval.preview;
    const payload = queuedApproval.payload;

    if (!payload) {
      ui.notifications.warn(queuedApproval.error || "Drop Trooper: could not queue GM damage approval.");
      return {
        ...preview,
        queued: false,
        pendingApproval: true,
        applyFailed: true,
        approvalPayload: null
      };
    }

    if (options?.deferApprovalMessage) {
      return {
        ...preview,
        queued: true,
        pendingApproval: true,
        applyFailed: false,
        approvalPayload: payload
      };
    }

    await createDropTrooperGmDamageApprovalMessage(payload);

    return {
      ...preview,
      queued: true,
      pendingApproval: true,
      applyFailed: false,
      approvalPayload: payload
    };
  }

  _buildGmCommandDiceApprovalPayload(targetActor, spendDice, options = {}) {
    const targetToken = targetActor?.getActiveTokens?.()[0] || null;
    const targetTokenId = options?.targetToken?.id || targetToken?.id || targetToken?.document?.id || null;
    const targetSceneId = options?.targetToken?.parent?.id || targetToken?.document?.parent?.id || canvas?.scene?.id || null;
    const gmUser = getDropTrooperActiveGmUser();
    const existingBonus = this._getPendingRollBonus(targetActor);
    const existingBonusDice = existingBonus?.dice || 0;
    const totalGrantedDice = existingBonusDice + (Math.max(0, Number(spendDice) || 0));
    const abilityName = options?.abilityName || "Command Dice";
    const existingSources = String(existingBonus?.source || "")
      .split("+")
      .map(part => part.trim())
      .filter(Boolean);
    const bonusSource = existingSources.includes(abilityName)
      ? existingSources.join(" + ") || abilityName
      : [...existingSources, abilityName].filter(Boolean).join(" + ") || abilityName;
    const preview = {
      queued: false,
      pendingApproval: false,
      applyFailed: false,
      approvalPayload: null,
      spendDice: Math.max(0, Number(spendDice) || 0),
      existingBonusDice,
      totalGrantedDice,
      bonusSource
    };

    if (!targetTokenId || !targetSceneId) {
      return {
        preview,
        payload: null,
        error: "Drop Trooper: could not find the targeted token for Command Dice approval."
      };
    }

    if (!gmUser) {
      return {
        preview,
        payload: null,
        error: "Drop Trooper: no active GM found to approve Command Dice."
      };
    }

    return {
      preview,
      payload: {
        requestType: "commandDice",
        requestId: foundry.utils.randomID(),
        gmUserId: gmUser.id,
        requestedByUserId: game.user?.id || null,
        requestedByName: game.user?.name || "Player",
        sourceActorId: options?.sourceActor?.id || this.actor?.id || null,
        sourceActorName: options?.sourceActor?.name || this.actor?.name || game.user?.name || "Attacker",
        sourceTokenId: options?.sourceToken?.id || this.actor?.token?.id || null,
        abilityItemId: options?.abilityItemId || null,
        abilityName,
        attackLabel: abilityName,
        weaponName: abilityName,
        sceneId: targetSceneId,
        tokenId: targetTokenId,
        actorId: targetActor?.id || null,
        targetName: options?.targetName || targetToken?.name || targetActor?.name || "Target",
        spendDice: Math.max(0, Number(spendDice) || 0),
        existingBonusDice,
        totalGrantedDice,
        bonusSource,
        createdAt: Date.now(),
        status: "pending"
      },
      error: null
    };
  }

  async _queueCommandDiceForGmApproval(targetActor, spendDice, options = {}) {
    const queuedApproval = this._buildGmCommandDiceApprovalPayload(targetActor, spendDice, options);
    const preview = queuedApproval.preview;
    const payload = queuedApproval.payload;

    if (!payload) {
      ui.notifications.warn(queuedApproval.error || "Drop Trooper: could not queue Command Dice approval.");
      return {
        ...preview,
        queued: false,
        pendingApproval: true,
        applyFailed: true,
        approvalPayload: null
      };
    }

    await createDropTrooperGmDamageApprovalMessage(payload);

    return {
      ...preview,
      queued: true,
      pendingApproval: true,
      applyFailed: false,
      approvalPayload: payload
    };
  }

  async _applyDamageToActor(targetActor, damage, options = {}) {
    const preview = this._previewDamageApplication(targetActor, damage, options);
    const canApplyDirectly = game.user?.isGM || targetActor?.isOwner === true;

    if (!canApplyDirectly) {
      return await this._queueDamageForGmApproval(targetActor, damage, options);
    }

    const updateData = {
      "system.armor.integrity.value": preview.newIntegrity
    };

    if (preview.tracksHealth) {
      updateData["system.health.value"] = preview.newHealth;
    }

    await targetActor.update(updateData);

    return {
      ...preview,
      queued: false,
      pendingApproval: false,
      applyFailed: false
    };
  }

  async _promptForCanvasPoint(message = "Click a point on the map.") {
    if (!canvas?.ready) {
      ui.notifications.warn("Canvas is not ready.");
      return null;
    }

    ui.notifications.info(message);

    return await new Promise((resolve) => {
      const stage = canvas.stage;

      stage.once("pointerdown", (event) => {
        const local = event.data.getLocalPosition(stage);
        resolve({ x: local.x, y: local.y });
      });
    });
  }

  async _createBlastTemplate(point, radius = 100, options = {}) {
    if (!canvas?.scene) return;

    const existingTemplates = canvas.templates.placeables;
    const existingIds = existingTemplates.map(t => t.id);

    if (existingIds.length > 0) {
      await canvas.scene.deleteEmbeddedDocuments("MeasuredTemplate", existingIds);
    }

    const blastTileTexture = String(options?.tileTexture ?? "").trim() || DROP_TROOPER_BLAST_TILE_TEXTURE;
    const blastSoundPath = String(options?.soundPath ?? "").trim() || DROP_TROOPER_BLAST_SOUND_PATH;

    const templateData = {
      t: "circle",
      user: game.user.id,
      x: point.x,
      y: point.y,
      direction: 0,
      distance: radius,
      fillColor: "#ff6600",
      flags: {
        "drop-trooper": {
          blastVisual: true,
          blastVisualData: {
            durationMs: DROP_TROOPER_BLAST_TILE_DURATION_MS,
            tileTexture: blastTileTexture
          }
        }
      }
    };

    playDropTrooperBlastSound(blastSoundPath).catch(err => {
      console.warn("Drop Trooper | Blast sound failed", err);
    });

    const createdTemplates = await canvas.scene.createEmbeddedDocuments("MeasuredTemplate", [templateData]);

    if (createdTemplates.length > 0) {
      const newTemplateId = createdTemplates[0].id;

      setTimeout(async () => {
        try {
          if (!canvas?.scene) return;

          const templateStillExists = canvas.templates.placeables.some(t => t.id === newTemplateId);

          if (templateStillExists) {
            await canvas.scene.deleteEmbeddedDocuments("MeasuredTemplate", [newTemplateId]);
          }
        } catch (err) {
          console.warn("Drop Trooper | Failed to auto-remove blast template", err);
        }
      }, 4000);
    }
  }

  async _createConeTemplate(origin, direction = 0, distance = 20, angle = 60, options = {}) {
    if (!canvas?.scene) return;

    const existingTemplates = canvas.templates.placeables;
    const existingIds = existingTemplates.map(t => t.id);

    if (existingIds.length > 0) {
      await canvas.scene.deleteEmbeddedDocuments("MeasuredTemplate", existingIds);
    }

    const normalizedDirection = this._normalizeDirection(direction);
    const coneTileTexture = String(options?.tileTexture ?? "").trim() || DROP_TROOPER_CONE_TILE_TEXTURE;
    const coneSoundPath = String(options?.soundPath ?? "").trim() || DROP_TROOPER_CONE_SOUND_PATH;

    const templateData = {
      t: "cone",
      user: game.user.id,
      x: origin.x,
      y: origin.y,
      direction: normalizedDirection,
      distance,
      angle,
      fillColor: coneTileTexture ? "#ffffff" : "#33cc88",
      flags: {
        "drop-trooper": {
          coneVisual: false,
          coneVisualData: {
            durationMs: DROP_TROOPER_CONE_TILE_DURATION_MS,
            tileTexture: coneTileTexture
          }
        }
      }
    };

    if (coneTileTexture) {
      templateData.texture = coneTileTexture;
    }

    if (coneSoundPath) {
      playDropTrooperConeSound(coneSoundPath).catch(err => {
        console.warn("Drop Trooper | Cone sound failed", err);
      });
    }

    const createdTemplates = await canvas.scene.createEmbeddedDocuments("MeasuredTemplate", [templateData]);

    if (createdTemplates.length > 0) {
      const newTemplateId = createdTemplates[0].id;

      setTimeout(async () => {
        try {
          if (!canvas?.scene) return;

          const templateStillExists = canvas.templates.placeables.some(t => t.id === newTemplateId);

          if (templateStillExists) {
            await canvas.scene.deleteEmbeddedDocuments("MeasuredTemplate", [newTemplateId]);
          }
        } catch (err) {
          console.warn("Drop Trooper | Failed to auto-remove cone template", err);
        }
      }, 4000);
    }
  }

  async _createSmokeTemplate(point, diameter = 30, durationRounds = 3) {
    if (!canvas?.scene) return null;

    const safeDiameter = Math.max(1, this._getNumericValue(diameter, 30));
    const safeDuration = Math.max(1, Math.floor(this._getNumericValue(durationRounds, 3)));
    const radius = safeDiameter / 2;
    const combatId = game.combat?.id || null;
    const createdRound = Number(game.combat?.round) || 0;
    const removeAtRound = combatId ? createdRound + safeDuration : null;

    const templateData = {
      t: "circle",
      user: game.user.id,
      x: point.x,
      y: point.y,
      direction: 0,
      distance: radius,
      fillColor: "#ffffff",
      borderColor: "#8e99a8",
      texture: "tokens/smoke.png",
      flags: {
        "drop-trooper": {
          smokeTemplate: true,
          smokeData: {
            diameter: safeDiameter,
            durationRounds: safeDuration,
            createdRound,
            removeAtRound,
            combatId
          }
        }
      }
    };

    const createdTemplates = await canvas.scene.createEmbeddedDocuments("MeasuredTemplate", [templateData]);
    return createdTemplates?.[0] || null;
  }

  async _removeExpiredSmokeTemplates(combat = game.combat) {
    if (!game.user?.isGM) return;
    if (!combat || !canvas?.scene) return;

    const currentRound = Number(combat.round) || 0;
    const templates = canvas.templates?.placeables || [];
    const expiredIds = [];

    for (const template of templates) {
      const smokeData = template.document?.getFlag("drop-trooper", "smokeData");
      if (!smokeData) continue;
      if (smokeData.combatId && smokeData.combatId !== combat.id) continue;

      const removeAtRound = Number(smokeData.removeAtRound);
      if (Number.isFinite(removeAtRound) && currentRound >= removeAtRound) {
        expiredIds.push(template.id);
      }
    }

    if (expiredIds.length > 0) {
      await canvas.scene.deleteEmbeddedDocuments("MeasuredTemplate", expiredIds);
    }
  }

  _getBlastZones(point, killRadius = 30, heavyRadius = 60, fragRadius = 100) {
    const zones = {
      kill: [],
      heavy: [],
      frag: []
    };

    for (const token of canvas.tokens.placeables) {
      if (!token.actor) continue;

      const distance = canvas.grid.measureDistance(point, token.center);

      if (distance <= killRadius) {
        zones.kill.push({ token, distance });
      } else if (distance <= heavyRadius) {
        zones.heavy.push({ token, distance });
      } else if (distance <= fragRadius) {
        zones.frag.push({ token, distance });
      }
    }

    return zones;
  }

  _getConeZones(sourceToken, direction, coneAngle = 60, killRange = 0, heavyRange = 0, fragRange = 0, coneRange = 0) {
    const zones = {
      kill: [],
      heavy: [],
      frag: []
    };

    const origin = sourceToken.center;
    const maxRange = Math.max(
      this._getNumericValue(coneRange, 0),
      this._getNumericValue(killRange, 0),
      this._getNumericValue(heavyRange, 0),
      this._getNumericValue(fragRange, 0)
    );

    if (maxRange <= 0) return zones;

    for (const token of canvas.tokens.placeables) {
      if (!token.actor) continue;
      if (token.id === sourceToken.id) continue;

      const distance = canvas.grid.measureDistance(origin, token.center);
      if (distance <= 0 || distance > maxRange) continue;

      const tokenDirection = this._getPointDirectionDegrees(origin, token.center);
      const angleDiff = this._getAngleDifference(direction, tokenDirection);

      if (angleDiff > coneAngle / 2) continue;

      if (killRange > 0 && distance <= killRange) {
        zones.kill.push({ token, distance });
      } else if (heavyRange > 0 && distance <= heavyRange) {
        zones.heavy.push({ token, distance });
      } else if (fragRange > 0 && distance <= fragRange) {
        zones.frag.push({ token, distance });
      }
    }

    return zones;
  }

  _formatBlastZoneList(entries) {
    if (!entries.length) {
      return `<div class="dt-chat-small">None</div>`;
    }

    return entries
      .map(entry => {
        return `
          <div class="dt-chat-line">
            <span class="dt-chat-strong">${entry.token.name}</span>
            <span class="dt-chat-small">(${Math.round(entry.distance)} ft)</span>
          </div>
        `;
      })
      .join("");
  }

  async _resolveBlastEntries(entries, zoneLabel, zoneDamageDice, weaponTier, approvalQueue = null, options = {}) {
    if (!entries.length) {
      return `
        <div class="dt-chat-section">
          <h4>${zoneLabel} Resolution</h4>
          <div class="dt-chat-small">No targets affected.</div>
        </div>
      `;
    }

    let html = `
      <div class="dt-chat-section">
        <h4>${zoneLabel} Resolution</h4>
    `;

    for (const entry of entries) {
      const targetToken = entry.token;
      const targetActor = targetToken.actor;

      if (!targetActor) continue;

      const preDefenseDamageDice = zoneDamageDice;
      const blastSourceToken = this.token?.document || this.actor?.token || null;
      const reactionDecision = await requestDropTrooperReactionDecision({
        reactionType: "incomingAttack",
        attackLabel: zoneLabel,
        weaponName: this.actor.system?.weapon?.name || "AOE Weapon",
        sourceActorId: this.actor?.id || null,
        sourceActorName: this.actor?.name || null,
        sourceTokenId: blastSourceToken?.id || null,
        targetActorId: targetActor?.id || null,
        targetActorName: targetActor?.name || null,
        targetTokenId: targetToken?.id || null
      });
      const targetResolution = await AttackWorkflowService.resolveTargetDamage({
        targetActor,
        targetToken,
        sourceActor: this.actor,
        sourceToken: blastSourceToken,
        weaponName: this.actor.system?.weapon?.name || "AOE Weapon",
        attackLabel: zoneLabel,
        weaponTier,
        damageTarget: normalizeDropTrooperWeaponDamageTarget(options?.damageTarget, "normal"),
        preDefenseDamageDice,
        attackMultiplier: 1,
        getDefenseData: actor => this._getAdjustedDefenseRollData(actor),
        rollDefense: pool => this._rollDicePool(pool),
        consumeDefense: (actor, defenseData) => this._consumePendingDefenseEffects(actor, defenseData),
        rollDamageDice: dice => this._rollDamageDice(dice),
        applyDamage: (actor, damage, applyOptions) => this._applyDamageToActor(actor, damage, applyOptions),
        deferApprovalMessage: Array.isArray(approvalQueue)
      });

      const beforeIntegrity = targetResolution.beforeIntegrity;
      const tracksHealth = targetResolution.tracksHealth;
      const beforeHealth = targetResolution.beforeHealth;
      const defenseData = targetResolution.defenseData;
      const defensePool = targetResolution.defensePool;
      const defenseResult = targetResolution.defenseResult;
      const cancelledDice = targetResolution.cancelledDice;
      const finalDamageDice = targetResolution.finalDamageDice;
      const damageRoll = targetResolution.damageRoll;
      const armorTier = targetResolution.armorTier;
      const tierMultiplier = targetResolution.tierMultiplier;
      const finalAppliedDamage = targetResolution.finalAppliedDamage;
      const applicationResult = targetResolution.applicationResult;

      if (Array.isArray(approvalQueue) && applicationResult.pendingApproval && applicationResult.approvalPayload) {
        approvalQueue.push(applicationResult.approvalPayload);
      }
      const reactionChoice = String(reactionDecision?.choice || "none");
      if (reactionChoice === "returnFire" && Array.isArray(options.collectReturnFireRequests)) {
        options.collectReturnFireRequests.push({
          actorId: targetActor?.id || null,
          sourceTokenId: targetToken?.id || null,
          targetTokenId: blastSourceToken?.id || null
        });
      }
      const reactionSummary = reactionChoice === "brace"
        ? "Brace"
        : (reactionChoice === "returnFire"
          ? "Return Fire"
          : "Return Fire spent, no shot");

      html += `
        <div class="dt-chat-line dt-chat-target-break">
          <span class="dt-chat-strong">${targetToken.name}</span>
          <span class="dt-chat-small">(${Math.round(entry.distance)} ft)</span>
        </div>

        <div class="dt-chat-grid dt-chat-grid--compact">
          <div class="dt-chat-line">
            <span class="dt-chat-small">Defense</span><br>
            <span class="dt-chat-strong">${defensePool}d6 → ${defenseResult.successes} success${defenseResult.successes === 1 ? "" : "es"}${defenseData.braceMultiplier > 1 ? ` • ${defenseData.pendingBrace?.source || "Brace"} x${defenseData.braceMultiplier}` : ""}</span>
          </div>
          <div class="dt-chat-line">
            <span class="dt-chat-small">Damage Dice</span><br>
            <span class="dt-chat-strong">${zoneDamageDice}d6 → ${finalDamageDice}d6</span>
          </div>
          <div class="dt-chat-line">
            <span class="dt-chat-small">Raw Damage</span><br>
            <span class="dt-chat-strong">${damageRoll.total}</span>
          </div>
          <div class="dt-chat-line">
            <span class="dt-chat-small">Armor</span><br>
            <span class="dt-chat-strong">${armorTier} (x${this._formatMultiplier(tierMultiplier)})</span>
          </div>
          <div class="dt-chat-line">
            <span class="dt-chat-small">${applicationResult.pendingApproval ? "Queued" : "Applied"}</span><br>
            <span class="dt-chat-final">${finalAppliedDamage}</span>
          </div>
        </div>

        ${applicationResult.pendingApproval ? `
        <div class="dt-chat-line dt-chat-line--compact">
          <span class="dt-chat-small">Status</span><br>
          <span class="dt-chat-strong">Waiting for GM approval</span>
        </div>` : ""}
        ${reactionChoice !== "none" ? `
        <div class="dt-chat-line dt-chat-line--compact">
          <span class="dt-chat-small">Reaction</span><br>
          <span class="dt-chat-strong">${escapeDropTrooperHtml(reactionSummary)}</span>
        </div>` : ""}

        <div class="dt-chat-grid dt-chat-grid--compact">
          <div class="dt-chat-line">
            <span class="dt-chat-small">Integrity</span><br>
            <span class="dt-chat-strong">${beforeIntegrity} → ${applicationResult.newIntegrity}</span>
          </div>
          ${tracksHealth ? `
          <div class="dt-chat-line">
            <span class="dt-chat-small">Health</span><br>
            <span class="dt-chat-strong">${beforeHealth} → ${applicationResult.newHealth}</span>
          </div>` : ""}
        </div>
      `;
    }

    html += `</div>`;
    return html;
  }

  async _onMicroMissileTest(event) {
    return await this._runWithPendingGmApprovalLock("AOE attack", async () => {

    const rollData = this._getAdjustedSkillAttackRollData("heavyWeapons", this.actor);
    const baseAttackPool = rollData.baseDice;
    const pendingBonus = rollData.pendingBonus;
    const pendingPenalty = rollData.pendingPenalty;
    const pendingAim = rollData.pendingAim;
    const bonusDice = rollData.bonusDice;
    const penaltyDice = rollData.penaltyDice;
    const aimDice = rollData.aimDice;
    const attackPool = rollData.totalDice;
    const attackPoolLabel = this._getSkillBreakdownText(rollData);
    const weaponTier = this.actor.system.weapon?.tier || "Medium";
    const damageTarget = normalizeDropTrooperWeaponDamageTarget(this.actor.system.weapon?.damageTarget, "normal");
    const weaponName = this.actor.system.weapon?.name || "AOE Weapon";

    const weaponData = this.actor.system.weapon ?? {};
    const blastRadius = weaponData.blastRadius === "" || weaponData.blastRadius === null || weaponData.blastRadius === undefined ? 100 : Number(weaponData.blastRadius);
    const killRadius = weaponData.killRadius === "" || weaponData.killRadius === null || weaponData.killRadius === undefined ? 30 : Number(weaponData.killRadius);
    const heavyRadius = weaponData.heavyRadius === "" || weaponData.heavyRadius === null || weaponData.heavyRadius === undefined ? 60 : Number(weaponData.heavyRadius);
    const fragRadius = weaponData.fragRadius === "" || weaponData.fragRadius === null || weaponData.fragRadius === undefined ? 100 : Number(weaponData.fragRadius);

    const killDamage = Number(this.actor.system.weapon?.killDamage) || 6;
    const heavyDamage = Number(this.actor.system.weapon?.heavyDamage) || 4;
    const fragDamage = Number(this.actor.system.weapon?.fragDamage) || 2;

    const point = await this._promptForCanvasPoint(`Click the ${weaponName} impact point on the map.`);
    if (!point) return false;

    const attackResult = await this._rollVisibleDicePool(finalAttackPool);
    if (bonusDice > 0 || penaltyDice > 0 || aimDice > 0) {
      await this._consumePendingAttackEffects(this.actor, rollData);
    }
    const attackDiceHtml = this._buildDiceHtml(attackResult.dieResults, true);
    const hit = attackResult.successes >= 1;

    let finalPoint = point;
    let attackResultText = "MISS";
    let attackNote = "Missed aim point. Scatter applied.";
    let scatterHtml = "";

    if (!hit) {
      const scatterDirectionRoll = await (new Roll("1d8")).evaluate();
      const scatterDistanceRoll = await (new Roll("1d10 * 5")).evaluate();

      const direction = scatterDirectionRoll.total;
      const distanceFeet = scatterDistanceRoll.total;

      const angleMap = {
        1: 270,
        2: 315,
        3: 0,
        4: 45,
        5: 90,
        6: 135,
        7: 180,
        8: 225
      };

      const angleDeg = angleMap[direction] ?? 0;
      const angleRad = angleDeg * (Math.PI / 180);

      const pixelsPerFoot = canvas.dimensions.size / canvas.dimensions.distance;
      const scatterPixels = distanceFeet * pixelsPerFoot;

      finalPoint = {
        x: point.x + Math.cos(angleRad) * scatterPixels,
        y: point.y + Math.sin(angleRad) * scatterPixels
      };

      scatterHtml = `
        <div class="dt-chat-section">
          <h4>Scatter</h4>
          <div class="dt-chat-grid">
            <div class="dt-chat-line">
              <span class="dt-chat-small">Direction</span><br>
              <span class="dt-chat-strong">${direction}</span>
            </div>
            <div class="dt-chat-line">
              <span class="dt-chat-small">Distance</span><br>
              <span class="dt-chat-strong">${distanceFeet} ft</span>
            </div>
          </div>
        </div>
      `;
    } else {
      attackResultText = "HIT";
      attackNote = "Hit aim point. Blast centered on clicked location.";
    }

    await this._createBlastTemplate(finalPoint, blastRadius, {
      soundPath: this.actor.system?.weapon?.blastSoundPath || DROP_TROOPER_BLAST_SOUND_PATH,
      tileTexture: this.actor.system?.weapon?.blastImagePath || DROP_TROOPER_BLAST_TILE_TEXTURE
    });

    const zones = this._getBlastZones(finalPoint, killRadius, heavyRadius, fragRadius);
    const gmApprovalQueue = [];
    const pendingReturnFireRequests = [];

    const killResolutionHtml = await this._resolveBlastEntries(zones.kill, "Kill Zone", killDamage, weaponTier, gmApprovalQueue, { damageTarget, collectReturnFireRequests: pendingReturnFireRequests });
    const heavyResolutionHtml = await this._resolveBlastEntries(zones.heavy, "Heavy Splash", heavyDamage, weaponTier, gmApprovalQueue, { damageTarget, collectReturnFireRequests: pendingReturnFireRequests });
    const fragResolutionHtml = await this._resolveBlastEntries(zones.frag, "Fragmentation", fragDamage, weaponTier, gmApprovalQueue, { damageTarget, collectReturnFireRequests: pendingReturnFireRequests });

    const content = `
      <div class="dt-chat-card">
        <div class="dt-chat-header">
          <div class="dt-chat-title">${this.actor.name}</div>
          <div class="dt-chat-subtitle">${weaponName}</div>
        </div>
        <div class="dt-chat-body">

          <div class="dt-chat-section">
            <h4>Attack Roll</h4>
            <div class="dt-chat-grid">
              <div class="dt-chat-line">
                <span class="dt-chat-small">Attack Pool</span><br>
                <span class="dt-chat-strong">${attackPool}d6</span>
              </div>
              <div class="dt-chat-line">
                <span class="dt-chat-small">Attack Dice</span><br>
                <span class="dt-chat-strong">${attackPoolLabel}</span>
              </div>
              <div class="dt-chat-line">
                <span class="dt-chat-small">Successes</span><br>
                <span class="dt-chat-strong">${attackResult.successes}</span>
              </div>
            </div>
            <div class="dt-chat-dice-row">${attackDiceHtml}</div>
            <div class="dt-chat-line dt-chat-line--compact">
              <span class="dt-chat-small">Result</span><br>
              <span class="dt-chat-strong">${attackResultText}</span>
            </div>
            <div class="dt-chat-line">
              <span class="dt-chat-small">Note</span><br>
              <span class="dt-chat-strong">${attackNote}</span>
            </div>
            <div class="dt-chat-line">
              <span class="dt-chat-small">Weapon Tier Used</span><br>
              <span class="dt-chat-strong">${weaponTier}</span>
            </div>
          </div>

          ${scatterHtml}

          <div class="dt-chat-section">
            <h4>Blast Zones</h4>
            <div class="dt-chat-line">
              <span class="dt-chat-small">Kill Zone</span><br>
              <span class="dt-chat-strong">0–${killRadius} ft</span>
            </div>
            ${this._formatBlastZoneList(zones.kill)}
          </div>

          <div class="dt-chat-section">
            <div class="dt-chat-line">
              <span class="dt-chat-small">Heavy Splash</span><br>
              <span class="dt-chat-strong">${killRadius}–${heavyRadius} ft</span>
            </div>
            ${this._formatBlastZoneList(zones.heavy)}
          </div>

          <div class="dt-chat-section">
            <div class="dt-chat-line">
              <span class="dt-chat-small">Fragmentation</span><br>
              <span class="dt-chat-strong">${heavyRadius}–${fragRadius} ft</span>
            </div>
            ${this._formatBlastZoneList(zones.frag)}
          </div>

          <div class="dt-chat-section">
            <h4>Zone Profile</h4>
            <div class="dt-chat-grid">
              <div class="dt-chat-line">
                <span class="dt-chat-small">Blast Radius</span><br>
                <span class="dt-chat-strong">${blastRadius} ft</span>
              </div>
              <div class="dt-chat-line">
                <span class="dt-chat-small">Kill Zone</span><br>
                <span class="dt-chat-strong">${killDamage}d6</span>
              </div>
              <div class="dt-chat-line">
                <span class="dt-chat-small">Heavy Splash</span><br>
                <span class="dt-chat-strong">${heavyDamage}d6</span>
              </div>
              <div class="dt-chat-line">
                <span class="dt-chat-small">Fragmentation</span><br>
                <span class="dt-chat-strong">${fragDamage}d6</span>
              </div>
            </div>
          </div>

          ${killResolutionHtml}
          ${heavyResolutionHtml}
          ${fragResolutionHtml}

        </div>
      </div>
    `;

    await ChatMessage.create({
      speaker: ChatMessage.getSpeaker({ actor: this.actor }),
      content
    });

    for (const pendingReturnFireRequest of pendingReturnFireRequests) {
      try {
        const returnFireResult = await requestDropTrooperReturnFire(pendingReturnFireRequest);
        if (!returnFireResult?.ok) {
          console.warn("Drop Trooper | Blast AOE Return Fire failed after attack card post", returnFireResult);
        }
      } catch (error) {
        console.error("Drop Trooper | Blast AOE Return Fire execution failed after attack card post", error);
      }
    }

    if (hit) {
      await playDropTrooperRandomHitSound();
    }

    if (options.consumeBonus && bonusDice > 0) {
      await this._consumePendingRollBonus(this.actor);
    }

    return true;
    });
  }

  async _onRollSkill(event) {
    const skillKey = event.currentTarget.dataset.skill;
    const poolData = this._getAdjustedSkillRollData(skillKey, this.actor);
    const label = this._getSkillLabel(skillKey) || "Skill";

    await this._rollPool(label, poolData.totalDice, "skill", {
      baseDice: poolData.baseDice,
      bonusDice: poolData.bonusDice,
      penaltyDice: poolData.penaltyDice,
      pushPenaltyDice: poolData.pushPenaltyDice,
      pushPenaltySource: poolData.pushPenalty?.source,
      bonusSource: poolData.pendingBonus?.source,
      penaltySource: poolData.pendingPenalty?.source,
      consumeBonus: poolData.bonusDice > 0,
      consumePenalty: poolData.penaltyDice > 0,
      pushPenaltyKey: skillKey,
      pushPenaltyLabel: label,
      poolData
    });
  }

  async _onRollAttribute(event) {
    const attributeKey = event.currentTarget.dataset.attribute;
    const label = this._getSkillLabel(attributeKey) || "Attribute";
    const rollData = this._getAdjustedRollData(Number(this.actor.system.attributes?.[attributeKey]) || 0, this.actor, {
      pushPenaltyKey: attributeKey,
      pushPenaltyLabel: label
    });

    await this._rollPool(label, rollData.totalDice, "attribute", {
      baseDice: rollData.baseDice,
      bonusDice: rollData.bonusDice,
      penaltyDice: rollData.penaltyDice,
      pushPenaltyDice: rollData.pushPenaltyDice,
      pushPenaltySource: rollData.pushPenalty?.source,
      bonusSource: rollData.pendingBonus?.source,
      penaltySource: rollData.pendingPenalty?.source,
      consumeBonus: rollData.bonusDice > 0,
      consumePenalty: rollData.penaltyDice > 0,
      pushPenaltyKey: attributeKey,
      pushPenaltyLabel: label
    });
  }

  _buildDirectAttackPushChatCardHtml(data = {}) {
    const actorName = escapeDropTrooperHtml(this.actor?.name || "Attacker");
    const targetName = escapeDropTrooperHtml(data.targetName || "Target");
    const headerSubtitle = escapeDropTrooperHtml(data.attackCardSubtitle || "Attack Workflow");
    const attackCardTag = escapeDropTrooperHtml(data.attackCardTag || "");
    const outcome = this._getAttackOutcome(Number(data.successes) || 0);
    const outcomeClass = this._getOutcomeClass(Number(data.successes) || 0);
    const attackDiceHtml = this._buildDiceHtml(Array.isArray(data.dieResults) ? data.dieResults : [], true);
    const shootPool = Math.max(0, Number(data.shootPool) || 0);
    const bonusDice = Math.max(0, Number(data.bonusDice) || 0);
    const penaltyDice = Math.max(0, Number(data.penaltyDice) || 0);
    const aimDice = Math.max(0, Number(data.aimDice) || 0);
    const pushPenaltyDice = Math.max(0, Number(data.pushPenaltyDice) || 0);
    const weaponName = escapeDropTrooperHtml(data.weaponName || "Weapon");
    const pushLabel = escapeDropTrooperHtml(data.pushPenaltyLabel || "Shooting");

    return `
      <div class="dt-chat-card">
        <div class="dt-chat-header">
          <div class="dt-chat-title">${actorName} → ${targetName}</div>
          <div class="dt-chat-subtitle">${headerSubtitle}</div>
        </div>
        <div class="dt-chat-body">
          <div class="dt-chat-section">
            <h4>Attack</h4>
            <div class="dt-chat-grid">
              <div class="dt-chat-line"><span class="dt-chat-small">Weapon</span><br><span class="dt-chat-strong">${weaponName}</span></div>
              <div class="dt-chat-line"><span class="dt-chat-small">Attack Pool</span><br><span class="dt-chat-strong">${shootPool}d6</span></div>
              <div class="dt-chat-line"><span class="dt-chat-small">Successes</span><br><span class="dt-chat-strong">${Number(data.successes) || 0}</span></div>
              ${shootPool <= 0 ? `<div class="dt-chat-line"><span class="dt-chat-small">Result</span><br><span class="dt-chat-strong">Automatic Miss (0 dice)</span></div>` : ""}
              ${bonusDice > 0 ? `<div class="dt-chat-line"><span class="dt-chat-small">${escapeDropTrooperHtml(data.bonusSource || "Bonus Dice")}</span><br><span class="dt-chat-strong">+${bonusDice}d6</span></div>` : ""}
              ${aimDice > 0 ? `<div class="dt-chat-line"><span class="dt-chat-small">${escapeDropTrooperHtml(data.aimSource || "Aim")}</span><br><span class="dt-chat-strong">+${aimDice}d6</span></div>` : ""}
              ${penaltyDice > 0 ? `<div class="dt-chat-line"><span class="dt-chat-small">${escapeDropTrooperHtml(data.penaltySource || "Penalty Dice")}</span><br><span class="dt-chat-strong">-${penaltyDice}d6</span></div>` : ""}
              ${pushPenaltyDice > 0 ? `<div class="dt-chat-line"><span class="dt-chat-small">${escapeDropTrooperHtml(data.pushPenaltySource || "Push Penalty")}</span><br><span class="dt-chat-strong">-${pushPenaltyDice}d6</span></div>` : ""}
              ${attackCardTag ? `<div class="dt-chat-line"><span class="dt-chat-small">Mode</span><br><span class="dt-chat-strong">${attackCardTag}</span></div>` : ""}
            </div>
            <div class="dt-chat-dice-row">${attackDiceHtml}</div>
            <div class="dt-chat-line dt-chat-line--compact">
              <span class="dt-chat-small">Outcome</span><br>
              <span class="dt-chat-outcome ${outcomeClass}">${outcome}</span>
            </div>
          </div>

          <div class="dt-chat-section dt-push-roll-section">
            <div class="dt-chat-line">
              <span class="dt-chat-small">Push Available</span><br>
              <span class="dt-chat-strong">Reroll this failed attack. A second failure adds -1 die to ${pushLabel} until Refit.</span>
            </div>
            <button type="button" class="dt-request-roll-btn dt-push-roll-btn" style="background:#c62828;color:#ffffff;border:1px solid #8e1d1d;border-radius:6px;padding:4px 10px;font-weight:700;cursor:pointer;">Push</button>
          </div>

          <div class="dt-chat-section">
            <h4>Result</h4>
            <div class="dt-chat-line"><span class="dt-chat-small">Damage</span><br><span class="dt-chat-strong">No damage rolled yet.</span></div>
          </div>
        </div>
      </div>
    `;
  }

_buildAoePushChatCardHtml(data = {}) {
  const actorName = escapeDropTrooperHtml(this.actor?.name || "Attacker");
  const weaponName = escapeDropTrooperHtml(data.weaponName || "AOE Weapon");
  const subtitle = escapeDropTrooperHtml(data.subtitle || "AOE Attack");
  const outcome = this._getAttackOutcome(Number(data.successes) || 0);
  const outcomeClass = this._getOutcomeClass(Number(data.successes) || 0);
  const attackDiceHtml = this._buildDiceHtml(Array.isArray(data.dieResults) ? data.dieResults : [], true);
  const attackPool = Math.max(0, Number(data.attackPool) || 0);
  const bonusDice = Math.max(0, Number(data.bonusDice) || 0);
  const penaltyDice = Math.max(0, Number(data.penaltyDice) || 0);
  const aimDice = Math.max(0, Number(data.aimDice) || 0);
  const pushPenaltyDice = Math.max(0, Number(data.pushPenaltyDice) || 0);
  const pushLabel = escapeDropTrooperHtml(data.pushPenaltyLabel || "Shooting");

  return `
    <div class="dt-chat-card">
      <div class="dt-chat-header">
        <div class="dt-chat-title">${actorName}</div>
        <div class="dt-chat-subtitle">${weaponName} — ${subtitle}</div>
      </div>
      <div class="dt-chat-body">
        <div class="dt-chat-section">
          <h4>Attack</h4>
          <div class="dt-chat-grid">
            <div class="dt-chat-line"><span class="dt-chat-small">Skill</span><br><span class="dt-chat-strong">${escapeDropTrooperHtml(data.skillLabel || data.skillKey || "Attack")}</span></div>
            <div class="dt-chat-line"><span class="dt-chat-small">Attack Pool</span><br><span class="dt-chat-strong">${attackPool}d6</span></div>
            <div class="dt-chat-line"><span class="dt-chat-small">Successes</span><br><span class="dt-chat-strong">${Number(data.successes) || 0}</span></div>
            ${attackPool <= 0 ? `<div class="dt-chat-line"><span class="dt-chat-small">Result</span><br><span class="dt-chat-strong">Automatic Miss (0 dice)</span></div>` : ""}
            ${bonusDice > 0 ? `<div class="dt-chat-line"><span class="dt-chat-small">${escapeDropTrooperHtml(data.bonusSource || "Bonus Dice")}</span><br><span class="dt-chat-strong">+${bonusDice}d6</span></div>` : ""}
            ${aimDice > 0 ? `<div class="dt-chat-line"><span class="dt-chat-small">${escapeDropTrooperHtml(data.aimSource || "Aim")}</span><br><span class="dt-chat-strong">+${aimDice}d6</span></div>` : ""}
            ${penaltyDice > 0 ? `<div class="dt-chat-line"><span class="dt-chat-small">${escapeDropTrooperHtml(data.penaltySource || "Penalty Dice")}</span><br><span class="dt-chat-strong">-${penaltyDice}d6</span></div>` : ""}
            ${pushPenaltyDice > 0 ? `<div class="dt-chat-line"><span class="dt-chat-small">${escapeDropTrooperHtml(data.pushPenaltySource || "Push Penalty")}</span><br><span class="dt-chat-strong">-${pushPenaltyDice}d6</span></div>` : ""}
          </div>
          <div class="dt-chat-dice-row">${attackDiceHtml}</div>
          <div class="dt-chat-line dt-chat-line--compact">
            <span class="dt-chat-small">Outcome</span><br>
            <span class="dt-chat-outcome ${outcomeClass}">${outcome}</span>
          </div>
        </div>

        <div class="dt-chat-section dt-push-roll-section">
          <div class="dt-chat-line">
            <span class="dt-chat-small">Push Available</span><br>
            <span class="dt-chat-strong">Push or decline before scatter, target resolution, GM queue, and FX continue. A second failure adds -1 die to ${pushLabel} until Refit.</span>
          </div>
          <div style="display:flex;gap:8px;flex-wrap:wrap;">
            <button type="button" class="dt-request-roll-btn dt-push-roll-btn" style="background:#c62828;color:#ffffff;border:1px solid #8e1d1d;border-radius:6px;padding:4px 10px;font-weight:700;cursor:pointer;">Push</button>
            <button type="button" class="dt-request-roll-btn dt-no-push-roll-btn" style="background:#444444;color:#ffffff;border:1px solid #222222;border-radius:6px;padding:4px 10px;font-weight:700;cursor:pointer;">No Push</button>
          </div>
        </div>

        <div class="dt-chat-section">
          <h4>Status</h4>
          <div class="dt-chat-line"><span class="dt-chat-small">Resolution</span><br><span class="dt-chat-strong">Waiting for Push / No Push choice before AOE resolves.</span></div>
        </div>
      </div>
    </div>
  `;
}

  async _resolveDirectAttackWorkflow(workflowData = {}) {
    const shootPool = Math.max(0, Number(workflowData.shootPool) || 0);
    const baseShootPool = Math.max(0, Number(workflowData.baseShootPool) || 0);
    const bonusDice = Math.max(0, Number(workflowData.bonusDice) || 0);
    const penaltyDice = Math.max(0, Number(workflowData.penaltyDice) || 0);
    const aimDice = Math.max(0, Number(workflowData.aimDice) || 0);
    const pushPenaltyDice = Math.max(0, Number(workflowData.pushPenaltyDice) || 0);
    const attackResult = workflowData.attackResult || { dieResults: [], successes: 0 };
    const baseDamage = Number(workflowData.baseDamage) || 0;
    const weaponName = workflowData.weaponName || "Weapon";
    const weaponTier = workflowData.weaponTier || "Medium";
    const damageTarget = normalizeDropTrooperWeaponDamageTarget(workflowData.damageTarget, "normal");
    const attackCardSubtitle = String(workflowData.attackCardSubtitle || "").trim() || "Attack Workflow";
    const attackCardTag = String(workflowData.attackCardTag || "").trim();
    const attackLabel = String(workflowData.attackLabel || "").trim() || (attackCardSubtitle === "Attack Workflow" ? "Direct Attack" : attackCardSubtitle);
    const pendingBonus = workflowData.pendingBonus || null;
    const pendingPenalty = workflowData.pendingPenalty || null;
    const pendingAim = workflowData.pendingAim || null;
    const rangeBandLabel = workflowData.rangeBandLabel || "Short";
    const rangePenaltyDice = Math.max(0, Number(workflowData.rangePenaltyDice) || 0);
    const rangeDistance = Math.max(0, Number(workflowData.rangeDistance) || 0);
    const targetLookup = getDropTrooperRequestedRollTarget(workflowData.targetSceneId, workflowData.targetTokenId, workflowData.targetActorId);
    const targetToken = targetLookup.token || null;
    const targetActor = targetLookup.actor || null;
    const sourceLookup = workflowData.sourceTokenId
      ? getDropTrooperRequestedRollTarget(workflowData.sceneId, workflowData.sourceTokenId, this.actor?.id)
      : null;
    const sourceToken = sourceLookup?.token || this._getActorTokenOnCanvas();

    if (!targetActor) {
      ui.notifications.warn("Target has no actor.");
      return false;
    }

    const attackDiceHtml = this._buildDiceHtml(attackResult.dieResults, true);
    const outcome = this._getAttackOutcome(attackResult.successes);
    const outcomeClass = this._getOutcomeClass(attackResult.successes);
    const effectWeapon = workflowData.weaponId
      ? this.actor?.items?.get?.(workflowData.weaponId) || null
      : null;
    const legacyWeapon = {
      name: weaponName,
      system: foundry.utils.deepClone(this.actor.system?.weapon || {})
    };
    const fxWeapon = effectWeapon || legacyWeapon;

    this._queueWeaponFireEffect(fxWeapon, {
      sourceToken,
      targetToken,
      stretchToTarget: true
    });

    let content = `
      <div class="dt-chat-card">
        <div class="dt-chat-header">
          <div class="dt-chat-title">${this.actor.name} → ${targetActor.name}</div>
          <div class="dt-chat-subtitle">${escapeDropTrooperHtml(attackCardSubtitle)}</div>
        </div>
        <div class="dt-chat-body">

          <div class="dt-chat-section">
            <h4>Attack</h4>
            <div class="dt-chat-grid">
              <div class="dt-chat-line"><span class="dt-chat-small">Attack Pool</span><br><span class="dt-chat-strong">${shootPool}d6</span></div>
              <div class="dt-chat-line"><span class="dt-chat-small">Successes</span><br><span class="dt-chat-strong">${attackResult.successes}</span></div>
              ${shootPool <= 0 ? `<div class="dt-chat-line"><span class="dt-chat-small">Result</span><br><span class="dt-chat-strong">Automatic Miss (0 dice)</span></div>` : ""}
              ${bonusDice > 0 ? `<div class="dt-chat-line"><span class="dt-chat-small">${escapeDropTrooperHtml(pendingBonus?.source || "Bonus Dice")}</span><br><span class="dt-chat-strong">+${bonusDice}d6</span></div>` : ""}
              ${aimDice > 0 ? `<div class="dt-chat-line"><span class="dt-chat-small">${escapeDropTrooperHtml(pendingAim?.source || "Aim")}</span><br><span class="dt-chat-strong">+${aimDice}d6</span></div>` : ""}
              ${penaltyDice > 0 ? `<div class="dt-chat-line"><span class="dt-chat-small">${escapeDropTrooperHtml(pendingPenalty?.source || "Penalty Dice")}</span><br><span class="dt-chat-strong">-${penaltyDice}d6</span></div>` : ""}
              <div class="dt-chat-line"><span class="dt-chat-small">Range</span><br><span class="dt-chat-strong">${escapeDropTrooperHtml(rangeBandLabel)} (${Math.round(rangeDistance)} ft)</span></div>
              ${rangePenaltyDice > 0 ? `<div class="dt-chat-line"><span class="dt-chat-small">Range Penalty</span><br><span class="dt-chat-strong">-${rangePenaltyDice}d6</span></div>` : ""}
              ${pushPenaltyDice > 0 ? `<div class="dt-chat-line"><span class="dt-chat-small">${escapeDropTrooperHtml(workflowData.pushPenaltySource || "Push Penalty")}</span><br><span class="dt-chat-strong">-${pushPenaltyDice}d6</span></div>` : ""}
              ${workflowData.pushUsed ? `<div class="dt-chat-line"><span class="dt-chat-small">Push</span><br><span class="dt-chat-strong">Used</span></div>` : ""}
              ${attackCardTag ? `<div class="dt-chat-line"><span class="dt-chat-small">Mode</span><br><span class="dt-chat-strong">${escapeDropTrooperHtml(attackCardTag)}</span></div>` : ""}
            </div>
            <div class="dt-chat-dice-row">${attackDiceHtml}</div>
            <div class="dt-chat-line dt-chat-line--compact">
              <span class="dt-chat-small">Outcome</span><br>
              <span class="dt-chat-outcome ${outcomeClass}">${outcome}</span>
            </div>
          </div>
    `;

    const reactionDecision = await requestDropTrooperReactionDecision({
      reactionType: "incomingAttack",
      attackLabel: workflowData.pushUsed ? `${attackLabel} (Pushed)` : attackLabel,
      weaponName,
      sourceActorId: this.actor?.id || null,
      sourceActorName: this.actor?.name || null,
      sourceTokenId: sourceToken?.id || null,
      targetActorId: targetActor?.id || null,
      targetActorName: targetActor?.name || null,
      targetTokenId: targetToken?.id || null
    });
    const reactionChoice = String(reactionDecision?.choice || "none");
    let pendingReturnFireRequest = reactionChoice === "returnFire"
      ? {
          actorId: targetActor?.id || null,
          sourceTokenId: targetToken?.id || null,
          targetTokenId: sourceToken?.id || null
        }
      : null;
    if (attackResult.successes >= 1) {
      const attackMods = this._getAttackDamageModifiers(attackResult.successes, baseDamage);
      const preDefenseDamageDice = attackMods.damageDice;

      const targetResolution = await AttackWorkflowService.resolveTargetDamage({
        targetActor,
        targetToken,
        sourceActor: this.actor,
        sourceToken,
        weaponName,
        attackLabel: workflowData.pushUsed ? `${attackLabel} (Pushed)` : attackLabel,
        weaponTier,
        damageTarget,
        preDefenseDamageDice,
        attackMultiplier: attackMods.multiplier,
        getDefenseData: actor => this._getAdjustedDefenseRollData(actor),
        rollDefense: pool => this._rollDicePool(pool),
        consumeDefense: (actor, defenseData) => this._consumePendingDefenseEffects(actor, defenseData),
        rollDamageDice: dice => this._rollDamageDice(dice),
        applyDamage: (actor, damage, applyOptions) => this._applyDamageToActor(actor, damage, applyOptions)
      });
      const defenseData = targetResolution.defenseData;
      const defensePool = targetResolution.defensePool;
      const defenseResult = targetResolution.defenseResult;
      const defenseDiceHtml = this._buildDiceHtml(defenseResult.dieResults, true);
      const cancelledDice = targetResolution.cancelledDice;
      const finalDamageDice = targetResolution.finalDamageDice;
      const damageRoll = targetResolution.damageRoll;
      const damageDiceHtml = this._buildDiceHtml(damageRoll.dieResults, false);
      const armorTier = targetResolution.armorTier;
      const tierMultiplier = targetResolution.tierMultiplier;
      const tierLabel = targetResolution.tierLabel;
      const scaledDamage = targetResolution.finalAppliedDamage;
      const applicationResult = targetResolution.applicationResult;

      const reactionSummary = reactionChoice === "brace"
        ? "Brace"
        : (reactionChoice === "returnFire"
          ? "Return Fire"
          : "Return Fire spent, no shot");

      content += `
          <div class="dt-chat-section">
            <h4>Defense</h4>
            <div class="dt-chat-grid">
              <div class="dt-chat-line"><span class="dt-chat-small">Defense Pool</span><br><span class="dt-chat-strong">${defensePool}d6</span></div>
              <div class="dt-chat-line"><span class="dt-chat-small">Dice Cancelled</span><br><span class="dt-chat-strong">${cancelledDice}</span></div>
              ${defenseData.braceMultiplier > 1 ? `<div class="dt-chat-line"><span class="dt-chat-small">${escapeDropTrooperHtml(defenseData.pendingBrace?.source || "Brace")}</span><br><span class="dt-chat-strong">x${defenseData.braceMultiplier}</span></div>` : ""}
            </div>
            <div class="dt-chat-dice-row">${defenseDiceHtml}</div>
            <div class="dt-chat-line dt-chat-line--compact"><span class="dt-chat-small">Defense Successes</span><br><span class="dt-chat-strong">${defenseResult.successes}</span></div>
          </div>

          <div class="dt-chat-section">
            <h4>Damage</h4>
            <div class="dt-chat-grid">
              <div class="dt-chat-line"><span class="dt-chat-small">Weapon</span><br><span class="dt-chat-strong">${escapeDropTrooperHtml(weaponName)}</span></div>
              <div class="dt-chat-line"><span class="dt-chat-small">Damage Type</span><br><span class="dt-chat-strong">${escapeDropTrooperHtml(getDropTrooperDamageTargetLabel(damageTarget))}</span></div>
              <div class="dt-chat-line"><span class="dt-chat-small">Base Damage</span><br><span class="dt-chat-strong">${baseDamage}d6</span></div>
              <div class="dt-chat-line"><span class="dt-chat-small">Pre-Defense Dice</span><br><span class="dt-chat-strong">${preDefenseDamageDice}d6</span></div>
              <div class="dt-chat-line"><span class="dt-chat-small">Final Damage Dice</span><br><span class="dt-chat-strong">${finalDamageDice}d6</span></div>
            </div>
            <div class="dt-chat-dice-row">${damageDiceHtml}</div>
            <div class="dt-chat-grid dt-chat-grid--compact">
              <div class="dt-chat-line"><span class="dt-chat-small">Raw Damage</span><br><span class="dt-chat-strong">${damageRoll.total}</span></div>
              <div class="dt-chat-line"><span class="dt-chat-small">Attack Multiplier</span><br><span class="dt-chat-strong">x${attackMods.multiplier}</span></div>
            </div>
          </div>

          <div class="dt-chat-section">
            <h4>Tier Interaction</h4>
            <div class="dt-chat-grid">
              <div class="dt-chat-line"><span class="dt-chat-small">Weapon Tier</span><br><span class="dt-chat-strong">${escapeDropTrooperHtml(weaponTier)}</span></div>
              <div class="dt-chat-line"><span class="dt-chat-small">Armor Tier</span><br><span class="dt-chat-strong">${escapeDropTrooperHtml(armorTier)}</span></div>
            </div>
            <div class="dt-chat-line dt-chat-line--compact"><span class="dt-chat-small">Result</span><br><span class="dt-chat-strong">${escapeDropTrooperHtml(tierLabel)}</span></div>
            <div class="dt-chat-line"><span class="dt-chat-small">Tier Multiplier</span><br><span class="dt-chat-strong">${this._formatMultiplier(tierMultiplier)}</span></div>
          </div>

          <div class="dt-chat-section">
            <h4>Applied Damage</h4>
            <div class="dt-chat-line"><span class="dt-chat-small">${applicationResult.pendingApproval ? "Queued Damage" : "Final Applied Damage"}</span><br><span class="dt-chat-final">${scaledDamage}</span></div>
            ${applicationResult.pendingApproval ? `<div class="dt-chat-line dt-chat-line--compact"><span class="dt-chat-small">Status</span><br><span class="dt-chat-strong">Waiting for GM approval</span></div>` : ""}
            ${reactionChoice !== "none" ? `<div class="dt-chat-line dt-chat-line--compact"><span class="dt-chat-small">Reaction</span><br><span class="dt-chat-strong">${escapeDropTrooperHtml(reactionSummary)}</span></div>` : ""}
            <div class="dt-chat-grid dt-chat-grid--compact">
              <div class="dt-chat-line"><span class="dt-chat-small">Integrity Damage</span><br><span class="dt-chat-strong">${applicationResult.integrityDamage}</span></div>
              ${applicationResult.tracksHealth ? `<div class="dt-chat-line"><span class="dt-chat-small">Health Damage</span><br><span class="dt-chat-strong">${applicationResult.healthDamage}</span></div>` : ""}
              <div class="dt-chat-line"><span class="dt-chat-small">Remaining Integrity</span><br><span class="dt-chat-strong">${applicationResult.newIntegrity}</span></div>
              ${applicationResult.tracksHealth ? `<div class="dt-chat-line"><span class="dt-chat-small">Remaining Health</span><br><span class="dt-chat-strong">${applicationResult.newHealth}</span></div>` : ""}
            </div>
          </div>
      `;
    } else {
      content += `
          <div class="dt-chat-section">
            <h4>Result</h4>
            <div class="dt-chat-line"><span class="dt-chat-small">Damage</span><br><span class="dt-chat-strong">No damage rolled.</span></div>
            ${reactionChoice !== "none" ? `<div class="dt-chat-line dt-chat-line--compact"><span class="dt-chat-small">Reaction</span><br><span class="dt-chat-strong">${escapeDropTrooperHtml(reactionChoice === "brace" ? "Brace" : "Return Fire")}</span></div>` : ""}
            ${workflowData.pushPenaltyApplied && workflowData.appliedPushPenalty ? `<div class="dt-chat-line dt-chat-line--compact"><span class="dt-chat-small">Push Penalty</span><br><span class="dt-chat-strong">-${Math.max(0, Number(workflowData.appliedPushPenalty.dice) || 0)}d6 to ${escapeDropTrooperHtml(workflowData.appliedPushPenalty.label || workflowData.pushPenaltyLabel || "Skill")} until Refit</span></div>` : ""}
          </div>
      `;
    }

    content += `
        </div>
      </div>
    `;

    await ChatMessage.create({
      speaker: ChatMessage.getSpeaker({ actor: this.actor }),
      content
    });

    if (pendingReturnFireRequest) {
      try {
        const returnFireResult = await requestDropTrooperReturnFire(pendingReturnFireRequest);
        if (!returnFireResult?.ok) {
          console.warn("Drop Trooper | Return Fire failed after attack card post", returnFireResult);
        }
      } catch (error) {
        console.error("Drop Trooper | Return Fire execution failed after attack card post", error);
      }
    }

    if (attackResult.successes >= 3) {
      await playDropTrooperCritSuccessCelebration();
    } else if (attackResult.successes >= 1) {
      await playDropTrooperRandomHitSound();
    }

    return true;
  }

  async _onRollShoot(event) {
    return await this._runWithPendingGmApprovalLock("attack", async () => {

    const rollData = this._getAdjustedSkillAttackRollData("shooting", this.actor);
    const baseShootPool = rollData.baseDice;
    const pendingBonus = rollData.pendingBonus;
    const pendingPenalty = rollData.pendingPenalty;
    const pendingAim = rollData.pendingAim;
    const bonusDice = rollData.bonusDice;
    const penaltyDice = rollData.penaltyDice;
    const aimDice = rollData.aimDice;
    const shootPool = rollData.totalDice;
    const pushPenaltyDice = rollData.pushPenaltyDice;

    const baseDamage = Number(this.actor.system.weapon?.baseDamage) || 0;
    const weaponName = this.actor.system.weapon?.name || "Weapon";
    const weaponTier = this.actor.system.weapon?.tier || "Medium";

    if (baseDamage <= 0) {
      ui.notifications.warn("Base Damage Dice must be at least 1.");
      return;
    }

    const targets = Array.from(game.user.targets);

    if (targets.length === 0) {
      ui.notifications.warn("No target selected.");
      return;
    }

    const targetToken = targets[0];
    const targetActor = targetToken.actor;
    const sourceToken = this._getActorTokenOnCanvas();

    if (!targetActor) {
      ui.notifications.warn("Target has no actor.");
      return;
    }

    const attackResult = await this._rollVisibleDicePool(shootPool);
    if (bonusDice > 0 || penaltyDice > 0 || aimDice > 0) {
      await this._consumePendingAttackEffects(this.actor, rollData);
    }

    const canOfferChatPush = shootPool > 0 && attackResult.successes <= 0;

    if (canOfferChatPush) {
      await ChatMessage.create({
        speaker: ChatMessage.getSpeaker({ actor: this.actor }),
        content: this._buildDirectAttackPushChatCardHtml({
          targetName: targetActor.name,
          weaponName,
          shootPool,
          successes: attackResult.successes,
          dieResults: attackResult.dieResults,
          bonusDice,
          penaltyDice,
          aimDice,
          pushPenaltyDice,
          pushPenaltySource: rollData.pushPenalty?.source || "Push Penalty",
          bonusSource: pendingBonus?.source || "Bonus Dice",
          penaltySource: pendingPenalty?.source || "Penalty Dice",
          aimSource: pendingAim?.source || "Aim",
          pushPenaltyLabel: rollData.skillLabel || this._getSkillLabel("shooting") || "Shooting"
        }),
        flags: {
          "drop-trooper": {
            pushRoll: {
              status: "pending",
              actorId: this.actor?.id || null,
              rollType: "attack",
              label: `${weaponName} ${attackLabel}`,
              totalDice: shootPool,
              baseDice: baseShootPool,
              bonusDice,
              penaltyDice,
              aimDice,
              pushPenaltyDice,
              pushPenaltySource: rollData.pushPenalty?.source || "Push Penalty",
              pushPenaltyKey: "shooting",
              pushPenaltyLabel: rollData.skillLabel || this._getSkillLabel("shooting") || "Shooting",
              bonusSource: pendingBonus?.source || "Bonus Dice",
              penaltySource: pendingPenalty?.source || "Penalty Dice",
              aimSource: pendingAim?.source || "Aim",
              baseDamage,
              weaponName,
              weaponTier,
              damageTarget,
              sceneId: canvas?.scene?.id || null,
              sourceTokenId: sourceToken?.id || null,
              targetSceneId: canvas?.scene?.id || null,
              targetTokenId: targetToken?.id || null,
              targetActorId: targetActor?.id || null,
              attackCardSubtitle,
              attackCardTag,
              attackLabel
            }
          }
        }
      });
      return true;
    }

    return await this._resolveDirectAttackWorkflow({
      attackResult,
      shootPool,
      baseShootPool,
      bonusDice,
      penaltyDice,
      aimDice,
      pushPenaltyDice,
      pushPenaltySource: rollData.pushPenalty?.source || "Push Penalty",
      pendingBonus,
      pendingPenalty,
      pendingAim,
      baseDamage,
      weaponName,
      weaponTier,
      damageTarget,
      sceneId: canvas?.scene?.id || null,
      sourceTokenId: sourceToken?.id || null,
      targetSceneId: canvas?.scene?.id || null,
      targetTokenId: targetToken?.id || null,
      targetActorId: targetActor?.id || null
    });
    });
  }

  async _onWeaponAttack(event) {
    event.preventDefault();

    const itemId = event.currentTarget.dataset.itemId;
    const weapon = this.actor.items.get(itemId);

    if (!weapon) {
      ui.notifications.warn("Weapon not found.");
      return;
    }

    const outOfArmorWeaponLock = getDropTrooperOutOfArmorWeaponLock(this.actor, weapon);
    if (outOfArmorWeaponLock.blocked) {
      ui.notifications.warn(outOfArmorWeaponLock.reason);
      return;
    }

    if (weapon.system?.aoeEnabled) {
      await this._onWeaponAoeAttack(weapon);
      return;
    }

    await this._onWeaponSingleAttack(weapon);
  }

  async _onWeaponSingleAttack(weapon, options = {}) {
    return await this._runWithPendingGmApprovalLock("attack", async () => {

    const skillKey = weapon.system?.skill || "shooting";
    const rollData = this._getAdjustedSkillAttackRollData(skillKey, this.actor);
    const baseAttackPool = rollData.baseDice;
    const pendingBonus = rollData.pendingBonus;
    const pendingPenalty = rollData.pendingPenalty;
    const pendingAim = rollData.pendingAim;
    const bonusDice = rollData.bonusDice;
    const penaltyDice = rollData.penaltyDice;
    const aimDice = rollData.aimDice;
    const attackPool = rollData.totalDice;
    const pushPenaltyDice = rollData.pushPenaltyDice;
    const baseDamage = Number(weapon.system?.baseDamage) || 0;
    const weaponName = weapon.name || "Weapon";
    const weaponTier = weapon.system?.tier || "Medium";
    const damageTarget = normalizeDropTrooperWeaponDamageTarget(weapon.system?.damageTarget, "normal");
    const attackCardSubtitle = String(options?.attackCardSubtitle || "").trim() || "Attack Workflow";
    const attackCardTag = String(options?.attackCardTag || "").trim();
    const attackLabel = String(options?.attackLabel || "").trim() || (attackCardSubtitle === "Attack Workflow" ? "Direct Attack" : attackCardSubtitle);

    const ammoState = this._getWeaponAmmoState(weapon);

    if (!this._validateWeaponAmmoState(weapon, ammoState)) return;

    if (baseDamage <= 0) {
      ui.notifications.warn(`${weaponName}: base damage dice must be at least 1.`);
      return;
    }

    const explicitTargetToken = options?.targetToken
      ? (options.targetToken.object || canvas?.tokens?.get(options.targetToken.id) || options.targetToken)
      : null;
    const targets = explicitTargetToken ? [explicitTargetToken] : Array.from(game.user.targets);

    if (targets.length === 0) {
      ui.notifications.warn(`No target selected for ${weaponName}.`);
      return;
    }

    const targetToken = targets[0];
    const targetActor = targetToken.actor;
    const sourceToken = this._getActorTokenOnCanvas();

    if (!targetActor) {
      ui.notifications.warn("Target has no actor.");
      return;
    }

    const rangeData = this._getAttackRangePenaltyData({
      weaponData: weapon.system || {},
      sourceToken,
      targetToken
    });
    if (rangeData.outOfRange) {
      ui.notifications.warn(`${weaponName} is out of range (${Math.round(rangeData.distance)} ft > ${rangeData.longRange} ft).`);
      return;
    }

    const finalAttackPool = Math.max(0, attackPool - Math.max(0, Number(rangeData.penaltyDice) || 0));

    if (ammoState.usesAmmo) {
      if (ammoState.ammo <= 0) {
        ui.notifications.warn(`${weaponName} is out of ammo.`);
        return;
      }

      await weapon.update({
        "system.ammo": ammoState.ammo - 1
      });
    }

    const attackResult = await this._rollVisibleDicePool(attackPool);
    if (bonusDice > 0 || penaltyDice > 0 || aimDice > 0) {
      await this._consumePendingAttackEffects(this.actor, rollData);
    }

    const canOfferChatPush = finalAttackPool > 0 && attackResult.successes <= 0;

    if (canOfferChatPush) {
      await ChatMessage.create({
        speaker: ChatMessage.getSpeaker({ actor: this.actor }),
        content: this._buildDirectAttackPushChatCardHtml({
          targetName: targetActor.name,
          weaponName,
          shootPool: finalAttackPool,
          successes: attackResult.successes,
          dieResults: attackResult.dieResults,
          bonusDice,
          penaltyDice,
          aimDice,
          pushPenaltyDice,
          pushPenaltySource: rollData.pushPenalty?.source || "Push Penalty",
          bonusSource: pendingBonus?.source || "Bonus Dice",
          penaltySource: pendingPenalty?.source || "Penalty Dice",
          aimSource: pendingAim?.source || "Aim",
          pushPenaltyLabel: rollData.skillLabel || this._getSkillLabel(skillKey) || skillKey,
          attackCardSubtitle,
          attackCardTag
        }),
        flags: {
          "drop-trooper": {
            pushRoll: {
              status: "pending",
              actorId: this.actor?.id || null,
              rollType: "attack",
              label: `${weaponName} ${attackLabel}`,
              totalDice: finalAttackPool,
              baseDice: baseAttackPool,
              bonusDice,
              penaltyDice,
              aimDice,
              pushPenaltyDice,
              pushPenaltySource: rollData.pushPenalty?.source || "Push Penalty",
              pushPenaltyKey: skillKey,
              pushPenaltyLabel: rollData.skillLabel || this._getSkillLabel(skillKey) || skillKey,
              bonusSource: pendingBonus?.source || "Bonus Dice",
              penaltySource: pendingPenalty?.source || "Penalty Dice",
              aimSource: pendingAim?.source || "Aim",
              baseDamage,
              weaponName,
              weaponTier,
              damageTarget,
              rangeBandLabel: rangeData.bandLabel,
              rangePenaltyDice: rangeData.penaltyDice,
              rangeDistance: rangeData.distance,
              rangeShort: rangeData.shortRange,
              rangeMedium: rangeData.mediumRange,
              rangeLong: rangeData.longRange,
              weaponId: weapon?.id || null,
              sceneId: canvas?.scene?.id || null,
              sourceTokenId: sourceToken?.id || null,
              targetSceneId: canvas?.scene?.id || null,
              targetTokenId: targetToken?.id || null,
              targetActorId: targetActor?.id || null,
              attackCardSubtitle,
              attackCardTag,
              attackLabel
            }
          }
        }
      });
      return true;
    }

    return await this._resolveDirectAttackWorkflow({
      attackResult,
      shootPool: finalAttackPool,
      baseShootPool: baseAttackPool,
      bonusDice,
      penaltyDice,
      aimDice,
      pushPenaltyDice,
      pushPenaltySource: rollData.pushPenalty?.source || "Push Penalty",
      pendingBonus,
      pendingPenalty,
      pendingAim,
      baseDamage,
      weaponName,
      weaponTier,
      damageTarget,
      attackCardSubtitle,
      attackCardTag,
      attackLabel,
      rangeBandLabel: rangeData.bandLabel,
      rangePenaltyDice: rangeData.penaltyDice,
      rangeDistance: rangeData.distance,
      rangeShort: rangeData.shortRange,
      rangeMedium: rangeData.mediumRange,
      rangeLong: rangeData.longRange,
      weaponId: weapon?.id || null,
      sceneId: canvas?.scene?.id || null,
      sourceTokenId: sourceToken?.id || null,
      targetSceneId: canvas?.scene?.id || null,
      targetTokenId: targetToken?.id || null,
      targetActorId: targetActor?.id || null,
      pushUsed: false,
      pushPenaltyApplied: false,
      appliedPushPenalty: null,
      pushPenaltyLabel: rollData.skillLabel || this._getSkillLabel(skillKey) || skillKey
    });
    });
  }
  async _onWeaponAoeAttack(weapon) {
    if (this._isSmokeWeapon(weapon)) {
      await this._onWeaponSmokeAttack(weapon);
      return;
    }

    const aoeType = this._getAoeType(weapon.system);

    if (aoeType === "cone") {
      await this._onWeaponConeAttack(weapon);
      return;
    }

    await this._onWeaponBlastAttack(weapon);
  }

  async _onWeaponSmokeAttack(weapon) {
    const skillKey = weapon.system?.skill || "heavyWeapons";
    const rollData = this._getAdjustedSkillAttackRollData(skillKey, this.actor);
    const baseAttackPool = rollData.baseDice;
    const pendingBonus = rollData.pendingBonus;
    const pendingPenalty = rollData.pendingPenalty;
    const pendingAim = rollData.pendingAim;
    const bonusDice = rollData.bonusDice;
    const penaltyDice = rollData.penaltyDice;
    const aimDice = rollData.aimDice;
    const attackPool = rollData.totalDice;
    const weaponName = weapon.name || "Smoke Grenade";
    const ammoState = this._getWeaponAmmoState(weapon);

    if (!this._validateWeaponAmmoState(weapon, ammoState)) return;

    if (ammoState.usesAmmo && ammoState.ammo <= 0) {
      ui.notifications.warn(`${weaponName} is out of ammo.`);
      return;
    }

    const smokeDiameter = Math.max(1, this._getNumericValue(weapon.system?.smokeDiameter, 30));
    const smokeDurationRounds = Math.max(1, Math.floor(this._getNumericValue(weapon.system?.smokeDurationRounds, 3)));

    const point = await this._promptForCanvasPoint(`Click the ${weaponName} landing point on the map.`);
    if (!point) return;

    const attackResult = await this._rollVisibleDicePool(attackPool);
    await this._consumePendingAttackEffects(this.actor, rollData);

    const attackDiceHtml = this._buildDiceHtml(attackResult.dieResults, true);
    const hit = attackResult.successes >= 1;

    let finalPoint = point;
    let attackResultText = "MISS";
    let attackNote = "Missed aim point. Smoke scatters from the selected point.";
    let scatterHtml = "";

    if (!hit) {
      const scatterDirectionRoll = await (new Roll("1d8")).evaluate();
      const scatterDistanceRoll = await (new Roll("1d10 * 5")).evaluate();

      const direction = scatterDirectionRoll.total;
      const distanceFeet = scatterDistanceRoll.total;

      const angleMap = {
        1: 270,
        2: 315,
        3: 0,
        4: 45,
        5: 90,
        6: 135,
        7: 180,
        8: 225
      };

      const angleDeg = angleMap[direction] ?? 0;
      const angleRad = angleDeg * (Math.PI / 180);
      const pixelsPerFoot = canvas.dimensions.size / canvas.dimensions.distance;
      const scatterPixels = distanceFeet * pixelsPerFoot;

      finalPoint = {
        x: point.x + Math.cos(angleRad) * scatterPixels,
        y: point.y + Math.sin(angleRad) * scatterPixels
      };

      scatterHtml = `
        <div class="dt-chat-section">
          <h4>Scatter</h4>
          <div class="dt-chat-grid">
            <div class="dt-chat-line">
              <span class="dt-chat-small">Direction</span><br>
              <span class="dt-chat-strong">${direction}</span>
            </div>
            <div class="dt-chat-line">
              <span class="dt-chat-small">Distance</span><br>
              <span class="dt-chat-strong">${distanceFeet} ft</span>
            </div>
          </div>
        </div>
      `;
    } else {
      attackResultText = "HIT";
      attackNote = "Smoke lands on the selected point.";
    }

    if (ammoState.usesAmmo) {
      await weapon.update({
        "system.ammo": ammoState.ammo - 1
      });
    }

    const createdTemplate = await this._createSmokeTemplate(finalPoint, smokeDiameter, smokeDurationRounds);
    const ammoDisplay = this._formatWeaponAmmoDisplay(weapon);
    const smokeData = createdTemplate?.getFlag?.("drop-trooper", "smokeData") || createdTemplate?.flags?.["drop-trooper"]?.smokeData || {};
    const expirationText = smokeData?.combatId
      ? `Round ${smokeData.removeAtRound}`
      : "Manual delete if no combat is active";

    const content = `
      <div class="dt-chat-card">
        <div class="dt-chat-header">
          <div class="dt-chat-title">${this.actor.name}</div>
          <div class="dt-chat-subtitle">${weaponName} — Smoke Grenade</div>
        </div>
        <div class="dt-chat-body">

          <div class="dt-chat-section">
            <h4>Attack Roll</h4>
            <div class="dt-chat-grid">
              <div class="dt-chat-line"><span class="dt-chat-small">Skill</span><br><span class="dt-chat-strong">${skillKey}</span></div>
              <div class="dt-chat-line"><span class="dt-chat-small">Base Pool</span><br><span class="dt-chat-strong">${baseAttackPool}d6</span></div>
              <div class="dt-chat-line"><span class="dt-chat-small">Attack Pool</span><br><span class="dt-chat-strong">${attackPool}d6</span></div>
              <div class="dt-chat-line"><span class="dt-chat-small">Successes</span><br><span class="dt-chat-strong">${attackResult.successes}</span></div>
              ${attackPool <= 0 ? `<div class="dt-chat-line"><span class="dt-chat-small">Result</span><br><span class="dt-chat-strong">Automatic Miss (0 dice)</span></div>` : ""}
              <div class="dt-chat-line"><span class="dt-chat-small">Ammo</span><br><span class="dt-chat-strong">${ammoDisplay}</span></div>
              ${bonusDice > 0 ? `<div class="dt-chat-line"><span class="dt-chat-small">${pendingBonus.source}</span><br><span class="dt-chat-strong">+${bonusDice}d6</span></div>` : ""}
              ${aimDice > 0 ? `<div class="dt-chat-line"><span class="dt-chat-small">${pendingAim.source}</span><br><span class="dt-chat-strong">+${aimDice}d6</span></div>` : ""}
              ${penaltyDice > 0 ? `<div class="dt-chat-line"><span class="dt-chat-small">${pendingPenalty.source}</span><br><span class="dt-chat-strong">-${penaltyDice}d6</span></div>` : ""}
            </div>
            <div class="dt-chat-dice-row">${attackDiceHtml}</div>
            <div class="dt-chat-line dt-chat-line--compact"><span class="dt-chat-small">Result</span><br><span class="dt-chat-strong">${attackResultText}</span></div>
            <div class="dt-chat-line"><span class="dt-chat-small">Note</span><br><span class="dt-chat-strong">${attackNote}</span></div>
          </div>

          ${scatterHtml}

          <div class="dt-chat-section">
            <h4>Smoke Cloud</h4>
            <div class="dt-chat-grid">
              <div class="dt-chat-line"><span class="dt-chat-small">Diameter</span><br><span class="dt-chat-strong">${smokeDiameter} ft</span></div>
              <div class="dt-chat-line"><span class="dt-chat-small">Radius</span><br><span class="dt-chat-strong">${smokeDiameter / 2} ft</span></div>
              <div class="dt-chat-line"><span class="dt-chat-small">Duration</span><br><span class="dt-chat-strong">${smokeDurationRounds} round${smokeDurationRounds === 1 ? "" : "s"}</span></div>
              <div class="dt-chat-line"><span class="dt-chat-small">Expires</span><br><span class="dt-chat-strong">${expirationText}</span></div>
            </div>
            <div class="dt-chat-line"><span class="dt-chat-small">GM Control</span><br><span class="dt-chat-strong">The measured template can be grabbed and deleted manually.</span></div>
          </div>

        </div>
      </div>
    `;

    ChatMessage.create({
      speaker: ChatMessage.getSpeaker({ actor: this.actor }),
      content
    });
  }

async _onWeaponBlastAttack(weapon) {
  return await this._runWithPendingGmApprovalLock("blast attack", async () => {

  const skillKey = weapon.system?.skill || "heavyWeapons";
  const rollData = this._getAdjustedSkillAttackRollData(skillKey, this.actor);
  const baseAttackPool = rollData.baseDice;
  const pendingBonus = rollData.pendingBonus;
  const pendingPenalty = rollData.pendingPenalty;
  const pendingAim = rollData.pendingAim;
  const bonusDice = rollData.bonusDice;
  const penaltyDice = rollData.penaltyDice;
  const aimDice = rollData.aimDice;
  const attackPool = rollData.totalDice;
  const pushPenaltyDice = rollData.pushPenaltyDice;

  const weaponTier = weapon.system?.tier || "Medium";
  const weaponName = weapon.name || "AOE Weapon";
  const damageTarget = normalizeDropTrooperWeaponDamageTarget(weapon.system?.damageTarget, "normal");
  const ammoState = this._getWeaponAmmoState(weapon);

  if (!this._validateWeaponAmmoState(weapon, ammoState)) return;

  if (ammoState.usesAmmo && ammoState.ammo <= 0) {
    ui.notifications.warn(`${weaponName} is out of ammo.`);
    return;
  }

  const blastRadius = this._getNumericValue(weapon.system?.blastRadius, 100);
  const killRadius = this._getNumericValue(weapon.system?.killRadius, 30);
  const heavyRadius = this._getNumericValue(weapon.system?.heavyRadius, 60);
  const fragRadius = this._getNumericValue(weapon.system?.fragRadius, 100);
  const killDamage = this._getNumericValue(weapon.system?.killDamage, 6);
  const heavyDamage = this._getNumericValue(weapon.system?.heavyDamage, 4);
  const fragDamage = this._getNumericValue(weapon.system?.fragDamage, 2);

  const point = await this._promptForCanvasPoint(`Click the ${weaponName} impact point on the map.`);
  if (!point) return;

  const sourceToken = this._getActorTokenOnCanvas();
  const rangeData = this._getAttackRangePenaltyData({
    weaponData: weapon.system || {},
    sourceToken,
    targetPoint: point
  });
  if (rangeData.outOfRange) {
    ui.notifications.warn(`${weaponName} is out of range (${Math.round(rangeData.distance)} ft > ${rangeData.longRange} ft).`);
    return;
  }

  const finalAttackPool = Math.max(0, attackPool - Math.max(0, Number(rangeData.penaltyDice) || 0));
  const attackResult = await this._rollVisibleDicePool(finalAttackPool);
  await this._consumePendingStandardRollEffects(this.actor, rollData);

  const canOfferChatPush = finalAttackPool > 0 && attackResult.successes <= 0;

  if (canOfferChatPush) {
    if (ammoState.usesAmmo) {
      await weapon.update({
        "system.ammo": ammoState.ammo - 1
      });
    }

    await ChatMessage.create({
      speaker: ChatMessage.getSpeaker({ actor: this.actor }),
      content: this._buildAoePushChatCardHtml({
        subtitle: "Blast AOE",
        weaponName,
        skillKey,
        skillLabel: rollData.skillLabel || this._getSkillLabel(skillKey) || skillKey,
        attackPool: finalAttackPool,
        successes: attackResult.successes,
        dieResults: attackResult.dieResults,
        bonusDice,
        penaltyDice,
        aimDice,
        pushPenaltyDice,
        pushPenaltySource: rollData.pushPenalty?.source || "Push Penalty",
        bonusSource: pendingBonus?.source || "Bonus Dice",
        penaltySource: pendingPenalty?.source || "Penalty Dice",
        aimSource: pendingAim?.source || "Aim",
        pushPenaltyLabel: rollData.skillLabel || this._getSkillLabel(skillKey) || skillKey
      }),
      flags: {
        "drop-trooper": {
          pushRoll: {
            status: "pending",
            actorId: this.actor?.id || null,
            rollType: "aoe-blast",
            label: `${weaponName} Blast Attack`,
            totalDice: finalAttackPool,
            baseDice: baseAttackPool,
            bonusDice,
            penaltyDice,
            aimDice,
            pushPenaltyDice,
            pushPenaltySource: rollData.pushPenalty?.source || "Push Penalty",
            pushPenaltyKey: skillKey,
            pushPenaltyLabel: rollData.skillLabel || this._getSkillLabel(skillKey) || skillKey,
            bonusSource: pendingBonus?.source || "Bonus Dice",
            penaltySource: pendingPenalty?.source || "Penalty Dice",
            aimSource: pendingAim?.source || "Aim",
            noPushAvailable: true,
            originalResult: {
              successes: attackResult.successes,
              dieResults: Array.isArray(attackResult.dieResults) ? attackResult.dieResults : []
            },
            weaponName,
            weaponTier,
            damageTarget,
            rangeBandLabel: rangeData.bandLabel,
            rangePenaltyDice: rangeData.penaltyDice,
            rangeDistance: rangeData.distance,
            rangeShort: rangeData.shortRange,
            rangeMedium: rangeData.mediumRange,
            rangeLong: rangeData.longRange,
            weaponId: weapon?.id || null,
            sceneId: canvas?.scene?.id || null,
            sourceTokenId: sourceToken?.id || null,
            point,
            blastRadius,
            killRadius,
            heavyRadius,
            fragRadius,
            killDamage,
            heavyDamage,
            fragDamage,
            ammoSpent: !!ammoState.usesAmmo
          }
        }
      }
    });
    return true;
  }

  return await this._resolveBlastAttackWorkflow({
    attackResult,
    attackPool: finalAttackPool,
    baseAttackPool,
    bonusDice,
    penaltyDice,
    aimDice,
    pushPenaltyDice,
    pushPenaltySource: rollData.pushPenalty?.source || "Push Penalty",
    pendingBonus,
    pendingPenalty,
    pendingAim,
    weaponName,
    weaponTier,
    damageTarget,
    rangeBandLabel: rangeData.bandLabel,
    rangePenaltyDice: rangeData.penaltyDice,
    rangeDistance: rangeData.distance,
    rangeShort: rangeData.shortRange,
    rangeMedium: rangeData.mediumRange,
    rangeLong: rangeData.longRange,
    weaponId: weapon?.id || null,
    sourceTokenId: sourceToken?.id || null,
    point,
    blastRadius,
    killRadius,
    heavyRadius,
    fragRadius,
    killDamage,
    heavyDamage,
    fragDamage,
    ammoSpent: false,
    pushUsed: false,
    pushDeclined: false,
    pushPenaltyApplied: false,
    appliedPushPenalty: null,
    pushPenaltyLabel: rollData.skillLabel || this._getSkillLabel(skillKey) || skillKey
  });
  });
}

async _resolveBlastAttackWorkflow(options = {}) {
  const attackResult = options.attackResult || { successes: 0, dieResults: [] };
  const attackPool = Math.max(0, Number(options.attackPool) || 0);
  const weaponName = options.weaponName || "AOE Weapon";
  const weaponTier = options.weaponTier || "Medium";
  const point = options.point || { x: 0, y: 0 };
  const blastRadius = this._getNumericValue(options.blastRadius, 100);
  const killRadius = this._getNumericValue(options.killRadius, 30);
  const heavyRadius = this._getNumericValue(options.heavyRadius, 60);
  const fragRadius = this._getNumericValue(options.fragRadius, 100);
  const killDamage = this._getNumericValue(options.killDamage, 6);
  const heavyDamage = this._getNumericValue(options.heavyDamage, 4);
  const fragDamage = this._getNumericValue(options.fragDamage, 2);
  const damageTarget = normalizeDropTrooperWeaponDamageTarget(options.damageTarget, "normal");
  const rangeBandLabel = options.rangeBandLabel || "Short";
  const rangePenaltyDice = Math.max(0, Number(options.rangePenaltyDice) || 0);
  const rangeDistance = Math.max(0, Number(options.rangeDistance) || 0);
  const bonusDice = Math.max(0, Number(options.bonusDice) || 0);
  const penaltyDice = Math.max(0, Number(options.penaltyDice) || 0);
  const aimDice = Math.max(0, Number(options.aimDice) || 0);
  const attackDiceHtml = this._buildDiceHtml(Array.isArray(attackResult.dieResults) ? attackResult.dieResults : [], true);
  const hit = Number(attackResult.successes) >= 1;

  let finalPoint = point;
  let attackResultText = "MISS";
  let attackNote = "Missed aim point. Scatter applied.";
  let scatterHtml = "";

  if (!hit) {
    const scatterDirectionRoll = await (new Roll("1d8")).evaluate();
    const scatterDistanceRoll = await (new Roll("1d10 * 5")).evaluate();

    const direction = scatterDirectionRoll.total;
    const distanceFeet = scatterDistanceRoll.total;

    const angleMap = {
      1: 270,
      2: 315,
      3: 0,
      4: 45,
      5: 90,
      6: 135,
      7: 180,
      8: 225
    };

    const angleDeg = angleMap[direction] ?? 0;
    const angleRad = angleDeg * (Math.PI / 180);
    const pixelsPerFoot = canvas.dimensions.size / canvas.dimensions.distance;
    const scatterPixels = distanceFeet * pixelsPerFoot;

    finalPoint = {
      x: point.x + Math.cos(angleRad) * scatterPixels,
      y: point.y + Math.sin(angleRad) * scatterPixels
    };

    scatterHtml = `
      <div class="dt-chat-section">
        <h4>Scatter</h4>
        <div class="dt-chat-grid">
          <div class="dt-chat-line">
            <span class="dt-chat-small">Direction</span><br>
            <span class="dt-chat-strong">${direction}</span>
          </div>
          <div class="dt-chat-line">
            <span class="dt-chat-small">Distance</span><br>
            <span class="dt-chat-strong">${distanceFeet} ft</span>
          </div>
        </div>
      </div>
    `;
  } else {
    attackResultText = "HIT";
    attackNote = "Hit aim point. Blast centered on clicked location.";
  }

  const weapon = options.weaponId ? this.actor.items.get(options.weaponId) : null;
  if (!options.ammoSpent && weapon) {
    const ammoState = this._getWeaponAmmoState(weapon);
    if (ammoState.usesAmmo) {
      if (ammoState.ammo <= 0) {
        ui.notifications.warn(`${weaponName} is out of ammo.`);
        return false;
      }
      await weapon.update({
        "system.ammo": ammoState.ammo - 1
      });
    }
  }

  const sourceToken = this._getCanvasTokenById(options.sourceTokenId) || this._getActorTokenOnCanvas();

  this._queueWeaponFireEffect(weapon || { name: weaponName, system: {} }, {
    sourceToken,
    targetPoint: finalPoint,
    stretchToTarget: true
  });

  await this._createBlastTemplate(finalPoint, blastRadius, {
    soundPath: this._getWeaponBlastSoundPath(weapon || { system: {}, name: weaponName }),
    tileTexture: this._getWeaponBlastImagePath(weapon || { system: {}, name: weaponName })
  });

  const zones = this._getBlastZones(finalPoint, killRadius, heavyRadius, fragRadius);
  const gmApprovalQueue = [];
  const pendingReturnFireRequests = [];
  const killResolutionHtml = await this._resolveBlastEntries(zones.kill, "Kill Zone", killDamage, weaponTier, gmApprovalQueue, { damageTarget, collectReturnFireRequests: pendingReturnFireRequests });
  const heavyResolutionHtml = await this._resolveBlastEntries(zones.heavy, "Heavy Splash", heavyDamage, weaponTier, gmApprovalQueue, { damageTarget, collectReturnFireRequests: pendingReturnFireRequests });
  const fragResolutionHtml = await this._resolveBlastEntries(zones.frag, "Fragmentation", fragDamage, weaponTier, gmApprovalQueue, { damageTarget, collectReturnFireRequests: pendingReturnFireRequests });
  const ammoDisplay = weapon ? this._formatWeaponAmmoDisplay(weapon) : (options.ammoSpent ? "Spent" : "n/a");

  const pushSummaryHtml = options.pushUsed
    ? `<div class="dt-chat-line"><span class="dt-chat-small">Push</span><br><span class="dt-chat-strong">${options.pushPenaltyApplied ? `Used — failed again (-1 ${escapeDropTrooperHtml(options.pushPenaltyLabel || "skill")})` : "Used"}</span></div>`
    : (options.pushDeclined
        ? `<div class="dt-chat-line"><span class="dt-chat-small">Push</span><br><span class="dt-chat-strong">Declined</span></div>`
        : "");

  const content = `
    <div class="dt-chat-card">
      <div class="dt-chat-header">
        <div class="dt-chat-title">${this.actor.name}</div>
        <div class="dt-chat-subtitle">${weaponName} — Blast AOE</div>
      </div>
      <div class="dt-chat-body">

        <div class="dt-chat-section">
          <h4>Attack Roll</h4>
          <div class="dt-chat-grid">
            <div class="dt-chat-line"><span class="dt-chat-small">Attack Pool</span><br><span class="dt-chat-strong">${attackPool}d6</span></div>
            <div class="dt-chat-line"><span class="dt-chat-small">Successes</span><br><span class="dt-chat-strong">${attackResult.successes}</span></div>
            ${attackPool <= 0 ? `<div class="dt-chat-line"><span class="dt-chat-small">Result</span><br><span class="dt-chat-strong">Automatic Miss (0 dice)</span></div>` : ""}
            <div class="dt-chat-line"><span class="dt-chat-small">Ammo</span><br><span class="dt-chat-strong">${ammoDisplay}</span></div>
            ${bonusDice > 0 ? `<div class="dt-chat-line"><span class="dt-chat-small">${escapeDropTrooperHtml(options.pendingBonus?.source || "Bonus Dice")}</span><br><span class="dt-chat-strong">+${bonusDice}d6</span></div>` : ""}
            ${aimDice > 0 ? `<div class="dt-chat-line"><span class="dt-chat-small">${escapeDropTrooperHtml(options.pendingAim?.source || "Aim")}</span><br><span class="dt-chat-strong">+${aimDice}d6</span></div>` : ""}
            ${penaltyDice > 0 ? `<div class="dt-chat-line"><span class="dt-chat-small">${escapeDropTrooperHtml(options.pendingPenalty?.source || "Penalty Dice")}</span><br><span class="dt-chat-strong">-${penaltyDice}d6</span></div>` : ""}
            ${pushSummaryHtml}
          </div>
          <div class="dt-chat-dice-row">${attackDiceHtml}</div>
          <div class="dt-chat-line dt-chat-line--compact"><span class="dt-chat-small">Result</span><br><span class="dt-chat-strong">${attackResultText}</span></div>
          <div class="dt-chat-line"><span class="dt-chat-small">Note</span><br><span class="dt-chat-strong">${attackNote}</span></div>
          <div class="dt-chat-line"><span class="dt-chat-small">Weapon Tier Used</span><br><span class="dt-chat-strong">${weaponTier}</span></div>
        </div>

        ${scatterHtml}

        <div class="dt-chat-section">
          <h4>Zone Profile</h4>
          <div class="dt-chat-grid">
            <div class="dt-chat-line"><span class="dt-chat-small">Blast Radius</span><br><span class="dt-chat-strong">${blastRadius} ft</span></div>
            <div class="dt-chat-line"><span class="dt-chat-small">Kill Zone</span><br><span class="dt-chat-strong">${killDamage}d6</span></div>
            <div class="dt-chat-line"><span class="dt-chat-small">Heavy Splash</span><br><span class="dt-chat-strong">${heavyDamage}d6</span></div>
            <div class="dt-chat-line"><span class="dt-chat-small">Fragmentation</span><br><span class="dt-chat-strong">${fragDamage}d6</span></div>
          </div>
        </div>

        <div class="dt-chat-section">
          <div class="dt-chat-line"><span class="dt-chat-small">Kill Zone</span><br><span class="dt-chat-strong">0–${killRadius} ft</span></div>
          ${this._formatBlastZoneList(zones.kill)}
        </div>

        <div class="dt-chat-section">
          <div class="dt-chat-line"><span class="dt-chat-small">Heavy Splash</span><br><span class="dt-chat-strong">${this._formatRangeBand(killRadius, heavyRadius)}</span></div>
          ${this._formatBlastZoneList(zones.heavy)}
        </div>

        <div class="dt-chat-section">
          <div class="dt-chat-line"><span class="dt-chat-small">Fragmentation</span><br><span class="dt-chat-strong">${this._formatRangeBand(heavyRadius, fragRadius)}</span></div>
          ${this._formatBlastZoneList(zones.frag)}
        </div>

        ${killResolutionHtml}
        ${heavyResolutionHtml}
        ${fragResolutionHtml}

      </div>
    </div>
  `;

  await ChatMessage.create({
    speaker: ChatMessage.getSpeaker({ actor: this.actor }),
    content
  });

  for (const pendingReturnFireRequest of pendingReturnFireRequests) {
    try {
      const returnFireResult = await requestDropTrooperReturnFire(pendingReturnFireRequest);
      if (!returnFireResult?.ok) {
        console.warn("Drop Trooper | Blast AOE Return Fire failed after attack card post", returnFireResult);
      }
    } catch (error) {
      console.error("Drop Trooper | Blast AOE Return Fire execution failed after attack card post", error);
    }
  }

  if (hit) {
    await playDropTrooperRandomHitSound();
  }

  await this._flushDeferredGmApprovals(gmApprovalQueue);
  return true;
}

async _onWeaponConeAttack(weapon) {
  return await this._runWithPendingGmApprovalLock("cone attack", async () => {

  const skillKey = weapon.system?.skill || "shooting";
  const rollData = this._getAdjustedSkillAttackRollData(skillKey, this.actor);
  const baseAttackPool = rollData.baseDice;
  const pendingBonus = rollData.pendingBonus;
  const pendingPenalty = rollData.pendingPenalty;
  const pendingAim = rollData.pendingAim;
  const bonusDice = rollData.bonusDice;
  const penaltyDice = rollData.penaltyDice;
  const aimDice = rollData.aimDice;
  const attackPool = rollData.totalDice;
  const pushPenaltyDice = rollData.pushPenaltyDice;
  const weaponTier = weapon.system?.tier || "Medium";
  const weaponName = weapon.name || "Cone Weapon";
  const damageTarget = normalizeDropTrooperWeaponDamageTarget(weapon.system?.damageTarget, "normal");
  const ammoState = this._getWeaponAmmoState(weapon);

  if (!this._validateWeaponAmmoState(weapon, ammoState)) return;

  if (ammoState.usesAmmo && ammoState.ammo <= 0) {
    ui.notifications.warn(`${weaponName} is out of ammo.`);
    return;
  }

  const sourceToken = this._getActorTokenOnCanvas();
  if (!sourceToken) {
    ui.notifications.warn(`${weaponName}: place or select this actor's token on the scene before using a cone attack.`);
    return;
  }

  const coneKillConfigured = weapon.system?.coneKillRange;
  const coneHeavyConfigured = weapon.system?.coneHeavyRange;
  const coneFragConfigured = weapon.system?.coneFragRange;

  const fallbackConeKill = this._getNumericValue(weapon.system?.killRadius, 0);
  const fallbackConeHeavy = this._getNumericValue(weapon.system?.heavyRadius, 0);
  const fallbackConeFrag = this._getNumericValue(weapon.system?.fragRadius, 0);

  const killRange = this._getNumericValue(
    coneKillConfigured,
    fallbackConeKill > 0 ? fallbackConeKill : 0
  );
  const heavyRange = this._getNumericValue(
    coneHeavyConfigured,
    fallbackConeHeavy > 0 ? fallbackConeHeavy : 0
  );
  const fragRange = this._getNumericValue(
    coneFragConfigured,
    fallbackConeFrag > 0 ? fallbackConeFrag : 0
  );

  const coneRange = this._getNumericValue(
    weapon.system?.coneRange,
    Math.max(fragRange, heavyRange, killRange)
  );
  const coneAngle = this._getNumericValue(weapon.system?.coneAngle, 60);
  const killDamage = this._getNumericValue(weapon.system?.killDamage, 6);
  const heavyDamage = this._getNumericValue(weapon.system?.heavyDamage, 4);
  const fragDamage = this._getNumericValue(weapon.system?.fragDamage, 2);

  if (coneRange <= 0) {
    ui.notifications.warn(`${weaponName}: cone range must be greater than 0.`);
    return;
  }

  const aimPoint = await this._promptForCanvasPoint(`Click a point to aim the ${weaponName} cone.`);
  if (!aimPoint) return;

  const sourcePoint = sourceToken.center;
  const aimedDirection = this._getPointDirectionDegrees(sourcePoint, aimPoint);

  const attackResult = await this._rollVisibleDicePool(attackPool);
  if (bonusDice > 0 || penaltyDice > 0 || aimDice > 0) {
    await this._consumePendingAttackEffects(this.actor, rollData);
  }

  const canOfferChatPush = attackPool > 0 && attackResult.successes <= 0;

  if (canOfferChatPush) {
    if (ammoState.usesAmmo) {
      await weapon.update({
        "system.ammo": ammoState.ammo - 1
      });
    }

    await ChatMessage.create({
      speaker: ChatMessage.getSpeaker({ actor: this.actor }),
      content: this._buildAoePushChatCardHtml({
        subtitle: "Cone AOE",
        weaponName,
        skillKey,
        skillLabel: rollData.skillLabel || this._getSkillLabel(skillKey) || skillKey,
        attackPool,
        successes: attackResult.successes,
        dieResults: attackResult.dieResults,
        bonusDice,
        penaltyDice,
        aimDice,
        pushPenaltyDice,
        pushPenaltySource: rollData.pushPenalty?.source || "Push Penalty",
        bonusSource: pendingBonus?.source || "Bonus Dice",
        penaltySource: pendingPenalty?.source || "Penalty Dice",
        aimSource: pendingAim?.source || "Aim",
        pushPenaltyLabel: rollData.skillLabel || this._getSkillLabel(skillKey) || skillKey
      }),
      flags: {
        "drop-trooper": {
          pushRoll: {
            status: "pending",
            actorId: this.actor?.id || null,
            rollType: "aoe-cone",
            label: `${weaponName} Cone Attack`,
            totalDice: attackPool,
            baseDice: baseAttackPool,
            bonusDice,
            penaltyDice,
            aimDice,
            pushPenaltyDice,
            pushPenaltySource: rollData.pushPenalty?.source || "Push Penalty",
            pushPenaltyKey: skillKey,
            pushPenaltyLabel: rollData.skillLabel || this._getSkillLabel(skillKey) || skillKey,
            bonusSource: pendingBonus?.source || "Bonus Dice",
            penaltySource: pendingPenalty?.source || "Penalty Dice",
            aimSource: pendingAim?.source || "Aim",
            noPushAvailable: true,
            originalResult: {
              successes: attackResult.successes,
              dieResults: Array.isArray(attackResult.dieResults) ? attackResult.dieResults : []
            },
            weaponName,
            weaponTier,
            damageTarget,
            weaponId: weapon?.id || null,
            sceneId: canvas?.scene?.id || null,
            sourceTokenId: sourceToken?.id || null,
            aimPoint,
            aimedDirection,
            killRange,
            heavyRange,
            fragRange,
            coneRange,
            coneAngle,
            killDamage,
            heavyDamage,
            fragDamage,
            ammoSpent: !!ammoState.usesAmmo
          }
        }
      }
    });
    return true;
  }

  return await this._resolveConeAttackWorkflow({
    attackResult,
    attackPool,
    bonusDice,
    penaltyDice,
    aimDice,
    pushPenaltyDice,
    pendingBonus,
    pendingPenalty,
    pendingAim,
    weaponName,
    weaponTier,
    damageTarget,
    weaponId: weapon?.id || null,
    sourceTokenId: sourceToken?.id || null,
    aimedDirection,
    killRange,
    heavyRange,
    fragRange,
    coneRange,
    coneAngle,
    killDamage,
    heavyDamage,
    fragDamage,
    ammoSpent: false,
    pushUsed: false,
    pushDeclined: false,
    pushPenaltyApplied: false,
    appliedPushPenalty: null,
    pushPenaltyLabel: rollData.skillLabel || this._getSkillLabel(skillKey) || skillKey
  });
  });
}

async _resolveConeAttackWorkflow(options = {}) {
  const attackResult = options.attackResult || { successes: 0, dieResults: [] };
  const attackPool = Math.max(0, Number(options.attackPool) || 0);
  const weaponName = options.weaponName || "Cone Weapon";
  const weaponTier = options.weaponTier || "Medium";
  const damageTarget = normalizeDropTrooperWeaponDamageTarget(options.damageTarget, "normal");
  const aimedDirection = Number(options.aimedDirection) || 0;
  const killRange = this._getNumericValue(options.killRange, 0);
  const heavyRange = this._getNumericValue(options.heavyRange, 0);
  const fragRange = this._getNumericValue(options.fragRange, 0);
  const coneRange = this._getNumericValue(options.coneRange, Math.max(fragRange, heavyRange, killRange));
  const coneAngle = this._getNumericValue(options.coneAngle, 60);
  const killDamage = this._getNumericValue(options.killDamage, 6);
  const heavyDamage = this._getNumericValue(options.heavyDamage, 4);
  const fragDamage = this._getNumericValue(options.fragDamage, 2);
  const bonusDice = Math.max(0, Number(options.bonusDice) || 0);
  const penaltyDice = Math.max(0, Number(options.penaltyDice) || 0);
  const aimDice = Math.max(0, Number(options.aimDice) || 0);

  const sourceToken = this._getCanvasTokenById(options.sourceTokenId) || this._getActorTokenOnCanvas();
  if (!sourceToken) {
    ui.notifications.warn(`${weaponName}: source token is no longer available on the scene.`);
    return false;
  }

  const attackDiceHtml = this._buildDiceHtml(Array.isArray(attackResult.dieResults) ? attackResult.dieResults : [], true);

  let finalDirection = aimedDirection;
  let attackResultText = Number(attackResult.successes) >= 1 ? "HIT" : "MISS";
  let attackNote = Number(attackResult.successes) >= 1
    ? "Cone fired in the aimed direction."
    : "Cone missed its aim and drifted 15° off target.";
  let scatterHtml = "";

  if (Number(attackResult.successes) <= 0) {
    const scatterSign = Math.random() < 0.5 ? -1 : 1;
    finalDirection = this._normalizeDirection(aimedDirection + (15 * scatterSign));
    scatterHtml = `
      <div class="dt-chat-section">
        <h4>Scatter</h4>
        <div class="dt-chat-grid">
          <div class="dt-chat-line"><span class="dt-chat-small">Aim</span><br><span class="dt-chat-strong">${Math.round(aimedDirection)}°</span></div>
          <div class="dt-chat-line"><span class="dt-chat-small">Final</span><br><span class="dt-chat-strong">${Math.round(finalDirection)}°</span></div>
          <div class="dt-chat-line"><span class="dt-chat-small">Shift</span><br><span class="dt-chat-strong">${scatterSign < 0 ? "15° left" : "15° right"}</span></div>
        </div>
      </div>
    `;
  }

  const weapon = options.weaponId ? this.actor.items.get(options.weaponId) : null;
  if (!options.ammoSpent && weapon) {
    const ammoState = this._getWeaponAmmoState(weapon);
    if (ammoState.usesAmmo) {
      if (ammoState.ammo <= 0) {
        ui.notifications.warn(`${weaponName} is out of ammo.`);
        return false;
      }
      await weapon.update({
        "system.ammo": ammoState.ammo - 1
      });
    }
  }

  const sourcePoint = sourceToken.center;
  const coneTargetPoint = this._projectPointFromDirection(sourcePoint, finalDirection, coneRange);

  this._queueWeaponFireEffect(weapon || { name: weaponName, system: {} }, {
    sourceToken,
    sourcePoint,
    targetPoint: coneTargetPoint,
    stretchToTarget: true
  });

  await this._createConeTemplate(sourcePoint, finalDirection, coneRange, coneAngle, {
    soundPath: this._getWeaponConeSoundPath(weapon || { system: {}, name: weaponName }),
    tileTexture: this._getWeaponConeImagePath(weapon || { system: {}, name: weaponName })
  });

  const zones = this._getConeZones(sourceToken, finalDirection, coneAngle, killRange, heavyRange, fragRange, coneRange);
  const gmApprovalQueue = [];
  const pendingReturnFireRequests = [];
  const killResolutionHtml = await this._resolveBlastEntries(zones.kill, "Kill Zone", killDamage, weaponTier, gmApprovalQueue, { damageTarget, collectReturnFireRequests: pendingReturnFireRequests });
  const heavyResolutionHtml = await this._resolveBlastEntries(zones.heavy, "Heavy Splash", heavyDamage, weaponTier, gmApprovalQueue, { damageTarget, collectReturnFireRequests: pendingReturnFireRequests });
  const fragResolutionHtml = await this._resolveBlastEntries(zones.frag, "Fragmentation", fragDamage, weaponTier, gmApprovalQueue, { damageTarget, collectReturnFireRequests: pendingReturnFireRequests });
  const ammoDisplay = weapon ? this._formatWeaponAmmoDisplay(weapon) : (options.ammoSpent ? "Spent" : "n/a");
  const hit = Number(attackResult.successes) >= 1;

  const pushSummaryHtml = options.pushUsed
    ? `<div class="dt-chat-line"><span class="dt-chat-small">Push</span><br><span class="dt-chat-strong">${options.pushPenaltyApplied ? `Used — failed again (-1 ${escapeDropTrooperHtml(options.pushPenaltyLabel || "skill")})` : "Used"}</span></div>`
    : (options.pushDeclined
        ? `<div class="dt-chat-line"><span class="dt-chat-small">Push</span><br><span class="dt-chat-strong">Declined</span></div>`
        : "");

  const content = `
    <div class="dt-chat-card">
      <div class="dt-chat-header">
        <div class="dt-chat-title">${this.actor.name}</div>
        <div class="dt-chat-subtitle">${weaponName} — Cone AOE</div>
      </div>
      <div class="dt-chat-body">

        <div class="dt-chat-section">
          <h4>Attack Roll</h4>
          <div class="dt-chat-grid">
            <div class="dt-chat-line"><span class="dt-chat-small">Attack Pool</span><br><span class="dt-chat-strong">${attackPool}d6</span></div>
            <div class="dt-chat-line"><span class="dt-chat-small">Successes</span><br><span class="dt-chat-strong">${attackResult.successes}</span></div>
            ${attackPool <= 0 ? `<div class="dt-chat-line"><span class="dt-chat-small">Result</span><br><span class="dt-chat-strong">Automatic Miss (0 dice)</span></div>` : ""}
            <div class="dt-chat-line"><span class="dt-chat-small">Ammo</span><br><span class="dt-chat-strong">${ammoDisplay}</span></div>
            <div class="dt-chat-line"><span class="dt-chat-small">Range</span><br><span class="dt-chat-strong">${escapeDropTrooperHtml(rangeBandLabel)} (${Math.round(rangeDistance)} ft)</span></div>
            ${rangePenaltyDice > 0 ? `<div class="dt-chat-line"><span class="dt-chat-small">Range Penalty</span><br><span class="dt-chat-strong">-${rangePenaltyDice}d6</span></div>` : ""}
            ${bonusDice > 0 ? `<div class="dt-chat-line"><span class="dt-chat-small">${escapeDropTrooperHtml(options.pendingBonus?.source || "Bonus Dice")}</span><br><span class="dt-chat-strong">+${bonusDice}d6</span></div>` : ""}
            ${aimDice > 0 ? `<div class="dt-chat-line"><span class="dt-chat-small">${escapeDropTrooperHtml(options.pendingAim?.source || "Aim")}</span><br><span class="dt-chat-strong">+${aimDice}d6</span></div>` : ""}
            ${penaltyDice > 0 ? `<div class="dt-chat-line"><span class="dt-chat-small">${escapeDropTrooperHtml(options.pendingPenalty?.source || "Penalty Dice")}</span><br><span class="dt-chat-strong">-${penaltyDice}d6</span></div>` : ""}
            ${pushSummaryHtml}
          </div>
          <div class="dt-chat-dice-row">${attackDiceHtml}</div>
          <div class="dt-chat-line dt-chat-line--compact"><span class="dt-chat-small">Result</span><br><span class="dt-chat-strong">${attackResultText}</span></div>
          <div class="dt-chat-line"><span class="dt-chat-small">Note</span><br><span class="dt-chat-strong">${attackNote}</span></div>
          <div class="dt-chat-line"><span class="dt-chat-small">Weapon Tier Used</span><br><span class="dt-chat-strong">${weaponTier}</span></div>
        </div>

        ${scatterHtml}

        <div class="dt-chat-section">
          <h4>Cone Profile</h4>
          <div class="dt-chat-grid">
            <div class="dt-chat-line"><span class="dt-chat-small">Range</span><br><span class="dt-chat-strong">${coneRange} ft</span></div>
            <div class="dt-chat-line"><span class="dt-chat-small">Angle</span><br><span class="dt-chat-strong">${coneAngle}°</span></div>
            <div class="dt-chat-line"><span class="dt-chat-small">Aim</span><br><span class="dt-chat-strong">${Math.round(aimedDirection)}°</span></div>
            <div class="dt-chat-line"><span class="dt-chat-small">Final</span><br><span class="dt-chat-strong">${Math.round(finalDirection)}°</span></div>
          </div>
        </div>

        <div class="dt-chat-section">
          <h4>Zone Profile</h4>
          <div class="dt-chat-grid">
            <div class="dt-chat-line"><span class="dt-chat-small">Kill Zone</span><br><span class="dt-chat-strong">${killDamage}d6</span></div>
            <div class="dt-chat-line"><span class="dt-chat-small">Heavy Splash</span><br><span class="dt-chat-strong">${heavyDamage}d6</span></div>
            <div class="dt-chat-line"><span class="dt-chat-small">Fragmentation</span><br><span class="dt-chat-strong">${fragDamage}d6</span></div>
          </div>
        </div>

        <div class="dt-chat-section">
          <div class="dt-chat-line"><span class="dt-chat-small">Kill Zone</span><br><span class="dt-chat-strong">0–${killRange} ft</span></div>
          ${this._formatBlastZoneList(zones.kill)}
        </div>

        <div class="dt-chat-section">
          <div class="dt-chat-line"><span class="dt-chat-small">Heavy Splash</span><br><span class="dt-chat-strong">${this._formatRangeBand(killRange, heavyRange)}</span></div>
          ${this._formatBlastZoneList(zones.heavy)}
        </div>

        <div class="dt-chat-section">
          <div class="dt-chat-line"><span class="dt-chat-small">Fragmentation</span><br><span class="dt-chat-strong">${this._formatRangeBand(heavyRange, fragRange)}</span></div>
          ${this._formatBlastZoneList(zones.frag)}
        </div>

        ${killResolutionHtml}
        ${heavyResolutionHtml}
        ${fragResolutionHtml}

      </div>
    </div>
  `;

  await ChatMessage.create({
    speaker: ChatMessage.getSpeaker({ actor: this.actor }),
    content
  });

  for (const pendingReturnFireRequest of pendingReturnFireRequests) {
    try {
      const returnFireResult = await requestDropTrooperReturnFire(pendingReturnFireRequest);
      if (!returnFireResult?.ok) {
        console.warn("Drop Trooper | Cone AOE Return Fire failed after attack card post", returnFireResult);
      }
    } catch (error) {
      console.error("Drop Trooper | Cone AOE Return Fire execution failed after attack card post", error);
    }
  }

  if (hit) {
    await playDropTrooperRandomHitSound();
  }

  await this._flushDeferredGmApprovals(gmApprovalQueue);
  return true;
}

  async _onWeaponReload(event) {
    event.preventDefault();

    const itemId = event.currentTarget.dataset.itemId;
    const weapon = this.actor.items.get(itemId);

    if (!weapon) {
      ui.notifications.warn("Weapon not found.");
      return;
    }

    const outOfArmorWeaponLock = getDropTrooperOutOfArmorWeaponLock(this.actor, weapon);
    if (outOfArmorWeaponLock.blocked) {
      ui.notifications.warn(outOfArmorWeaponLock.reason);
      return;
    }

    const weaponName = weapon.name || "Weapon";
    const ammoState = this._getWeaponAmmoState(weapon);

    if (!ammoState.usesAmmo) {
      ui.notifications.info(`${weaponName} does not use ammo.`);
      return;
    }

    if (!this._validateWeaponAmmoState(weapon, ammoState)) return;

    if (ammoState.ammo >= ammoState.magSize) {
      ui.notifications.info(`${weaponName} is already fully loaded.`);
      return;
    }

    if (ammoState.spareAmmo <= 0) {
      ui.notifications.warn(`${weaponName} has no spare ammo left.`);
      return;
    }

    const needed = Math.max(0, ammoState.magSize - ammoState.ammo);
    const roundsLoaded = Math.min(needed, ammoState.spareAmmo);
    const newAmmo = ammoState.ammo + roundsLoaded;
    const newSpareAmmo = ammoState.spareAmmo - roundsLoaded;

    await weapon.update({
      "system.ammo": newAmmo,
      "system.ammoMax": newSpareAmmo
    });

    ui.notifications.info(`${weaponName} reloaded ${roundsLoaded} round${roundsLoaded === 1 ? "" : "s"}.`);
  }

  async _onWeaponOverwatchToggle(event) {
    event.preventDefault();

    const input = event.currentTarget;
    const itemId = String(input?.dataset?.itemId || "").trim();
    const weapon = this.actor.items.get(itemId);
    if (!weapon || weapon.type !== "weapon") return;

    const wantsPreferred = Boolean(input.checked);
    const isAoe = Boolean(weapon.system?.aoeEnabled);
    if (wantsPreferred && isAoe) {
      input.checked = false;
      ui.notifications?.warn?.(`${weapon.name} cannot be the Overwatch weapon while AOE Weapon is checked.`);
      return;
    }

    if (wantsPreferred) {
      await this.actor.setFlag("drop-trooper", "overwatchWeaponId", weapon.id);
    } else {
      const currentPreferredId = String(this.actor.getFlag("drop-trooper", "overwatchWeaponId") || "").trim();
      if (currentPreferredId === weapon.id) {
        await this.actor.unsetFlag("drop-trooper", "overwatchWeaponId");
      }
    }

    this.render(false);
  }

  async _onWeaponCreate(event) {
    event.preventDefault();

    if (!game.user?.isGM && this._isDroneActor(this.actor)) {
      ui.notifications.warn("Only the GM can change drone weapons.");
      return;
    }

    const defaultSkill = this._isDroneActor(this.actor) ? "droneControl" : undefined;

    const created = await this.actor.createEmbeddedDocuments("Item", [{
      name: "New Weapon",
      type: "weapon",
      system: {
        displayOrder: this._getNextDisplayOrder("weapon"),
        ...(defaultSkill ? { skill: defaultSkill } : {})
      }
    }]);

    if (created?.length) {
      created[0].sheet.render(true);
    }
  }

  async _onNpcBlueprintExport(event) {
    event.preventDefault();
    await exportDropTrooperNpcBlueprint(this.actor);
  }

  async _onWeaponEdit(event) {
    event.preventDefault();

    if (!game.user?.isGM && this._isDroneActor(this.actor)) {
      ui.notifications.warn("Only the GM can edit drone weapons.");
      return;
    }

    const itemId = event.currentTarget.dataset.itemId;
    const item = this.actor.items.get(itemId);

    if (!item) {
      ui.notifications.warn("Weapon not found.");
      return;
    }

    item.sheet.render(true);
  }

  async _onWeaponDelete(event) {
    event.preventDefault();

    if (!game.user?.isGM && this._isDroneActor(this.actor)) {
      ui.notifications.warn("Only the GM can delete drone weapons.");
      return;
    }

    const itemId = event.currentTarget.dataset.itemId;
    const item = this.actor.items.get(itemId);

    if (!item) return;

    const confirmed = await Dialog.confirm({
      title: "Delete Weapon",
      content: `<p>Delete <strong>${item.name}</strong> from ${this.actor.name}?</p>`
    });

    if (!confirmed) return;

    await item.delete();
  }

  async _onAbilityCreate(event) {
    event.preventDefault();

    if (!game.user?.isGM && this._isDroneActor(this.actor)) {
      ui.notifications.warn("Only the GM can change drone abilities.");
      return;
    }

    const defaultLinkedSkill = this._isDroneActor(this.actor) ? "droneControl" : undefined;

    const created = await this.actor.createEmbeddedDocuments("Item", [{
      name: "New Ability",
      type: "ability",
      system: {
        displayOrder: this._getNextDisplayOrder("ability"),
        ...(defaultLinkedSkill ? { linkedSkill: defaultLinkedSkill } : {})
      }
    }]);

    if (created?.length) {
      created[0].sheet.render(true);
    }
  }

  async _onAbilityUse(event) {
    event.preventDefault();

    const itemId = event.currentTarget.dataset.itemId;
    const ability = this.actor.items.get(itemId);

    if (!ability) {
      ui.notifications.warn("Ability not found.");
      return;
    }

    const outOfArmorAbilityLock = getDropTrooperOutOfArmorAbilityLock(this.actor, ability);
    if (outOfArmorAbilityLock.blocked) {
      ui.notifications.warn(outOfArmorAbilityLock.reason);
      return;
    }

    if (ability.system?.specialType === "commandDice") {
      await this._useCommandDiceAbility(ability);
      return;
    }

    if (ability.system?.specialType === "repairKit") {
      await this._useRepairKitAbility(ability);
      return;
    }

    if (ability.system?.specialType === "sensorSweep") {
      await this._useSensorSweepAbility(ability);
      return;
    }

    if (ability.system?.specialType === "flightPack") {
      await this._useFlightAbility(ability);
      return;
    }

    await this._useSkillAbility(ability);
  }

  async _useSkillAbility(ability) {
    const skillKey = ability.system?.linkedSkill || "tech";
    const poolData = this._getAdjustedSkillRollData(skillKey, this.actor);
    const rollData = poolData;
    const baseDice = rollData.baseDice;
    const flatBonus = Number(ability.system?.bonusDice) || 0;
    const pendingBonus = rollData.pendingBonus;
    const pendingPenalty = rollData.pendingPenalty;
    const bonusDice = rollData.bonusDice;
    const penaltyDice = rollData.penaltyDice;
    const totalDice = Math.max(0, rollData.totalDice + flatBonus);
    const label = ability.name || "Ability";

    const result = await this._rollVisibleDicePool(totalDice);
    await this._consumePendingStandardRollEffects(this.actor, rollData);
    const diceHtml = this._buildDiceHtml(result.dieResults, true);
    const linkedSkillLabel = this._getSkillLabel(skillKey);

    const content = `
      <div class="dt-chat-card">
        <div class="dt-chat-header">
          <div class="dt-chat-title">${this.actor.name}</div>
          <div class="dt-chat-subtitle">${label}</div>
        </div>
        <div class="dt-chat-body">
          <div class="dt-chat-section">
            <div class="dt-chat-grid">
              <div class="dt-chat-line"><span class="dt-chat-small">Linked Skill</span><br><span class="dt-chat-strong">${linkedSkillLabel}</span></div>
              ${this._getSkillBreakdownHtml(poolData)}
              <div class="dt-chat-line"><span class="dt-chat-small">Dice Rolled</span><br><span class="dt-chat-strong">${totalDice}d6</span></div>
              <div class="dt-chat-line"><span class="dt-chat-small">Ability Bonus</span><br><span class="dt-chat-strong">+${flatBonus}d6</span></div>
              ${bonusDice > 0 ? `<div class="dt-chat-line"><span class="dt-chat-small">${pendingBonus.source}</span><br><span class="dt-chat-strong">+${bonusDice}d6</span></div>` : ""}
              ${penaltyDice > 0 ? `<div class="dt-chat-line"><span class="dt-chat-small">${pendingPenalty.source}</span><br><span class="dt-chat-strong">-${penaltyDice}d6</span></div>` : ""}
              <div class="dt-chat-line"><span class="dt-chat-small">Successes</span><br><span class="dt-chat-strong">${result.successes}</span></div>
            </div>
            <div class="dt-chat-dice-row">${diceHtml}</div>
            ${ability.system?.notes ? `<div class="dt-chat-line dt-chat-line--compact"><span class="dt-chat-small">Notes</span><br><span class="dt-chat-strong">${ability.system.notes}</span></div>` : ""}
          </div>
        </div>
      </div>
    `;

    ChatMessage.create({
      speaker: ChatMessage.getSpeaker({ actor: this.actor }),
      content
    });

    if (result.successes >= 3) {
      await playDropTrooperCritSuccessCelebration();
    }
  }

  async _useRepairKitAbility(ability) {
    const abilityName = ability.name || "Repair Kit";
    const skillKey = ability.system?.linkedSkill || "tech";
    const flatBonus = Number(ability.system?.bonusDice) || 0;
    const poolData = this._getAdjustedSkillRollData(skillKey, this.actor);
    const rollData = poolData;
    const pendingBonus = rollData.pendingBonus;
    const pendingPenalty = rollData.pendingPenalty;
    const bonusDice = rollData.bonusDice;
    const penaltyDice = rollData.penaltyDice;
    const poolCurrent = Number(ability.system?.pool?.value) || 0;
    const poolMax = Number(ability.system?.pool?.max) || 0;

    if (poolMax > 0 && poolCurrent <= 0) {
      ui.notifications.warn(`${abilityName} has no uses remaining.`);
      return;
    }

    const targets = Array.from(game.user.targets);
    const targetToken = targets[0] || this._getActorTokenOnCanvas();
    const targetActor = targetToken?.actor || this.actor;

    if (!targetActor) {
      ui.notifications.warn(`${abilityName}: no valid target found.`);
      return;
    }

    const integrityData = targetActor.system?.armor?.integrity;
    if (!integrityData) {
      ui.notifications.warn(`${abilityName}: target has no armor integrity.`);
      return;
    }

    const integrityCurrent = Number(integrityData.value) || 0;
    const integrityMax = Number(integrityData.max) || 0;
    const healthData = targetActor.system?.health;
    const healthCurrent = Number(healthData?.value) || 0;
    const healthMax = Number(healthData?.max) || 0;
    const healthMissing = Math.max(0, healthMax - healthCurrent);
    const integrityMissing = Math.max(0, integrityMax - integrityCurrent);

    if (healthMissing <= 0 && integrityMissing <= 0) {
      ui.notifications.info(`${targetActor.name} is already at full health and integrity.`);
      return;
    }

    const totalDice = Math.max(0, rollData.totalDice + flatBonus);

    const skillResult = await this._rollVisibleDicePool(totalDice);
    await this._consumePendingStandardRollEffects(this.actor, rollData);
    const skillDiceHtml = this._buildDiceHtml(skillResult.dieResults, true);

    await this._showDice3D(`1d6`);
    const repairRoll = await this._rollDamageDice(1);
    const repairDiceHtml = this._buildDiceHtml(repairRoll.dieResults, false);

    let successRepairRoll = { dieResults: [], total: 0 };
    let successRepairDiceHtml = "";
    if (skillResult.successes > 0) {
      await this._showDice3D(`${skillResult.successes}d6`);
      successRepairRoll = await this._rollDamageDice(skillResult.successes);
      successRepairDiceHtml = this._buildDiceHtml(successRepairRoll.dieResults, false);
    }

    const rawRepair = repairRoll.total + successRepairRoll.total;

    let remainingRepair = rawRepair;

    let healthApplied = 0;
    let newHealth = healthCurrent;
    if (healthMissing > 0) {
      healthApplied = Math.min(remainingRepair, healthMissing);
      newHealth = healthCurrent + healthApplied;
      remainingRepair -= healthApplied;
    }

    let integrityApplied = 0;
    let newIntegrity = integrityCurrent;
    if (integrityMissing > 0) {
      integrityApplied = Math.min(remainingRepair, integrityMissing);
      newIntegrity = integrityCurrent + integrityApplied;
      remainingRepair -= integrityApplied;
    }

    const appliedRepair = healthApplied + integrityApplied;
    const canApplyDirectly = game.user?.isGM || targetActor?.isOwner === true;
    let pendingApproval = false;

    if (canApplyDirectly) {
      await targetActor.update({
        "system.health.value": newHealth,
        "system.armor.integrity.value": newIntegrity
      });
    } else {
      const targetTokenId = targetToken?.id || targetToken?.document?.id || null;
      const targetSceneId = targetToken?.parent?.id || targetToken?.document?.parent?.id || canvas?.scene?.id || null;
      const gmUser = getDropTrooperActiveGmUser();

      if (!targetTokenId || !targetSceneId || !gmUser) {
        ui.notifications.warn(`${abilityName}: no active GM approval path was found for ${targetActor.name}.`);
        return;
      }

      const approvalWindowOpened = await beginDropTrooperPendingApprovalWindow(game.user?.id, "repair kit");
      if (!approvalWindowOpened) {
        ui.notifications.warn("Finish the pending GM approval before starting another repair kit request.");
        return;
      }

      try {
        await createDropTrooperGmDamageApprovalMessage({
          requestType: "repairKit",
          requestId: foundry.utils.randomID(),
          gmUserId: gmUser.id,
          requestedByUserId: game.user?.id || null,
          requestedByName: game.user?.name || "Player",
          sourceActorId: this.actor?.id || null,
          sourceActorName: this.actor?.name || game.user?.name || "Trooper",
          sourceTokenId: this.actor?.token?.id || null,
          abilityItemId: ability?.id || null,
          abilityName,
          attackLabel: abilityName,
          weaponName: abilityName,
          sceneId: targetSceneId,
          tokenId: targetTokenId,
          actorId: targetActor?.id || null,
          targetName: targetToken?.name || targetActor?.name || "Target",
          healthRepair: healthApplied,
          integrityRepair: integrityApplied,
          newHealth,
          newIntegrity,
          createdAt: Date.now(),
          status: "pending"
        });
        pendingApproval = true;
      } catch (err) {
        await releaseDropTrooperPendingApprovalWindow(game.user?.id);
        ui.notifications.warn(err?.message || `${abilityName}: failed to send GM approval request.`);
        return;
      }
    }

    if (poolMax > 0) {
      await ability.update({
        "system.pool.value": Math.max(0, poolCurrent - 1),
        "system.pool.max": poolMax
      });
    }

    const linkedSkillLabel = this._getSkillLabel(skillKey);
    const remainingUses = poolMax > 0 ? Math.max(0, poolCurrent - 1) : "—";

    const content = `
      <div class="dt-chat-card">
        <div class="dt-chat-header">
          <div class="dt-chat-title">${this.actor.name}</div>
          <div class="dt-chat-subtitle">${abilityName}</div>
        </div>
        <div class="dt-chat-body">
          <div class="dt-chat-section">
            <div class="dt-chat-grid">
              <div class="dt-chat-line"><span class="dt-chat-small">Target</span><br><span class="dt-chat-strong">${targetActor.name}</span></div>
              <div class="dt-chat-line"><span class="dt-chat-small">Linked Skill</span><br><span class="dt-chat-strong">${linkedSkillLabel}</span></div>
              ${this._getSkillBreakdownHtml(poolData)}
              <div class="dt-chat-line"><span class="dt-chat-small">Skill Dice</span><br><span class="dt-chat-strong">${totalDice}d6</span></div>
              ${bonusDice > 0 ? `<div class="dt-chat-line"><span class="dt-chat-small">${pendingBonus.source}</span><br><span class="dt-chat-strong">+${bonusDice}d6</span></div>` : ""}
              ${penaltyDice > 0 ? `<div class="dt-chat-line"><span class="dt-chat-small">${pendingPenalty.source}</span><br><span class="dt-chat-strong">-${penaltyDice}d6</span></div>` : ""}
              <div class="dt-chat-line"><span class="dt-chat-small">Successes</span><br><span class="dt-chat-strong">${skillResult.successes}</span></div>
            </div>
            <div class="dt-chat-dice-row">${skillDiceHtml}</div>
          </div>

          <div class="dt-chat-section">
            <div class="dt-chat-grid">
              <div class="dt-chat-line"><span class="dt-chat-small">Base Repair</span><br><span class="dt-chat-strong">${repairRoll.total}</span></div>
              <div class="dt-chat-line"><span class="dt-chat-small">Success Repair Dice</span><br><span class="dt-chat-strong">${skillResult.successes}d6 = ${successRepairRoll.total}</span></div>
              <div class="dt-chat-line"><span class="dt-chat-small">Repair Applied</span><br><span class="dt-chat-final">${appliedRepair}</span></div>
              <div class="dt-chat-line"><span class="dt-chat-small">Health</span><br><span class="dt-chat-strong">${healthCurrent} → ${newHealth}</span></div>
              <div class="dt-chat-line"><span class="dt-chat-small">Integrity</span><br><span class="dt-chat-strong">${integrityCurrent} → ${newIntegrity}</span></div>
            </div>
            <div class="dt-chat-dice-row">${repairDiceHtml}</div>
            ${skillResult.successes > 0 ? `<div class="dt-chat-dice-row">${successRepairDiceHtml}</div>` : ""}
            ${pendingApproval ? `<div class="dt-chat-line dt-chat-line--compact"><span class="dt-chat-small">Status</span><br><span class="dt-chat-strong">Waiting for GM approval</span></div>` : ""}
            ${poolMax > 0 ? `<div class="dt-chat-line dt-chat-line--compact"><span class="dt-chat-small">Uses Remaining</span><br><span class="dt-chat-strong">${remainingUses} / ${poolMax}</span></div>` : ""}
          </div>
        </div>
      </div>
    `;

    ChatMessage.create({
      speaker: ChatMessage.getSpeaker({ actor: this.actor }),
      content
    });

    if (skillResult.successes >= 3) {
      await playDropTrooperCritSuccessCelebration();
    }
  }

  _getActiveSmokeTemplates() {
    if (!canvas?.ready) return [];

    return (canvas.templates?.placeables || []).filter(template => {
      return !!template?.document?.getFlag("drop-trooper", "smokeData");
    });
  }

  _getPixelsPerDistanceUnit() {
    const gridDistance = Number(canvas?.scene?.grid?.distance) || Number(canvas?.grid?.distance) || 5;
    const gridSize = Number(canvas?.scene?.grid?.size) || Number(canvas?.grid?.size) || 100;
    return gridSize / gridDistance;
  }

  _distanceUnitsToPixels(distanceUnits) {
    return Math.max(0, Number(distanceUnits) || 0) * this._getPixelsPerDistanceUnit();
  }

  _getWeaponRangeBands(weaponData = {}) {
    const shortRange = Math.max(0, Number(weaponData?.shortRange) || 0);
    const mediumRange = Math.max(shortRange, Number(weaponData?.mediumRange) || 0);
    const longRange = Math.max(mediumRange, Number(weaponData?.longRange) || 0);
    return { shortRange, mediumRange, longRange };
  }

  _measureDropTrooperDistance(sourceToken, target = null) {
    if (!canvas?.ready || !sourceToken?.center || !target) return 0;
    const destination = target?.center
      ? target.center
      : ((Number(target?.x) || Number(target?.x) === 0) && (Number(target?.y) || Number(target?.y) === 0)
          ? { x: Number(target.x) || 0, y: Number(target.y) || 0 }
          : null);
    if (!destination) return 0;
    return Math.max(0, Number(canvas.grid.measureDistance(sourceToken.center, destination)) || 0);
  }

  _getAttackRangePenaltyData(options = {}) {
    const {
      weaponData = {},
      sourceToken = null,
      targetToken = null,
      targetPoint = null
    } = options;

    const aoeEnabled = !!weaponData?.aoeEnabled;
    const aoeType = String(weaponData?.aoeType || "blast").trim().toLowerCase();
    if (aoeEnabled && aoeType === "cone") {
      return {
        applies: false,
        ignored: true,
        distance: 0,
        shortRange: 0,
        mediumRange: 0,
        longRange: 0,
        bandLabel: "Cone",
        penaltyDice: 0,
        outOfRange: false
      };
    }

    const { shortRange, mediumRange, longRange } = this._getWeaponRangeBands(weaponData);
    const distance = this._measureDropTrooperDistance(sourceToken, targetToken || targetPoint || null);

    let bandLabel = "Short";
    let penaltyDice = 0;
    let outOfRange = false;

    if (longRange > 0 && distance > longRange) {
      bandLabel = "Out of Range";
      penaltyDice = 0;
      outOfRange = true;
    } else if (mediumRange > 0 && distance > mediumRange) {
      bandLabel = "Long";
      penaltyDice = 4;
    } else if (shortRange > 0 && distance > shortRange) {
      bandLabel = "Medium";
      penaltyDice = 2;
    }

    return {
      applies: true,
      ignored: false,
      distance,
      shortRange,
      mediumRange,
      longRange,
      bandLabel,
      penaltyDice,
      outOfRange
    };
  }

  _isPointInsideSmoke(point) {
    if (!point) return false;

    const smokeTemplates = this._getActiveSmokeTemplates();
    if (!smokeTemplates.length) return false;

    return smokeTemplates.some(template => {
      const center = { x: Number(template.document?.x) || 0, y: Number(template.document?.y) || 0 };
      const radiusFeet = Number(template.document?.distance) || Number(template.document?.getFlag("drop-trooper", "smokeData")?.diameter) / 2 || 0;
      const radiusPx = this._distanceUnitsToPixels(radiusFeet);
      const dx = point.x - center.x;
      const dy = point.y - center.y;
      return ((dx * dx) + (dy * dy)) <= (radiusPx * radiusPx);
    });
  }

  _segmentIntersectsSmoke(startPoint, endPoint) {
    if (!startPoint || !endPoint) return false;

    const smokeTemplates = this._getActiveSmokeTemplates();
    if (!smokeTemplates.length) return false;

    const ax = Number(startPoint.x) || 0;
    const ay = Number(startPoint.y) || 0;
    const bx = Number(endPoint.x) || 0;
    const by = Number(endPoint.y) || 0;
    const abx = bx - ax;
    const aby = by - ay;
    const abLenSq = (abx * abx) + (aby * aby);

    return smokeTemplates.some(template => {
      const cx = Number(template.document?.x) || 0;
      const cy = Number(template.document?.y) || 0;
      const radiusFeet = Number(template.document?.distance) || Number(template.document?.getFlag("drop-trooper", "smokeData")?.diameter) / 2 || 0;
      const radiusPx = this._distanceUnitsToPixels(radiusFeet);

      if (abLenSq <= 0) {
        const dx = ax - cx;
        const dy = ay - cy;
        return ((dx * dx) + (dy * dy)) <= (radiusPx * radiusPx);
      }

      const t = Math.max(0, Math.min(1, (((cx - ax) * abx) + ((cy - ay) * aby)) / abLenSq));
      const closestX = ax + (abx * t);
      const closestY = ay + (aby * t);
      const dx = closestX - cx;
      const dy = closestY - cy;
      return ((dx * dx) + (dy * dy)) <= (radiusPx * radiusPx);
    });
  }

  _isSensorSweepBlockedBySmoke(sourceToken, targetToken) {
    if (!sourceToken?.center || !targetToken?.center) return false;
    if (!this._getActiveSmokeTemplates().length) return false;

    if (this._isPointInsideSmoke(sourceToken.center)) return true;
    if (this._isPointInsideSmoke(targetToken.center)) return true;
    return this._segmentIntersectsSmoke(sourceToken.center, targetToken.center);
  }

  _getSensorSweepTargets(sourceToken, rangeFeet) {
    if (!canvas?.ready || !sourceToken || rangeFeet <= 0) return [];
    if (this._isPointInsideSmoke(sourceToken.center)) return [];

    const targets = [];

    for (const token of canvas.tokens.placeables) {
      if (!token?.actor) continue;
      if (token.id === sourceToken.id) continue;

      const distance = canvas.grid.measureDistance(sourceToken.center, token.center);
      if (distance > rangeFeet) continue;
      if (this._isSensorSweepBlockedBySmoke(sourceToken, token)) continue;

      targets.push({
        token,
        distance,
        wasHidden: !!token.document?.hidden
      });
    }

    targets.sort((a, b) => a.distance - b.distance);
    return targets;
  }

  async _temporarilyRevealSensorSweepTargets(entries, durationMs = 1500) {
    const hiddenEntries = (entries || []).filter(entry => entry?.token?.document?.hidden);
    if (!hiddenEntries.length || !game.user?.isGM) return;

    const idsToReveal = hiddenEntries.map(entry => entry.token.id).filter(Boolean);
    if (!idsToReveal.length) return;

    try {
      await canvas.scene.updateEmbeddedDocuments("Token", idsToReveal.map(id => ({ _id: id, hidden: false })));
    } catch (err) {
      console.warn("Drop Trooper | Failed to reveal sensor sweep targets", err);
      return;
    }

    setTimeout(async () => {
      try {
        if (!canvas?.scene) return;
        const updates = idsToReveal.map(id => {
          const tokenDoc = canvas.scene.tokens.get(id);
          if (!tokenDoc || tokenDoc.hidden) return null;
          return { _id: id, hidden: true };
        }).filter(Boolean);

        if (updates.length) {
          await canvas.scene.updateEmbeddedDocuments("Token", updates);
        }
      } catch (err) {
        console.warn("Drop Trooper | Failed to restore hidden sensor sweep targets", err);
      }
    }, Math.max(250, Number(durationMs) || 1500));
  }

  async _showSensorSweepPings(entries, durationMs = 1500) {
    if (!canvas?.ready || !entries?.length) return;

    const container = new PIXI.Container();
    container.zIndex = 10000;
    canvas.stage.addChild(container);

    for (const entry of entries) {
      const graphics = new PIXI.Graphics();
      const x = entry.token.center.x;
      const y = entry.token.center.y;

      graphics.lineStyle(3, 0x66ffcc, 1);
      graphics.drawCircle(x, y, 24);
      graphics.lineStyle(2, 0x66ffcc, 0.9);
      graphics.moveTo(x - 34, y);
      graphics.lineTo(x - 14, y);
      graphics.moveTo(x + 14, y);
      graphics.lineTo(x + 34, y);
      graphics.moveTo(x, y - 34);
      graphics.lineTo(x, y - 14);
      graphics.moveTo(x, y + 14);
      graphics.lineTo(x, y + 34);
      container.addChild(graphics);
    }

    container.alpha = 1;

    setTimeout(() => {
      try {
        canvas.stage.removeChild(container);
        container.destroy({ children: true });
      } catch (err) {
        console.warn("Drop Trooper | Failed to remove sensor sweep pings", err);
      }
    }, durationMs);
  }

  async _useSensorSweepAbility(ability) {
    const abilityName = ability.name || "Sensor Sweep";
    const skillKey = ability.system?.linkedSkill || "sensors";
    const flatBonus = Number(ability.system?.bonusDice) || 0;
    const poolData = this._getAdjustedSkillRollData(skillKey, this.actor);
    const rollData = poolData;
    const pendingBonus = rollData.pendingBonus;
    const pendingPenalty = rollData.pendingPenalty;
    const bonusDice = rollData.bonusDice;
    const penaltyDice = rollData.penaltyDice;
    const totalDice = Math.max(0, rollData.totalDice + flatBonus);
    const baseRange = this._getNumericValue(ability.system?.baseRange, 60);
    const rangePerSuccess = this._getNumericValue(ability.system?.rangePerSuccess, 30);
    const pingDurationMs = this._getNumericValue(ability.system?.pingDurationMs, 1500);
    const linkedSkillLabel = this._getSkillLabel(skillKey);
    const poolCurrent = Number(ability.system?.pool?.value) || 0;
    const poolMax = Number(ability.system?.pool?.max) || 0;

    if (poolMax > 0 && poolCurrent <= 0) {
      ui.notifications.warn(`${abilityName} has no uses remaining.`);
      return;
    }

    const sourceToken = this._getActorTokenOnCanvas();
    if (!sourceToken) {
      ui.notifications.warn(`${abilityName}: place or select this actor's token on the scene first.`);
      return;
    }

    const result = await this._rollVisibleDicePool(totalDice);
    await this._consumePendingStandardRollEffects(this.actor, rollData);
    const diceHtml = this._buildDiceHtml(result.dieResults, true);
    const totalRange = baseRange + (result.successes * rangePerSuccess);

    const smokeBlocked = this._isPointInsideSmoke(sourceToken.center);
    const detectedEntries = (result.successes <= 0 || smokeBlocked)
      ? []
      : this._getSensorSweepTargets(sourceToken, totalRange);

    if (poolMax > 0) {
      await ability.update({
        "system.pool.value": Math.max(0, poolCurrent - 1),
        "system.pool.max": poolMax
      });
    }

    await this._temporarilyRevealSensorSweepTargets(detectedEntries, pingDurationMs);
    await this._showSensorSweepPings(detectedEntries, pingDurationMs);

    const contactHtml = detectedEntries.length
      ? detectedEntries.map(entry => `
          <div class="dt-chat-line">
            <span class="dt-chat-strong">${entry.token.name}</span>
            <span class="dt-chat-small">(${Math.round(entry.distance)} ft${entry.wasHidden ? ", hidden" : ""})</span>
          </div>
        `).join("")
      : `<div class="dt-chat-small">${smokeBlocked ? "Sweep blocked by smoke." : "No contacts detected."}</div>`;

    const content = `
      <div class="dt-chat-card">
        <div class="dt-chat-header">
          <div class="dt-chat-title">${this.actor.name}</div>
          <div class="dt-chat-subtitle">${abilityName}</div>
        </div>
        <div class="dt-chat-body">
          <div class="dt-chat-section">
            <div class="dt-chat-grid">
              <div class="dt-chat-line"><span class="dt-chat-small">Linked Skill</span><br><span class="dt-chat-strong">${linkedSkillLabel}</span></div>
              ${this._getSkillBreakdownHtml(poolData)}
              <div class="dt-chat-line"><span class="dt-chat-small">Dice Rolled</span><br><span class="dt-chat-strong">${totalDice}d6</span></div>
              <div class="dt-chat-line"><span class="dt-chat-small">Ability Bonus</span><br><span class="dt-chat-strong">+${flatBonus}d6</span></div>
              ${bonusDice > 0 ? `<div class="dt-chat-line"><span class="dt-chat-small">${pendingBonus.source}</span><br><span class="dt-chat-strong">+${bonusDice}d6</span></div>` : ""}
              ${penaltyDice > 0 ? `<div class="dt-chat-line"><span class="dt-chat-small">${pendingPenalty.source}</span><br><span class="dt-chat-strong">-${penaltyDice}d6</span></div>` : ""}
              <div class="dt-chat-line"><span class="dt-chat-small">Base Range</span><br><span class="dt-chat-strong">${baseRange} ft</span></div>
              <div class="dt-chat-line"><span class="dt-chat-small">Range / Success</span><br><span class="dt-chat-strong">+${rangePerSuccess} ft</span></div>
              <div class="dt-chat-line"><span class="dt-chat-small">Successes</span><br><span class="dt-chat-strong">${result.successes}</span></div>
              <div class="dt-chat-line"><span class="dt-chat-small">Final Range</span><br><span class="dt-chat-strong">${totalRange} ft</span></div>
              ${poolMax > 0 ? `<div class="dt-chat-line"><span class="dt-chat-small">Uses Remaining</span><br><span class="dt-chat-strong">${Math.max(0, poolCurrent - 1)} / ${poolMax}</span></div>` : ""}
            </div>
            <div class="dt-chat-dice-row">${diceHtml}</div>
          </div>

          <div class="dt-chat-section">
            <h4>Sensor Contacts</h4>
            <div class="dt-chat-line">
              <span class="dt-chat-small">Detection Rules</span><br>
              <span class="dt-chat-strong">Sweeps all tokens in range, ignores walls, blocked by smoke.</span>
            </div>
            <div class="dt-chat-line dt-chat-line--compact">
              <span class="dt-chat-small">Contacts Found</span><br>
              <span class="dt-chat-strong">${detectedEntries.length}</span>
            </div>
            <div class="dt-chat-dice-row">
              ${contactHtml}
            </div>
          </div>

          ${ability.system?.notes ? `
          <div class="dt-chat-section">
            <div class="dt-chat-line"><span class="dt-chat-small">Notes</span><br><span class="dt-chat-strong">${ability.system.notes}</span></div>
          </div>` : ""}
        </div>
      </div>
    `;

    ChatMessage.create({
      speaker: ChatMessage.getSpeaker({ actor: this.actor }),
      content
    });

    if (result.successes >= 3) {
      await playDropTrooperCritSuccessCelebration();
    }
  }

  _getFlightMishapTable() {
    return [
      {
        label: "Overheat Warning",
        effect: "Jets sputter and cut out. Flight fails, the trooper stays grounded, and cannot use Flight again until next turn."
      },
      {
        label: "Spin Out",
        effect: "The suit yaws sideways. Drift 1d6 squares in a random direction, then land off-balance."
      },
      {
        label: "Hard Landing",
        effect: "The trooper gets airborne but crashes down early. Move only half distance, then lose 1 action next turn."
      },
      {
        label: "Thruster Flare",
        effect: "A bright exhaust bloom gives away the trooper's position. They are easy to spot until the end of the round."
      },
      {
        label: "Smoke Belch",
        effect: "The pack belches smoke and soot. Place a small smoke patch around the trooper until the end of the round."
      },
      {
        label: "Power Drain",
        effect: "The suit browns out. The trooper cannot Aim or Brace until next turn."
      },
      {
        label: "Wild Burst",
        effect: "The thrusters kick too hard. The trooper overshoots the landing point by a short distance and ends exposed."
      },
      {
        label: "Gyro Failure",
        effect: "The stabilizers glitch. The trooper lands where intended but ends prone or unstable."
      },
      {
        label: "Comms Screech",
        effect: "The suit screams static across local comms. Nearby allies are distracted, but nobody is harmed."
      },
      {
        label: "Control Lock",
        effect: "Flight fails completely. The trooper must manually reset the pack before trying again."
      }
    ];
  }

  async _rollFlightMishap() {
    const table = this._getFlightMishapTable();
    let total = 1;

    try {
      const roll = await new Roll(`1d10`).evaluate();
      total = Math.max(1, Math.min(10, Number(roll.total) || 1));

      if (game?.dice3d) {
        try {
          await game.dice3d.showForRoll(roll, game.user, true, null, false);
        } catch (err) {
          console.warn("Drop Trooper | Dice So Nice flight mishap roll failed", err);
        }
      }
    } catch (err) {
      console.warn("Drop Trooper | Flight mishap roll failed", err);
    }

    return {
      roll: total,
      ...table[total - 1]
    };
  }

  async _useFlightAbility(ability) {
    const abilityName = ability.name || "Flight";
    const skillKey = ability.system?.linkedSkill || "maneuvering";
    const flatBonus = Number(ability.system?.bonusDice) || 0;
    const poolData = this._getAdjustedSkillRollData(skillKey, this.actor);
    const rollData = poolData;
    const baseDice = rollData.baseDice;
    const pendingBonus = rollData.pendingBonus;
    const pendingPenalty = rollData.pendingPenalty;
    const bonusDice = rollData.bonusDice;
    const penaltyDice = rollData.penaltyDice;
    const totalDice = Math.max(0, rollData.totalDice + flatBonus);
    const linkedSkillLabel = this._getSkillLabel(skillKey);
    const poolCurrent = Number(ability.system?.pool?.value) || 0;
    const poolMax = Number(ability.system?.pool?.max) || 0;

    if (poolMax > 0 && poolCurrent <= 0) {
      ui.notifications.warn(`${abilityName} has no uses remaining.`);
      return;
    }

    const result = await this._rollVisibleDicePool(totalDice);
    await this._consumePendingStandardRollEffects(this.actor, rollData);

    let remainingUses = poolCurrent;
    if (poolMax > 0) {
      remainingUses = Math.max(0, poolCurrent - 1);
      await ability.update({
        "system.pool.value": remainingUses,
        "system.pool.max": poolMax
      });
    }

    const diceHtml = this._buildDiceHtml(result.dieResults, true);
    const mishap = result.successes > 0 ? null : await this._rollFlightMishap();
    const outcomeTitle = mishap ? "Flight Mishap" : "Flight Stable";
    const outcomeText = mishap
      ? mishap.label
      : "Flight engages normally. Resolve movement on the scene as usual.";
    const effectText = mishap
      ? mishap.effect
      : "No mishap triggered.";

    const content = `
      <div class="dt-chat-card">
        <div class="dt-chat-header">
          <div class="dt-chat-title">${this.actor.name}</div>
          <div class="dt-chat-subtitle">${abilityName}</div>
        </div>
        <div class="dt-chat-body">
          <div class="dt-chat-section">
            <div class="dt-chat-grid">
              <div class="dt-chat-line"><span class="dt-chat-small">Linked Skill</span><br><span class="dt-chat-strong">${linkedSkillLabel}</span></div>
              ${this._getSkillBreakdownHtml(poolData)}
              <div class="dt-chat-line"><span class="dt-chat-small">Dice Rolled</span><br><span class="dt-chat-strong">${totalDice}d6</span></div>
              <div class="dt-chat-line"><span class="dt-chat-small">Ability Bonus</span><br><span class="dt-chat-strong">+${flatBonus}d6</span></div>
              ${bonusDice > 0 ? `<div class="dt-chat-line"><span class="dt-chat-small">${pendingBonus.source}</span><br><span class="dt-chat-strong">+${bonusDice}d6</span></div>` : ""}
              ${penaltyDice > 0 ? `<div class="dt-chat-line"><span class="dt-chat-small">${pendingPenalty.source}</span><br><span class="dt-chat-strong">-${penaltyDice}d6</span></div>` : ""}
              <div class="dt-chat-line"><span class="dt-chat-small">Successes</span><br><span class="dt-chat-strong">${result.successes}</span></div>
              ${poolMax > 0 ? `<div class="dt-chat-line"><span class="dt-chat-small">Uses Remaining</span><br><span class="dt-chat-strong">${remainingUses} / ${poolMax}</span></div>` : ""}
            </div>
            <div class="dt-chat-dice-row">${diceHtml}</div>
          </div>

          <div class="dt-chat-section">
            <h4>${outcomeTitle}</h4>
            <div class="dt-chat-line dt-chat-line--compact"><span class="dt-chat-small">Result</span><br><span class="dt-chat-strong">${outcomeText}</span></div>
            ${mishap ? `<div class="dt-chat-line"><span class="dt-chat-small">Mishap Roll</span><br><span class="dt-chat-strong">${mishap.roll} / 10</span></div>` : ""}
            <div class="dt-chat-line"><span class="dt-chat-small">Effect</span><br><span class="dt-chat-strong">${effectText}</span></div>
          </div>

          ${ability.system?.notes ? `
          <div class="dt-chat-section">
            <div class="dt-chat-line"><span class="dt-chat-small">Notes</span><br><span class="dt-chat-strong">${ability.system.notes}</span></div>
          </div>` : ""}
        </div>
      </div>
    `;

    ChatMessage.create({
      speaker: ChatMessage.getSpeaker({ actor: this.actor }),
      content
    });

    if (result.successes >= 3) {
      await playDropTrooperCritSuccessCelebration();
    }
  }

  async _useCommandDiceAbility(ability) {
    return await this._runWithPendingGmApprovalLock("Command Dice request", async () => {

    const poolCurrent = Number(ability.system?.pool?.value) || 0;
    const poolMax = Number(ability.system?.pool?.max) || 0;
    const abilityName = ability.name || "Command Dice";

    if (poolCurrent <= 0) {
      ui.notifications.warn(`${abilityName} has no dice remaining.`);
      return;
    }

    const targetedTokens = Array.from(game.user?.targets || []).filter(token => token?.actor);
    if (targetedTokens.length !== 1) {
      ui.notifications.warn(`${abilityName}: target exactly 1 token first.`);
      return;
    }

    const targetToken = targetedTokens[0];
    const targetActor = targetToken.actor;
    if (!targetActor) {
      ui.notifications.warn(`${abilityName}: the targeted token does not have an actor.`);
      return;
    }

    const targetLabel = targetToken.name && targetToken.name !== targetActor.name
      ? `${targetToken.name} (${targetActor.name})`
      : (targetToken.name || targetActor.name || "Target");

    const dialogResult = await Dialog.wait({
      title: abilityName,
      content: `
        <form>
          <div class="form-group">
            <label>Target</label>
            <div><strong>${targetLabel}</strong></div>
          </div>
          <div class="form-group">
            <label>Dice to Spend (1-${poolCurrent})</label>
            <input type="number" name="spendDice" min="1" max="${poolCurrent}" value="1" />
          </div>
        </form>
      `,
      buttons: {
        use: {
          label: "Use",
          callback: (html) => {
            const spendDice = Number(html.find('[name="spendDice"]').val()) || 0;
            return { spendDice };
          }
        },
        cancel: {
          label: "Cancel",
          callback: () => null
        }
      },
      default: "use",
      close: () => null
    });

    if (!dialogResult) return;

    const spendDice = Number(dialogResult.spendDice) || 0;
    if (spendDice <= 0 || spendDice > poolCurrent) {
      ui.notifications.warn(`${abilityName}: choose a valid number of dice to spend.`);
      return;
    }

    const canApplyDirectly = game.user?.isGM || targetActor?.isOwner === true;
    let existingBonus = this._getPendingRollBonus(targetActor);
    let existingBonusDice = existingBonus?.dice || 0;
    let totalGrantedDice = existingBonusDice + spendDice;
    let bonusSource = abilityName;
    let pendingApproval = false;

    if (canApplyDirectly) {
      const existingSources = String(existingBonus?.source || "")
        .split("+")
        .map(part => part.trim())
        .filter(Boolean);
      bonusSource = existingSources.includes(abilityName)
        ? existingSources.join(" + ") || abilityName
        : [...existingSources, abilityName].filter(Boolean).join(" + ") || abilityName;

      await this._setPendingRollBonus(targetActor, totalGrantedDice, bonusSource);
    } else {
      const queuedResult = await this._queueCommandDiceForGmApproval(targetActor, spendDice, {
        sourceActor: this.actor,
        sourceToken: this.actor?.getActiveTokens?.()[0] || null,
        targetToken,
        targetName: targetLabel,
        abilityName,
        abilityItemId: ability.id
      });

      if (queuedResult?.applyFailed) {
        return;
      }

      existingBonusDice = queuedResult?.existingBonusDice || 0;
      totalGrantedDice = queuedResult?.totalGrantedDice || (existingBonusDice + spendDice);
      bonusSource = queuedResult?.bonusSource || abilityName;
      pendingApproval = true;
    }

    await ability.update({
      "system.pool.value": poolCurrent - spendDice,
      "system.pool.max": poolMax
    });

    const content = `
      <div class="dt-chat-card">
        <div class="dt-chat-header">
          <div class="dt-chat-title">${this.actor.name}</div>
          <div class="dt-chat-subtitle">${abilityName}</div>
        </div>
        <div class="dt-chat-body">
          <div class="dt-chat-section">
            <div class="dt-chat-grid">
              <div class="dt-chat-line"><span class="dt-chat-small">Target</span><br><span class="dt-chat-strong">${targetLabel}</span></div>
              <div class="dt-chat-line"><span class="dt-chat-small">Dice Spent</span><br><span class="dt-chat-strong">${spendDice}</span></div>
              <div class="dt-chat-line"><span class="dt-chat-small">Dice Granted</span><br><span class="dt-chat-strong">+${spendDice}d6</span></div>
              ${existingBonusDice > 0 ? `<div class="dt-chat-line"><span class="dt-chat-small">Existing Bonus</span><br><span class="dt-chat-strong">+${existingBonusDice}d6</span></div>` : ""}
              <div class="dt-chat-line"><span class="dt-chat-small">Next Roll Bonus</span><br><span class="dt-chat-strong">+${totalGrantedDice}d6</span></div>
              <div class="dt-chat-line"><span class="dt-chat-small">Pool Remaining</span><br><span class="dt-chat-strong">${poolCurrent - spendDice} / ${poolMax}</span></div>
            </div>
            <div class="dt-chat-line dt-chat-line--compact"><span class="dt-chat-small">Result</span><br><span class="dt-chat-strong">${pendingApproval ? `${targetLabel}'s next roll bonus is waiting for GM approval.` : `${targetLabel}'s next roll gains +${totalGrantedDice}d6. If that roll is an attack, the bonus applies to the attack roll only, not the damage roll.`}</span></div>
          </div>
        </div>
      </div>
    `;

    ChatMessage.create({
      speaker: ChatMessage.getSpeaker({ actor: this.actor }),
      content
    });

    return true;
    });
  }

  async _onAbilityReset(event) {
    event.preventDefault();

    if (!game.user?.isGM && this._isDroneActor(this.actor)) {
      ui.notifications.warn("Only the GM can reset drone ability pools.");
      return;
    }

    const itemId = event.currentTarget.dataset.itemId;
    const ability = this.actor.items.get(itemId);
    if (!ability) return;

    const max = Number(ability.system?.pool?.max) || 0;
    await ability.update({
      "system.pool.value": max
    });

    ui.notifications.info(`${ability.name} reset to ${max}.`);
  }

  async _onAbilityEdit(event) {
    event.preventDefault();

    if (!game.user?.isGM && this._isDroneActor(this.actor)) {
      ui.notifications.warn("Only the GM can edit drone abilities.");
      return;
    }

    const itemId = event.currentTarget.dataset.itemId;
    const ability = this.actor.items.get(itemId);

    if (!ability) {
      ui.notifications.warn("Ability not found.");
      return;
    }

    ability.sheet.render(true);
  }

  async _onAbilityDelete(event) {
    event.preventDefault();

    if (!game.user?.isGM && this._isDroneActor(this.actor)) {
      ui.notifications.warn("Only the GM can delete drone abilities.");
      return;
    }

    const itemId = event.currentTarget.dataset.itemId;
    const ability = this.actor.items.get(itemId);
    if (!ability) return;

    const confirmed = await Dialog.confirm({
      title: "Delete Ability",
      content: `<p>Delete <strong>${ability.name}</strong> from ${this.actor.name}?</p>`
    });

    if (!confirmed) return;

    await ability.delete();
  }

  async _onAim(event) {
    event.preventDefault();

    await this._setPendingAttackAim(this.actor, 2, "Aim");

    const content = `
      <div class="dt-chat-card">
        <div class="dt-chat-header">
          <div class="dt-chat-title">${this.actor.name}</div>
          <div class="dt-chat-subtitle">Aim</div>
        </div>
        <div class="dt-chat-body">
          <div class="dt-chat-section">
            <div class="dt-chat-grid">
              <div class="dt-chat-line">
                <span class="dt-chat-small">Next Attack Bonus</span><br>
                <span class="dt-chat-final">+2d6</span>
              </div>
            </div>
            <div class="dt-chat-line dt-chat-line--compact">
              <span class="dt-chat-small">Result</span><br>
              <span class="dt-chat-strong">Aim active: next attack roll gains +2 dice.</span>
            </div>
          </div>
        </div>
      </div>
    `;

    ChatMessage.create({
      speaker: ChatMessage.getSpeaker({ actor: this.actor }),
      content
    });
  }

  async _onBrace(event) {
    event.preventDefault();

    const defensePool = Number(this.actor.system.skills?.defense) || 0;

    if (defensePool <= 0) {
      ui.notifications.warn(`${this.actor.name} has no Defense dice for Brace.`);
      return;
    }

    await this._setPendingDefenseBrace(this.actor, 2, "Brace");

    const content = `
      <div class="dt-chat-card">
        <div class="dt-chat-header">
          <div class="dt-chat-title">${this.actor.name}</div>
          <div class="dt-chat-subtitle">Brace</div>
        </div>
        <div class="dt-chat-body">
          <div class="dt-chat-section">
            <div class="dt-chat-grid">
              <div class="dt-chat-line">
                <span class="dt-chat-small">Current Defense</span><br>
                <span class="dt-chat-strong">${defensePool}d6</span>
              </div>
              <div class="dt-chat-line">
                <span class="dt-chat-small">Next Defense Roll</span><br>
                <span class="dt-chat-final">${defensePool * 2}d6</span>
              </div>
            </div>
            <div class="dt-chat-line dt-chat-line--compact">
              <span class="dt-chat-small">Result</span><br>
              <span class="dt-chat-strong">Brace active: next defense roll is doubled.</span>
            </div>
          </div>
        </div>
      </div>
    `;

    ChatMessage.create({
      speaker: ChatMessage.getSpeaker({ actor: this.actor }),
      content
    });
  }

  async _onRollDefense(event) {
    const defenseData = this._getAdjustedDefenseRollData(this.actor);

    await this._rollPool("Defense", defenseData.totalDice, "defense", {
      baseDice: defenseData.baseDice,
      bonusDice: defenseData.bonusDice,
      penaltyDice: defenseData.penaltyDice,
      bonusSource: defenseData.pendingBonus?.source,
      penaltySource: defenseData.pendingPenalty?.source,
      defenseMultiplier: defenseData.braceMultiplier,
      defenseMultiplierSource: defenseData.pendingBrace?.source,
      preMultiplierDice: defenseData.preBraceDice,
      consumeBonus: defenseData.bonusDice > 0,
      consumePenalty: defenseData.penaltyDice > 0,
      consumeBrace: defenseData.braceMultiplier > 1
    });
  }

  async _onRollDamage(event) {
    const baseDamage = Number(this.actor.system.weapon?.baseDamage) || 0;

    if (baseDamage <= 0) {
      ui.notifications.warn("Base Damage Dice must be at least 1.");
      return;
    }

    const roll = await this._rollDamageDice(baseDamage);
    const diceHtml = this._buildDiceHtml(roll.dieResults, false);

    const content = `
      <div class="dt-chat-card">
        <div class="dt-chat-header">
          <div class="dt-chat-title">${this.actor.name}</div>
          <div class="dt-chat-subtitle">Manual Damage Roll</div>
        </div>
        <div class="dt-chat-body">
          <div class="dt-chat-section">
            <div class="dt-chat-grid">
              <div class="dt-chat-line"><span class="dt-chat-small">Weapon</span><br><span class="dt-chat-strong">${this.actor.system.weapon?.name || "Weapon"}</span></div>
              <div class="dt-chat-line"><span class="dt-chat-small">Base Damage</span><br><span class="dt-chat-strong">${baseDamage}d6</span></div>
            </div>
            <div class="dt-chat-dice-row">${diceHtml}</div>
            <div class="dt-chat-line dt-chat-line--compact"><span class="dt-chat-small">Total Damage</span><br><span class="dt-chat-final">${roll.total}</span></div>
          </div>
        </div>
      </div>
    `;

    ChatMessage.create({
      speaker: ChatMessage.getSpeaker({ actor: this.actor }),
      content
    });
  }

  async _onDeployAssignedDrone(event) {
    event.preventDefault();

    if (String(this.actor?.type || "") !== "trooper") return;

    try {
      const selectedDrone = await this._promptTrooperDroneSelection(this.actor, {
        title: `${this.actor?.name || "Trooper"} • Deploy Drone`,
        confirmLabel: "Deploy"
      });
      if (!selectedDrone) return;

      const result = await requestOrPerformDropTrooperDroneDeploy(this.actor.id, selectedDrone.id);
      if (result?.message) {
        ui.notifications.info(result.message);
      }
    } catch (err) {
      console.warn("Drop Trooper | Drone deploy failed", err);
      ui.notifications.error(err?.message || `Failed to deploy the assigned drone for ${this.actor?.name || "trooper"}.`);
    }
  }

  async _onRecallAssignedDrone(event) {
    event.preventDefault();

    if (String(this.actor?.type || "") !== "trooper") return;

    try {
      const result = await requestOrPerformDropTrooperDroneRecall(this.actor.id);
      if (result?.message) {
        ui.notifications.info(result.message);
      }
    } catch (err) {
      console.warn("Drop Trooper | Drone recall failed", err);
      ui.notifications.error(err?.message || `Failed to recall the assigned drone for ${this.actor?.name || "trooper"}.`);
    }
  }

  async _onToggleOutOfArmor(event) {
    event.preventDefault();

    if (String(this.actor?.type || "") !== "trooper") return;

    const mode = String(event?.currentTarget?.dataset?.armorMode || "").trim() || "toggle";

    try {
      const result = await requestOrPerformDropTrooperArmorToggle(this.actor.id, mode);
      if (result?.message) {
        ui.notifications.info(result.message);
      }
    } catch (err) {
      console.warn("Drop Trooper | Out of armor toggle failed", err);
      ui.notifications.error(err?.message || `Failed to change armor state for ${this.actor?.name || "trooper"}.`);
    }
  }

  async _onNanoRepair(event) {
    event.preventDefault();
    await AbilityService.nanoRepair(this.actor);
  }

}

class DropTrooperWeaponSheet extends ItemSheet {
  static get defaultOptions() {
    return foundry.utils.mergeObject(super.defaultOptions, {
      classes: ["drop-trooper", "sheet", "item"],
      width: 600,
      height: 700,
      resizable: true
    });
  }

  get template() {
    if (this.item.type === "ability") {
      return "systems/drop-trooper/templates/actor/ability-sheet.hbs";
    }

    return "systems/drop-trooper/templates/actor/weapon-sheet.hbs";
  }

  getData() {
    const data = super.getData();
    data.system = this.item.system;
    return data;
  }

  activateListeners(html) {
    super.activateListeners(html);
    applyDropTrooperItemSheetPermissions(html, this);
  }
}

const DROP_TROOPER_PLAYER_DIRECT_TROOPER_FIELDS = new Set([
  "system.identity.callsign",
  "system.identity.squad",
  "system.identity.role",
  "system.identity.rank",
  "system.identity.player",
  "system.combat.momentum.value",
  "system.armor.integrity.value",
  "system.health.value",
  "system.armor.notes"
]);

const DROP_TROOPER_PLAYER_DIRECT_TROOPER_BUTTON_SELECTORS = [
  ".dt-side-tab",
  ".roll-attribute",
  ".roll-skill",
  ".roll-defense",
  ".weapon-attack",
  ".weapon-reload",
  ".ability-use",
  ".nano-repair",
  ".drone-deploy",
  ".drone-recall"
];

const DROP_TROOPER_PLAYER_DIRECT_DRONE_BUTTON_SELECTORS = [
  ".roll-skill",
  ".roll-defense",
  ".weapon-attack",
  ".weapon-reload",
  ".ability-use"
];

function getDropTrooperDefaultHasReaction(actor) {
  if (!actor) return false;
  if (actor.type === "trooper") return true;
  return false;
}

function getDropTrooperReactionState(actor) {
  const combat = actor?.system?.combat || {};
  const hasReaction = combat.hasReaction !== undefined
    ? Boolean(combat.hasReaction)
    : getDropTrooperDefaultHasReaction(actor);
  const reactionAvailable = hasReaction && (combat.reactionAvailable !== undefined ? Boolean(combat.reactionAvailable) : true);
  const overwatch = hasReaction && Boolean(combat.overwatch);
  return { hasReaction, reactionAvailable, overwatch };
}

async function ensureDropTrooperReactionDefaults() {
  if (!game.user?.isGM) return;
  const updates = [];
  for (const actor of game.actors || []) {
    const combat = actor?.system?.combat || {};
    const hasReaction = combat.hasReaction !== undefined ? Boolean(combat.hasReaction) : getDropTrooperDefaultHasReaction(actor);
    const reactionAvailable = hasReaction ? (combat.reactionAvailable !== undefined ? Boolean(combat.reactionAvailable) : true) : false;
    const overwatch = hasReaction ? Boolean(combat.overwatch) : false;
    const actorUpdates = { _id: actor.id };
    let changed = false;
    if (combat.hasReaction === undefined) { actorUpdates["system.combat.hasReaction"] = hasReaction; changed = true; }
    if (combat.reactionAvailable === undefined) { actorUpdates["system.combat.reactionAvailable"] = reactionAvailable; changed = true; }
    if (combat.overwatch === undefined) { actorUpdates["system.combat.overwatch"] = overwatch; changed = true; }
    if (changed) updates.push(actorUpdates);
  }
  if (updates.length) {
    await Actor.updateDocuments(updates);
  }
}

async function refreshDropTrooperTurnReactionState(combat) {
  if (!game.user?.isGM || !combat) return;
  const updates = [];
  const actorIds = new Set();
  for (const combatant of combat.combatants || []) {
    const actor = combatant?.actor;
    if (!actor || actorIds.has(actor.id)) continue;
    actorIds.add(actor.id);
    const state = getDropTrooperReactionState(actor);
    if (!state.hasReaction) continue;
    updates.push({ _id: actor.id, "system.combat.reactionAvailable": true, "system.combat.overwatch": false });
  }
  if (updates.length) await Actor.updateDocuments(updates);
}

const DROP_TROOPER_SHEET_CHANGE_RULES = {
  trooper: {
    "system.attributes.strength": { type: "number", label: "STR" },
    "system.attributes.agility": { type: "number", label: "AGI" },
    "system.attributes.perception": { type: "number", label: "PER" },
    "system.attributes.tech": { type: "number", label: "TEC" },
    "system.attributes.will": { type: "number", label: "WIL" },
    "system.combat.initiative": { type: "number", label: "Initiative" },
    "system.combat.momentum.max": { type: "number", label: "Momentum Max" },
    "system.combat.speed": { type: "number", label: "Speed" },
    "system.combat.hasReaction": { type: "boolean", label: "Reactions Enabled" },
    "system.combat.reactionAvailable": { type: "boolean", label: "Reaction Available" },
    "system.combat.overwatch": { type: "boolean", label: "On Overwatch" },
    "system.combat.suppressed": { type: "boolean", label: "Suppressed" },
    "system.drone.uses": { type: "number", label: "Drone Uses" },
    "system.drone.usesMax": { type: "number", label: "Drone Max Uses" },
    "system.drone.assignedActorId": { type: "multiline", label: "Assigned Drone Actor IDs" },
    "system.drone.assignedActorName": { type: "multiline", label: "Assigned Drone Names" },
    "system.armor.tier": { type: "enum", label: "Armor Tier", choices: ["Light", "Medium", "Heavy", "Ultra"] },
    "system.armor.integrity.max": { type: "number", label: "Integrity Max" },
    "system.health.max": { type: "number", label: "Health Max" },
    "system.nanoRepair.uses": { type: "number", label: "Nano Uses" },
    "system.systemDamage.leftArm": { type: "boolean", label: "Left Arm" },
    "system.systemDamage.rightArm": { type: "boolean", label: "Right Arm" },
    "system.systemDamage.leftLeg": { type: "boolean", label: "Left Leg" },
    "system.systemDamage.rightLeg": { type: "boolean", label: "Right Leg" },
    "system.systemDamage.sensors": { type: "boolean", label: "Sensors / Vision" },
    "system.systemDamage.thrusters": { type: "boolean", label: "Thrusters / Flight" },
    "system.skills.shooting": { type: "number", label: "Shooting" },
    "system.skills.maneuvering": { type: "number", label: "Maneuvering" },
    "system.skills.melee": { type: "number", label: "Melee" },
    "system.skills.heavyWeapons": { type: "number", label: "Heavy Weapons" },
    "system.skills.recon": { type: "number", label: "Recon" },
    "system.skills.sensors": { type: "number", label: "Sensors" },
    "system.skills.electronics": { type: "number", label: "Electronics" },
    "system.skills.engineering": { type: "number", label: "Engineering" },
    "system.skills.droneControl": { type: "number", label: "Drone Control" },
    "system.skills.command": { type: "number", label: "Command" },
    "system.skills.discipline": { type: "number", label: "Discipline" },
    "system.skills.survival": { type: "number", label: "Survival" },
    "system.skills.defense": { type: "number", label: "Defense Dice" }
  }
};

function getDropTrooperSheetChangeRule(actorType, fieldPath) {
  const actorRules = DROP_TROOPER_SHEET_CHANGE_RULES[String(actorType || "")] || null;
  if (!actorRules) return null;
  return actorRules[String(fieldPath || "")] || null;
}

function formatDropTrooperSheetChangeValue(value, rule = {}) {
  const type = String(rule?.type || "string");
  if (type === "boolean") {
    return value ? "Yes" : "No";
  }

  if (type === "multiline") {
    const lines = String(value ?? "")
      .split(/\r?\n/)
      .map(part => part.trim())
      .filter(Boolean);
    return lines.length ? lines.join(" • ") : "—";
  }

  if (type === "enum") {
    return String(value ?? "").trim() || "—";
  }

  if (type === "number") {
    return Number.isFinite(Number(value)) ? String(Number(value)) : "0";
  }

  return String(value ?? "").trim() || "—";
}

function normalizeDropTrooperRequestedSheetChangeValue(actorType, fieldPath, value) {
  const rule = getDropTrooperSheetChangeRule(actorType, fieldPath);
  if (!rule) {
    throw new Error("That sheet field cannot be changed through the GM queue.");
  }

  const type = String(rule.type || "string");
  if (type === "number") {
    const numeric = Number(value);
    if (!Number.isFinite(numeric)) {
      throw new Error(`${rule.label || "That field"} needs a valid number.`);
    }
    return numeric;
  }

  if (type === "boolean") {
    if (typeof value === "string") {
      const normalized = value.trim().toLowerCase();
      return normalized === "true" || normalized === "1" || normalized === "yes" || normalized === "on";
    }
    return !!value;
  }

  if (type === "enum") {
    const normalized = String(value ?? "").trim();
    const choices = Array.isArray(rule.choices) ? rule.choices.map(choice => String(choice)) : [];
    if (!choices.includes(normalized)) {
      throw new Error(`${rule.label || "That field"} must be one of: ${choices.join(", ")}.`);
    }
    return normalized;
  }

  if (type === "multiline") {
    return String(value ?? "").replace(/\r\n/g, "\n").trim();
  }

  return String(value ?? "").trim();
}

function areDropTrooperSheetChangeValuesEqual(actorType, fieldPath, leftValue, rightValue) {
  const normalizedLeft = normalizeDropTrooperRequestedSheetChangeValue(actorType, fieldPath, leftValue);
  const normalizedRight = normalizeDropTrooperRequestedSheetChangeValue(actorType, fieldPath, rightValue);
  return foundry.utils.isEmpty(normalizedLeft) && foundry.utils.isEmpty(normalizedRight)
    ? true
    : JSON.stringify(normalizedLeft) === JSON.stringify(normalizedRight);
}

function getDropTrooperControlCurrentValue(control) {
  if (!control) return null;
  if (control.type === "checkbox") return !!control.checked;
  return control.value;
}

function getDropTrooperControlLabel(control) {
  if (!control) return String(control?.name || "Field");

  const rowLabel = control.closest(".dt-skill-row")?.querySelector("label");
  if (rowLabel?.textContent?.trim()) return rowLabel.textContent.trim();

  const cardTitle = control.closest(".dt-item-card")?.querySelector(".dt-item-title");
  if (cardTitle?.textContent?.trim()) return cardTitle.textContent.trim();

  let cursor = control.previousElementSibling;
  while (cursor) {
    if (cursor.matches?.("label")) {
      const text = cursor.textContent?.trim();
      if (text) return text;
    }
    cursor = cursor.previousElementSibling;
  }

  const checkLabel = control.closest("label.dt-check");
  if (checkLabel?.textContent?.trim()) {
    return checkLabel.textContent.trim().replace(/\s+/g, " ");
  }

  return String(control.name || "Field").trim() || "Field";
}

function isDropTrooperQueuedSheetChangeControl(control, actorType) {
  const fieldPath = String(control?.name || "").trim();
  if (!fieldPath) return false;
  if (!getDropTrooperSheetChangeRule(actorType, fieldPath)) return false;
  if (String(actorType || "") === "trooper" && DROP_TROOPER_PLAYER_DIRECT_TROOPER_FIELDS.has(fieldPath)) return false;
  return true;
}

function restoreDropTrooperSheetChangeControlValue(control, actor) {
  if (!control || !actor) return;
  const fieldPath = String(control.name || "").trim();
  const value = foundry.utils.getProperty(actor, fieldPath);

  if (control.type === "checkbox") {
    control.checked = !!value;
    return;
  }

  control.value = value == null ? "" : String(value);
}

function markDropTrooperSheetChangeControlEditable(control, actorType) {
  if (!control || !isDropTrooperQueuedSheetChangeControl(control, actorType)) return;
  control.disabled = false;
  control.readOnly = false;
  control.classList?.add("dt-sheet-change-input");

  if (control.tagName === "TEXTAREA") {
    control.title = "GM approval required. Use Ctrl+Enter to send a request.";
  } else if (control.matches?.("select") || control.type === "checkbox") {
    control.title = "GM approval required. Changing this will send a request.";
  } else {
    control.title = "GM approval required. Press Enter to send a request.";
  }
}

async function sendDropTrooperSheetChangeRequestFromControl(control, actor) {
  const fieldPath = String(control?.name || "").trim();
  if (!fieldPath || !actor) return;

  try {
    const result = await requestOrPerformDropTrooperSheetChange(actor.id, fieldPath, getDropTrooperControlCurrentValue(control), {
      fieldLabel: getDropTrooperControlLabel(control)
    });

    restoreDropTrooperSheetChangeControlValue(control, actor);

    if (result?.message) ui.notifications.info(result.message);
  } catch (err) {
    restoreDropTrooperSheetChangeControlValue(control, actor);
    ui.notifications.warn(err?.message || "Could not send that sheet change request.");
  }
}

async function promptDropTrooperSheetChangeRequest(control, actorType) {
  const fieldPath = String(control?.name || "").trim();
  const rule = getDropTrooperSheetChangeRule(actorType, fieldPath);
  if (!rule) return null;

  const label = rule.label || getDropTrooperControlLabel(control);
  const currentValue = getDropTrooperControlCurrentValue(control);
  const currentDisplay = formatDropTrooperSheetChangeValue(currentValue, rule);
  const dialogId = `dt-sheet-change-${foundry.utils.randomID()}`;

  let valueHtml = "";
  if (rule.type === "boolean") {
    valueHtml = `
      <label style="display:block;margin-bottom:6px;font-weight:700;">Requested Value</label>
      <select name="requestedValue" style="width:100%;">
        <option value="true" ${currentValue ? "selected" : ""}>Yes</option>
        <option value="false" ${!currentValue ? "selected" : ""}>No</option>
      </select>
    `;
  } else if (rule.type === "enum") {
    const options = (rule.choices || []).map(choice => {
      const selected = String(choice) === String(currentValue ?? "") ? "selected" : "";
      return `<option value="${escapeDropTrooperHtml(choice)}" ${selected}>${escapeDropTrooperHtml(choice)}</option>`;
    }).join("");
    valueHtml = `
      <label style="display:block;margin-bottom:6px;font-weight:700;">Requested Value</label>
      <select name="requestedValue" style="width:100%;">${options}</select>
    `;
  } else if (rule.type === "multiline") {
    valueHtml = `
      <label style="display:block;margin-bottom:6px;font-weight:700;">Requested Value</label>
      <textarea name="requestedValue" rows="5" style="width:100%;resize:vertical;">${escapeDropTrooperHtml(String(currentValue ?? ""))}</textarea>
    `;
  } else {
    const inputType = rule.type === "number" ? "number" : "text";
    valueHtml = `
      <label style="display:block;margin-bottom:6px;font-weight:700;">Requested Value</label>
      <input type="${inputType}" name="requestedValue" value="${escapeDropTrooperHtml(String(currentValue ?? ""))}" style="width:100%;" />
    `;
  }

  return await new Promise(resolve => {
    let settled = false;
    const finish = result => {
      if (settled) return;
      settled = true;
      resolve(result);
    };

    new Dialog({
      title: `Request GM Change: ${label}`,
      content: `
        <form id="${dialogId}" class="drop-trooper-sheet-change-request" style="display:grid;gap:8px;">
          <div><strong>Field:</strong> ${escapeDropTrooperHtml(label)}</div>
          <div><strong>Current:</strong> ${escapeDropTrooperHtml(currentDisplay)}</div>
          ${valueHtml}
        </form>
      `,
      buttons: {
        submit: {
          label: "Send Request",
          callback: html => {
            const root = html?.[0]?.querySelector?.(`#${dialogId}`) || html?.[0];
            const input = root?.querySelector?.("[name='requestedValue']");
            if (!input) {
              finish(null);
              return;
            }
            finish(input.type === "checkbox" ? !!input.checked : input.value);
          }
        },
        cancel: {
          label: "Cancel",
          callback: () => finish(null)
        }
      },
      default: "submit",
      close: () => finish(null)
    }).render(true);
  });
}

async function requestOrPerformDropTrooperSheetChange(actorId, fieldPath, requestedValue, options = {}) {
  const actor = game.actors?.get(String(actorId || "").trim());
  if (!actor || String(actor.type || "") !== "trooper") {
    throw new Error("Trooper not found for that sheet change request.");
  }

  const rule = getDropTrooperSheetChangeRule(actor.type, fieldPath);
  if (!rule) {
    throw new Error("That sheet field cannot be changed through the GM queue.");
  }

  const normalizedValue = normalizeDropTrooperRequestedSheetChangeValue(actor.type, fieldPath, requestedValue);
  const currentValue = foundry.utils.getProperty(actor, fieldPath);
  if (areDropTrooperSheetChangeValuesEqual(actor.type, fieldPath, currentValue, normalizedValue)) {
    throw new Error(`${rule.label || "That field"} is already set to that value.`);
  }

  if (game.user?.isGM) {
    await actor.update({ [fieldPath]: normalizedValue });
    return {
      ok: true,
      applied: true,
      message: `${actor.name}: ${rule.label || "sheet change"} updated.`
    };
  }

  const approvalWindowOpened = await beginDropTrooperPendingApprovalWindow(game.user?.id, "sheet change request");
  if (!approvalWindowOpened) {
    throw new Error("Finish the pending GM approval before starting another sheet change request.");
  }

  try {
    await createDropTrooperGmDamageApprovalMessage({
      requestType: "sheetChange",
      sourceActorId: actor.id,
      sourceActorName: actor.name || "Trooper",
      trooperActorId: actor.id,
      targetName: actor.name || "Trooper",
      requestedByUserId: game.user?.id || "",
      requestedByName: game.user?.name || "Player",
      fieldPath,
      fieldLabel: String(options.fieldLabel || rule.label || fieldPath).trim(),
      currentValue,
      currentValueDisplay: formatDropTrooperSheetChangeValue(currentValue, rule),
      requestedValue: normalizedValue,
      requestedValueDisplay: formatDropTrooperSheetChangeValue(normalizedValue, rule)
    });

    return {
      ok: true,
      queued: true,
      message: `${actor.name}: ${rule.label || "sheet change"} request sent to the GM queue.`
    };
  } catch (err) {
    await releaseDropTrooperPendingApprovalWindow(game.user?.id);
    throw err;
  }
}

function setDropTrooperControlLocked(control, locked = true) {
  if (!control) return;
  if (control.matches?.("button")) {
    control.disabled = !!locked;
    return;
  }

  control.disabled = !!locked;
  control.readOnly = !!locked;
}

function applyDropTrooperActorSheetPermissions(html, sheet) {
  if (game.user?.isGM) return;

  const actor = sheet?.actor;
  const actorType = String(actor?.type || "");
  const root = html?.[0] || html;
  if (!actor || !root?.querySelectorAll) return;

  root.querySelectorAll("img[data-edit]").forEach(img => {
    img.style.pointerEvents = "none";
    img.style.opacity = "0.9";
    img.title = `${img.title || actor.name || "Sheet"} (GM only edit)`;
  });

  if (actorType === "trooper") {
    root.querySelectorAll("input[name], select[name], textarea[name], button").forEach(control => {
      setDropTrooperControlLocked(control, true);
    });

    for (const fieldPath of DROP_TROOPER_PLAYER_DIRECT_TROOPER_FIELDS) {
      const control = root.querySelector(`[name="${CSS.escape(fieldPath)}"]`);
      setDropTrooperControlLocked(control, false);
    }

    const requestableControls = Array.from(root.querySelectorAll("input[name], select[name], textarea[name]"))
      .filter(control => isDropTrooperQueuedSheetChangeControl(control, actor.type));

    for (const control of requestableControls) {
      markDropTrooperSheetChangeControlEditable(control, actor.type);
      restoreDropTrooperSheetChangeControlValue(control, actor);
    }

    for (const selector of DROP_TROOPER_PLAYER_DIRECT_TROOPER_BUTTON_SELECTORS) {
      root.querySelectorAll(selector).forEach(button => {
        button.disabled = false;
      });
    }

    root.querySelectorAll(".weapon-delete, .ability-delete, .ability-create, .weapon-create, .ability-reset").forEach(button => {
      button.disabled = true;
    });

    attachDropTrooperSheetChangeInputRequests(root, actor);
    return;
  }

  if (actorType === "drone") {
    root.querySelectorAll("input[name], select[name], textarea[name], button").forEach(control => {
      setDropTrooperControlLocked(control, true);
    });

    for (const selector of DROP_TROOPER_PLAYER_DIRECT_DRONE_BUTTON_SELECTORS) {
      root.querySelectorAll(selector).forEach(button => {
        button.disabled = false;
      });
    }

    root.querySelectorAll(".weapon-delete, .ability-delete, .ability-create, .weapon-create, .ability-reset").forEach(button => {
      button.disabled = true;
    });

    root.querySelectorAll(".weapon-edit, .ability-edit, .dt-drag-handle").forEach(control => {
      control.style.pointerEvents = "none";
      control.style.opacity = "0.6";
      control.title = "GM only edit";
    });
  }
}

function attachDropTrooperSheetChangeInputRequests(root, actor) {
  if (!root?.querySelectorAll || !actor) return;

  const requestableControls = Array.from(root.querySelectorAll("input[name], select[name], textarea[name]"))
    .filter(control => isDropTrooperQueuedSheetChangeControl(control, actor.type));

  for (const control of requestableControls) {
    if (control.dataset.dtSheetRequestBound === "true") continue;
    control.dataset.dtSheetRequestBound = "true";

    control.addEventListener("keydown", async event => {
      const isTextarea = control.tagName === "TEXTAREA";
      const shouldSubmit = event.key === "Enter" && (!isTextarea || event.ctrlKey || event.metaKey);
      if (!shouldSubmit) return;

      event.preventDefault();
      event.stopPropagation();

      await sendDropTrooperSheetChangeRequestFromControl(control, actor);
    });

    control.addEventListener("change", async event => {
      if (control.matches?.("select") || control.type === "checkbox") {
        event.preventDefault();
        event.stopPropagation();
        await sendDropTrooperSheetChangeRequestFromControl(control, actor);
        return;
      }

      event.preventDefault();
      event.stopPropagation();
    });

    control.addEventListener("blur", () => {
      restoreDropTrooperSheetChangeControlValue(control, actor);
    });
  }
}

function applyDropTrooperItemSheetPermissions(html, sheet) {
  if (game.user?.isGM) return;

  const root = html?.[0] || html;
  if (!root?.querySelectorAll) return;

  root.querySelectorAll("img[data-edit]").forEach(img => {
    img.style.pointerEvents = "none";
    img.style.opacity = "0.9";
    img.title = `${img.title || sheet?.item?.name || "Item"} (GM only edit)`;
  });

  root.querySelectorAll("input[name], select[name], textarea[name], button").forEach(control => {
    setDropTrooperControlLocked(control, true);
  });
}

function getDropTrooperOutOfArmorState(actor) {
  const raw = actor?.getFlag?.("drop-trooper", DROP_TROOPER_OUT_OF_ARMOR_FLAG) || actor?.flags?.["drop-trooper"]?.[DROP_TROOPER_OUT_OF_ARMOR_FLAG] || {};
  return {
    active: !!raw?.active,
    savedArmorTier: String(raw?.savedArmorTier || "").trim() || "",
    savedIntegrityValue: Number.isFinite(Number(raw?.savedIntegrityValue)) ? Number(raw.savedIntegrityValue) : null,
    savedIntegrityMax: Number.isFinite(Number(raw?.savedIntegrityMax)) ? Number(raw.savedIntegrityMax) : null,
    armoredTokenImage: String(raw?.armoredTokenImage || "").trim(),
    unarmoredTokenImage: String(raw?.unarmoredTokenImage || "").trim(),
    shellTileId: String(raw?.shellTileId || "").trim(),
    shellSceneId: String(raw?.shellSceneId || "").trim()
  };
}

function isDropTrooperActorOutOfArmor(actor) {
  return getDropTrooperOutOfArmorState(actor).active;
}

function normalizeDropTrooperArmorTierValue(value, fallback = "Medium") {
  const normalized = String(value ?? "").trim().toLowerCase();
  if (normalized === "light") return "Light";
  if (normalized === "medium") return "Medium";
  if (normalized === "heavy") return "Heavy";
  if (normalized === "ultra") return "Ultra";
  return fallback;
}

function getDropTrooperConfiguredUnarmoredTokenImage(actor, tokenDocument = null) {
  const configured = String(actor?.getFlag?.("drop-trooper", "outOfArmorTokenImage") || "").trim();
  if (configured) return configured;

  const currentImage = String(tokenDocument?.texture?.src || "").trim();
  const actorImage = String(actor?.img || "").trim();
  if (actorImage && actorImage !== currentImage) return actorImage;

  const prototypeImage = String(actor?.prototypeToken?.texture?.src || "").trim();
  if (prototypeImage && prototypeImage !== currentImage) return prototypeImage;

  return currentImage;
}

function getDropTrooperOutOfArmorWeaponLock(actor, weapon) {
  if (!actor || !weapon || !isDropTrooperActorOutOfArmor(actor)) {
    return { blocked: false, reason: "" };
  }

  const tier = normalizeDropTrooperArmorTierValue(weapon?.system?.tier, "Medium");
  if (tier === "Light") {
    return { blocked: false, reason: "" };
  }

  return {
    blocked: true,
    reason: `${weapon.name || "That weapon"} cannot be used while out of armor. Only Light weapons stay active.`
  };
}

function getDropTrooperOutOfArmorAbilityLock(actor, ability) {
  if (!actor || !ability || !isDropTrooperActorOutOfArmor(actor)) {
    return { blocked: false, reason: "" };
  }

  const specialType = String(ability?.system?.specialType || "").trim();
  const normalizedName = normalizeDropTrooperString(ability?.name).toLowerCase();

  if (DROP_TROOPER_OUT_OF_ARMOR_ALLOWED_ABILITY_SPECIAL_TYPES.has(specialType) || DROP_TROOPER_OUT_OF_ARMOR_ALLOWED_ABILITY_NAMES.has(normalizedName)) {
    return { blocked: false, reason: "" };
  }

  return {
    blocked: true,
    reason: `${ability.name || "That ability"} cannot be used while out of armor. Only Command Dice, Repair Kit, and Sensor Sweep stay active.`
  };
}

function getDropTrooperArmorShellTile(scene, actorOrActorId) {
  const actorId = typeof actorOrActorId === "string"
    ? String(actorOrActorId || "").trim()
    : String(actorOrActorId?.id || "").trim();

  if (!scene || !actorId) return null;

  return scene.tiles?.find(tile => String(tile?.flags?.["drop-trooper"]?.[DROP_TROOPER_ARMOR_SHELL_TILE_FLAG]?.actorId || "").trim() === actorId) || null;
}

function getDropTrooperPrimaryTrooperToken(actor) {
  if (!actor) return null;
  const tokens = getDropTrooperCanvasTokensForActor(actor);
  return tokens.find(token => !token?.document?.getFlag?.("drop-trooper", DROP_TROOPER_ARMOR_SHELL_TILE_FLAG)) || tokens[0] || null;
}

function isDropTrooperTokenNearArmorShell(tokenDocument, tileDocument) {
  if (!tokenDocument || !tileDocument) return false;

  const gridSize = Math.max(1, Number(canvas?.grid?.size) || 100);
  const tokenWidth = Math.max(1, Number(tokenDocument?.width) || 1) * gridSize;
  const tokenHeight = Math.max(1, Number(tokenDocument?.height) || 1) * gridSize;
  const tileWidth = Math.max(1, Number(tileDocument?.width) || gridSize);
  const tileHeight = Math.max(1, Number(tileDocument?.height) || gridSize);
  const padding = Math.round(gridSize * 0.35);

  const tokenLeft = Number(tokenDocument?.x) || 0;
  const tokenTop = Number(tokenDocument?.y) || 0;
  const tokenRight = tokenLeft + tokenWidth;
  const tokenBottom = tokenTop + tokenHeight;

  const tileLeft = Number(tileDocument?.x) || 0;
  const tileTop = Number(tileDocument?.y) || 0;
  const tileRight = tileLeft + tileWidth;
  const tileBottom = tileTop + tileHeight;

  return !(
    tokenRight < (tileLeft - padding) ||
    tokenLeft > (tileRight + padding) ||
    tokenBottom < (tileTop - padding) ||
    tokenTop > (tileBottom + padding)
  );
}

function buildDropTrooperArmorShellTileData(actor, tokenDocument) {
  const gridSize = Math.max(1, Number(canvas?.grid?.size) || 100);
  const width = Math.max(1, Number(tokenDocument?.width) || 1) * gridSize;
  const height = Math.max(1, Number(tokenDocument?.height) || 1) * gridSize;
  const textureSrc = String(tokenDocument?.texture?.src || actor?.prototypeToken?.texture?.src || actor?.img || "").trim();

  if (!textureSrc) {
    throw new Error(`${actor?.name || "Trooper"}: no armor token image was found.`);
  }

  return {
    x: Number(tokenDocument?.x) || 0,
    y: Number(tokenDocument?.y) || 0,
    width,
    height,
    rotation: Number(tokenDocument?.rotation) || 0,
    hidden: false,
    overhead: false,
    locked: false,
    texture: {
      src: textureSrc
    },
    alpha: Number(tokenDocument?.alpha) || 1,
    z: 100,
    flags: {
      "drop-trooper": {
        [DROP_TROOPER_ARMOR_SHELL_TILE_FLAG]: {
          actorId: actor.id,
          actorName: actor.name || "Trooper"
        }
      }
    }
  };
}

async function performDropTrooperExitArmor(trooperActorId) {
  const actor = game.actors?.get(String(trooperActorId || "").trim());
  if (!actor || String(actor.type || "") !== "trooper") {
    throw new Error("Trooper not found.");
  }

  if (!canvas?.ready || !canvas.scene) {
    throw new Error("Open the battle map before exiting armor.");
  }

  const state = getDropTrooperOutOfArmorState(actor);
  if (state.active) {
    return {
      ok: true,
      active: true,
      message: `${actor.name}: already out of armor.`
    };
  }

  const token = getDropTrooperPrimaryTrooperToken(actor);
  const tokenDocument = token?.document || null;
  if (!tokenDocument) {
    throw new Error(`${actor.name}: place this trooper on the scene before exiting armor.`);
  }

  const savedArmorTier = normalizeDropTrooperArmorTierValue(actor.system?.armor?.tier, "Medium");
  const savedIntegrityValue = Number.isFinite(Number(actor?.system?.armor?.integrity?.value))
    ? Number(actor.system.armor.integrity.value)
    : DROP_TROOPER_OUT_OF_ARMOR_INTEGRITY;
  const savedIntegrityMax = Number.isFinite(Number(actor?.system?.armor?.integrity?.max))
    ? Number(actor.system.armor.integrity.max)
    : Math.max(savedIntegrityValue, DROP_TROOPER_OUT_OF_ARMOR_INTEGRITY);
  const armoredTokenImage = String(tokenDocument?.texture?.src || actor?.prototypeToken?.texture?.src || actor?.img || "").trim();
  const unarmoredTokenImage = getDropTrooperConfiguredUnarmoredTokenImage(actor, tokenDocument);

  const tileData = buildDropTrooperArmorShellTileData(actor, tokenDocument);
  const createdTiles = await canvas.scene.createEmbeddedDocuments("Tile", [tileData]);
  const shellTile = createdTiles?.[0];
  if (!shellTile) {
    throw new Error(`${actor.name}: failed to leave the armor shell on the map.`);
  }

  try {
    await actor.update({
      "system.armor.tier": "Light",
      "system.armor.integrity.value": DROP_TROOPER_OUT_OF_ARMOR_INTEGRITY,
      "system.armor.integrity.max": DROP_TROOPER_OUT_OF_ARMOR_INTEGRITY
    });

    await actor.setFlag("drop-trooper", DROP_TROOPER_OUT_OF_ARMOR_FLAG, {
      active: true,
      savedArmorTier,
      savedIntegrityValue,
      savedIntegrityMax,
      armoredTokenImage,
      unarmoredTokenImage,
      shellTileId: shellTile.id,
      shellSceneId: canvas.scene.id
    });

    if (unarmoredTokenImage && unarmoredTokenImage !== armoredTokenImage) {
      await tokenDocument.update({
        "texture.src": unarmoredTokenImage
      });
    }

    return {
      ok: true,
      active: true,
      message: `${actor.name}: exited armor. Light armor mode is now active.`
    };
  } catch (err) {
    await actor.update({
      "system.armor.tier": savedArmorTier,
      "system.armor.integrity.value": savedIntegrityValue,
      "system.armor.integrity.max": savedIntegrityMax
    }).catch(() => {});
    await canvas.scene.deleteEmbeddedDocuments("Tile", [shellTile.id]).catch(() => {});
    await actor.unsetFlag("drop-trooper", DROP_TROOPER_OUT_OF_ARMOR_FLAG).catch(() => {});
    throw err;
  }
}

async function performDropTrooperReturnArmor(trooperActorId) {
  const actor = game.actors?.get(String(trooperActorId || "").trim());
  if (!actor || String(actor.type || "") !== "trooper") {
    throw new Error("Trooper not found.");
  }

  if (!canvas?.ready || !canvas.scene) {
    throw new Error("Open the battle map before returning to armor.");
  }

  const state = getDropTrooperOutOfArmorState(actor);
  if (!state.active) {
    return {
      ok: true,
      active: false,
      message: `${actor.name}: already in armor.`
    };
  }

  const token = getDropTrooperPrimaryTrooperToken(actor);
  const tokenDocument = token?.document || null;
  if (!tokenDocument) {
    throw new Error(`${actor.name}: place this trooper on the scene before returning to armor.`);
  }

  const shellScene = state.shellSceneId
    ? (game.scenes?.get(state.shellSceneId) || null)
    : canvas.scene;
  const shellTile = shellScene
    ? ((state.shellTileId && shellScene.tiles?.get(state.shellTileId)) || getDropTrooperArmorShellTile(shellScene, actor))
    : null;
  const shellMissing = !shellTile;

  if (!shellMissing && state.shellSceneId && state.shellSceneId !== canvas.scene.id) {
    throw new Error(`${actor.name}: return to the scene where the armor shell was left behind.`);
  }

  if (!shellMissing && !isDropTrooperTokenNearArmorShell(tokenDocument, shellTile)) {
    throw new Error(`${actor.name}: move back to the dropped armor before getting back in.`);
  }

  await actor.update({
    "system.armor.tier": normalizeDropTrooperArmorTierValue(state.savedArmorTier, "Medium"),
    "system.armor.integrity.value": Number.isFinite(state.savedIntegrityValue) ? state.savedIntegrityValue : DROP_TROOPER_OUT_OF_ARMOR_INTEGRITY,
    "system.armor.integrity.max": Number.isFinite(state.savedIntegrityMax) ? state.savedIntegrityMax : DROP_TROOPER_OUT_OF_ARMOR_INTEGRITY
  });

  if (state.armoredTokenImage) {
    await tokenDocument.update({
      "texture.src": state.armoredTokenImage
    });
  }

  if (!shellMissing && shellScene) {
    await shellScene.deleteEmbeddedDocuments("Tile", [shellTile.id]).catch(() => {});
  }
  await actor.unsetFlag("drop-trooper", DROP_TROOPER_OUT_OF_ARMOR_FLAG).catch(() => {});

  return {
    ok: true,
    active: false,
    message: shellMissing
      ? `${actor.name}: armor restored. The dropped shell was missing, so the system cleared the out-of-armor state automatically.`
      : `${actor.name}: back in armor.`
  };
}

async function requestOrPerformDropTrooperArmorToggle(trooperActorId, mode = "toggle") {
  const actor = game.actors?.get(String(trooperActorId || "").trim());
  if (!actor || String(actor.type || "") !== "trooper") {
    throw new Error("Trooper not found.");
  }

  const state = getDropTrooperOutOfArmorState(actor);
  const normalizedMode = String(mode || "").trim().toLowerCase();
  const desiredMode = normalizedMode === "toggle"
    ? (state.active ? "return" : "exit")
    : (normalizedMode === "return" ? "return" : "exit");

  if (game.user?.isGM) {
    return desiredMode === "return"
      ? performDropTrooperReturnArmor(trooperActorId)
      : performDropTrooperExitArmor(trooperActorId);
  }

  return queueDropTrooperGmArmorApproval(trooperActorId, desiredMode);
}

function applyDropTrooperOutOfArmorSheetState(html, sheet) {
  const actor = sheet?.actor;
  if (!actor || String(actor.type || "") !== "trooper") return;

  const root = html?.[0] || html;
  if (!root?.querySelectorAll) return;

  const state = getDropTrooperOutOfArmorState(actor);
  const armorHeading = Array.from(root.querySelectorAll(".dt-card > h2")).find(heading => String(heading?.textContent || "").trim() === "Armor");
  const armorCard = armorHeading?.closest(".dt-card") || null;

  if (armorCard) {
    armorCard.querySelectorAll(".dt-out-of-armor-panel").forEach(node => node.remove());

    const shellStatus = state.active
      ? ((state.shellSceneId && canvas?.scene?.id && state.shellSceneId !== canvas.scene.id)
          ? "Armor shell is on another scene."
          : (((state.shellTileId && canvas?.scene?.tiles?.get(state.shellTileId)) || getDropTrooperArmorShellTile(canvas?.scene, actor))
              ? "Return to the shell to get back in."
              : "Armor shell not found."))
      : "Exit the suit, drop the armor shell on the map, and switch to Light armor mode.";

    const panel = document.createElement("div");
    panel.className = "dt-item-meta dt-out-of-armor-panel";
    panel.style.margin = "8px 0 10px 0";
    panel.innerHTML = `
      <div style="display:grid;gap:6px;">
        <div><strong>${state.active ? "Out of Armor" : "Armored"}</strong></div>
        <div>${escapeDropTrooperHtml(shellStatus)}</div>
        <div>Out of Armor = Light tier, ${DROP_TROOPER_OUT_OF_ARMOR_INTEGRITY} Integrity, Light weapons only, Command Dice / Repair Kit / Sensor Sweep only.</div>
        <div class="dt-button-row">
          <button type="button" class="armor-mode-toggle" data-armor-mode="${state.active ? "return" : "exit"}">${state.active ? "Return to Armor" : "Exit Armor"}</button>
        </div>
      </div>
    `;
    armorHeading.insertAdjacentElement("afterend", panel);

    panel.querySelector(".armor-mode-toggle")?.addEventListener("click", event => {
      sheet._onToggleOutOfArmor(event);
    });
  }

  const isOutOfArmor = state.active;

  root.querySelectorAll(".dt-weapon-card[data-item-id]").forEach(card => {
    const itemId = String(card?.dataset?.itemId || "").trim();
    const weapon = actor.items.get(itemId);
    if (!weapon) return;

    const lock = getDropTrooperOutOfArmorWeaponLock(actor, weapon);
    card.style.opacity = lock.blocked ? "0.72" : "";
    card.title = lock.blocked ? lock.reason : "";

    card.querySelectorAll(".weapon-attack, .weapon-reload").forEach(button => {
      if (!button.classList.contains("weapon-delete")) {
        button.disabled = !!lock.blocked;
        if (lock.blocked) button.title = lock.reason;
      }
    });

    let note = card.querySelector(".dt-out-of-armor-note");
    if (lock.blocked && isOutOfArmor) {
      if (!note) {
        note = document.createElement("div");
        note.className = "dt-item-meta dt-out-of-armor-note";
        note.style.marginTop = "6px";
        card.querySelector(".dt-item-main")?.appendChild(note);
      }
      note.textContent = "Blocked while out of armor";
    } else if (note) {
      note.remove();
    }
  });

  root.querySelectorAll(".dt-ability-card[data-item-id]").forEach(card => {
    const itemId = String(card?.dataset?.itemId || "").trim();
    const ability = actor.items.get(itemId);
    if (!ability) return;

    const lock = getDropTrooperOutOfArmorAbilityLock(actor, ability);
    card.style.opacity = lock.blocked ? "0.72" : "";
    card.title = lock.blocked ? lock.reason : "";

    card.querySelectorAll(".ability-use").forEach(button => {
      button.disabled = !!lock.blocked;
      if (lock.blocked) button.title = lock.reason;
    });

    let note = card.querySelector(".dt-out-of-armor-note");
    if (lock.blocked && isOutOfArmor) {
      if (!note) {
        note = document.createElement("div");
        note.className = "dt-item-meta dt-out-of-armor-note";
        note.style.marginTop = "6px";
        card.querySelector(".dt-item-main")?.appendChild(note);
      }
      note.textContent = "Blocked while out of armor";
    } else if (note) {
      note.remove();
    }
  });
}

const DROP_TROOPER_NPC_BLUEPRINT_FLAG = "npcBlueprintMeta";
const DROP_TROOPER_NPC_IMPORT_COMMAND = "/dt-npc";
const DROP_TROOPER_NPC_EXPORT_COMMAND = "/dt-export-npc";

function escapeDropTrooperHtml(value) {
  return foundry.utils.escapeHTML(String(value ?? ""));
}

function normalizeDropTrooperString(value) {
  return String(value ?? "").trim();
}

function normalizeDropTrooperWeaponEffectType(value, fallback = "auto") {
  const raw = normalizeDropTrooperString(value).toLowerCase().replace(/[_-]+/g, " ").replace(/\s+/g, " ");
  const map = {
    auto: "auto",
    ballistic: "ballistic",
    bullet: "ballistic",
    rifle: "ballistic",
    pistol: "ballistic",
    firearm: "ballistic",
    gun: "ballistic",
    laser: "laser",
    beam: "laser",
    plasma: "plasma",
    lightning: "lightning",
    electric: "lightning",
    tesla: "lightning",
    missile: "missile",
    rocket: "missile",
    launcher: "missile",
    grenade: "grenade",
    frag: "grenade",
    bomb: "grenade",
    flamer: "flamer",
    flame: "flamer",
    fire: "flamer",
    acid: "acid",
    ice: "ice",
    cold: "ice",
    cryo: "ice",
    frost: "ice",
    poison: "poison",
    toxic: "poison",
    venom: "poison",
    smoke: "smoke",
    sonic: "sonic",
    thunder: "sonic",
    force: "force",
    arcane: "force",
    radiant: "radiant",
    holy: "radiant",
    necrotic: "necrotic",
    necro: "necrotic",
    emp: "emp",
    psychic: "psychic",
    psionic: "psychic",
    heal: "healing",
    healing: "healing",
    nano: "nano",
    nanite: "nano",
    corrosive: "corrosive",
    void: "void",
    shadow: "void",
    none: "none",
    off: "none"
  };

  return map[raw] || fallback;
}

function normalizeDropTrooperWeaponDamageTarget(value, fallback = "normal") {
  const raw = normalizeDropTrooperString(value).toLowerCase().replace(/[_-]+/g, " ").replace(/\s+/g, " ");
  const map = {
    normal: "normal",
    standard: "normal",
    armor: "normal",
    integrity: "normal",
    health: "health",
    "health only": "health",
    healthonly: "health",
    bypass: "health",
    "bypass armor": "health",
    internal: "health",
    direct: "health"
  };

  return map[raw] || fallback;
}

function getDropTrooperDamageTargetLabel(value) {
  return normalizeDropTrooperWeaponDamageTarget(value, "normal") === "health"
    ? "Health Only"
    : "Normal";
}

function normalizeDropTrooperSkill(value, fallback = "shooting") {
  const raw = normalizeDropTrooperString(value).toLowerCase().replace(/[_-]+/g, " ").replace(/\s+/g, " ");
  const map = {
    shooting: "shooting",
    "heavy weapons": "heavyWeapons",
    heavyweapons: "heavyWeapons",
    melee: "melee",
    maneuvering: "maneuvering",
    recon: "recon",
    sensors: "sensors",
    electronics: "electronics",
    engineering: "engineering",
    "drone control": "droneControl",
    dronecontrol: "droneControl",
    command: "command",
    discipline: "discipline",
    survival: "survival",
    defense: "defense",
    strength: "strength",
    agility: "agility",
    perception: "perception",
    tech: "tech",
    will: "will"
  };

  return map[raw] || fallback;
}

function normalizeDropTrooperArmorTier(value, fallback = "Medium") {
  const raw = normalizeDropTrooperString(value).toLowerCase();
  const map = {
    light: "Light",
    medium: "Medium",
    heavy: "Heavy",
    ultra: "Ultra"
  };

  return map[raw] || fallback;
}

function normalizeDropTrooperTier(value, fallback = "Standard") {
  const raw = normalizeDropTrooperString(value);
  if (!raw) return fallback;
  return raw;
}

function normalizeDropTrooperAbilityType(value) {
  const raw = normalizeDropTrooperString(value).toLowerCase();
  return raw === "special" ? "special" : "skill";
}

function normalizeDropTrooperSpecialType(value) {
  const raw = normalizeDropTrooperString(value).toLowerCase();
  const map = {
    commanddice: "commandDice",
    repairkit: "repairKit",
    sensorsweep: "sensorSweep",
    flight: "flightPack",
    flightpack: "flightPack",
    none: "none",
    "": "none"
  };

  return map[raw.replace(/\s+/g, "")] || "none";
}

function parseDropTrooperMaybeNumber(value, fallback = 0) {
  const raw = normalizeDropTrooperString(value);
  if (!raw || raw === "-") return fallback;
  const parsed = Number(raw);
  return Number.isFinite(parsed) ? parsed : fallback;
}

function parseDropTrooperMaybeAmmoValue(value) {
  const raw = normalizeDropTrooperString(value);
  if (!raw || raw === "-") return "";
  const parsed = Number(raw);
  return Number.isFinite(parsed) ? parsed : "";
}

function parseDropTrooperPoolValue(value) {
  const raw = normalizeDropTrooperString(value);
  if (!raw || raw === "-") {
    return { value: 0, max: 0 };
  }

  const slashMatch = raw.match(/^(\d+)\s*\/\s*(\d+)$/);
  if (slashMatch) {
    return {
      value: Number(slashMatch[1]) || 0,
      max: Number(slashMatch[2]) || 0
    };
  }

  const parsed = Number(raw);
  if (Number.isFinite(parsed)) {
    return { value: parsed, max: parsed };
  }

  return { value: 0, max: 0 };
}

function parseDropTrooperWeaponMode(value) {
  const raw = normalizeDropTrooperString(value).toLowerCase();
  if (raw === "blast") return "blast";
  if (raw === "cone") return "cone";
  return "direct";
}

function parseDropTrooperTags(value) {
  const raw = normalizeDropTrooperString(value);
  if (!raw || raw === "-") return [];
  return raw.split(",").map(part => normalizeDropTrooperString(part)).filter(Boolean);
}

function parseDropTrooperBlueprintNamedFields(body) {
  const fields = {};
  let namedCount = 0;

  for (const rawSegment of String(body ?? "").split("|")) {
    const segment = rawSegment.trim();
    if (!segment) continue;

    const colonIndex = segment.indexOf(":");
    if (colonIndex === -1) {
      continue;
    }

    const key = segment.slice(0, colonIndex).trim().toLowerCase().replace(/\s+/g, " ");
    const value = segment.slice(colonIndex + 1).trim();
    if (!key) continue;

    fields[key] = value;
    namedCount += 1;
  }

  return namedCount > 0 ? fields : null;
}

function getDropTrooperBlueprintField(fields, aliases = []) {
  if (!fields) return "";
  for (const alias of aliases) {
    const key = String(alias ?? "").trim().toLowerCase().replace(/\s+/g, " ");
    if (key && Object.prototype.hasOwnProperty.call(fields, key)) {
      return fields[key];
    }
  }
  return "";
}

function parseDropTrooperRangeTriplet(value, defaults = [0, 0, 0]) {
  const raw = normalizeDropTrooperString(value);
  if (!raw || raw === "-") {
    return [...defaults];
  }

  const parts = raw.split(/[\/,]/).map(part => part.trim()).filter(Boolean);
  if (parts.length >= 3) {
    return [
      parseDropTrooperMaybeNumber(parts[0], defaults[0] ?? 0),
      parseDropTrooperMaybeNumber(parts[1], defaults[1] ?? 0),
      parseDropTrooperMaybeNumber(parts[2], defaults[2] ?? 0)
    ];
  }

  const single = parseDropTrooperMaybeNumber(raw, Number.NaN);
  if (Number.isFinite(single)) {
    return [single, single, single];
  }

  return [...defaults];
}

function parseDropTrooperBlueprintRangeValue(value, fallback = 0) {
  const raw = normalizeDropTrooperString(value).toLowerCase();
  if (!raw || raw === "-") return fallback;
  if (raw === "self" || raw === "touch" || raw === "adjacent" || raw === "melee") return 0;
  return parseDropTrooperMaybeNumber(raw, fallback);
}

function inferDropTrooperAbilitySpecialType(fields, abilityName = "", linkedSkill = "") {
  const explicit = normalizeDropTrooperSpecialType(getDropTrooperBlueprintField(fields, ["special", "special type", "specialtype"]));
  if (explicit !== "none") {
    return explicit;
  }

  const nameRaw = normalizeDropTrooperString(abilityName).toLowerCase();
  const skillRaw = normalizeDropTrooperString(linkedSkill).toLowerCase();

  if (nameRaw.includes("sensor sweep") || nameRaw.includes("scan") || nameRaw.includes("ping")) {
    return "sensorSweep";
  }

  if (nameRaw.includes("repair kit")) {
    return "repairKit";
  }

  if (nameRaw.includes("flight") || nameRaw.includes("jump jet") || nameRaw.includes("jump pack")) {
    return "flightPack";
  }

  if (nameRaw.includes("command dice")) {
    return "commandDice";
  }

  if (skillRaw === "sensors") {
    return "sensorSweep";
  }

  return "none";
}

function buildDropTrooperBlueprintAbilityNotes(description = "", extraNotes = "", costValue = "", rangeValue = "") {
  const parts = [];
  const desc = normalizeDropTrooperString(description);
  const extra = normalizeDropTrooperString(extraNotes);
  const cost = normalizeDropTrooperString(costValue);
  const range = normalizeDropTrooperString(rangeValue);

  if (desc) parts.push(desc);
  if (extra) parts.push(extra);
  if (cost) parts.push(`Cost: ${cost}`);
  if (range && !/^\d+$/.test(range)) parts.push(`Range: ${range}`);

  return parts.join(" | ");
}

function parseDropTrooperBlueprint(rawText) {
  const text = String(rawText ?? "").replace(/\r/g, "");
  const lines = text.split("\n");
  const blueprint = {
    name: "",
    archetype: "",
    tier: "Standard",
    armor: "Medium",
    integrity: 8,
    health: 8,
    initiative: 0,
    shooting: 2,
    defense: 1,
    weapons: [],
    abilities: [],
    notes: "",
    image: "",
    spawnCount: 1
  };

  let section = "fields";

  for (const rawLine of lines) {
    const line = rawLine.trim();
    if (!line) continue;

    const lower = line.toLowerCase();
    if (lower === "weapons:") {
      section = "weapons";
      continue;
    }

    if (lower === "abilities:") {
      section = "abilities";
      continue;
    }

    if (section === "weapons" && /^[\-*•]/.test(line)) {
      const body = line.replace(/^[\-*•]\s*/, "").trim();
      const namedFields = parseDropTrooperBlueprintNamedFields(body);

      if (namedFields) {
        const weaponName = getDropTrooperBlueprintField(namedFields, ["name"]);
        if (!weaponName) continue;

        let modeRaw = getDropTrooperBlueprintField(namedFields, ["mode", "type"]);
        const blastSpecRaw = getDropTrooperBlueprintField(namedFields, ["blast", "blast radii", "blast radius"]);
        const coneSpecRaw = getDropTrooperBlueprintField(namedFields, ["cone", "cone ranges", "cone range"]);
        const effectRaw = getDropTrooperBlueprintField(namedFields, ["effect", "aoe effect", "aoeeffect"]);
        const tags = parseDropTrooperTags(getDropTrooperBlueprintField(namedFields, ["tags", "tag"]));
        const notes = normalizeDropTrooperString(getDropTrooperBlueprintField(namedFields, ["notes", "description"]));

        if (!modeRaw && coneSpecRaw) modeRaw = "cone";
        if (!modeRaw && (blastSpecRaw || effectRaw.toLowerCase() === "smoke")) modeRaw = "blast";

        const mode = parseDropTrooperWeaponMode(modeRaw);
        const isSmoke = effectRaw.toLowerCase() === "smoke" || tags.some(tag => tag.toLowerCase() === "smoke");

        const [killRadius, heavyRadius, fragRadius] = parseDropTrooperRangeTriplet(blastSpecRaw, [30, 60, 100]);
        const [coneKillRange, coneHeavyRange, coneFragRange] = parseDropTrooperRangeTriplet(coneSpecRaw, [15, 30, 45]);
        const baseDamage = parseDropTrooperMaybeNumber(getDropTrooperBlueprintField(namedFields, ["damage", "base damage", "basedamage"]), 0);

        blueprint.weapons.push({
          name: weaponName,
          skill: normalizeDropTrooperSkill(getDropTrooperBlueprintField(namedFields, ["skill", "linked skill", "linkedskill"]), "shooting"),
          tier: normalizeDropTrooperArmorTier(getDropTrooperBlueprintField(namedFields, ["tier", "armor tier", "armortier"]), "Medium"),
          baseDamage,
          ammo: parseDropTrooperMaybeAmmoValue(getDropTrooperBlueprintField(namedFields, ["ammo"])),
          magSize: parseDropTrooperMaybeAmmoValue(getDropTrooperBlueprintField(namedFields, ["mag", "mag size", "magsize"])),
          ammoMax: parseDropTrooperMaybeAmmoValue(getDropTrooperBlueprintField(namedFields, ["reserve", "ammo max", "ammomax"])),
          aoeEnabled: mode !== "direct",
          aoeType: mode === "cone" ? "cone" : "blast",
          aoeEffect: isSmoke ? "smoke" : "damage",
          tags,
          notes: notes || tags.join(", "),
          damageTarget: normalizeDropTrooperDamageTarget(getDropTrooperBlueprintField(namedFields, ["damage target", "damagetarget", "damage target type", "damagetargettype"]), "normal"),
          blastRadius: parseDropTrooperMaybeNumber(getDropTrooperBlueprintField(namedFields, ["blast radius", "blastradius"]), fragRadius),
          killRadius: parseDropTrooperMaybeNumber(getDropTrooperBlueprintField(namedFields, ["kill radius", "killradius"]), killRadius),
          heavyRadius: parseDropTrooperMaybeNumber(getDropTrooperBlueprintField(namedFields, ["heavy radius", "heavyradius"]), heavyRadius),
          fragRadius: parseDropTrooperMaybeNumber(getDropTrooperBlueprintField(namedFields, ["frag radius", "fragradius"]), fragRadius),
          killDamage: parseDropTrooperMaybeNumber(getDropTrooperBlueprintField(namedFields, ["kill damage", "killdamage"]), baseDamage),
          heavyDamage: parseDropTrooperMaybeNumber(getDropTrooperBlueprintField(namedFields, ["heavy damage", "heavydamage"]), Math.max(0, baseDamage - 1)),
          fragDamage: parseDropTrooperMaybeNumber(getDropTrooperBlueprintField(namedFields, ["frag damage", "fragdamage"]), Math.max(0, baseDamage - 2)),
          coneRange: parseDropTrooperMaybeNumber(getDropTrooperBlueprintField(namedFields, ["cone range", "conerange"]), coneFragRange || 45),
          coneAngle: getDropTrooperBlueprintField(namedFields, ["cone angle", "coneangle"]) || "60",
          coneKillRange: parseDropTrooperMaybeNumber(getDropTrooperBlueprintField(namedFields, ["cone kill", "cone kill range", "conekillrange"]), coneKillRange),
          coneHeavyRange: parseDropTrooperMaybeNumber(getDropTrooperBlueprintField(namedFields, ["cone heavy", "cone heavy range", "coneheavyrange"]), coneHeavyRange),
          coneFragRange: parseDropTrooperMaybeNumber(getDropTrooperBlueprintField(namedFields, ["cone frag", "cone frag range", "conefragrange"]), coneFragRange),
          fireEffect: normalizeDropTrooperWeaponEffectType(getDropTrooperBlueprintField(namedFields, ["fire effect", "fireeffect"]), "auto"),
          fireSoundPath: normalizeDropTrooperString(getDropTrooperBlueprintField(namedFields, ["fire sound", "firesound", "fire sound path", "firesoundpath"])),
          blastSoundPath: normalizeDropTrooperString(getDropTrooperBlueprintField(namedFields, ["blast sound", "blastsound", "blast sound path", "blastsoundpath"])),
          blastImagePath: normalizeDropTrooperString(getDropTrooperBlueprintField(namedFields, ["blast image", "blastimage", "blast image path", "blastimagepath"])),
          coneSoundPath: normalizeDropTrooperString(getDropTrooperBlueprintField(namedFields, ["cone sound", "conesound", "cone sound path", "conesoundpath"])),
          coneImagePath: normalizeDropTrooperString(getDropTrooperBlueprintField(namedFields, ["cone image", "coneimage", "cone image path", "coneimagepath"])),
          smokeDiameter: parseDropTrooperMaybeNumber(getDropTrooperBlueprintField(namedFields, ["smoke diameter", "smokediameter"]), 30),
          smokeDurationRounds: parseDropTrooperMaybeNumber(getDropTrooperBlueprintField(namedFields, ["smoke duration", "smokeduration", "smoke duration rounds", "smokedurationrounds"]), 3)
        });
        continue;
      }

      const parts = body.split("|").map(part => part.trim());
      if (!parts[0]) continue;

      const mode = parseDropTrooperWeaponMode(parts[7]);
      const tags = parseDropTrooperTags(parts[8]);
      const isSmoke = tags.some(tag => tag.toLowerCase() === "smoke");

      blueprint.weapons.push({
        name: parts[0],
        skill: normalizeDropTrooperSkill(parts[1], "shooting"),
        tier: normalizeDropTrooperArmorTier(parts[2], "Medium"),
        baseDamage: parseDropTrooperMaybeNumber(parts[3], 0),
        ammo: parseDropTrooperMaybeAmmoValue(parts[4]),
        magSize: parseDropTrooperMaybeAmmoValue(parts[5]),
        ammoMax: parseDropTrooperMaybeAmmoValue(parts[6]),
        aoeEnabled: mode !== "direct",
        aoeType: mode === "cone" ? "cone" : "blast",
        aoeEffect: isSmoke ? "smoke" : "damage",
        tags,
        notes: tags.join(", "),
        damageTarget: normalizeDropTrooperDamageTarget(parts[9], "normal")
      });
      continue;
    }

    if (section === "abilities" && /^[\-*•]/.test(line)) {
      const body = line.replace(/^[\-*•]\s*/, "").trim();
      const namedFields = parseDropTrooperBlueprintNamedFields(body);

      if (namedFields) {
        const abilityName = getDropTrooperBlueprintField(namedFields, ["name"]);
        if (!abilityName) continue;

        const rawType = getDropTrooperBlueprintField(namedFields, ["type", "ability type", "abilitytype"]);
        const linkedSkillRaw = getDropTrooperBlueprintField(namedFields, ["skill", "linked skill", "linkedskill", "category"]);
        const linkedSkill = normalizeDropTrooperSkill(linkedSkillRaw, "tech");
        const rangeValue = getDropTrooperBlueprintField(namedFields, ["range", "base range", "baserange"]);
        const description = getDropTrooperBlueprintField(namedFields, ["description", "desc"]);
        const extraNotes = getDropTrooperBlueprintField(namedFields, ["notes"]);
        const costValue = getDropTrooperBlueprintField(namedFields, ["cost"]);

        blueprint.abilities.push({
          name: abilityName,
          abilityType: normalizeDropTrooperAbilityType(rawType === "special" ? "special" : "skill"),
          linkedSkill,
          bonusDice: parseDropTrooperMaybeNumber(getDropTrooperBlueprintField(namedFields, ["bonus", "bonus dice", "bonusdice"]), 0),
          specialType: inferDropTrooperAbilitySpecialType(namedFields, abilityName, linkedSkillRaw),
          pool: parseDropTrooperPoolValue(getDropTrooperBlueprintField(namedFields, ["pool"])),
          notes: buildDropTrooperBlueprintAbilityNotes(description, extraNotes, costValue, rangeValue),
          baseRange: parseDropTrooperBlueprintRangeValue(rangeValue, 60),
          rangePerSuccess: parseDropTrooperMaybeNumber(getDropTrooperBlueprintField(namedFields, ["range per success", "rangepersuccess"]), 30),
          pingDurationMs: parseDropTrooperMaybeNumber(getDropTrooperBlueprintField(namedFields, ["ping duration", "pingduration", "ping duration ms", "pingdurationms"]), 1500)
        });
        continue;
      }

      const parts = body.split("|").map(part => part.trim());
      if (!parts[0]) continue;
      const pool = parseDropTrooperPoolValue(parts[5]);

      blueprint.abilities.push({
        name: parts[0],
        abilityType: normalizeDropTrooperAbilityType(parts[1]),
        linkedSkill: normalizeDropTrooperSkill(parts[2], "tech"),
        bonusDice: parseDropTrooperMaybeNumber(parts[3], 0),
        specialType: normalizeDropTrooperSpecialType(parts[4]),
        pool,
        notes: normalizeDropTrooperString(parts[6])
      });
      continue;
    }

    const colonIndex = line.indexOf(":");
    if (colonIndex === -1) continue;

    const key = line.slice(0, colonIndex).trim().toLowerCase();
    const value = line.slice(colonIndex + 1).trim();

    switch (key) {
      case "name":
        blueprint.name = value;
        break;
      case "archetype":
        blueprint.archetype = value;
        break;
      case "tier":
        blueprint.tier = normalizeDropTrooperTier(value, "Standard");
        break;
      case "armor":
        blueprint.armor = normalizeDropTrooperArmorTier(value, "Medium");
        break;
      case "integrity":
        blueprint.integrity = parseDropTrooperMaybeNumber(value, 8);
        break;
      case "health":
        blueprint.health = parseDropTrooperMaybeNumber(value, 8);
        break;
      case "initiative":
        blueprint.initiative = parseDropTrooperMaybeNumber(value, 0);
        break;
      case "shooting":
        blueprint.shooting = parseDropTrooperMaybeNumber(value, 2);
        break;
      case "defense":
        blueprint.defense = parseDropTrooperMaybeNumber(value, 1);
        break;
      case "notes":
        blueprint.notes = value;
        break;
      case "image":
        blueprint.image = value;
        break;
      case "spawn count":
        blueprint.spawnCount = Math.max(1, parseDropTrooperMaybeNumber(value, 1));
        break;
      default:
        break;
    }
  }

  if (!blueprint.name) {
    throw new Error("Blueprint is missing Name.");
  }

  return blueprint;
}

function getDropTrooperDerivedAoeDamage(weaponData = {}) {
  const baseDamage = parseDropTrooperMaybeNumber(weaponData.baseDamage, 0);
  if (baseDamage <= 0) {
    return { killDamage: 0, heavyDamage: 0, fragDamage: 0 };
  }

  return {
    killDamage: parseDropTrooperMaybeNumber(weaponData.killDamage, baseDamage),
    heavyDamage: parseDropTrooperMaybeNumber(weaponData.heavyDamage, Math.max(0, baseDamage - 1)),
    fragDamage: parseDropTrooperMaybeNumber(weaponData.fragDamage, Math.max(0, baseDamage - 2))
  };
}

function buildDropTrooperLegacyWeaponData(weaponData = {}) {
  const aoeDamage = getDropTrooperDerivedAoeDamage(weaponData);
  return {
    name: weaponData.name || "Weapon",
    tier: normalizeDropTrooperArmorTier(weaponData.tier, "Medium"),
    baseDamage: parseDropTrooperMaybeNumber(weaponData.baseDamage, 4),
    aoeEnabled: !!weaponData.aoeEnabled,
    blastRadius: parseDropTrooperMaybeNumber(weaponData.blastRadius, 100),
    killRadius: parseDropTrooperMaybeNumber(weaponData.killRadius, 30),
    heavyRadius: parseDropTrooperMaybeNumber(weaponData.heavyRadius, 60),
    fragRadius: parseDropTrooperMaybeNumber(weaponData.fragRadius, 100),
    killDamage: aoeDamage.killDamage,
    heavyDamage: aoeDamage.heavyDamage,
    fragDamage: aoeDamage.fragDamage,
    blastSoundPath: normalizeDropTrooperString(weaponData.blastSoundPath),
    blastImagePath: normalizeDropTrooperString(weaponData.blastImagePath),
    coneSoundPath: normalizeDropTrooperString(weaponData.coneSoundPath),
    coneImagePath: normalizeDropTrooperString(weaponData.coneImagePath),
    ammo: weaponData.ammo ?? "",
    magSize: weaponData.magSize ?? "",
    ammoMax: weaponData.ammoMax ?? "",
    coneRange: parseDropTrooperMaybeNumber(weaponData.coneRange, 20),
    coneAngle: String(weaponData.coneAngle ?? "60"),
    coneKillRange: parseDropTrooperMaybeNumber(weaponData.coneKillRange, 0),
    coneHeavyRange: parseDropTrooperMaybeNumber(weaponData.coneHeavyRange, 0),
    coneFragRange: parseDropTrooperMaybeNumber(weaponData.coneFragRange, 0),
    fireEffect: normalizeDropTrooperWeaponEffectType(weaponData.fireEffect, "auto"),
    fireSoundPath: normalizeDropTrooperString(weaponData.fireSoundPath),
    aoeEffect: weaponData.aoeEffect === "smoke" ? "smoke" : "damage",
    smokeDiameter: parseDropTrooperMaybeNumber(weaponData.smokeDiameter, 30),
    smokeDurationRounds: parseDropTrooperMaybeNumber(weaponData.smokeDurationRounds, 3)
  };
}

function buildDropTrooperWeaponItemData(weaponData = {}, index = 0) {
  const aoeDamage = getDropTrooperDerivedAoeDamage(weaponData);
  return {
    name: weaponData.name || "Weapon",
    type: "weapon",
    system: {
      tier: normalizeDropTrooperArmorTier(weaponData.tier, "Medium"),
      baseDamage: parseDropTrooperMaybeNumber(weaponData.baseDamage, 4),
      skill: normalizeDropTrooperSkill(weaponData.skill, "shooting"),
      ammo: weaponData.ammo ?? "",
      notes: weaponData.notes || "",
      aoeEnabled: !!weaponData.aoeEnabled,
      aoeType: weaponData.aoeType === "cone" ? "cone" : "blast",
      blastRadius: parseDropTrooperMaybeNumber(weaponData.blastRadius, 100),
      killRadius: parseDropTrooperMaybeNumber(weaponData.killRadius, 30),
      heavyRadius: parseDropTrooperMaybeNumber(weaponData.heavyRadius, 60),
      fragRadius: parseDropTrooperMaybeNumber(weaponData.fragRadius, 100),
      killDamage: aoeDamage.killDamage,
      heavyDamage: aoeDamage.heavyDamage,
      fragDamage: aoeDamage.fragDamage,
      blastSoundPath: normalizeDropTrooperString(weaponData.blastSoundPath),
      blastImagePath: normalizeDropTrooperString(weaponData.blastImagePath),
      coneSoundPath: normalizeDropTrooperString(weaponData.coneSoundPath),
      coneImagePath: normalizeDropTrooperString(weaponData.coneImagePath),
      magSize: weaponData.magSize ?? "",
      ammoMax: weaponData.ammoMax ?? "",
      coneRange: parseDropTrooperMaybeNumber(weaponData.coneRange, 20),
      coneAngle: String(weaponData.coneAngle ?? "60"),
      coneKillRange: parseDropTrooperMaybeNumber(weaponData.coneKillRange, 0),
      coneHeavyRange: parseDropTrooperMaybeNumber(weaponData.coneHeavyRange, 0),
      coneFragRange: parseDropTrooperMaybeNumber(weaponData.coneFragRange, 0),
      fireEffect: normalizeDropTrooperWeaponEffectType(weaponData.fireEffect, "auto"),
      fireSoundPath: normalizeDropTrooperString(weaponData.fireSoundPath),
      aoeEffect: weaponData.aoeEffect === "smoke" ? "smoke" : "damage",
      smokeDiameter: parseDropTrooperMaybeNumber(weaponData.smokeDiameter, 30),
      smokeDurationRounds: parseDropTrooperMaybeNumber(weaponData.smokeDurationRounds, 3),
      damageTarget: normalizeDropTrooperDamageTarget(weaponData.damageTarget || weaponData.damageTargetType, "normal"),
      displayOrder: parseDropTrooperMaybeNumber(weaponData.displayOrder, index)
    }
  };
}

function buildDropTrooperAbilityItemData(abilityData = {}, index = 0) {
  return {
    name: abilityData.name || "Ability",
    type: "ability",
    system: {
      abilityType: normalizeDropTrooperAbilityType(abilityData.abilityType),
      linkedSkill: normalizeDropTrooperSkill(abilityData.linkedSkill, "tech"),
      bonusDice: parseDropTrooperMaybeNumber(abilityData.bonusDice, 0),
      specialType: normalizeDropTrooperSpecialType(abilityData.specialType),
      pool: {
        value: parseDropTrooperMaybeNumber(abilityData.pool?.value, 0),
        max: parseDropTrooperMaybeNumber(abilityData.pool?.max, 0)
      },
      notes: abilityData.notes || "",
      baseRange: parseDropTrooperMaybeNumber(abilityData.baseRange, 60),
      rangePerSuccess: parseDropTrooperMaybeNumber(abilityData.rangePerSuccess, 30),
      pingDurationMs: parseDropTrooperMaybeNumber(abilityData.pingDurationMs, 1500),
      displayOrder: parseDropTrooperMaybeNumber(abilityData.displayOrder, index)
    }
  };
}

function buildDropTrooperNpcBlueprintText(actor) {
  const meta = actor.getFlag("drop-trooper", DROP_TROOPER_NPC_BLUEPRINT_FLAG) || {};
  const weapons = actor.items.filter(item => item.type === "weapon");
  const abilities = actor.items.filter(item => item.type === "ability");

  const weaponLines = weapons.length
    ? weapons.map(weapon => {
        const mode = weapon.system?.aoeEnabled ? (weapon.system?.aoeType === "cone" ? "cone" : "blast") : "direct";
        const tags = [];
        if (weapon.system?.aoeEnabled && weapon.system?.aoeEffect === "smoke") tags.push("smoke");
        const notes = normalizeDropTrooperString(weapon.system?.notes);
        if (notes && !tags.includes(notes)) tags.push(notes);
        const tagText = tags.length ? tags.join(", ") : "-";
        const ammo = weapon.system?.ammo === "" || weapon.system?.ammo === null || weapon.system?.ammo === undefined ? "-" : weapon.system.ammo;
        const mag = weapon.system?.magSize === "" || weapon.system?.magSize === null || weapon.system?.magSize === undefined ? "-" : weapon.system.magSize;
        const spare = weapon.system?.ammoMax === "" || weapon.system?.ammoMax === null || weapon.system?.ammoMax === undefined ? "-" : weapon.system.ammoMax;
        return `- ${weapon.name} | ${weapon.system?.skill || "shooting"} | ${weapon.system?.tier || "Medium"} | ${Number(weapon.system?.baseDamage) || 0} | ${ammo} | ${mag} | ${spare} | ${mode} | ${tagText}`;
      })
    : [`- ${actor.system?.weapon?.name || "Weapon"} | shooting | ${actor.system?.weapon?.tier || "Medium"} | ${Number(actor.system?.weapon?.baseDamage) || 0} | ${actor.system?.weapon?.ammo || "-"} | ${actor.system?.weapon?.magSize || "-"} | ${actor.system?.weapon?.ammoMax || "-"} | direct | -`];

  const abilityLines = abilities.map(ability => {
    const poolCurrent = Number(ability.system?.pool?.value) || 0;
    const poolMax = Number(ability.system?.pool?.max) || 0;
    const poolText = poolMax > 0 ? `${poolCurrent}/${poolMax}` : "0";
    return `- ${ability.name} | ${ability.system?.abilityType || "skill"} | ${ability.system?.linkedSkill || "tech"} | ${Number(ability.system?.bonusDice) || 0} | ${ability.system?.specialType || "none"} | ${poolText} | ${normalizeDropTrooperString(ability.system?.notes)}`;
  });

  return [
    `Name: ${actor.name}`,
    `Archetype: ${meta.archetype || ""}`,
    `Tier: ${meta.tier || "Standard"}`,
    `Armor: ${actor.system?.armor?.tier || "Medium"}`,
    `Integrity: ${Number(actor.system?.armor?.integrity?.value) || 0}`,
    `Health: ${Number(actor.system?.health?.value) || 0}`,
    `Initiative: ${Number(actor.system?.combat?.initiative) || 0}`,
    `Shooting: ${Number(actor.system?.skills?.shooting) || 0}`,
    `Defense: ${Number(actor.system?.skills?.defense) || 0}`,
    "",
    "Weapons:",
    ...weaponLines,
    "",
    "Abilities:",
    ...(abilityLines.length ? abilityLines : [""]),
    "",
    `Notes: ${meta.notes || ""}`,
    `Image: ${actor.img || ""}`,
    `Spawn Count: ${Number(meta.spawnCount) || 1}`
  ].join("\n");
}

function showDropTrooperBlueprintDialog(title, blueprintText) {
  const escaped = escapeDropTrooperHtml(blueprintText);
  new Dialog({
    title,
    content: `
      <form class="trooper-sheet">
        <section class="dt-card">
          <h2>Blueprint</h2>
          <textarea class="dt-blueprint-textarea" readonly>${escaped}</textarea>
          <p class="dt-item-help">Copy this text back into chat or save it for later. Use ${DROP_TROOPER_NPC_IMPORT_COMMAND} to import a blueprint into Foundry.</p>
        </section>
      </form>
    `,
    buttons: {
      close: {
        label: "Close"
      }
    }
  }).render(true);
}

async function exportDropTrooperNpcBlueprint(actor) {
  if (!actor || actor.type !== "npc") {
    ui.notifications.warn("Select or open an NPC first.");
    return;
  }

  const blueprintText = buildDropTrooperNpcBlueprintText(actor);
  showDropTrooperBlueprintDialog(`${actor.name} Blueprint`, blueprintText);

  await ChatMessage.create({
    whisper: ChatMessage.getWhisperRecipients("GM").map(user => user.id),
    speaker: ChatMessage.getSpeaker({ actor }),
    content: `
      <div class="dt-chat-card">
        <div class="dt-chat-header">
          <div class="dt-chat-title">${escapeDropTrooperHtml(actor.name)}</div>
          <div class="dt-chat-subtitle">NPC Blueprint Export</div>
        </div>
        <div class="dt-chat-body">
          <div class="dt-chat-section">
            <pre class="dt-blueprint-pre">${escapeDropTrooperHtml(blueprintText)}</pre>
          </div>
        </div>
      </div>
    `
  });
}

async function createDropTrooperNpcFromBlueprint(rawText) {
  const blueprint = parseDropTrooperBlueprint(rawText);
  const img = normalizeDropTrooperString(blueprint.image) || "icons/svg/mystery-man.svg";
  const primaryWeapon = blueprint.weapons[0] || {
    name: "Weapon",
    tier: "Medium",
    baseDamage: 4,
    ammo: "",
    magSize: "",
    ammoMax: "",
    aoeEnabled: false,
    aoeType: "blast",
    aoeEffect: "damage"
  };

  const actor = await Actor.create({
    name: blueprint.name,
    type: "npc",
    img,
    system: {
      nameplate: blueprint.archetype || "",
      armor: {
        tier: normalizeDropTrooperArmorTier(blueprint.armor, "Medium"),
        integrity: {
          value: parseDropTrooperMaybeNumber(blueprint.integrity, 8),
          max: parseDropTrooperMaybeNumber(blueprint.integrity, 8)
        }
      },
      health: {
        value: parseDropTrooperMaybeNumber(blueprint.health, 8),
        max: parseDropTrooperMaybeNumber(blueprint.health, 8)
      },
      combat: {
        initiative: parseDropTrooperMaybeNumber(blueprint.initiative, 0)
      },
      skills: {
        shooting: parseDropTrooperMaybeNumber(blueprint.shooting, 2),
        defense: parseDropTrooperMaybeNumber(blueprint.defense, 1)
      },
      weapon: buildDropTrooperLegacyWeaponData(primaryWeapon)
    },
    prototypeToken: {
      name: blueprint.name,
      actorLink: false,
      texture: { src: img }
    }
  });

  console.log("[Drop Trooper] NPC blueprint parsed", {
    name: blueprint.name,
    weapons: blueprint.weapons,
    abilities: blueprint.abilities
  });

  if (blueprint.weapons.length > 0) {
    try {
      const weaponItems = blueprint.weapons.map((weapon, index) => buildDropTrooperWeaponItemData(weapon, index));
      console.log("[Drop Trooper] Creating NPC weapon items", weaponItems);
      await actor.createEmbeddedDocuments("Item", weaponItems);
    } catch (error) {
      console.error("[Drop Trooper] Failed to create imported NPC weapon items.", error, blueprint.weapons);
      ui.notifications.error(`Failed to import weapon items for ${actor.name}. Check console.`);
    }
  }

  if (blueprint.abilities.length > 0) {
    try {
      const abilityItems = blueprint.abilities.map((ability, index) => buildDropTrooperAbilityItemData(ability, index));
      console.log("[Drop Trooper] Creating NPC ability items", abilityItems);
      await actor.createEmbeddedDocuments("Item", abilityItems);
    } catch (error) {
      console.error("[Drop Trooper] Failed to create imported NPC ability items.", error, blueprint.abilities);
      ui.notifications.error(`Failed to import ability items for ${actor.name}. Check console.`);
    }
  }

  await actor.setFlag("drop-trooper", DROP_TROOPER_NPC_BLUEPRINT_FLAG, {
    archetype: blueprint.archetype || "",
    tier: blueprint.tier || "Standard",
    notes: blueprint.notes || "",
    spawnCount: Math.max(1, parseDropTrooperMaybeNumber(blueprint.spawnCount, 1))
  });

  ui.notifications.info(`Created NPC: ${actor.name}`);
  actor.sheet?.render(true);
  return actor;
}

function getDropTrooperActiveNpcActor() {
  const controlled = canvas?.tokens?.controlled?.find(token => token?.actor?.type === "npc")?.actor;
  if (controlled) return controlled;

  const openSheet = Object.values(ui.windows).find(app => app instanceof DropTrooperSheet && app.actor?.type === "npc");
  if (openSheet?.actor) return openSheet.actor;

  return null;
}

function openDropTrooperNpcImportDialog(prefillText = "") {
  const escaped = escapeDropTrooperHtml(prefillText);

  new Dialog({
    title: "Import Drop Trooper NPC Blueprint",
    content: `
      <form class="trooper-sheet">
        <section class="dt-card">
          <h2>Paste Blueprint</h2>
          <textarea name="blueprint" class="dt-blueprint-textarea">${escaped}</textarea>
          <p class="dt-item-help">This creates one editable NPC actor in the Actors tab. It does not place tokens on the map. Supports both legacy pipe-delimited blueprints and labeled Name:/Skill:/Mode: style weapon and ability lines.</p>
        </section>
      </form>
    `,
    buttons: {
      import: {
        label: "Import NPC",
        callback: async html => {
          const blueprintText = html.find("textarea[name='blueprint']").val();
          try {
            await createDropTrooperNpcFromBlueprint(blueprintText);
          } catch (err) {
            console.error("Drop Trooper | NPC blueprint import failed", err);
            ui.notifications.error(`NPC import failed: ${err.message}`);
          }
        }
      },
      cancel: {
        label: "Cancel"
      }
    },
    default: "import"
  }).render(true);
}

function handleDropTrooperNpcChatCommand(messageText) {
  if (!game.user?.isGM) {
    ui.notifications.warn("Only the GM can import or export Drop Trooper NPC blueprints.");
    return false;
  }

  const trimmed = String(messageText ?? "").trim();

  if (trimmed.startsWith(DROP_TROOPER_NPC_IMPORT_COMMAND)) {
    const rawBlueprint = trimmed.slice(DROP_TROOPER_NPC_IMPORT_COMMAND.length).trim();
    if (rawBlueprint) {
      createDropTrooperNpcFromBlueprint(rawBlueprint).catch(err => {
        console.error("Drop Trooper | NPC blueprint import failed", err);
        ui.notifications.error(`NPC import failed: ${err.message}`);
      });
    } else {
      openDropTrooperNpcImportDialog();
    }
    return false;
  }

  if (trimmed.startsWith(DROP_TROOPER_NPC_EXPORT_COMMAND)) {
    const actor = getDropTrooperActiveNpcActor();
    exportDropTrooperNpcBlueprint(actor).catch(err => {
      console.error("Drop Trooper | NPC blueprint export failed", err);
      ui.notifications.error(`NPC export failed: ${err.message}`);
    });
    return false;
  }

  return true;
}

function getDropTrooperHudAmmoText(weapon) {
  const ammo = weapon.system?.ammo;
  const magSize = weapon.system?.magSize;
  const spareAmmo = weapon.system?.ammoMax;

  const hasAmmo = ammo !== undefined && ammo !== null && String(ammo).trim() !== "";
  const hasMag = magSize !== undefined && magSize !== null && String(magSize).trim() !== "";
  const hasSpare = spareAmmo !== undefined && spareAmmo !== null && String(spareAmmo).trim() !== "";

  if (!hasAmmo && !hasMag && !hasSpare) return "—";

  const current = hasAmmo ? ammo : "?";
  const mag = hasMag ? magSize : "?";
  const spare = hasSpare ? spareAmmo : "?";

  return `${current} / ${mag} / ${spare}`;
}

const DROP_TROOPER_GROUP_ACTED_FLAG = "groupActed";
const DROP_TROOPER_GROUP_ACTED_LEGACY_ICON = "icons/svg/combat.svg";
const DROP_TROOPER_GROUP_ACTED_TINT = "#ff7a00";
const DROP_TROOPER_GROUP_ACTED_ALPHA = 0.62;

function getDropTrooperGroupSignature(actor) {
  if (!actor) return "";

  const weaponSignature = actor.items
    .filter(item => item.type === "weapon")
    .map(item => `${item.name}::${item.system?.skill || "shooting"}::${item.system?.aoeEnabled ? "aoe" : "direct"}`)
    .sort()
    .join("||");

  return `${actor.type}::${actor.name}::${weaponSignature}`;
}

function getDropTrooperGroupActedData(tokenLike) {
  const document = tokenLike?.document || tokenLike;
  return document?.getFlag?.("drop-trooper", DROP_TROOPER_GROUP_ACTED_FLAG) || null;
}

function isDropTrooperGroupActedToken(tokenLike, combat = game.combat) {
  const data = getDropTrooperGroupActedData(tokenLike);
  if (!data || !combat) return false;
  return data.combatId === combat.id && Number(data.round) === Number(combat.round);
}

async function setDropTrooperGroupActedMarker(tokenLike) {
  if (!game.combat) return;

  const document = tokenLike?.document || tokenLike;
  if (!document) return;

  const existingData = getDropTrooperGroupActedData(document) || {};
  const previousAlpha = Object.prototype.hasOwnProperty.call(existingData, "previousAlpha")
    ? existingData.previousAlpha
    : (document.alpha ?? 1);
  const previousTint = Object.prototype.hasOwnProperty.call(existingData, "previousTint")
    ? existingData.previousTint
    : (document.texture?.tint ?? null);

  await document.setFlag("drop-trooper", DROP_TROOPER_GROUP_ACTED_FLAG, {
    combatId: game.combat.id,
    round: Number(game.combat.round) || 0,
    label: "Group Fired",
    previousAlpha,
    previousTint
  });

  const effects = Array.isArray(document.effects) ? [...document.effects] : [];
  const filteredEffects = effects.filter(effect => effect !== DROP_TROOPER_GROUP_ACTED_LEGACY_ICON);

  const updateData = {};
  if ((document.alpha ?? 1) !== DROP_TROOPER_GROUP_ACTED_ALPHA) {
    updateData.alpha = DROP_TROOPER_GROUP_ACTED_ALPHA;
  }
  if ((document.texture?.tint ?? null) !== DROP_TROOPER_GROUP_ACTED_TINT) {
    updateData["texture.tint"] = DROP_TROOPER_GROUP_ACTED_TINT;
  }
  if (filteredEffects.length !== effects.length) {
    updateData.effects = filteredEffects;
  }

  if (Object.keys(updateData).length) {
    await document.update(updateData);
  }
}

async function clearDropTrooperGroupActedMarker(tokenLike) {
  const document = tokenLike?.document || tokenLike;
  if (!document) return;

  const markerData = getDropTrooperGroupActedData(document) || {};
  const previousAlpha = Object.prototype.hasOwnProperty.call(markerData, "previousAlpha")
    ? markerData.previousAlpha
    : 1;
  const previousTint = Object.prototype.hasOwnProperty.call(markerData, "previousTint")
    ? markerData.previousTint
    : null;

  await document.unsetFlag("drop-trooper", DROP_TROOPER_GROUP_ACTED_FLAG);

  const effects = Array.isArray(document.effects) ? [...document.effects] : [];
  const filteredEffects = effects.filter(effect => effect !== DROP_TROOPER_GROUP_ACTED_LEGACY_ICON);

  const updateData = {};
  if ((document.alpha ?? 1) !== previousAlpha) {
    updateData.alpha = previousAlpha;
  }
  if ((document.texture?.tint ?? null) !== previousTint) {
    updateData["texture.tint"] = previousTint;
  }
  if (filteredEffects.length !== effects.length) {
    updateData.effects = filteredEffects;
  }

  if (Object.keys(updateData).length) {
    await document.update(updateData);
  }
}

async function clearExpiredDropTrooperGroupMarkers(combat) {
  if (!game.user?.isGM || !canvas?.scene || !combat) return;

  const tokenDocs = canvas.scene.tokens?.contents || [];
  const currentRound = Number(combat.round) || 0;
  const staleDocs = tokenDocs.filter(tokenDoc => {
    const data = tokenDoc.getFlag("drop-trooper", DROP_TROOPER_GROUP_ACTED_FLAG);
    if (!data) return false;
    if (data.combatId && data.combatId !== combat.id) return false;
    const appliedRound = Number(data.round);
    return !Number.isFinite(appliedRound) || appliedRound < currentRound;
  });

  for (const tokenDoc of staleDocs) {
    await clearDropTrooperGroupActedMarker(tokenDoc);
  }
}

function getDropTrooperGroupHudData(tokens) {
  const validTokens = (tokens || []).filter(token => token?.actor);
  if (validTokens.length < 2) {
    return { valid: false };
  }

  const firstActor = validTokens[0].actor;
  if (!firstActor || firstActor.type !== "npc") {
    return { valid: false };
  }

  const signature = getDropTrooperGroupSignature(firstActor);
  const allMatch = validTokens.every(token => token.actor?.type === "npc" && getDropTrooperGroupSignature(token.actor) === signature);
  if (!allMatch) {
    return { valid: false };
  }

  const combat = game.combat;
  const actedTokens = combat ? validTokens.filter(token => isDropTrooperGroupActedToken(token, combat)) : [];
  const readyTokens = combat ? validTokens.filter(token => !isDropTrooperGroupActedToken(token, combat)) : validTokens;
  const weapons = sortDropTrooperItemsByDisplayOrder(firstActor.items.filter(item => item.type === "weapon" && !item.system?.aoeEnabled));

  return {
    valid: true,
    actor: firstActor,
    tokens: validTokens,
    readyTokens,
    actedTokens,
    weapons,
    hasStandardAttack: weapons.length === 0
  };
}

async function toggleDropTrooperOverwatchFromHud(actor) {
  if (!actor) return false;

  const state = getDropTrooperReactionState(actor);
  if (!state.hasReaction) {
    ui.notifications.warn(`${actor.name} does not have reactions enabled.`);
    return false;
  }

  if (state.overwatch) {
    await actor.update({ "system.combat.overwatch": false });
    await ChatMessage.create({
      speaker: ChatMessage.getSpeaker({ actor }),
      content: `<div class="dt-chat-card"><div class="dt-chat-header"><div class="dt-chat-title">${actor.name}</div><div class="dt-chat-subtitle">Overwatch</div></div><div class="dt-chat-body"><div class="dt-chat-section"><div class="dt-chat-line dt-chat-line--compact"><span class="dt-chat-small">Status</span><br><span class="dt-chat-strong">Overwatch canceled.</span></div></div></div></div>`
    });
    return true;
  }

  if (!state.reactionAvailable) {
    ui.notifications.warn(`${actor.name} has already used their reaction this turn.`);
    return false;
  }

  await actor.update({ "system.combat.overwatch": true });
  await ChatMessage.create({
    speaker: ChatMessage.getSpeaker({ actor }),
    content: `<div class="dt-chat-card"><div class="dt-chat-header"><div class="dt-chat-title">${actor.name}</div><div class="dt-chat-subtitle">Overwatch</div></div><div class="dt-chat-body"><div class="dt-chat-section"><div class="dt-chat-line dt-chat-line--compact"><span class="dt-chat-small">Status</span><br><span class="dt-chat-strong">${actor.name} enters Overwatch.</span></div></div></div></div>`
  });
  return true;
}

async function runDropTrooperHudAction(actor, action, itemId = null, rollKey = null) {
  const sheet = actor?.sheet;
  if (!sheet) return;

  if (action === "overwatch") {
    await toggleDropTrooperOverwatchFromHud(actor);
    return;
  }

  if (action === "brace") {
    await sheet._onBrace({ preventDefault: () => {} });
    return;
  }

  if (action === "aim") {
    await sheet._onAim({ preventDefault: () => {} });
    return;
  }

  if (action === "skill-roll" && rollKey) {
    await sheet._onRollSkill({
      preventDefault: () => {},
      currentTarget: { dataset: { skill: rollKey } }
    });
    return;
  }

  if (action === "attribute-roll" && rollKey) {
    await sheet._onRollAttribute({
      preventDefault: () => {},
      currentTarget: { dataset: { attribute: rollKey } }
    });
    return;
  }

  if (action === "attack") {
    if (itemId) {
      const weapon = actor.items.get(itemId);
      if (!weapon) return;

      const outOfArmorWeaponLock = getDropTrooperOutOfArmorWeaponLock(actor, weapon);
      if (outOfArmorWeaponLock.blocked) {
        ui.notifications.warn(outOfArmorWeaponLock.reason);
        return;
      }

      if (weapon.system?.aoeEnabled) {
        await sheet._onWeaponAoeAttack(weapon);
      } else {
        await sheet._onWeaponSingleAttack(weapon);
      }
      return;
    }

    await sheet._onRollShoot({ preventDefault: () => {} });
    return;
  }

  if (action === "reload" && itemId) {
    await sheet._onWeaponReload({
      preventDefault: () => {},
      currentTarget: { dataset: { itemId } }
    });
    return;
  }

  if (action === "nano-repair") {
    await sheet._onNanoRepair({ preventDefault: () => {} });
    return;
  }

  if (action === "ability" && itemId) {
    await sheet._onAbilityUse({
      preventDefault: () => {},
      currentTarget: { dataset: { itemId } }
    });
    return;
  }
}

const DROP_TROOPER_ATTRIBUTE_REQUEST_OPTIONS = [
  { key: "strength", label: "Strength (STR)" },
  { key: "agility", label: "Agility (AGI)" },
  { key: "perception", label: "Perception (PER)" },
  { key: "tech", label: "Tech (TEC)" },
  { key: "will", label: "Will (WIL)" }
];

const DROP_TROOPER_SKILL_REQUEST_OPTIONS = [
  { key: "shooting", label: "Shooting" },
  { key: "heavyWeapons", label: "Heavy Weapons" },
  { key: "melee", label: "Melee" },
  { key: "maneuvering", label: "Maneuvering" },
  { key: "recon", label: "Recon" },
  { key: "sensors", label: "Sensors" },
  { key: "electronics", label: "Electronics" },
  { key: "engineering", label: "Engineering" },
  { key: "droneControl", label: "Drone Control" },
  { key: "command", label: "Command" },
  { key: "discipline", label: "Discipline" },
  { key: "survival", label: "Survival" }
];

function getDropTrooperSupportedControlledTokens() {
  if (!canvas?.ready) return [];

  return (canvas.tokens?.controlled || []).filter(token => {
    const sheet = token?.actor?.sheet;
    return !!token?.actor && !!sheet && typeof sheet._onRollSkill === "function" && typeof sheet._onRollAttribute === "function";
  });
}

function getDropTrooperRequestedRollLabel(rollType, rollKey) {
  const options = rollType === "attribute"
    ? DROP_TROOPER_ATTRIBUTE_REQUEST_OPTIONS
    : DROP_TROOPER_SKILL_REQUEST_OPTIONS;

  return options.find(option => option.key === rollKey)?.label || "Requested Roll";
}

function canUserResolveDropTrooperRequestedRoll(actor, user = game.user) {
  if (!actor || !user) return false;
  if (user.isGM) return true;

  if (typeof actor.testUserPermission === "function") {
    const ownerLevel = CONST.DOCUMENT_OWNERSHIP_LEVELS?.OWNER ?? CONST.DOCUMENT_PERMISSION_LEVELS?.OWNER ?? 3;
    return actor.testUserPermission(user, ownerLevel);
  }

  return actor.isOwner === true;
}

function getDropTrooperRequestedRollTarget(sceneId, tokenId, actorId) {
  const scene = sceneId ? game.scenes?.get(sceneId) : canvas?.scene;
  const tokenDocument = scene?.tokens?.get(tokenId) || null;
  const token = tokenDocument?.object || (canvas?.scene?.id === scene?.id ? canvas.tokens?.get(tokenId) : null) || null;
  const actor = token?.actor || tokenDocument?.actor || game.actors?.get(actorId) || null;

  return { scene, tokenDocument, token, actor };
}

