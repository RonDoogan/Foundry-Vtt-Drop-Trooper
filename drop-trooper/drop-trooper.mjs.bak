Hooks.on("preUpdateActor", (actor, changed) => {
  if (!isDropTrooperDroneActor(actor)) return;

  const nextIntegrity = getDropTrooperDroneNextIntegrity(actor, changed);
  if (nextIntegrity <= 0) {
    foundry.utils.setProperty(changed, "system.combat.deployed", false);
    foundry.utils.setProperty(changed, "system.combat.actionsRemaining", 0);
    foundry.utils.setProperty(changed, "system.combat.deploymentPaid", false);
  }

  const controllerActorId = getDropTrooperDroneNextControllerActorId(actor, changed);
  const controllerActor = controllerActorId ? game.actors?.get(controllerActorId) : null;

  if (controllerActor && String(controllerActor.type || "") === "trooper") {
    if (!foundry.utils.hasProperty(changed, "system.control.controllerName")) {
      foundry.utils.setProperty(changed, "system.control.controllerName", String(controllerActor.name || "").trim());
    }
  }

  const nextDeployed = getDropTrooperDroneNextDeployed(actor, changed);
  if (!nextDeployed) return;

  if (!controllerActorId) {
    ui.notifications.warn(`${actor.name}: set Controller Actor ID before deploying this drone.`);
    return false;
  }

  if (!controllerActor) {
    ui.notifications.warn(`${actor.name}: Controller Actor ID does not match a valid actor.`);
    return false;
  }

  if (String(controllerActor.type || "") !== "trooper") {
    ui.notifications.warn(`${actor.name}: Controller Actor ID must point to a trooper actor.`);
    return false;
  }

  if (nextIntegrity <= 0) {
    ui.notifications.warn(`${actor.name}: drones at 0 Integrity cannot be deployed.`);
    return false;
  }

  const conflictingDrone = findDropTrooperActiveDroneConflict(controllerActorId, actor.id);
  if (conflictingDrone) {
    ui.notifications.warn(`${actor.name}: ${conflictingDrone.name} is already the active drone for this trooper.`);
    return false;
  }

  if (!foundry.utils.hasProperty(changed, "system.combat.actionsRemaining")) {
    foundry.utils.setProperty(changed, "system.combat.actionsRemaining", getDropTrooperDroneNextActionsPerTurn(actor, changed));
  }
});

Hooks.on("updateActor", (actor, changed) => {
  renderDropTrooperHud();

  if (game.user?.isGM && isDropTrooperDroneActor(actor)) {
    const deployChangedToActive = foundry.utils.hasProperty(changed, "system.combat.deployed")
      && Boolean(foundry.utils.getProperty(changed, "system.combat.deployed")) === true;
    const controllerChanged = foundry.utils.hasProperty(changed, "system.control.controllerActorId");
    const shouldSyncDroneOwnership = getDropTrooperDroneCurrentDeployed(actor) && (deployChangedToActive || controllerChanged);

    if (shouldSyncDroneOwnership) {
      syncDropTrooperDroneOwnershipFromController(actor, {
        notifyGmOnFailure: true
      }).catch(err => {
        console.warn("Drop Trooper | Failed to sync drone ownership", err);
      });
    }
  }

  if (!game.user?.isGM) return;
  const healthChanged = foundry.utils.hasProperty(changed, "system.health.value");
  const integrityChanged = foundry.utils.hasProperty(changed, "system.armor.integrity.value");
  if (!healthChanged && !integrityChanged) return;

  syncDropTrooperDefeatStateForActor(actor, {
    playSound: true,
    tokenDocument: getDropTrooperTokenDocumentFromActor(actor)
  }).catch(err => {
    console.warn("Drop Trooper | Failed to sync defeated state", err);
  });
});

