<form class="trooper-sheet">
  <header class="dt-header dt-header-with-portrait">
    <div class="dt-header-portrait-wrap">
      <img class="dt-portrait" src="{{actor.img}}" data-edit="img" title="{{actor.name}}" />
    </div>
    <div class="dt-header-main">
      <h1>{{actor.name}}</h1>
      <div class="dt-subtitle">NPC Combat Unit</div>
      <div class="dt-header-actions">
        <button type="button" class="npc-blueprint-export dt-header-action-button">Export Blueprint</button>
      </div>
    </div>
  </header>

  <section>
    <h2>Armor</h2>

    <label>Armor Tier</label>
    <select name="system.armor.tier">
      <option value="Light" {{#if (eq system.armor.tier "Light")}}selected{{/if}}>Light</option>
      <option value="Medium" {{#if (eq system.armor.tier "Medium")}}selected{{/if}}>Medium</option>
      <option value="Heavy" {{#if (eq system.armor.tier "Heavy")}}selected{{/if}}>Heavy</option>
      <option value="Ultra" {{#if (eq system.armor.tier "Ultra")}}selected{{/if}}>Ultra</option>
    </select>

    <label>Integrity</label>
    <input type="number" name="system.armor.integrity.value" value="{{system.armor.integrity.value}}"/>

    <label>Integrity Max</label>
    <input type="number" name="system.armor.integrity.max" value="{{system.armor.integrity.max}}"/>
  </section>

  <section>
    <h2>Health</h2>

    <label>Health</label>
    <input type="number" name="system.health.value" value="{{system.health.value}}"/>

    <label>Health Max</label>
    <input type="number" name="system.health.max" value="{{system.health.max}}"/>
  </section>

  <section>
    <h2>Combat</h2>

    <label>Initiative</label>
    <input type="number" name="system.combat.initiative" value="{{system.combat.initiative}}"/>

    <label>Defense Dice</label>
    <input type="number" name="system.skills.defense" value="{{system.skills.defense}}"/>

    <label>Shooting Dice</label>
    <input type="number" name="system.skills.shooting" value="{{system.skills.shooting}}"/>
  </section>

  <section>
    <h2>Weapon (Legacy Standard Attack)</h2>

    <label>Name</label>
    <input type="text" name="system.weapon.name" value="{{system.weapon.name}}"/>

    <label>Tier</label>
    <select name="system.weapon.tier">
      <option value="Light" {{#if (eq system.weapon.tier "Light")}}selected{{/if}}>Light</option>
      <option value="Medium" {{#if (eq system.weapon.tier "Medium")}}selected{{/if}}>Medium</option>
      <option value="Heavy" {{#if (eq system.weapon.tier "Heavy")}}selected{{/if}}>Heavy</option>
      <option value="Ultra" {{#if (eq system.weapon.tier "Ultra")}}selected{{/if}}>Ultra</option>
    </select>

    <label>Damage Dice</label>
    <input type="number" name="system.weapon.baseDamage" value="{{system.weapon.baseDamage}}"/>

    <div class="dt-section-subtitle">Imported NPCs use the item weapons below for full attack behavior. This legacy block is kept for compatibility.</div>
  </section>

  <section class="dt-card dt-item-section-card">
    <div class="dt-section-header">
      <div>
        <h2>Weapon Items</h2>
        <div class="dt-section-subtitle">Use these for direct fire, reloads, blast, cone, and smoke</div>
      </div>
      <button type="button" class="weapon-create dt-inline-create">Add Weapon</button>
    </div>

    <div class="dt-item-stack">
      {{#each weapons as |item|}}
      <div class="dt-item-card dt-weapon-card" data-item-id="{{item._id}}">
        <div class="dt-item-main">
          <div class="dt-item-title-row">
            <a class="dt-item-title weapon-edit" data-item-id="{{item._id}}">{{item.name}}</a>
            <span class="dt-item-badge">{{item.attackLabel}}</span>
          </div>
          <div class="dt-item-meta">
            <span>{{item.system.skill}}</span>
            <span>•</span>
            <span>{{item.system.tier}}</span>
            <span>•</span>
            <span>{{item.ammoDisplay}}</span>
          </div>
        </div>
        <div class="dt-item-actions">
          <button type="button" class="weapon-attack" data-item-id="{{item._id}}">{{item.attackLabel}}</button>
          {{#if item.reloadVisible}}<button type="button" class="weapon-reload" data-item-id="{{item._id}}">Reload</button>{{/if}}
          <button type="button" class="weapon-delete dt-danger-button" data-item-id="{{item._id}}">Delete</button>
        </div>
      </div>
      {{/each}}
    </div>
  </section>

  <section>
    <button type="button" class="roll-shoot">Attack</button>
    <button type="button" class="roll-defense">Defense</button>
  </section>


  <section>
    <div class="dt-section-header">
      <h2>Abilities</h2>
      <button type="button" class="ability-create">Add Ability</button>
    </div>

    <div class="dt-ability-list">
      <div class="dt-ability-list-header">
        <div>Ability</div>
        <div>Mode</div>
        <div>Linked</div>
        <div>Pool</div>
        <div>Actions</div>
      </div>

      {{#each abilities as |item|}}
        <div class="dt-ability-row" data-item-id="{{item._id}}">
          <div class="dt-ability-name-cell">
            <a class="dt-ability-name ability-edit" data-item-id="{{item._id}}">{{item.name}}</a>
          </div>
          <div class="dt-ability-mode-cell">{{item.abilityModeLabel}}</div>
          <div class="dt-ability-linked-cell">{{item.linkedSkillLabel}}</div>
          <div class="dt-ability-pool-cell">{{item.poolDisplay}}</div>
          <div class="dt-ability-actions-cell">
            <button type="button" class="ability-use" data-item-id="{{item._id}}">Use</button>
            {{#if item.resetVisible}}<button type="button" class="ability-reset" data-item-id="{{item._id}}">Reset</button>{{/if}}
            <button type="button" class="ability-delete dt-danger-button" data-item-id="{{item._id}}">Delete</button>
          </div>
        </div>
      {{/each}}
    </div>
  </section>
</form>
