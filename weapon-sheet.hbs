<form class="weapon-sheet">
  <header>
    <h1>{{item.name}}</h1>
  </header>

  <section>
    <label>Weapon Tier</label>
    <select name="system.tier">
      <option value="Light" {{#if (eq system.tier "Light")}}selected{{/if}}>Light</option>
      <option value="Medium" {{#if (eq system.tier "Medium")}}selected{{/if}}>Medium</option>
      <option value="Heavy" {{#if (eq system.tier "Heavy")}}selected{{/if}}>Heavy</option>
      <option value="Ultra" {{#if (eq system.tier "Ultra")}}selected{{/if}}>Ultra</option>
    </select>

    <label>Skill Used</label>
    <select name="system.skill">
      <option value="shooting" {{#if (eq system.skill "shooting")}}selected{{/if}}>Shooting</option>
      <option value="heavyWeapons" {{#if (eq system.skill "heavyWeapons")}}selected{{/if}}>Heavy Weapons</option>
      <option value="melee" {{#if (eq system.skill "melee")}}selected{{/if}}>Melee</option>
      <option value="maneuvering" {{#if (eq system.skill "maneuvering")}}selected{{/if}}>Maneuvering</option>
      <option value="recon" {{#if (eq system.skill "recon")}}selected{{/if}}>Recon</option>
      <option value="sensors" {{#if (eq system.skill "sensors")}}selected{{/if}}>Sensors</option>
      <option value="electronics" {{#if (eq system.skill "electronics")}}selected{{/if}}>Electronics</option>
      <option value="engineering" {{#if (eq system.skill "engineering")}}selected{{/if}}>Engineering</option>
      <option value="droneControl" {{#if (eq system.skill "droneControl")}}selected{{/if}}>Drone Control</option>
      <option value="command" {{#if (eq system.skill "command")}}selected{{/if}}>Command</option>
      <option value="discipline" {{#if (eq system.skill "discipline")}}selected{{/if}}>Discipline</option>
      <option value="survival" {{#if (eq system.skill "survival")}}selected{{/if}}>Survival</option>
    </select>

    <label>Base Damage Dice</label>
    <input type="number" name="system.baseDamage" value="{{system.baseDamage}}" />

    <label>Ammo Current</label>
    <input type="number" name="system.ammo" value="{{system.ammo}}" />

    <label>Magazine Size</label>
    <input type="number" name="system.magSize" value="{{system.magSize}}" />

    <label>Max Ammo Carried</label>
    <input type="number" name="system.ammoMax" value="{{system.ammoMax}}" />

    <p class="notes">Example: Ammo Current 12, Magazine Size 12, Max Ammo Carried 24. Fire spends from Ammo Current. Reload pulls rounds from Max Ammo Carried into the magazine.</p>

    <label>Notes</label>
    <textarea name="system.notes">{{system.notes}}</textarea>
  </section>

  <hr>

  <section>
    <label>
      <input type="checkbox" name="system.aoeEnabled" {{checked system.aoeEnabled}}>
      AOE Weapon
    </label>

    <label>AOE Type</label>
    <select name="system.aoeType">
      <option value="blast" {{#if (eq system.aoeType "blast")}}selected{{/if}}>Blast</option>
      <option value="cone" {{#if (eq system.aoeType "cone")}}selected{{/if}}>Cone</option>
    </select>
  </section>

  <hr>

  <section>
    <h2>AOE Damage Bands / Blast AOE</h2>

    <label>Blast Radius</label>
    <input type="number" name="system.blastRadius" value="{{system.blastRadius}}" />

    <label>Kill Radius</label>
    <input type="number" name="system.killRadius" value="{{system.killRadius}}" />

    <label>Heavy Radius</label>
    <input type="number" name="system.heavyRadius" value="{{system.heavyRadius}}" />

    <label>Fragment Radius</label>
    <input type="number" name="system.fragRadius" value="{{system.fragRadius}}" />

    <label>Kill Damage Dice</label>
    <input type="number" name="system.killDamage" value="{{system.killDamage}}" />

    <label>Heavy Damage Dice</label>
    <input type="number" name="system.heavyDamage" value="{{system.heavyDamage}}" />

    <label>Fragment Damage Dice</label>
    <input type="number" name="system.fragDamage" value="{{system.fragDamage}}" />
  </section>

  <hr>

  <section>
    <h2>Cone AOE</h2>

    <label>Cone Range</label>
    <input type="number" name="system.coneRange" value="{{system.coneRange}}" />

    <label>Cone Angle</label>
    <select name="system.coneAngle">
      <option value="15" {{#if (eq system.coneAngle "15")}}selected{{/if}}>15°</option>
      <option value="20" {{#if (eq system.coneAngle "20")}}selected{{/if}}>20°</option>
      <option value="25" {{#if (eq system.coneAngle "25")}}selected{{/if}}>25°</option>
      <option value="30" {{#if (eq system.coneAngle "30")}}selected{{/if}}>30°</option>
      <option value="35" {{#if (eq system.coneAngle "35")}}selected{{/if}}>35°</option>
      <option value="40" {{#if (eq system.coneAngle "40")}}selected{{/if}}>40°</option>
      <option value="45" {{#if (eq system.coneAngle "45")}}selected{{/if}}>45°</option>
      <option value="50" {{#if (eq system.coneAngle "50")}}selected{{/if}}>50°</option>
      <option value="55" {{#if (eq system.coneAngle "55")}}selected{{/if}}>55°</option>
      <option value="60" {{#if (eq system.coneAngle "60")}}selected{{/if}}>60°</option>
      <option value="65" {{#if (eq system.coneAngle "65")}}selected{{/if}}>65°</option>
      <option value="70" {{#if (eq system.coneAngle "70")}}selected{{/if}}>70°</option>
      <option value="75" {{#if (eq system.coneAngle "75")}}selected{{/if}}>75°</option>
      <option value="80" {{#if (eq system.coneAngle "80")}}selected{{/if}}>80°</option>
      <option value="85" {{#if (eq system.coneAngle "85")}}selected{{/if}}>85°</option>
      <option value="90" {{#if (eq system.coneAngle "90")}}selected{{/if}}>90°</option>
    </select>

    <label>Cone Kill Range</label>
    <input type="number" name="system.coneKillRange" value="{{system.coneKillRange}}" />

    <label>Cone Heavy Range</label>
    <input type="number" name="system.coneHeavyRange" value="{{system.coneHeavyRange}}" />

    <label>Cone Fragment Range</label>
    <input type="number" name="system.coneFragRange" value="{{system.coneFragRange}}" />

    <p class="notes">Cone range bands use the same Kill / Heavy / Fragment damage fields above. For a full-strength spray, set Cone Kill Range to the full cone range and leave Heavy / Fragment at 0.</p>
  </section>
</form>
